# PostgreSQL（docker compose 默认映射 54329）
# DATABASE_URL=postgresql://walker:walker@127.0.0.1:54329/walker
# 本机 Postgres 直连（localhost:5432）示例：
# DATABASE_URL=postgresql://postgres:postgre@127.0.0.1:5432/walker

# 仅当为 true 时 Intake 等才调模型（首版无调用也安全）
AI_ENABLED=false

# 管理 API Bearer 令牌（≥16 字符）。未配置时管理面全部拒绝（fail-closed）
ADMIN_API_TOKEN=change-me-to-a-long-secret

PORT=8788
NODE_ENV=development
