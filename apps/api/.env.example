# —— 本地默认：SQLite 文件（免 Docker / 免本机 PG）——
DATABASE_URL="file:./data/walker.db"
WALKER_DB_PROVIDER=sqlite

# —— 未来生产 PostgreSQL（示例）——
# WALKER_DB_PROVIDER=postgresql
# DATABASE_URL=postgresql://walker:walker@127.0.0.1:54329/walker
# docker compose up -d   # 可选：仓库自带 postgres:16

# 仅当为 true 时 Intake 等才调模型
AI_ENABLED=false

PORT=8788
NODE_ENV=development

# 验收用：强制存储不可写
# STORAGE_UNAVAILABLE=true

# 管理端内容目录（默认探测 monorepo content/log）
# CONTENT_LOG_DIR=/absolute/path/to/content/log

# 保存内容后是否自动 pnpm content:gen（默认开）
# CONTENT_GEN_ON_SAVE=false

# 内容发布（pnpm content:publish）
# CONTENT_PUBLISH_COMMIT=true
# CONTENT_PUBLISH_PUSH=true
