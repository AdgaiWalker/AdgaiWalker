{
  "name": "@walker/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/main.ts",
    "start": "tsx --tsconfig tsconfig.json src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "tsx ../../scripts/prisma-env.ts generate",
    "prisma:migrate": "tsx ../../scripts/prisma-env.ts migrate",
    "prisma:push": "tsx ../../scripts/prisma-env.ts push",
    "prisma:deploy": "tsx ../../scripts/prisma-env.ts migrate",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@prisma/client": "^6.10.1",
    "@walker/shared": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.32",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
