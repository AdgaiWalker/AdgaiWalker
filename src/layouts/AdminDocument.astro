---
import HeadCommon from '@/components/shared/HeadCommon.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <HeadCommon
      title={title}
      description="Walker 个人知识生产与决策系统后台"
      themeColor="#edf3f2"
    />
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body>
    <slot />
  </body>
</html>
