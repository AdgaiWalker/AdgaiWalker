---
/**
 * FullscreenLayout — 全屏页面布局
 * 无侧边栏、无导航栏，全屏内容展示
 * 用于：/about
 */

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title = 'Walker — 行过万里水路',
  description = 'Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。',
  ogImage = '/images/hero-bg.png',
  ogTitle,
  ogDescription,
} = Astro.props;

import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import '../styles/global.css';

const pageTitle = ogTitle ?? title;
const pageDescription = ogDescription ?? description;
const canonical = Astro.url.href;
const absoluteOgImage = new URL(ogImage, Astro.site ?? Astro.url).href;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#1a1a2e" />
    <meta name="author" content="Walker (秋知)" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Walker RSS" href={new URL('/rss.xml', Astro.site ?? Astro.url)} />

    <!-- Fonts API 自托管字体 -->
    <Font cssVariable="--font-body" preload />
    <Font cssVariable="--font-heading" preload />
    <Font cssVariable="--font-mono" />
    <Font cssVariable="--font-cjk" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Walker 知识空间" />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <ClientRouter />
    <title>{title}</title>
  </head>

  <body class="fullscreen-layout">
    <slot />

    {/* 返回首页浮动按钮 */}
    <a href="/" class="fullscreen-back-btn" aria-label="返回首页">
      <iconify-icon icon="lucide:arrow-left" width="18" height="18"></iconify-icon>
    </a>
  </body>
</html>

<style>
  .fullscreen-layout {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    overflow-x: hidden;
    font-family: 'Inter', 'PingFang SC', 'Noto Sans SC', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .fullscreen-back-btn {
    position: fixed;
    top: 1.5rem;
    left: 1.5rem;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
  }

  .fullscreen-back-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
    transform: translateX(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }
</style>
