---
import Base from './Base.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
}

const {
  title = 'Walker — 行过万里水路',
  description = 'Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。',
  ogImage = '/images/hero-bg.png',
  ogTitle,
  ogDescription,
  canonicalUrl,
} = Astro.props;
---

<Base
  fullscreen
  title={title}
  description={description}
  ogImage={ogImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  canonicalUrl={canonicalUrl}
  themeColor="#1a1a2e"
>
  <slot />

  {/* 顶部胶囊导航 — 和首页一致 */}
  <div class="fullscreen-nav">
    <a href="/" class="fullscreen-nav-btn" title="首页">
      <Icon name="lucide:home" width={14} height={14} />
      <span>首页</span>
    </a>
    <a href="/content" class="fullscreen-nav-btn" title="内容">
      <Icon name="lucide:layout-grid" width={14} height={14} />
      <span>内容</span>
    </a>
    <button class="fullscreen-nav-btn fullscreen-nav-icon-only" id="fullscreen-theme-toggle" aria-label="切换主题" title="切换主题">
      <Icon name="lucide:sun" width={14} height={14} />
    </button>
  </div>
</Base>

<style>
  :global(body.fullscreen-layout) {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    overflow-x: hidden;
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .fullscreen-nav {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .fullscreen-nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 32px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  /* 亮色主题下增强导航可见度 */
  :global(body.theme-nature) .fullscreen-nav-btn {
    background: rgba(0, 0, 0, 0.05);
    border-color: rgba(0, 0, 0, 0.08);
    color: var(--color-parchment-dim);
  }

  :global(body.theme-nature) .fullscreen-nav-btn:hover {
    background: rgba(0, 0, 0, 0.1);
    color: var(--color-parchment);
  }

  .fullscreen-nav-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .fullscreen-nav-icon-only {
    padding: 0;
    width: 32px;
    justify-content: center;
  }
</style>

<script>
  import { cycleTheme } from '../lib/theme';

  function initFullscreenNav() {
    const btn = document.getElementById('fullscreen-theme-toggle');
    if (!btn) return;

    btn.addEventListener('click', () => cycleTheme());
  }
  initFullscreenNav();
  document.addEventListener('astro:page-load', initFullscreenNav);
</script>
