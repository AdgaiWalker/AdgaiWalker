---
/**
 * ArticleLayout — 文章详情页三栏布局
 * 左栏：导航 + 文章列表（嵌套在 Navigation 中）
 * 中栏：TOC 目录
 * 右栏：文章正文
 *
 * 用于：/ai/[slug], /life/[slug]
 */
import Base from './Base.astro';
import TableOfContents from '../components/article/TableOfContents.astro';
import ArticleNav from '../components/article/ArticleNav.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface ArticleEntry {
  id: string;
  title: string;
  date: Date;
  tags?: string[];
  summary?: string;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  headings: Heading[];
  currentSlug: string;
  category: 'ai' | 'life';
  articleList: ArticleEntry[];
}

const {
  title,
  description,
  ogImage,
  ogTitle,
  ogDescription,
  canonicalUrl,
  headings,
  currentSlug,
  category,
  articleList,
} = Astro.props;
---

<Base
  title={title}
  description={description}
  ogImage={ogImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  canonicalUrl={canonicalUrl}
  pureMode={true}
>
  {/* 将文章列表注入到 Navigation 的 slot 中 */}
  <Fragment slot="nav-extension">
    <ArticleNav
      articles={articleList}
      currentSlug={currentSlug}
      category={category}
      basePath={`/${category}`}
    />
  </Fragment>

  <div class="article-layout" id="article-layout">
    {/* 中栏 — TOC 目录 */}
    <aside class="article-toc-column" id="toc-column">
      <TableOfContents headings={headings} />
    </aside>

    {/* 右栏 — 文章正文 */}
    <main class="article-content-column">
      <slot />
    </main>
  </div>
</Base>

<style>
  .article-layout {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    background: #f6f2ea;
  }

  /* 中栏 — TOC 目录 */
  .article-toc-column {
    position: sticky;
    top: 0;
    height: 100vh;
    padding: 5.25rem 0 2rem;
    overflow-y: auto;
    border-right: 1px solid rgba(42, 59, 62, 0.08);
    background: #fffdf9;
  }

  .article-toc-column::-webkit-scrollbar {
    width: 3px;
  }
  .article-toc-column::-webkit-scrollbar-track {
    background: transparent;
  }
  .article-toc-column::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.05);
    border-radius: 3px;
  }
  .article-toc-column:hover::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
  }

  /* 右栏 — 文章正文 */
  .article-content-column {
    min-height: 100vh;
    padding: 0 4rem;
  }

  /* 响应式：中等屏幕隐藏 TOC */
  @media (max-width: 1279px) {
    .article-layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .article-toc-column {
      display: none;
    }

    .article-content-column {
      padding: 0 2rem;
    }
  }

  @media (max-width: 640px) {
    .article-content-column {
      padding: 0 1rem;
    }
  }
</style>

<script>
  import '../scripts/toc-tracker';
</script>
