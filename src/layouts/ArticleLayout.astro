---
import { POSTS } from '@/lib/routes';
/**
 * ArticleLayout — 文章详情页三栏布局
 * 左栏：导航 + 文章列表（嵌套在 Navigation 中）
 * 中栏：TOC 目录（可折叠 + 可拖拽调整宽度）
 * 右栏：文章正文
 *
 * 用于：/posts/[slug]
 */
import Base from './Base.astro';
import TableOfContents from '../components/article/TableOfContents.astro';
import ArticleNav from '../components/article/ArticleNav.astro';
import { Icon } from 'astro-icon/components';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface ArticleEntry {
  id: string;
  title: string;
  date: Date;
  tags?: string[];
  summary?: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  themeColor?: string;
  headings: Heading[];
  currentSlug: string;
  articleList: ArticleEntry[];
}

const {
  headings,
  currentSlug,
  articleList,
  ...seoProps
} = Astro.props;
---

<Base
  {...seoProps}
  pureMode={false}
>
  {/* 将文章列表注入到 Navigation 的 slot 中 */}
  <Fragment slot="nav-extension">
    <ArticleNav
      articles={articleList}
      currentSlug={currentSlug}
      basePath={POSTS}
    />
  </Fragment>

  <div class="article-layout" id="article-layout">
    {/* 中栏 — TOC 目录（可折叠 + 可调整宽度） */}
    <aside class="article-toc-column" id="toc-column">
      {/* 折叠按钮 */}
      <button
        class="toc-toggle-btn"
        id="toc-toggle-btn"
        type="button"
        aria-label="折叠目录"
      >
        <Icon name="lucide:panel-left-close" width={14} height={14} class="toggle-icon" />
      </button>

      {/* 动态液态高亮目录指示针 */}
      <div class="toc-active-indicator opacity-0" id="toc-indicator"></div>
      <TableOfContents headings={headings} />

      {/* 拖拽调整宽度的手柄 */}
      <div class="toc-resize-handle" id="toc-resize-handle" aria-hidden="true">
        <div class="resize-grip"></div>
      </div>
    </aside>

    {/* 展开按钮（TOC 折叠时显示） */}
    <button
      class="toc-expand-btn"
      id="toc-expand-btn"
      type="button"
      aria-label="展开目录"
      hidden
    >
      <Icon name="lucide:panel-left-open" width={14} height={14} />
    </button>

    {/* 右栏 — 文章正文 */}
    <main class="article-content-column">
      <article class="prose-glass-panel panel-glass" id="prose-panel">
        <slot />
      </article>
    </main>
  </div>
</Base>

<style>
  /* ===== 三栏布局：CSS 变量驱动宽度 ===== */
  .article-layout {
    --toc-width: 220px;
    --toc-min: 160px;
    --toc-max: 340px;

    min-height: 100vh;
    display: flex;
    background: transparent;
  }

  /* 中栏 — TOC 目录 */
  .article-toc-column {
    position: relative;
    flex-shrink: 0;
    width: var(--toc-width);
    min-width: var(--toc-min);
    max-width: var(--toc-max);
    height: 100vh;
    position: sticky;
    top: 0;
    padding: 5.25rem 0 2rem;
    overflow-y: auto;
    overflow-x: hidden;
    border-right: 1px solid var(--color-nav-border);
    background: var(--color-nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: width 0.28s cubic-bezier(0.16, 1, 0.3, 1),
                min-width 0.28s cubic-bezier(0.16, 1, 0.3, 1),
                padding 0.28s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.2s ease;
  }

  .article-toc-column::-webkit-scrollbar {
    width: 3px;
  }
  .article-toc-column::-webkit-scrollbar-track {
    background: transparent;
  }
  .article-toc-column::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--color-parchment-dim) 15%, transparent);
    border-radius: 3px;
  }
  .article-toc-column:hover::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--color-parchment-dim) 35%, transparent);
  }

  /* ===== TOC 折叠状态 ===== */
  .article-toc-column.is-collapsed {
    width: 0;
    min-width: 0;
    padding: 5.25rem 0 2rem;
    border-right: none;
    overflow: hidden;
    pointer-events: none;
  }

  /* ===== 折叠按钮 ===== */
  .toc-toggle-btn {
    position: absolute;
    top: 4.75rem;
    right: 0.5rem;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 6px;
    border: 1px solid var(--color-nav-border);
    background: var(--color-nav-bg);
    color: var(--color-parchment-dim);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, background 0.15s ease, color 0.15s ease;
  }

  .article-toc-column:hover .toc-toggle-btn {
    opacity: 0.7;
  }

  .toc-toggle-btn:hover {
    opacity: 1;
    background: var(--color-brand-glow);
    color: var(--color-brand);
    border-color: color-mix(in srgb, var(--color-brand) 30%, transparent);
  }

  /* ===== 展开按钮（折叠时出现） ===== */
  .toc-expand-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 100vh;
    position: sticky;
    top: 0;
    border: none;
    border-right: 1px solid var(--color-nav-border);
    background: var(--color-nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--color-parchment-dim);
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .toc-expand-btn:hover {
    opacity: 1;
    color: var(--color-brand);
    background: var(--color-brand-glow);
  }

  .toc-expand-btn[hidden] {
    display: none;
  }

  /* ===== 拖拽手柄 ===== */
  .toc-resize-handle {
    position: absolute;
    top: 0;
    right: -3px;
    width: 6px;
    height: 100%;
    cursor: col-resize;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .resize-grip {
    width: 3px;
    height: 32px;
    border-radius: 3px;
    background: var(--color-parchment-dim);
    opacity: 0;
    transition: opacity 0.2s ease, height 0.2s ease, background 0.15s ease;
  }

  .toc-resize-handle:hover .resize-grip {
    opacity: 0.35;
    height: 48px;
  }

  .toc-resize-handle.is-dragging .resize-grip {
    opacity: 0.6;
    height: 64px;
    background: var(--color-brand);
  }

  .article-toc-column.is-collapsed .toc-resize-handle {
    display: none;
  }

  /* ===== 右栏 — 文章正文 ===== */
  .article-content-column {
    flex: 1;
    min-width: 0;
    display: flex;
    justify-content: center;
    padding: 1rem 2rem 6rem;
  }

  /* 磨砂纸张卷轴 */
  .prose-glass-panel {
    width: 100%;
    max-width: 780px;
    padding: 2.5rem 3rem;
    border-radius: 32px;
    box-shadow: inset 0 0 20px var(--color-inner-shadow) !important;
    border-color: var(--color-border) !important;
    background: var(--color-card) !important;
    transform: none !important;
  }

  .prose-glass-panel:hover {
    box-shadow: inset 0 0 20px var(--color-inner-shadow) !important;
    border-color: var(--color-border) !important;
    background: var(--color-card) !important;
    transform: none !important;
  }

  /* ===== 响应式：中等屏幕隐藏 TOC ===== */
  @media (max-width: 1279px) {
    .article-toc-column {
      display: none;
    }

    .toc-expand-btn {
      display: none !important;
    }

    .article-content-column {
      padding: 6rem 1rem 3rem;
    }

    .prose-glass-panel {
      padding: 1.5rem !important;
      border-radius: 20px;
    }
  }

  @media (max-width: 640px) {
    .article-content-column {
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }
  }
</style>

<script>
  import '../scripts/toc-highlight';

  const TOC_WIDTH_KEY = 'walker-toc-width';
  const TOC_COLLAPSED_KEY = 'walker-toc-collapsed';
  const DEFAULT_TOC_WIDTH = 220;
  const MIN_TOC_WIDTH = 160;
  const MAX_TOC_WIDTH = 340;

  function initArticleLayout() {
    const layout = document.getElementById('article-layout');
    const tocColumn = document.getElementById('toc-column');
    const toggleBtn = document.getElementById('toc-toggle-btn');
    const expandBtn = document.getElementById('toc-expand-btn');
    const resizeHandle = document.getElementById('toc-resize-handle');

    if (!layout || !tocColumn || !toggleBtn || !expandBtn || !resizeHandle) return;

    // ---- Auto-collapse when TOC is empty ----
    const tocLinks = tocColumn.querySelectorAll('.toc-link');
    if (tocLinks.length === 0) {
      collapseToc(tocColumn, expandBtn);
      localStorage.setItem(TOC_COLLAPSED_KEY, 'true');
      return; // no need for resize/toggle when empty
    }

    // ---- Restore saved state ----
    const savedWidth = localStorage.getItem(TOC_WIDTH_KEY);
    const savedCollapsed = localStorage.getItem(TOC_COLLAPSED_KEY);
    const tocWidth = savedWidth ? parseInt(savedWidth, 10) : DEFAULT_TOC_WIDTH;

    if (savedCollapsed === 'true') {
      collapseToc(tocColumn, expandBtn);
    } else {
      setTocWidth(tocColumn, tocWidth);
    }

    // ---- Toggle button ----
    toggleBtn.addEventListener('click', () => {
      collapseToc(tocColumn, expandBtn);
      localStorage.setItem(TOC_COLLAPSED_KEY, 'true');
    });

    // ---- Expand button ----
    expandBtn.addEventListener('click', () => {
      expandToc(tocColumn, expandBtn);
      localStorage.setItem(TOC_COLLAPSED_KEY, 'false');
    });

    // ---- Drag resize ----
    let isDragging = false;
    let startX = 0;
    let startWidth = 0;

    resizeHandle.addEventListener('mousedown', (e: MouseEvent) => {
      isDragging = true;
      startX = e.clientX;
      startWidth = tocColumn.offsetWidth;
      resizeHandle.classList.add('is-dragging');
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
      e.preventDefault();
    });

    document.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isDragging) return;
      const delta = e.clientX - startX;
      const newWidth = Math.min(MAX_TOC_WIDTH, Math.max(MIN_TOC_WIDTH, startWidth + delta));
      setTocWidth(tocColumn, newWidth);
    });

    document.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      resizeHandle.classList.remove('is-dragging');
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
      localStorage.setItem(TOC_WIDTH_KEY, String(tocColumn.offsetWidth));
    });

    // ---- Double-click to collapse/expand ----
    resizeHandle.addEventListener('dblclick', () => {
      if (tocColumn.classList.contains('is-collapsed')) {
        expandToc(tocColumn, expandBtn);
        localStorage.setItem(TOC_COLLAPSED_KEY, 'false');
      } else {
        collapseToc(tocColumn, expandBtn);
        localStorage.setItem(TOC_COLLAPSED_KEY, 'true');
      }
    });
  }

  function setTocWidth(tocColumn: HTMLElement, width: number) {
    tocColumn.style.width = `${width}px`;
    tocColumn.style.minWidth = `${width}px`;
  }

  function collapseToc(tocColumn: HTMLElement, expandBtn: HTMLElement) {
    tocColumn.classList.add('is-collapsed');
    expandBtn.removeAttribute('hidden');
  }

  function expandToc(tocColumn: HTMLElement, expandBtn: HTMLElement) {
    tocColumn.classList.remove('is-collapsed');
    expandBtn.setAttribute('hidden', '');
    // Restore saved width
    const savedWidth = localStorage.getItem(TOC_WIDTH_KEY);
    const width = savedWidth ? parseInt(savedWidth, 10) : DEFAULT_TOC_WIDTH;
    setTocWidth(tocColumn, width);
  }

  initArticleLayout();
  document.addEventListener('astro:page-load', initArticleLayout);
</script>
