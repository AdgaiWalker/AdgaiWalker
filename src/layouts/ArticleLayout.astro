---
import { POSTS } from '@/shared/routes';
/**
 * ArticleLayout — 沉浸式阅读布局
 * 内容直接浮在空间里，没有盒子。工具是幽灵，需要时才出现。
 *
 * 用于：/posts/[slug]
 */
import Base from './Base.astro';
import TableOfContents from '../components/article/TableOfContents.astro';
import ArticleNav from '../components/article/ArticleNav.astro';
import { Icon } from 'astro-icon/components';

import type { ArticleEntry } from '@/types/article';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  themeColor?: string;
  headings: Heading[];
  currentSlug: string;
  articleList: ArticleEntry[];
}

const {
  headings,
  currentSlug,
  articleList,
  ...seoProps
} = Astro.props;

const tocItems = headings.filter(h => h.depth >= 2 && h.depth <= 3);
const hasToc = tocItems.length > 0;
---

<Base
  {...seoProps}
  pureMode={true}
>
  {/* 文章列表注入到 Navigation 的 slot 中 */}
  <Fragment slot="nav-extension">
    <ArticleNav
      articles={articleList}
      currentSlug={currentSlug}
      basePath={POSTS}
    />
  </Fragment>

  {/* 沉浸式阅读区域 */}
  <div class="reading-space" id="reading-space">
    {/* 左边缘提示区 — 侧边栏幽灵（扩大悬停热区 + 悬停文字提示） */}
    <div class="sidebar-ghost-hint" id="sidebar-ghost-hint" aria-hidden="true"></div>

    {/* 阅读进度条 */}
    <div class="reading-progress" id="reading-progress" aria-hidden="true">
      <div class="reading-progress-bar" id="reading-progress-bar"></div>
      <span class="reading-progress-pct" id="reading-progress-pct"></span>
    </div>

    {/* 移动端浮动导航按钮 */}
    <button class="article-fab-nav" id="article-fab-nav" aria-label="打开导航">
      <Icon name="lucide:compass" width={18} height={18} />
    </button>

    {/* 移动端 TOC 抽屉 */}
    {hasToc && (
      <div class="mobile-toc-drawer" id="mobile-toc-drawer">
        <div class="mobile-toc-overlay" id="mobile-toc-overlay"></div>
        <div class="mobile-toc-content">
          <div class="mobile-toc-handle"></div>
          <div class="mobile-toc-header">目录</div>
          <TableOfContents headings={headings} instanceId="mobile" />
        </div>
      </div>
    )}

    {/* 幽灵 TOC — hover 右边缘或按 T 键出现 */}
    {hasToc && (
      <aside class="ghost-toc" id="ghost-toc" aria-label="文章目录">
        <div class="ghost-toc-inner">
          <TableOfContents headings={headings} instanceId="ghost" />
        </div>
      </aside>
    )}

    {/* 右边缘提示线 — TOC 幽灵（放在 aside 外部，避免继承 opacity） */}
    {hasToc && (
      <div class="ghost-toc-hint" id="ghost-toc-hint" aria-hidden="true"></div>
    )}

    {/* 内容 — 直接浮在空间里，没有盒子 */}
    <div class="reading-content">
      <slot />
    </div>
  </div>
</Base>

<style>
  /* ===== 沉浸式阅读空间 ===== */
  .reading-space {
    position: relative;
    min-height: 100vh;
    display: flex;
    justify-content: center;
  }

  /* ===== 内容 — 无容器，直接浮在空间 ===== */
  .reading-content {
    width: 100%;
    max-width: 700px;
    padding: 6rem 2rem 8rem;
    position: relative;
    z-index: 1;
  }

  /* ===== 幽灵 TOC ===== */
  .ghost-toc {
    position: fixed;
    top: 0;
    right: 0;
    width: 220px;
    height: 100vh;
    padding: 5.5rem 1rem 2rem 0;
    z-index: 30;
    pointer-events: none;
    opacity: 0;
    transform: translateX(12px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .ghost-toc.is-visible {
    pointer-events: auto;
    opacity: 1;
    transform: translateX(0);
  }

  .ghost-toc-inner {
    height: 100%;
    padding: 1rem 1.25rem;
    border-left: 1px solid var(--color-nav-border);
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    overflow-y: auto;
  }

  .ghost-toc-inner::-webkit-scrollbar {
    width: 2px;
  }
  .ghost-toc-inner::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--color-parchment-dim) 20%, transparent);
    border-radius: 2px;
  }

  /* ===== 右边缘提示线（TOC） ===== */
  .ghost-toc-hint {
    position: fixed;
    top: 50%;
    right: 0;
    width: 2px;
    height: 40px;
    transform: translateY(-50%);
    background: color-mix(in srgb, var(--color-brand) 20%, transparent);
    border-radius: 2px;
    pointer-events: none;
    opacity: 0.6;
    transition: opacity 0.3s ease;
    z-index: 29;
  }

  /* TOC 可见时隐藏提示线 */
  .ghost-toc.is-visible ~ .ghost-toc-hint {
    opacity: 0;
  }

  /* TOC 首次引导脉冲 */
  @keyframes toc-hint-pulse {
    0% { opacity: 0.6; height: 40px; }
    30% { opacity: 1; height: 80px; }
    60% { opacity: 0.8; height: 60px; }
    100% { opacity: 0.6; height: 40px; }
  }

  .ghost-toc-hint.is-pulsing {
    animation: toc-hint-pulse 0.8s ease-out;
  }

  /* ===== 左边缘提示区（侧边栏） ===== */
  .sidebar-ghost-hint {
    position: fixed;
    top: 50%;
    left: 0;
    width: 24px;
    height: 80px;
    transform: translateY(-50%);
    pointer-events: auto;
    cursor: pointer;
    z-index: 29;
  }

  /* 可见的竖线（伪元素绘制，保持 2px） */
  .sidebar-ghost-hint::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 40px;
    background: color-mix(in srgb, var(--color-brand) 15%, transparent);
    border-radius: 2px;
    pointer-events: none;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  /* 悬停时显示"导航"文字提示 */
  .sidebar-ghost-hint::after {
    content: '导航';
    position: absolute;
    top: 50%;
    left: 10px;
    transform: translateY(-50%);
    font-size: 0.6rem;
    font-family: var(--font-mono, monospace);
    color: var(--color-brand);
    opacity: 0;
    transition: opacity 0.2s ease;
    white-space: nowrap;
    pointer-events: none;
  }

  .sidebar-ghost-hint:hover::before {
    opacity: 0.8;
  }

  .sidebar-ghost-hint:hover::after {
    opacity: 0.7;
  }

  /* 侧边栏可见时隐藏提示线 */
  :global(html:not([data-sidebar-hidden])) .sidebar-ghost-hint {
    opacity: 0;
  }

  /* ===== 阅读进度条 ===== */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 40;
    background: transparent;
    pointer-events: none;
  }

  .reading-progress-bar {
    height: 100%;
    width: 0%;
    background: color-mix(in srgb, var(--color-brand) 60%, transparent);
    transition: width 0.1s linear;
  }

  .reading-progress-pct {
    position: fixed;
    top: 5px;
    font-family: var(--font-mono, monospace);
    font-size: 10px;
    font-weight: 700;
    color: var(--color-brand);
    opacity: 0;
    transition: opacity 0.2s ease, left 0.1s linear;
    pointer-events: none;
  }

  /* ===== 幽灵侧边栏 — 宽度归零 ===== */
  :global(html[data-sidebar-hidden]) :global(#main-nav) {
    width: 0 !important;
    min-width: 0 !important;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, width 0.3s ease;
  }

  /* ===== 移动端浮动导航按钮 ===== */
  .article-fab-nav {
    display: none;
    position: fixed;
    bottom: 1.5rem;
    left: 1rem;
    z-index: 35;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-card);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border);
    color: var(--color-parchment-dim);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
  }

  .article-fab-nav:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
    color: var(--color-brand);
  }

  /* ===== 移动端 TOC 抽屉 ===== */
  .mobile-toc-drawer {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 45;
  }

  .mobile-toc-drawer.is-open {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .mobile-toc-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .mobile-toc-drawer.is-open .mobile-toc-overlay {
    opacity: 1;
  }

  .mobile-toc-content {
    position: relative;
    max-height: 60vh;
    background: var(--color-card);
    border-top-left-radius: 1.25rem;
    border-top-right-radius: 1.25rem;
    padding: 0.75rem 1.25rem 1.5rem;
    overflow-y: auto;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-toc-drawer.is-open .mobile-toc-content {
    transform: translateY(0);
  }

  .mobile-toc-handle {
    width: 2rem;
    height: 3px;
    border-radius: 2px;
    background: var(--color-nav-border);
    margin: 0 auto 0.75rem;
  }

  .mobile-toc-header {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-parchment);
    margin-bottom: 0.5rem;
  }

  /* ===== 响应式 ===== */
  @media (max-width: 1279px) {
    .ghost-toc,
    .ghost-toc-hint,
    .sidebar-ghost-hint {
      display: none;
    }

    .article-fab-nav {
      display: flex;
    }

    .mobile-toc-drawer {
      display: none;
    }

    .mobile-toc-drawer.is-open {
      display: flex;
    }

    .reading-content {
      padding: 6rem 1.5rem 4rem;
    }
  }

  @media (min-width: 1280px) {
    .mobile-toc-drawer {
      display: none !important;
    }
  }

  @media (max-width: 640px) {
    .reading-content {
      padding: 5.5rem 1rem 3rem;
    }
  }
</style>

<script>
  import '../scripts/toc-highlight';

  let articleAbort: AbortController | null = null;
  let ghostSidebarObserver: MutationObserver | null = null;

  function initGhostToc(signal: AbortSignal) {
    const toc = document.getElementById('ghost-toc');
    if (!toc) return;

    // 首次引导脉冲
    const tocHint = document.getElementById('ghost-toc-hint');
    if (tocHint && !localStorage.getItem('walker-toc-hint-seen')) {
      setTimeout(() => {
        tocHint.classList.add('is-pulsing');
        tocHint.addEventListener('animationend', () => {
          tocHint.classList.remove('is-pulsing');
        }, { once: true, signal });
        localStorage.setItem('walker-toc-hint-seen', '1');
      }, 1500);
    }

    let hideTimer: ReturnType<typeof setTimeout>;

    document.addEventListener('mousemove', (e: MouseEvent) => {
      const viewportWidth = window.innerWidth;
      const inRightZone = e.clientX > viewportWidth - 60;

      clearTimeout(hideTimer);
      if (inRightZone) {
        toc.classList.add('is-visible');
      } else {
        hideTimer = setTimeout(() => {
          toc.classList.remove('is-visible');
        }, 400);
      }
    }, { signal });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement || (e.target as HTMLElement).isContentEditable) return;
      if (e.key === 't' && !e.ctrlKey && !e.metaKey && !e.altKey) {
        e.preventDefault();
        toc.classList.toggle('is-visible');
      }
    }, { signal });
  }

  function initReadingProgress(signal: AbortSignal) {
    const bar = document.getElementById('reading-progress-bar');
    const pct = document.getElementById('reading-progress-pct');
    if (!bar) return;

    const update = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
      const widthPct = progress * 100;
      bar.style.width = `${widthPct}%`;

      if (pct) {
        if (progress > 0.05 && progress < 0.99) {
          pct.textContent = `${Math.round(widthPct)}%`;
          pct.style.left = `${widthPct}%`;
          pct.style.opacity = '0.7';
        } else {
          pct.style.opacity = '0';
        }
      }
    };

    window.addEventListener('scroll', update, { passive: true, signal });
    update();
  }

  function initGhostSidebar(signal: AbortSignal) {
    const root = document.documentElement;

    // 自动折叠并隐藏侧边栏
    root.setAttribute('data-sidebar-collapsed', '');
    root.setAttribute('data-sidebar-hidden', '');

    // 侧边栏被展开时（[ 键），同步移除 ghost 隐藏
    ghostSidebarObserver = new MutationObserver(() => {
      if (!root.hasAttribute('data-sidebar-collapsed')) {
        root.removeAttribute('data-sidebar-hidden');
      }
    });
    ghostSidebarObserver.observe(root, { attributes: true, attributeFilter: ['data-sidebar-collapsed'] });

    // 鼠标移到左边缘 → 露出折叠图标
    let sidebarHideTimer: ReturnType<typeof setTimeout>;

    document.addEventListener('mousemove', (e: MouseEvent) => {
      const inLeftZone = e.clientX < 60;
      clearTimeout(sidebarHideTimer);

      if (inLeftZone && root.hasAttribute('data-sidebar-collapsed')) {
        root.removeAttribute('data-sidebar-hidden');
      } else if (!inLeftZone && root.hasAttribute('data-sidebar-collapsed')) {
        sidebarHideTimer = setTimeout(() => {
          if (root.hasAttribute('data-sidebar-collapsed')) {
            root.setAttribute('data-sidebar-hidden', '');
          }
        }, 600);
      }
    }, { signal });
  }

  function initFabNav(signal: AbortSignal) {
    const fabNav = document.getElementById('article-fab-nav');
    const drawer = document.getElementById('mobile-toc-drawer');
    const overlay = document.getElementById('mobile-toc-overlay');

    if (fabNav && drawer) {
      // 有 TOC 的文章页 → FAB 打开 TOC 抽屉
      fabNav.addEventListener('click', () => {
        drawer.classList.toggle('is-open');
      }, { signal });

      overlay?.addEventListener('click', () => {
        drawer.classList.remove('is-open');
      }, { signal });

      drawer.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          drawer.classList.remove('is-open');
        }, { signal });
      });
    } else if (fabNav) {
      // 无 TOC → 打开导航菜单
      fabNav.addEventListener('click', () => {
        document.getElementById('menu-toggle')?.click();
      }, { signal });
    }
  }

  function initArticleScripts() {
    articleAbort?.abort();
    articleAbort = new AbortController();
    const { signal } = articleAbort;

    initGhostToc(signal);
    initGhostSidebar(signal);
    initReadingProgress(signal);
    initFabNav(signal);
  }

  initArticleScripts();
  document.addEventListener('astro:page-load', initArticleScripts);
  document.addEventListener('astro:before-swap', () => {
    articleAbort?.abort();
    articleAbort = null;
    ghostSidebarObserver?.disconnect();
    ghostSidebarObserver = null;
    document.documentElement.removeAttribute('data-sidebar-hidden');
  });
</script>
