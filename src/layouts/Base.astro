---
import HeadCommon from '../components/shared/HeadCommon.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { getSolarTerm } from '../lib/solar-terms';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  themeColor?: string;
  pureMode?: boolean;
  /** 隐藏导航（全屏页使用） */
  hideNav?: boolean;
  /** 隐藏页脚（全屏页使用） */
  hideFooter?: boolean;
  theme?: string;
  brandColor?: string;
  brandSecondaryColor?: string;
}

const {
  title = 'Walker — 行过万里水路',
  description = 'Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。',
  ogImage = '/images/hero-bg.png',
  ogTitle,
  ogDescription,
  canonicalUrl,
  themeColor,
  pureMode = false,
  hideNav = false,
  hideFooter = false,
  theme,
  brandColor,
  brandSecondaryColor,
} = Astro.props;

const term = getSolarTerm(new Date());

const bodyStyles = [
  brandColor ? `--color-brand: ${brandColor};` : '',
  brandSecondaryColor ? `--color-brand-secondary: ${brandSecondaryColor};` : '',
  brandColor ? `--color-brand-glow: ${brandColor}20;` : '',
  brandColor ? `--orb-color-1: ${brandColor}14;` : '',
  brandColor ? `--orb-color-2: ${brandColor}12;` : '',
  brandColor ? `--orb-color-3: ${brandColor}10;` : '',
  brandColor ? `--orb-color-4: ${brandColor}08;` : '',
].filter(Boolean).join(' ');

const isHome = Astro.url.pathname === '/';
---

<!DOCTYPE html>
<html lang="zh-CN">

  <head>
    <HeadCommon
      title={title}
      description={description}
      ogImage={ogImage}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      canonicalUrl={canonicalUrl}
      themeColor={themeColor}
    />
    
    <!-- JSON-LD 结构化数据 -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Walker 知识空间",
      "alternateName": "秋知的个人博客",
      "url": Astro.site?.toString() || "https://iwalk.pro",
      "description": "Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。",
      "author": {
        "@type": "Person",
        "name": "Walker (秋知)",
        "url": Astro.site?.toString() || "https://iwalk.pro"
      },
      "inLanguage": "zh-CN"
    })} />
    
    <!-- 传递 pureMode 给环境脚本 -->
    <meta name="env-pure-mode" content={pureMode ? "true" : "false"} />

    <!-- 昼夜交替自适应控制 (Diurnal Cycle Switcher) -->
    <script is:inline>
      (function() {
        function updateDiurnalTheme() {
          const hour = new Date().getHours();
          const isNight = hour < 6 || hour >= 18;
          if (isNight) {
            document.documentElement.classList.add('theme-dark');
            document.documentElement.classList.remove('theme-light');
            document.body?.classList.add('theme-dark');
            document.body?.classList.remove('theme-light');
          } else {
            document.documentElement.classList.add('theme-light');
            document.documentElement.classList.remove('theme-dark');
            document.body?.classList.add('theme-light');
            document.body?.classList.remove('theme-dark');
          }
        }
        updateDiurnalTheme();
        document.addEventListener('astro:page-load', updateDiurnalTheme);
      })();
    </script>

    {/* 注入二十四节气「时令共振」主题全局 CSS 变量 */}
    <style is:global define:vars={{
      stBrand: term.colors.brand,
      stBrandGlow: `${term.colors.brand}20`,
      stBrandSecondary: term.colors.brandSecondary,
      stBg: term.colors.bg,
      stCard: term.colors.card,
      stBorder: term.colors.border,
      stParchment: term.colors.parchment,
      stParchmentDim: term.colors.parchmentDim,
      stMistBg: term.colors.mistBg,
      stOrb1: term.colors.orb1,
      stOrb2: term.colors.orb2,
      stOrb3: term.colors.orb3,
      stOrb4: term.colors.orb4,
    }}>
      body.theme-solar-term, body:not([class*="theme-"]) {
        --color-brand: var(--stBrand);
        --color-brand-glow: var(--stBrandGlow);
        --color-brand-secondary: var(--stBrandSecondary);
        --color-bg: var(--stBg);
        --color-card: var(--stCard);
        --color-border: var(--stBorder);
        --color-parchment: var(--stParchment);
        --color-parchment-dim: var(--stParchmentDim);
        --color-mist-bg: var(--stMistBg);
        --orb-color-1: var(--stOrb1);
        --orb-color-2: var(--stOrb2);
        --orb-color-3: var(--stOrb3);
        --orb-color-4: var(--stOrb4);
        background-color: var(--stBg);
        color: var(--stParchment);
      }
    </style>
  </head>
  <body 
    class:list={["min-h-screen flex flex-col", theme ? `theme-${theme}` : "theme-solar-term", pureMode ? "reading-mode" : "", hideNav ? "fullscreen-layout" : ""]}
    data-page-theme={theme}
    data-theme-type={term.themeType}
    style={bodyStyles || undefined}
  >
    {/* 全局环境背景层：自适应晶莹底色，搭载细微噪声格网纹理与光晕 */}
    <div class="fixed inset-0 -z-20 overflow-hidden bg-transparent" aria-hidden="true">
      {/* 极弱极细格线网纹 */}
      <div class="absolute inset-0 opacity-[0.015] pointer-events-none" style="background-image: radial-gradient(#000 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>
    </div>
    
    {/* 全局 Orbs 流光自适应背景 — 搭载 transition:persist 跨页面无缝留存 */}
    <div id="dynamic-bg-glows" class="fixed inset-0 -z-30 overflow-hidden pointer-events-none transition-all duration-1000" transition:persist aria-hidden="true">
      <div class="glow-orb" id="orb-1"></div>
      <div class="glow-orb" id="orb-2"></div>
      <div class="glow-orb" id="orb-3"></div>
      <div class="glow-orb" id="orb-4"></div>
      {/* 模糊雾罩，过滤光晕边缘，实现晶莹朦胧感 */}
      <div id="mist-overlay" class="absolute inset-0 z-0 pointer-events-none backdrop-blur-[160px] saturate-[140%] transition-all duration-1000"></div>
    </div>
    
    {/* 鼠标跟随光晕 */}
    <div class="mouse-glow" id="mouse-glow" aria-hidden="true"></div>
    
    {/* 噪点纹理叠加 */}
    <div class="grain-overlay" aria-hidden="true"></div>

    {!hideNav && <Navigation>
      <slot name="nav-extension" />
    </Navigation>}
    <div class:list={["flex flex-col flex-1 w-full", !isHome && !hideNav && "site-main-shell"]}>
      <main class="flex-1 relative z-10 w-full">
        <slot />
      </main>
      {!isHome && !hideFooter && <Footer />}
    </div>

    {/* 全局返回顶部按钮 */}
    <button class="back-to-top" id="back-to-top" aria-label="返回顶部">
      <Icon name="lucide:arrow-up" width={18} height={18} />
    </button>

    <script>
      import '../scripts/scroll-fade';
      import '../scripts/page-transitions';
      import { setupTilt } from '../scripts/tilt-effect';

      // --- 鼠标跟随光晕 ---
      let glowAbort: AbortController | null = null;
      let tiltCleanup: (() => void) | null = null;
      let backToTopAbort: AbortController | null = null;

      const setupMouseGlow = () => {
        glowAbort?.abort();
        glowAbort = new AbortController();
        const glow = document.getElementById('mouse-glow');
        if (!glow) return;
        const { signal } = glowAbort;
        
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        
        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          glow.style.left = mouseX + 'px';
          glow.style.top = mouseY + 'px';
          glow.style.opacity = '1';
        }, { signal });

        document.addEventListener('mouseleave', () => {
          glow.style.opacity = '0';
        }, { signal });
      };

      const setupPanelTilt = () => {
        tiltCleanup?.();
        tiltCleanup = setupTilt('.panel-glass:not(.prose-glass-panel)', {
          perspective: 1200,
          maxRotation: 2,
          scale: 1.008,
        });
      };

      const setupBackToTop = () => {
        backToTopAbort?.abort();
        backToTopAbort = new AbortController();
        const btn = document.getElementById('back-to-top');
        if (!btn) return;
        const { signal } = backToTopAbort;

        const update = () => {
          btn.classList.toggle('is-visible', window.scrollY > 300);
        };

        window.addEventListener('scroll', update, { passive: true, signal });
        btn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }, { signal });
        update();
      };

      const initAll = () => {
        setupMouseGlow();
        setupPanelTilt();
        setupBackToTop();
      };

      const cleanupAll = () => {
        glowAbort?.abort();
        glowAbort = null;
        tiltCleanup?.();
        tiltCleanup = null;
        backToTopAbort?.abort();
        backToTopAbort = null;
      };

      // 首次加载与视图切换挂载
      initAll();
      document.addEventListener('astro:page-load', initAll);
      document.addEventListener('astro:before-swap', cleanupAll);
    </script>
  </body>
</html>
