---
import HeadCommon from '../components/shared/HeadCommon.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  pureMode?: boolean;
  theme?: 'nature' | 'blue' | 'emerald' | 'charcoal';
}

const {
  title = 'Walker — 行过万里水路',
  description = 'Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。',
  ogImage = '/images/hero-bg.png',
  ogTitle,
  ogDescription,
  canonicalUrl,
  pureMode = false,
} = Astro.props;

const isHome = Astro.url.pathname === '/';
---

<!DOCTYPE html>
<html lang="zh-CN" style="--color-brand:#35bfab;--color-primary:#2a3b3e;--color-secondary:#6b7c82;--color-brand-secondary:#1fc9e7;--color-bg:#eef0ec;--color-border:#ffffffcc;--color-card:#ffffff80;--color-article:#ffffffcc">

  <head>
    <HeadCommon
      title={title}
      description={description}
      ogImage={ogImage}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      canonicalUrl={canonicalUrl}
    />
    
    <!-- JSON-LD 结构化数据 -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Walker 知识空间",
      "alternateName": "秋知的个人博客",
      "url": Astro.site?.toString() || "https://iwalk.pro",
      "description": "Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。",
      "author": {
        "@type": "Person",
        "name": "Walker (秋知)",
        "url": Astro.site?.toString() || "https://iwalk.pro"
      },
      "inLanguage": "zh-CN"
    })} />
    
    <!-- 传递 pureMode 给环境脚本 -->
    <meta name="env-pure-mode" content={pureMode ? "true" : "false"} />
  </head>
  <body class:list={["min-h-screen flex flex-col", pureMode ? "reading-mode" : ""]}>
    {/* 全局环境背景层：自适应晶莹底色，搭载细微噪声格网纹理与光晕 */}
    <div class="fixed inset-0 -z-20 overflow-hidden bg-transparent" aria-hidden="true">
      {/* 极弱极细格线网纹 */}
      <div class="absolute inset-0 opacity-[0.015] pointer-events-none" style="background-image: radial-gradient(#000 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>
    </div>
    
    {/* 鼠标跟随光晕 */}
    <div class="mouse-glow" id="mouse-glow" aria-hidden="true"></div>
    
    {/* 噪点纹理叠加 */}
    <div class="grain-overlay" aria-hidden="true"></div>

    <Navigation transition:persist>
      <slot name="nav-extension" />
    </Navigation>
    <div class:list={["flex flex-col flex-1 w-full", !isHome && "site-main-shell"]} transition:animate="fade">
      <main class="flex-1 relative z-10 w-full">
        <slot />
      </main>
      {!isHome && <Footer />}
    </div>

    <script>
      import '../scripts/scroll-fade';

      // --- 鼠标跟随光晕 ---
      let glowAbort: AbortController | null = null;
      let tiltAbort: AbortController | null = null;
      let tiltFrame = 0;

      const setupMouseGlow = () => {
        glowAbort?.abort();
        glowAbort = new AbortController();
        const glow = document.getElementById('mouse-glow');
        if (!glow) return;
        const { signal } = glowAbort;
        
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        
        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          glow.style.left = mouseX + 'px';
          glow.style.top = mouseY + 'px';
          glow.style.opacity = '1';
        }, { signal });

        document.addEventListener('mouseleave', () => {
          glow.style.opacity = '0';
        }, { signal });
      };

      // --- 3D 磁性卡片逻辑 ---
      const setupTilt = () => {
        tiltAbort?.abort();
        tiltAbort = new AbortController();
        const { signal } = tiltAbort;
        const cards = document.querySelectorAll('.panel-glass');
        
        cards.forEach((card: any) => {
          card.addEventListener('mousemove', (e: MouseEvent) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            
            // 计算旋转角度 (最大 2 度，更细腻)
            const rotateX = ((y - centerY) / centerY) * -2;
            const rotateY = ((x - centerX) / centerX) * 2;
            
            cancelAnimationFrame(tiltFrame);
            tiltFrame = requestAnimationFrame(() => {
              card.style.transform = `perspective(1200px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.008, 1.008, 1.008)`;
            });
          }, { signal });
          
          card.addEventListener('mouseleave', () => {
            cancelAnimationFrame(tiltFrame);
            card.style.transform = `perspective(1200px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
          }, { signal });
        });
      };

      setupMouseGlow();
      setupTilt();
      document.addEventListener('astro:page-load', () => {
        setupMouseGlow();
        setupTilt();
      });

      document.addEventListener('astro:before-swap', () => {
        glowAbort?.abort();
        glowAbort = null;
        tiltAbort?.abort();
        tiltAbort = null;
        cancelAnimationFrame(tiltFrame);
      });
    </script>
  </body>
</html>
