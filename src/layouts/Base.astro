---
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  pureMode?: boolean;
  theme?: 'nature' | 'blue' | 'emerald' | 'charcoal';
}

const {
  title = 'Walker — 行过万里水路',
  description = 'Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。',
  ogImage = '/images/hero-bg.png',
  ogTitle,
  ogDescription,
  canonicalUrl,
  pureMode = false,
  theme = 'nature',
} = Astro.props;

const isHome = Astro.url.pathname === '/';
const pageTitle = ogTitle ?? title;
const pageDescription = ogDescription ?? description;
const canonical = canonicalUrl ?? Astro.url.href;
const absoluteOgImage = new URL(ogImage, Astro.site ?? Astro.url).href;
---

<!DOCTYPE html>
<html lang="zh-CN" style="--color-brand:#35bfab;--color-primary:#2a3b3e;--color-secondary:#6b7c82;--color-brand-secondary:#1fc9e7;--color-bg:#eef0ec;--color-border:#ffffffcc;--color-card:#ffffff80;--color-article:#ffffffcc">

  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#35bfab" />
    <meta name="author" content="Walker (秋知)" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Walker RSS" href={new URL('/rss.xml', Astro.site ?? Astro.url)} />
    
    <!-- 引入外部字体 (增加 Inter + Sora) -->
    <link rel="preconnect" href="https://fonts.googleapis.cn">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.cn/css2?family=Inter:wght@300;400;500;600;700&family=Sora:wght@300;400;500;600;700&family=Share+Tech+Mono&family=JetBrains+Mono:wght@400;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Walker 知识空间" />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={absoluteOgImage} />
    
    <!-- JSON-LD 结构化数据 -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Walker 知识空间",
      "alternateName": "秋知的个人博客",
      "url": Astro.site?.toString() || "https://iwalk.pro",
      "description": "Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。",
      "author": {
        "@type": "Person",
        "name": "Walker (秋知)",
        "url": Astro.site?.toString() || "https://iwalk.pro"
      },
      "inLanguage": "zh-CN"
    })} />
    
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <ClientRouter />
    
    <!-- 传递 pureMode 给环境脚本 -->
    <meta name="env-pure-mode" content={pureMode ? "true" : "false"} />
    <title>{title}</title>
  </head>
  <body class:list={["min-h-screen flex flex-col", pureMode ? "bg-[#fdfdfd] reading-mode" : ""]}>
    {!pureMode && (
      <>
        <!-- 环境背景层 (精致渐变 + 大色块) -->
        <div class="fixed inset-0 -z-20 overflow-hidden" style="background: linear-gradient(145deg, #eef2e8 0%, #e4e8dd 30%, #e8ebe5 60%, #edf0ea 100%);" aria-hidden="true">
          <!-- 柔和渐变晕影 - 更大、更柔和 -->
          <div class="absolute top-[-20%] left-[-5%] w-[70%] h-[60%] rounded-full blur-[160px]" style="background: rgba(216, 230, 190, 0.35); animation: subtle-float 20s ease-in-out infinite;"></div>
          <div class="absolute bottom-[-10%] right-[-5%] w-[60%] h-[60%] rounded-full blur-[160px]" style="background: rgba(220, 235, 200, 0.3); animation: subtle-float 25s ease-in-out infinite reverse;"></div>
          <div class="absolute top-[20%] right-[20%] w-[45%] h-[45%] rounded-full blur-[140px]" style="background: rgba(53, 191, 171, 0.06); animation: subtle-float 18s ease-in-out infinite 2s;"></div>
          <div class="absolute bottom-[30%] left-[30%] w-[35%] h-[35%] rounded-full blur-[120px]" style="background: rgba(200, 225, 195, 0.25); animation: subtle-float 22s ease-in-out infinite 4s;"></div>
        </div>

        <!-- 背景 canvas (用于动态模糊光影) -->
        <canvas id="ambient-particles" class="fixed inset-0 -z-10 pointer-events-none opacity-15" aria-hidden="true"></canvas>
        
        <!-- 鼠标跟随光晕 -->
        <div class="mouse-glow" id="mouse-glow" aria-hidden="true"></div>
        
        <!-- 噪点纹理叠加 -->
        <div class="grain-overlay" aria-hidden="true"></div>
      </>
    )}

    {!isHome && (
      <Navigation transition:persist>
        <slot name="nav-extension" />
      </Navigation>
    )}
    <div class:list={["flex flex-col flex-1 w-full", isHome ? "" : "lg:pl-[260px]"]} transition:animate="fade">
      <main class="flex-1 relative z-10 w-full">
        <slot />
      </main>
      {!isHome && <Footer />}
    </div>

    <script>
      import '../scripts/ambient';
      import '../scripts/scroll-fade';

      // --- 鼠标跟随光晕 ---
      const setupMouseGlow = () => {
        const glow = document.getElementById('mouse-glow');
        if (!glow) return;
        
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        
        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          glow.style.left = mouseX + 'px';
          glow.style.top = mouseY + 'px';
          glow.style.opacity = '1';
        });

        document.addEventListener('mouseleave', () => {
          glow.style.opacity = '0';
        });
      };

      // --- 3D 磁性卡片逻辑 ---
      const setupTilt = () => {
        const cards = document.querySelectorAll('.panel-glass');
        
        cards.forEach((card: any) => {
          card.addEventListener('mousemove', (e: MouseEvent) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            
            // 计算旋转角度 (最大 2 度，更细腻)
            const rotateX = ((y - centerY) / centerY) * -2;
            const rotateY = ((x - centerX) / centerX) * 2;
            
            card.style.transform = `perspective(1200px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.008, 1.008, 1.008)`;
          });
          
          card.addEventListener('mouseleave', () => {
            card.style.transform = `perspective(1200px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
          });
        });
      };

      setupMouseGlow();
      setupTilt();
      document.addEventListener('astro:page-load', () => {
        setupMouseGlow();
        setupTilt();
      });
    </script>
  </body>
</html>
