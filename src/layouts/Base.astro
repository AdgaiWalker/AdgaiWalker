---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

import JsonLd from '../components/JsonLd.astro';

interface Props {
  title?: string;
  description?: string;
  jsonLd?: { type: 'concept' | 'content'; data: Record<string, any> };
}

const {
  title = 'Walker',
  description = '用 AI 做更少但更好的事',
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@300;400;500;700&family=Sora:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
    {jsonLd && <JsonLd type={jsonLd.type} data={jsonLd.data} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <Navigation />
    <main class="flex-1 pt-14">
      <slot />
    </main>
    <Footer />
  </body>
</html>
