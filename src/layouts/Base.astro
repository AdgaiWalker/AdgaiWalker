---
import HeadCommon from '../components/shared/HeadCommon.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  themeColor?: string;
  pureMode?: boolean;
  fullscreen?: boolean;
}

const {
  title = 'Walker — 行过万里水路',
  description = 'Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。',
  ogImage = '/images/hero-bg.png',
  ogTitle,
  ogDescription,
  canonicalUrl,
  themeColor,
  pureMode = false,
  fullscreen = false,
} = Astro.props;

const isHome = Astro.url.pathname === '/';
---

<!DOCTYPE html>
<html lang="zh-CN">

  <head>
    <HeadCommon
      title={title}
      description={description}
      ogImage={ogImage}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      canonicalUrl={canonicalUrl}
      themeColor={themeColor}
    />
    
    <!-- JSON-LD 结构化数据 -->
    {!fullscreen && <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Walker 知识空间",
      "alternateName": "秋知的个人博客",
      "url": Astro.site?.toString() || "https://iwalk.pro",
      "description": "Walker 的个人航海日志，记录 AI 探索、独立开发与生活点滴。",
      "author": {
        "@type": "Person",
        "name": "Walker (秋知)",
        "url": Astro.site?.toString() || "https://iwalk.pro"
      },
      "inLanguage": "zh-CN"
    })} />}
    
    <!-- 传递 pureMode 给环境脚本 -->
    <meta name="env-pure-mode" content={pureMode ? "true" : "false"} />
  </head>
  <body class:list={["min-h-screen flex flex-col", pureMode ? "reading-mode" : "", fullscreen ? "fullscreen-layout" : ""]}>
    {/* 全局环境背景层：自适应晶莹底色，搭载细微噪声格网纹理与光晕 */}
    {!fullscreen && <div class="fixed inset-0 -z-20 overflow-hidden bg-transparent" aria-hidden="true">
      {/* 极弱极细格线网纹 */}
      <div class="absolute inset-0 opacity-[0.015] pointer-events-none" style="background-image: radial-gradient(#000 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>
    </div>}
    
    {/* 鼠标跟随光晕 */}
    {!fullscreen && <div class="mouse-glow" id="mouse-glow" aria-hidden="true"></div>}
    
    {/* 噪点纹理叠加 */}
    {!fullscreen && <div class="grain-overlay" aria-hidden="true"></div>}

    {!fullscreen && <Navigation transition:persist>
      <slot name="nav-extension" />
    </Navigation>}
    <div class:list={["flex flex-col flex-1 w-full", !isHome && !fullscreen && "site-main-shell"]}>
      <main class="flex-1 relative z-10 w-full">
        <slot />
      </main>
      {!isHome && !fullscreen && <Footer />}
    </div>

    {!fullscreen && <script>
      import '../scripts/scroll-fade';
      import '../scripts/page-transitions';
      import { setupTilt } from '../scripts/tilt-effect';

      // --- 鼠标跟随光晕 ---
      let glowAbort: AbortController | null = null;
      let tiltCleanup: (() => void) | null = null;

      const setupMouseGlow = () => {
        glowAbort?.abort();
        glowAbort = new AbortController();
        const glow = document.getElementById('mouse-glow');
        if (!glow) return;
        const { signal } = glowAbort;
        
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        
        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          glow.style.left = mouseX + 'px';
          glow.style.top = mouseY + 'px';
          glow.style.opacity = '1';
        }, { signal });

        document.addEventListener('mouseleave', () => {
          glow.style.opacity = '0';
        }, { signal });
      };

      const setupPanelTilt = () => {
        tiltCleanup?.();
        tiltCleanup = setupTilt('.panel-glass:not(.prose-glass-panel)', {
          perspective: 1200,
          maxRotation: 2,
          scale: 1.008,
        });
      };

      setupMouseGlow();
      setupPanelTilt();
      document.addEventListener('astro:page-load', () => {
        setupMouseGlow();
        setupPanelTilt();
      });

      document.addEventListener('astro:before-swap', () => {
        glowAbort?.abort();
        glowAbort = null;
        tiltCleanup?.();
        tiltCleanup = null;
      });
    </script>}
  </body>
</html>
