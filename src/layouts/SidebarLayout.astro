---
/**
 * SidebarLayout — 内页通用布局（侧边栏 + 内容区）
 * 用于：/ai, /ai/learn, /ai/sources, /ai/toolkit, /ai/ideas, /life, /about
 */
import Base from './Base.astro';
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  /** 页面标题（中文） */
  pageTitle?: string;
  /** 页面副标题（英文） */
  pageSubtitle?: string;
  /** 页面图标（Lucide icon 名称） */
  pageIcon?: string;
  /** 文章/条目总数 */
  itemCount?: number;
  /** 计数单位 */
  itemUnit?: string;
}

const {
  title,
  description,
  ogImage,
  ogTitle,
  ogDescription,
  canonicalUrl,
  pageTitle,
  pageSubtitle,
  pageIcon,
  itemCount,
  itemUnit = '篇文章',
} = Astro.props;
---

<Base
  title={title}
  description={description}
  ogImage={ogImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  canonicalUrl={canonicalUrl}
>
  <div class="sidebar-layout-content">
    {/* 页面头部区域 */}
    {pageTitle && (
      <header class="page-header">
        <div class="page-header-title">
          {pageIcon && (
            <span class="page-header-icon">
              <iconify-icon icon={`lucide:${pageIcon}`} width="20" height="20"></iconify-icon>
            </span>
          )}
          <div>
            <h1 class="page-header-h1">{pageTitle}</h1>
            {pageSubtitle && (
              <span class="page-header-subtitle">{pageSubtitle}</span>
            )}
          </div>
        </div>
        {typeof itemCount === 'number' && (
          <div class="page-header-count">
            {itemCount} {itemUnit}
          </div>
        )}
      </header>
    )}

    {/* 页面主体（筛选器 + 内容由外部 slot 提供） */}
    <slot />
  </div>
</Base>

<style>
  .sidebar-layout-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 2.25rem 4.5rem;
  }

  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.35rem;
    border-bottom: 1px solid rgba(42, 59, 62, 0.06);
  }

  .page-header-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .page-header-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 11px;
    border: 1px solid rgba(53, 191, 171, 0.16);
    background: rgba(53, 191, 171, 0.08);
    color: #218f80;
    flex-shrink: 0;
  }

  .page-header-h1 {
    font-family: 'Sora', 'PingFang SC', system-ui, sans-serif;
    font-size: clamp(1.55rem, 2.2vw, 2rem);
    font-weight: 700;
    color: #2a3b3e;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .page-header-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(42, 59, 62, 0.38);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .page-header-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: rgba(42, 59, 62, 0.42);
    letter-spacing: 0.03em;
    margin-top: 0.5rem;
  }

  @media (max-width: 1024px) {
    .sidebar-layout-content {
      padding: 6rem 1.25rem 3rem;
    }
  }
</style>
