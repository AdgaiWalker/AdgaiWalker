---
import Base from '../../layouts/Base.astro';
import ConceptCard from '../../components/ConceptCard.astro';
import {
  buildConceptCounts,
  getActiveConcepts,
  getLayerConcepts,
  getPublishedLogEntries,
  groupDomainConcepts,
} from '../../utils/knowledge';

const allConcepts = await getActiveConcepts();
const allLog = await getPublishedLogEntries();
const conceptCounts = buildConceptCounts(allLog);

const frameworkConcepts = getLayerConcepts(allConcepts);
const domainGroups = groupDomainConcepts(allConcepts);
---

<Base title="概念图谱 — Walker">
  <div class="relative">
    <div class="fixed inset-0 pointer-events-none z-0"
      style="background: linear-gradient(180deg, #132040 0%, #0a1628 30%, #060e1a 100%);">
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 pt-28 pb-20">
      <div class="mb-16">
        <h1 class="font-heading text-4xl md:text-5xl text-parchment tracking-wide">概念图谱</h1>
        <p class="mt-3 text-parchment/30 text-sm font-body">
          知识的节点，思想的坐标
        </p>
        <div class="mt-4 w-16 h-px bg-gold/30"></div>
      </div>

      <!-- 五层逻辑 -->
      <section class="mb-20">
        <div class="flex items-center gap-4 mb-10">
          <h2 class="font-heading text-xl text-gold tracking-wide">五层逻辑</h2>
          <div class="flex-1 h-px bg-gradient-to-r from-gold/20 to-transparent"></div>
        </div>

        <div class="relative">
          {frameworkConcepts.map((concept, i) => (
            <div class="flex items-stretch gap-4 mb-6">
              <div class="flex flex-col items-center">
                <div class="w-8 h-8 rounded-full border border-gold/40 flex items-center justify-center text-gold/70 text-xs font-heading">
                  {concept.data.symbol}
                </div>
                {i < frameworkConcepts.length - 1 && (
                  <div class="flex-1 w-px bg-gradient-to-b from-gold/30 to-gold/5 mt-2"></div>
                )}
              </div>
              <div class="flex-1 pb-2">
                <ConceptCard
                  id={concept.id}
                  title={concept.data.title}
                  symbol={concept.data.symbol}
                  layer={concept.data.layer}
                  contentCount={conceptCounts.get(concept.id) ?? 0}
                  body={concept.body}
                />
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- 领域概念 -->
      {domainGroups.length > 0 && (
        <section>
          <div class="flex items-center gap-4 mb-10">
            <h2 class="font-heading text-xl text-parchment tracking-wide">领域概念</h2>
            <div class="flex-1 h-px bg-gradient-to-r from-mist/20 to-transparent"></div>
          </div>

          <div class="grid gap-8 md:grid-cols-2">
            {domainGroups.map(([domain, concepts]) => (
              <div>
                <h3 class="font-heading text-sm text-mist tracking-wider uppercase mb-4">{domain}</h3>
                <div class="grid gap-4">
                  {concepts.map(concept => (
                    <ConceptCard
                      id={concept.id}
                      title={concept.data.title}
                      contentCount={conceptCounts.get(concept.id) ?? 0}
                      body={concept.body}
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</Base>
