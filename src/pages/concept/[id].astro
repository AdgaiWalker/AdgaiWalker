---
import Base from '../../layouts/Base.astro';
import ConceptCard from '../../components/ConceptCard.astro';
import TraceCard from '../../components/TraceCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const concepts = await getCollection('concepts', ({ data }) => data.status === 'active');
  return concepts.map(concept => ({
    params: { id: concept.id },
    props: { concept },
  }));
}

const { concept } = Astro.props;
const { Content } = await render(concept);

const allLog = await getCollection('log', ({ data }) => data.published);
const relatedEntries = allLog
  .filter(e => e.data.concepts?.includes(concept.id))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allConcepts = await getCollection('concepts', ({ data }) => data.status === 'active');
const relatedConcepts = allConcepts.filter(c =>
  concept.data.related.includes(c.id) && c.id !== concept.id
);

const conceptCounts = new Map<string, number>();
allLog.forEach(entry => {
  entry.data.concepts?.forEach(id => {
    conceptCounts.set(id, (conceptCounts.get(id) ?? 0) + 1);
  });
});
---

<Base title={`${concept.data.title} — Walker`}>
  <div class="relative">
    <div class="fixed inset-0 pointer-events-none z-0"
      style="background: linear-gradient(180deg, #132040 0%, #0a1628 30%, #060e1a 100%);">
    </div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 pt-28 pb-20">
      <header class="mb-12">
        <div class="flex items-center gap-4 mb-4">
          {concept.data.symbol && (
            <div class="w-12 h-12 rounded-full border border-gold/40 flex items-center justify-center text-gold/70 text-xl font-heading">
              {concept.data.symbol}
            </div>
          )}
          <div>
            <h1 class="font-heading text-3xl md:text-4xl text-parchment leading-tight">
              {concept.data.title}
            </h1>
            {concept.data.layer && (
              <span class="text-gold/50 text-xs font-heading tracking-wider">
                五层逻辑 · 第 {concept.data.layer} 层
              </span>
            )}
          </div>
        </div>

        <div class="flex gap-2 flex-wrap">
          {concept.data.domain.map(d => (
            <span class="text-xs px-2 py-0.5 rounded bg-sea-light/20 text-mist-light">{d}</span>
          ))}
          <span class="text-xs text-mist/50">{relatedEntries.length} 篇关联内容</span>
        </div>
      </header>

      <div class="prose prose-invert max-w-none
                  prose-headings:font-heading prose-headings:text-parchment
                  prose-p:text-parchment prose-p:leading-relaxed
                  prose-a:text-gold prose-a:no-underline hover:prose-a:text-gold-glow
                  prose-code:text-gold prose-code:bg-sea-deep prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono
                  prose-blockquote:border-gold/40 prose-blockquote:text-parchment/70
                  prose-strong:text-parchment
                  prose-li:text-parchment/85">
        <Content />
      </div>

      {relatedConcepts.length > 0 && (
        <section class="mt-16">
          <div class="flex items-center gap-3 mb-6">
            <h2 class="font-heading text-lg text-parchment">关联概念</h2>
            <div class="flex-1 h-px bg-mist/10"></div>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            {relatedConcepts.map(rc => (
              <ConceptCard
                id={rc.id}
                title={rc.data.title}
                symbol={rc.data.symbol}
                layer={rc.data.layer}
                contentCount={conceptCounts.get(rc.id) ?? 0}
                body={rc.body}
              />
            ))}
          </div>
        </section>
      )}

      {relatedEntries.length > 0 && (
        <section class="mt-16">
          <div class="flex items-center gap-3 mb-6">
            <h2 class="font-heading text-lg text-parchment">关联内容</h2>
            <div class="flex-1 h-px bg-mist/10"></div>
          </div>
          <div class="columns-1 md:columns-2 gap-6">
            {relatedEntries.map(entry => (
              <TraceCard
                title={entry.data.title}
                date={entry.data.date}
                tags={entry.data.tags}
                type={entry.data.type}
                slug={entry.id}
                cover={entry.data.cover}
                excerpt={entry.body ? entry.body.replace(/^import\s+.*$/gm, '').replace(/<[^>]+>/g, '').replace(/[#*_`\[\]()>|]/g, '').trim().slice(0, 150) + '...' : undefined}
              />
            ))}
          </div>
        </section>
      )}

      <footer class="mt-16 pt-8 border-t border-mist/20">
        <a href="/concept" class="text-gold font-heading text-sm tracking-wider hover:text-gold-glow transition-colors no-underline">
          ← 返回概念图谱
        </a>
      </footer>
    </div>
  </div>
</Base>
