---
/**
 * /posts/[slug] — 统一文章详情页
 * 沉浸式阅读：内容直接浮在空间里
 */
import ContentShell from '../../layouts/ContentShell.astro';
import BlockPrompt from '../../components/blocks/BlockPrompt.astro';
import BlockDialogue from '../../components/blocks/BlockDialogue.astro';
import BlockVideo from '../../components/blocks/BlockVideo.astro';
import BlockCallout from '../../components/blocks/BlockCallout.astro';
import BlockResource from '../../components/blocks/BlockResource.astro';
import BlockStep from '../../components/blocks/BlockStep.astro';
import BlockFeedback from '../../components/blocks/BlockFeedback.astro';
import LikeCounter from '../../components/LikeCounter.astro';
import GiscusWidget from '../../components/GiscusWidget.astro';
import AdminEditBar from '../../components/admin/AdminEditBar.astro';
import InlineEditor from '../../components/admin/InlineEditor.astro';
import VersionHistory from '../../components/admin/VersionHistory.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import { POSTS, buildPostPath } from '@/shared/routes';
import { getPublishedPosts, getVersionChain, getSeriesEntries } from '@/knowledge/content';
import { getRelatedPosts, summarizeArticleBody } from '@/knowledge/posts';
import { CHARS_PER_MINUTE_ZH } from '@/shared/constants';
import { formatDateLocale } from '@/shared/format';

import { render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

export const prerender = true;

	type ArticleResource = CollectionEntry<'log'>['data']['resources'][number];

	export async function getStaticPaths() {
  const entries = await getPublishedPosts();

  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry, allEntries: entries },
  }));
}

const { entry, allEntries } = Astro.props;

if (!entry) {
  return Astro.redirect('/404');
}

const { Content, headings } = await render(entry);

const components = { BlockPrompt, BlockDialogue, BlockVideo, BlockCallout, BlockResource, BlockStep };

const rawBody = entry.body || '';
const { description, readingTime } = summarizeArticleBody(rawBody, CHARS_PER_MINUTE_ZH);
const coverImage = entry.data.cover;
const ogImage = typeof coverImage === 'string' ? coverImage : coverImage?.src;

const resources = entry.data.resources || [];

// 版本链 & 系列导航
const versionChain = allEntries ? getVersionChain(allEntries, entry.id) : [];
const hasVersion = versionChain.length > 0;

const seriesName = entry.data.series;
const seriesEntries = seriesName && allEntries
  ? getSeriesEntries(allEntries, seriesName).map(e => ({
      id: e.id,
      title: e.data.title,
      order: e.data.seriesOrder ?? 0,
    }))
  : [];
const currentSeriesIndex = seriesEntries.findIndex(e => e.id === entry.id);
const hasSeries = seriesEntries.length > 1; // 系列只有 1 篇时不显示导航
const seriesPrev = hasSeries && currentSeriesIndex > 0 ? seriesEntries[currentSeriesIndex - 1] : null;
const seriesNext = hasSeries && currentSeriesIndex < seriesEntries.length - 1 ? seriesEntries[currentSeriesIndex + 1] : null;

// 相关推荐：基于 tags 重叠度匹配，排除自身，取前 3 篇
const relatedPosts = allEntries ? getRelatedPosts(entry, allEntries) : [];
---

	<ContentShell
	  title={`${entry.data.title} — Walker`}
	  description={description}
	  ogTitle={entry.data.title}
	  ogDescription={entry.data.summary ?? entry.data.description ?? description}
	  ogImage={ogImage ?? '/images/hero-bg.png'}
	  canonicalUrl={Astro.url.href}
	  headings={headings}
	  contentId={entry.id}
	>
    {/* 面包屑 — 方向感 */}
    <div class="article-breadcrumb">
      <a href={POSTS} class="breadcrumb-link">
        <Icon name="lucide:arrow-left" width={14} height={14} />
        文章
      </a>
      <span class="breadcrumb-sep">/</span>
      <time class="breadcrumb-date">{formatDateLocale(entry.data.date)}</time>
      <span class="breadcrumb-sep">·</span>
      <span class="breadcrumb-reading-time">{readingTime} 分钟</span>
    </div>

    {/* 标题 — 文章的门面 */}
    <h1 class="article-title" data-pagefind-meta="title">
      {entry.data.title}
    </h1>

    {/* 标签 — 身份 */}
    <div class="article-tags">
      {entry.data.tags.map((tag: string) => (
        <span class="article-tag">{tag}</span>
      ))}
    </div>

    {/* 封面图 */}
    {coverImage && (
      <div class="article-cover">
        {typeof coverImage === 'string' ? (
          <Image src={coverImage} alt={entry.data.title} width={1280} height={549} class="cover-img" />
        ) : (
          <Image src={coverImage} alt={entry.data.title} class="cover-img" />
        )}
      </div>
    )}

    {/* 摘要 */}
    {entry.data.summary && (
      <div class="article-summary reveal">
        {entry.data.summary}
      </div>
    )}

    {/* 正文 — 内容即主角 */}
    <div class="prose prose-walker max-w-none break-words" id="article-body">
      <Content components={components} />
    </div>

    {/* 就地编辑器（预渲染隐藏，admin 进入编辑态时激活） */}
    <InlineEditor slug={entry.id} mode="inline" />

    {/* 内容反馈（P1-B02）—— 正文结束后采集"有用 / 需补充 / 已过时"明确信号，
        与底部 LikeCounter 区分：点赞是弱信号，这是直接导向行动的结果反馈 */}
    <BlockFeedback contentId={entry.id} />

	    {/* 相关资源 */}
    {resources.length > 0 && (
      <section class="article-section">
        <h2 class="section-heading">
          <Icon name="lucide:link-2" width={20} height={20} class="section-icon" />
          相关资源
        </h2>
        <div class="resource-list">
          {resources.map((res: ArticleResource) => (
            <ResourceCard
              type={res.type}
              url={res.url}
              name={res.name}
              description={res.description}
            />
          ))}
        </div>
      </section>
    )}

    {/* 版本 & 系列导航 */}
    {(hasVersion || hasSeries) && (
      <section class="article-nav-links">
        {/* 版本导航 */}
        {hasVersion && (
          <div class="nav-block version-block">
            <div class="nav-label">
              <Icon name="lucide:git-branch" width={14} height={14} />
              版本迭代
            </div>
            <div class="version-chain">
              {versionChain.map((v, i) => (
                v.id === entry.id ? (
                  <span class="version-current">v{v.data.version ?? i + 1}</span>
                ) : (
                  <a href={buildPostPath(v.id)} class="version-link">
                    v{v.data.version ?? i + 1}
                  </a>
                )
              ))}
            </div>
          </div>
        )}

        {/* 系列导航 */}
        {hasSeries && (
          <div class="nav-block series-block">
            <div class="nav-label">
              <Icon name="lucide:layers" width={14} height={14} />
              {seriesName}
              <span class="series-progress">{currentSeriesIndex + 1}/{seriesEntries.length}</span>
            </div>
            <div class="series-nav">
              {seriesPrev ? (
                <a href={buildPostPath(seriesPrev.id)} class="series-link series-prev">
                  <Icon name="lucide:chevron-left" width={14} height={14} />
                  {seriesPrev.title}
                </a>
              ) : <span />}
              {seriesNext ? (
                <a href={buildPostPath(seriesNext.id)} class="series-link series-next">
                  {seriesNext.title}
                  <Icon name="lucide:chevron-right" width={14} height={14} />
                </a>
              ) : <span />}
            </div>
          </div>
        )}
      </section>
    )}

    {/* 相关推荐 — 继续阅读的路径 */}
    {relatedPosts.length > 0 && (
      <section class="article-section">
        <h2 class="section-heading">
          <Icon name="lucide:sparkles" width={20} height={20} class="section-icon" />
          继续阅读
        </h2>
        <div class="related-grid">
          {relatedPosts.map(post => (
            <a href={buildPostPath(post.id)} class="related-card group/rc">
              <div class="related-card-title group-hover/rc:text-brand transition-colors">{post.title}</div>
              {post.summary && (
                <p class="related-card-summary">{post.summary}</p>
              )}
              <div class="related-card-tags">
                {post.tags.slice(0, 2).map((t: string) => (
                  <span class="related-tag">#{t}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* 评论区 — 反馈闭环 */}
    <GiscusWidget />

    {/* 底部 — 阅读结束 */}
    <footer class="article-footer">
      <a href={POSTS} class="footer-back">
        <Icon name="lucide:arrow-left" width={14} height={14} />
        返回文章
      </a>
      <div class="footer-like">
        <LikeCounter pagePath={buildPostPath(entry.id)} />
      </div>
    </footer>
  <AdminEditBar slug={entry.id} visibility={entry.data.visibility ?? (entry.data.published ? 'public' : 'draft')} />
  <VersionHistory />
	</ContentShell>

<style>
  /* ===== 面包屑 ===== */
  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-parchment-dim);
    opacity: 0.7;
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-parchment-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb-link:hover {
    color: var(--color-brand);
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  .breadcrumb-date {
    opacity: 0.6;
  }

  .breadcrumb-reading-time {
    opacity: 0.4;
    font-size: 0.7rem;
  }

  /* ===== 标题 ===== */
  .article-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 850;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-parchment);
    margin-bottom: 1rem;
  }

  /* ===== 标签 ===== */
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2.5rem;
  }

  .article-tag {
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-parchment-dim);
    opacity: 0.6;
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 15%, transparent);
  }

  /* ===== 封面 ===== */
  .article-cover {
    margin: 0 -2rem 2.5rem;
    aspect-ratio: 21/9;
    overflow: hidden;
    border-radius: 1rem;
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== 摘要 ===== */
  .article-summary {
    margin-bottom: 2.5rem;
    padding-left: 1.5rem;
    border-left: 3px solid color-mix(in srgb, var(--color-brand) 40%, transparent);
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-parchment-dim);
    font-style: italic;
  }

  /* ===== 分区（视频/资源）===== */
  .article-section {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-parchment);
    margin-bottom: 1rem;
  }

  .section-icon {
    color: var(--color-brand);
  }

  /* ===== 视频 ===== */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.75rem;
  }

  .video-card {
    text-decoration: none;
    display: block;
  }

  .video-card-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
    border-radius: 0.75rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .video-card:hover .video-card-inner {
    border-color: color-mix(in srgb, var(--color-brand) 25%, transparent);
    background: var(--color-brand-glow);
  }

  .video-platform {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-parchment-dim) 6%, transparent);
    color: var(--color-parchment-dim);
    flex-shrink: 0;
  }

  .video-card:hover .video-platform {
    color: var(--color-brand);
  }

  .video-info {
    min-width: 0;
  }

  .video-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-parchment);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .video-platform-name {
    font-size: 0.7rem;
    color: var(--color-parchment-dim);
    opacity: 0.6;
    text-transform: capitalize;
  }

  /* ===== 资源 ===== */
  .resource-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* ===== 版本 & 系列导航 ===== */
  .article-nav-links {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .nav-block {
    padding: 1rem 1.25rem;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-parchment-dim) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 8%, transparent);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
  }

  .nav-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-parchment-dim);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .version-chain {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .version-current {
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.78rem;
    font-weight: 700;
    font-family: var(--font-mono);
    background: color-mix(in srgb, var(--color-brand) 15%, transparent);
    color: var(--color-brand);
    border: 1px solid color-mix(in srgb, var(--color-brand) 25%, transparent);
  }

  .version-link {
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 12%, transparent);
    transition: all 0.2s ease;
  }

  .version-link:hover {
    color: var(--color-brand);
    border-color: color-mix(in srgb, var(--color-brand) 30%, transparent);
    background: color-mix(in srgb, var(--color-brand) 5%, transparent);
  }

  .series-progress {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    opacity: 0.5;
    margin-left: auto;
  }

  .series-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .series-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    color: var(--color-parchment-dim);
    text-decoration: none;
    max-width: 45%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }

  .series-link:hover {
    color: var(--color-brand);
  }

  .series-next {
    margin-left: auto;
    text-align: right;
    flex-direction: row-reverse;
  }

  /* ===== 底部 ===== */
  .article-footer {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-parchment-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-back:hover {
    color: var(--color-brand);
  }

  .footer-like {
    transform: scale(1.1);
    transform-origin: right center;
  }

  /* ===== 相关推荐 ===== */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  .related-card {
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .related-card:hover {
    border-color: color-mix(in srgb, var(--color-brand) 25%, transparent);
    background: var(--color-brand-glow);
  }

  .related-card-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-parchment);
    margin-bottom: 0.4rem;
  }

  .related-card-summary {
    font-size: 0.75rem;
    color: var(--color-parchment-dim);
    opacity: 0.6;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .related-card-tags {
    display: flex;
    gap: 0.3rem;
  }

  .related-tag {
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    opacity: 0.5;
  }

  /* ===== 响应式 ===== */
  @media (max-width: 640px) {
    .article-cover {
      margin: 0 -1rem 2rem;
      border-radius: 0.75rem;
    }

    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>


