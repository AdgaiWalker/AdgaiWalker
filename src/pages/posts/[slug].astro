---
/**
 * /posts/[slug] — 统一文章详情页
 * 沉浸式阅读：内容直接浮在空间里
 */
import ContentShell from '../../layouts/ContentShell.astro';
import BlockPrompt from '../../components/blocks/BlockPrompt.astro';
import BlockDialogue from '../../components/blocks/BlockDialogue.astro';
import BlockVideo from '../../components/blocks/BlockVideo.astro';
import BlockCallout from '../../components/blocks/BlockCallout.astro';
import BlockResource from '../../components/blocks/BlockResource.astro';
import BlockStep from '../../components/blocks/BlockStep.astro';
import BlockFeedback from '../../components/blocks/BlockFeedback.astro';
import LikeCounter from '../../components/LikeCounter.astro';
import GiscusWidget from '../../components/GiscusWidget.astro';
import AdminEditBar from '../../components/admin/AdminEditBar.astro';
import InlineEditor from '../../components/admin/InlineEditor.astro';
import VersionHistory from '../../components/admin/VersionHistory.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import { POSTS, buildPostPath } from '@/shared/routes';
import { getPublishedPosts, getVersionChain, getSeriesEntries } from '@/knowledge/content';
import { getRelatedPosts, summarizeArticleBody } from '@/knowledge/posts';
import { CHARS_PER_MINUTE_ZH } from '@/shared/constants';
import { formatDateLocale } from '@/shared/format';

import { render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { resolveLayout, getContentLabel, getDomainLabel, getStatusSymbol } from '@/knowledge/block-types';
import DianZiWordmark from '../../components/DianZiWordmark.astro';

export const prerender = true;

	type ArticleResource = CollectionEntry<'log'>['data']['resources'][number];

	export async function getStaticPaths() {
  const entries = await getPublishedPosts();

  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry, allEntries: entries },
  }));
}

const { entry, allEntries } = Astro.props;

if (!entry) {
  return Astro.redirect('/404');
}

const { Content, headings } = await render(entry);

const components = { BlockPrompt, BlockDialogue, BlockVideo, BlockCallout, BlockResource, BlockStep };

const rawBody = entry.body || '';
const { description, readingTime } = summarizeArticleBody(rawBody, CHARS_PER_MINUTE_ZH);
const coverImage = entry.data.cover;
const ogImage = typeof coverImage === 'string' ? coverImage : coverImage?.src;

const resources = entry.data.resources || [];

// 版本链 & 系列导航
const versionChain = allEntries ? getVersionChain(allEntries, entry.id) : [];
const hasVersion = versionChain.length > 0;

const seriesName = entry.data.series;
const seriesEntries = seriesName && allEntries
  ? getSeriesEntries(allEntries, seriesName).map(e => ({
      id: e.id,
      title: e.data.title,
      order: e.data.seriesOrder ?? 0,
    }))
  : [];
const currentSeriesIndex = seriesEntries.findIndex(e => e.id === entry.id);
const hasSeries = seriesEntries.length > 1; // 系列只有 1 篇时不显示导航
const seriesPrev = hasSeries && currentSeriesIndex > 0 ? seriesEntries[currentSeriesIndex - 1] : null;
const seriesNext = hasSeries && currentSeriesIndex < seriesEntries.length - 1 ? seriesEntries[currentSeriesIndex + 1] : null;

// 相关推荐：基于 tags 重叠度匹配，排除自身，取前 3 篇
const relatedPosts = allEntries ? getRelatedPosts(entry, allEntries) : [];

// 布局模板：优先读 frontmatter 的 layout 字段，没有则回退到 form 映射
const layout = resolveLayout(entry.data.layout, entry.data.form);
const contentLabel = getContentLabel(entry.data.form, entry.data.intent);
const domainLabel = getDomainLabel(entry.data.domain);
const statusInfo = getStatusSymbol(entry.data.status);

// 创作者及落款时空元数据（带默认 fallback 支撑通用化）
const author = entry.data.author || entry.data.signature || 'Walker';
const location = entry.data.location || entry.data.stamp;
const environment = entry.data.environment;
const action = entry.data.action || '落笔于';

// 拼装社交分享的带前缀摘要，支持 3 秒判断
const ogDesc = [
  entry.data.form ? `[${contentLabel.label}${domainLabel ? ` · ${domainLabel}` : ''}]` : '',
  entry.data.summary ?? entry.data.description ?? description
].filter(Boolean).join(' ');
---

	<ContentShell
	  title={`${entry.data.title} — Walker`}
	  description={description}
	  ogTitle={entry.data.title}
	  ogDescription={ogDesc}
	  ogImage={ogImage ?? '/images/hero-bg.png'}
	  canonicalUrl={Astro.url.href}
	  headings={headings}
	  contentId={entry.id}
	  layout={layout}
	  form={entry.data.form}
	  theme={entry.data.theme}
	  brandColor={entry.data.brandColor}
	  brandSecondaryColor={entry.data.brandSecondaryColor}
	>
    {/* 面包屑 — 方向感 */}
    <div class="article-breadcrumb">
      <a href={POSTS} class="breadcrumb-link">
        <Icon name="lucide:arrow-left" width={14} height={14} />
        文章
      </a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-reading-time">{readingTime} 分钟阅读</span>
    </div>

    {/* 内容声明栏 — 3 秒判断「这篇跟我有没有关系」 */}
    <div class="content-declaration">
      <span class="declaration-label">{contentLabel.label}</span>
      {domainLabel && (
        <span class="declaration-sep">·</span>
        <span class="declaration-label">{domainLabel}</span>
      )}
      {entry.data.status && (
        <span class="declaration-sep">·</span>
        <span class="declaration-status-wrap">
          <DianZiWordmark status={entry.data.status} />
        </span>
      )}
      {entry.data.form === 'idea' && (
        <a href={`/posts/${entry.id}/canvas`} class="declaration-canvas-link">
          进入画布 →
        </a>
      )}
    </div>

    {/* 标题 — 文章的门面 */}
    <h1 class="article-title" data-pagefind-meta="title">
      {entry.data.title}
    </h1>

    {/* 创作者落款时空区 — 有质感的、分开展示的元数据栏 */}
    <div class="oriental-meta-chips reveal">
      {/* 1. 作者 */}
      <div class="meta-chip chip-author">
        <Icon name="lucide:user" width={12} height={12} class="chip-icon text-brand" />
        <span class="chip-label">创作者</span>
        <span class="chip-value">{author}</span>
      </div>

      {/* 2. 地点与动作 */}
      {location && (
        <div class="meta-chip chip-location">
          <Icon name="lucide:map-pin" width={12} height={12} class="chip-icon text-amber-500" />
          <span class="chip-label">{action}</span>
          <span class="chip-value font-medium">{location}</span>
        </div>
      )}

      {/* 3. 环境与氛围 */}
      {environment && (
        <div class="meta-chip chip-environment">
          <Icon name="lucide:moon" width={12} height={12} class="chip-icon text-indigo-400" />
          <span class="chip-label">环境</span>
          <span class="chip-value">{environment}</span>
        </div>
      )}
      
      {/* 4. 时间 */}
      <div class="meta-chip chip-time">
        <Icon name="lucide:calendar" width={12} height={12} class="chip-icon text-emerald-500" />
        <span class="chip-label">发布于</span>
        <span class="chip-value">{formatDateLocale(entry.data.date)}</span>
      </div>
    </div>

    {/* 封面图 */}
    {coverImage && (
      <div class="article-cover">
        {typeof coverImage === 'string' ? (
          <Image src={coverImage} alt={entry.data.title} width={1280} height={549} class="cover-img" />
        ) : (
          <Image src={coverImage} alt={entry.data.title} class="cover-img" />
        )}
      </div>
    )}

    {/* 摘要 */}
    {entry.data.summary && (
      <div class="article-summary reveal">
        {entry.data.summary}
      </div>
    )}

    {/* 正文 — 内容即主角 */}
    <div class="prose prose-walker max-w-none break-words" id="article-body">
      <Content components={components} />
    </div>



    {/* 就地编辑器（预渲染隐藏，admin 进入编辑态时激活） */}
    <InlineEditor slug={entry.id} mode="inline" />

    {entry.data.aiInsights && entry.data.showAi !== false && (
      <div class="insights-inline reveal">
        <hr class="insights-divider" />
        <h3 class="insights-heading">洞察</h3>
        
        {entry.data.aiInsights.insight && (
          <p class="insights-desc">{entry.data.aiInsights.insight}</p>
        )}
        
        <div class="insights-grid">
          {entry.data.aiInsights.opportunities && entry.data.aiInsights.opportunities.length > 0 && (
            <div class="insight-section">
              <span class="insight-sec-title">机会</span>
              <ul class="insight-list">
                {entry.data.aiInsights.opportunities.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          )}
          
          {entry.data.aiInsights.risks && entry.data.aiInsights.risks.length > 0 && (
            <div class="insight-section">
              <span class="insight-sec-title">风险</span>
              <ul class="insight-list">
                {entry.data.aiInsights.risks.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          )}
          
          {entry.data.aiInsights.steps && entry.data.aiInsights.steps.length > 0 && (
            <div class="insight-section insight-section--full">
              <span class="insight-sec-title">推荐落地路径</span>
              <ol class="insight-steps">
                {entry.data.aiInsights.steps.map((item: string, idx: number) => (
                  <li>
                    <span class="step-num">{idx + 1}</span>
                    <span class="step-text">{item}</span>
                  </li>
                ))}
              </ol>
            </div>
          )}
        </div>
      </div>
    )}

    {/* P3-A 隐私告知：本页匿名统计阅读深度（读到哪/是否读完）用于改进内容。
        不采集 IP/身份；浏览器开启 DoNotTrack 即不采集。
        先告知再采集（放在 BlockFeedback 之前），符合隐私原则。 */}
    <aside class="telemetry-privacy-note" aria-label="阅读统计隐私告知">
      匿名统计阅读深度以改进内容；不采集身份，浏览器开启「禁止追踪」即关闭。
    </aside>

    {/* 内容反馈（P1-B02）—— 正文结束后采集"有用 / 需补充 / 已过时"明确信号，
        与底部 LikeCounter 区分：点赞是弱信号，这是直接导向行动的结果反馈 */}
    <BlockFeedback contentId={entry.id} />

    {((entry.data.collaborative === true) || (entry.data.form === 'idea' && entry.data.collaborative !== false)) && (
      <div class="nls-co-create-hub reveal">
        <div class="collab-dots-interactive" id="collab-dots-interactive">
          <span class="collab-dot-main">●</span>
          <span class="collab-dot-sub">°</span>
          <div class="collab-ripple" id="collab-ripple"></div>
        </div>
        <p class="collab-invite">这个点子正在寻找同频者。</p>
        
        <div class="hub-collab-bar" id="collab-entry-bar" data-content-id={entry.id}>
          <div class="hub-actions">
            <a href={`/posts/${entry.id}/canvas`} class="hub-btn hub-btn-primary">
              进入共创画布
            </a>
            <button type="button" class="hub-btn hub-btn-secondary" id="collab-join-btn">
              靠近这个想法
            </button>
          </div>
        </div>

        <span class="collab-count" id="collab-count-text">正在加载同频者数据...</span>

        <dialog class="collab-dialog" id="collab-dialog">
          <div class="collab-dialog-content">
            <div class="collab-dialog-header">
              <h3 class="collab-dialog-title">靠近这个点子</h3>
              <button type="button" class="collab-dialog-close" id="collab-dialog-close" aria-label="关闭">
                <Icon name="lucide:x" width={18} height={18} />
              </button>
            </div>
            <form class="collab-form" id="collab-form">
              <div class="collab-form-group">
                <label for="collab-role">我的技能身份</label>
                <input type="text" id="collab-role" name="role" placeholder="如：前端开发 / UI 设计 / 深度体验者" required maxLength={80} />
              </div>
              <div class="collab-form-group">
                <label for="collab-suggestion">我对此的第一步行动建议</label>
                <textarea id="collab-suggestion" name="suggestion" placeholder="如：第一步可以建立静态草稿，或者我对此有不同的实现路径..." rows={4} required maxLength={400}></textarea>
              </div>
              <div class="collab-form-status" id="collab-form-status" hidden></div>
              <div class="collab-actions-row">
                <button type="submit" class="collab-submit-btn" id="collab-submit-btn">
                  <span>确认靠近</span>
                </button>
                <a href={`/posts/${entry.id}/canvas`} class="collab-canvas-link-btn" id="collab-canvas-link-btn">
                  <span>进入共创画布</span>
                </a>
              </div>
            </form>
          </div>
        </dialog>
      </div>
    )}

	    {/* 相关资源 */}
    {resources.length > 0 && (
      <section class="article-section">
        <h2 class="section-heading">
          <Icon name="lucide:link-2" width={20} height={20} class="section-icon" />
          相关资源
        </h2>
        <div class="resource-list">
          {resources.map((res: ArticleResource) => (
            <ResourceCard
              type={res.type}
              url={res.url}
              name={res.name}
              description={res.description}
            />
          ))}
        </div>
      </section>
    )}

    {/* 版本 & 系列导航 */}
    {(hasVersion || hasSeries) && (
      <section class="article-nav-links">
        {/* 版本导航 */}
        {hasVersion && (
          <div class="nav-block version-block">
            <div class="nav-label">
              <Icon name="lucide:git-branch" width={14} height={14} />
              版本迭代
            </div>
            <div class="version-chain">
              {versionChain.map((v, i) => (
                v.id === entry.id ? (
                  <span class="version-current">v{v.data.version ?? i + 1}</span>
                ) : (
                  <a href={buildPostPath(v.id)} class="version-link">
                    v{v.data.version ?? i + 1}
                  </a>
                )
              ))}
            </div>
          </div>
        )}

        {/* 系列导航 */}
        {hasSeries && (
          <div class="nav-block series-block">
            <div class="nav-label">
              <Icon name="lucide:layers" width={14} height={14} />
              {seriesName}
              <span class="series-progress">{currentSeriesIndex + 1}/{seriesEntries.length}</span>
            </div>
            <div class="series-nav">
              {seriesPrev ? (
                <a href={buildPostPath(seriesPrev.id)} class="series-link series-prev">
                  <Icon name="lucide:chevron-left" width={14} height={14} />
                  {seriesPrev.title}
                </a>
              ) : <span />}
              {seriesNext ? (
                <a href={buildPostPath(seriesNext.id)} class="series-link series-next">
                  {seriesNext.title}
                  <Icon name="lucide:chevron-right" width={14} height={14} />
                </a>
              ) : <span />}
            </div>
          </div>
        )}
      </section>
    )}

    {/* 相关推荐 — 继续阅读的路径（aside slot：immersive 回流底部 / media 右侧栏） */}
    {relatedPosts.length > 0 && (
      <section slot="aside" class="article-section article-section--aside">
        <h2 class="section-heading">
          <Icon name="lucide:sparkles" width={20} height={20} class="section-icon" />
          继续阅读
        </h2>
        <div class="related-grid related-grid--aside">
          {relatedPosts.map(post => (
            <a href={buildPostPath(post.id)} class="related-card group/rc">
              <div class="related-card-title group-hover/rc:text-brand transition-colors">{post.title}</div>
              {post.summary && (
                <p class="related-card-summary">{post.summary}</p>
              )}
              <div class="related-card-tags">
                {post.tags.slice(0, 2).map((t: string) => (
                  <span class="related-tag">#{t}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* 评论区 — 反馈闭环 */}
    <GiscusWidget />

    {/* 标签 — 文末标注主题 */}
    {entry.data.tags.length > 0 && (
      <div class="article-tags-end">
        {entry.data.tags.map((tag: string) => (
          <span class="article-tag-end">#{tag}</span>
        ))}
      </div>
    )}

    {/* 底部 — 阅读结束 */}
    <footer class="article-footer">
      <a href={POSTS} class="footer-back">
        <Icon name="lucide:arrow-left" width={14} height={14} />
        返回列表
      </a>

      {/* 生产资料所有权：一等公民的 Markdown 导出 */}
      <a href={`/api/posts/${entry.id}/export`} class="footer-export" title="将这篇内容作为生产资料导出为 Markdown 手稿">
        <Icon name="lucide:download" width={13} height={13} />
        <span>导出 Markdown</span>
      </a>

      <div class="footer-like">
        <LikeCounter pagePath={buildPostPath(entry.id)} />
      </div>
    </footer>
  <AdminEditBar slug={entry.id} visibility={entry.data.visibility ?? (entry.data.published ? 'public' : 'draft')} layout={layout} />
  <VersionHistory />
	</ContentShell>

<style>
  /* ===== 面包屑 ===== */
  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-parchment-dim);
    opacity: 0.7;
  }

  /* ===== 创作者落款时空区 ===== */
  .oriental-meta-chips {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: -1rem 0 2rem;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.6rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
    background: color-mix(in srgb, var(--color-parchment-dim) 3%, transparent);
    font-size: 0.72rem;
    line-height: 1;
    color: var(--color-parchment-dim);
    transition: all 0.2s ease;
  }

  .meta-chip:hover {
    border-color: color-mix(in srgb, var(--color-brand) 30%, transparent);
    background: color-mix(in srgb, var(--color-brand) 4%, transparent);
  }

  .chip-icon {
    opacity: 0.8;
  }

  .chip-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.55;
    margin-right: 0.15rem;
  }

  .chip-value {
    color: var(--color-parchment);
    font-weight: 500;
  }

  /* P3-A 阅读遥测隐私告知：轻量、不阻断。
     不加 opacity——parchment-dim 自身 ~4.57:1 过 WCAG AA，
     叠 opacity:0.6 会把有效对比度拉到 ~2.7:1，跌破 AA 4.5:1 阈值。 */
  .telemetry-privacy-note {
    margin: 0.75rem 0 2rem;
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--color-parchment-dim);
    font-family: var(--font-mono);
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-parchment-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb-link:hover {
    color: var(--color-brand);
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  .breadcrumb-date {
    opacity: 0.6;
  }

  .breadcrumb-reading-time {
    opacity: 0.4;
    font-size: 0.7rem;
  }

  /* ===== 内容声明栏 ===== */
  .content-declaration {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-parchment-dim);
    width: 100%;
  }

  .declaration-label {
    font-weight: 700;
    color: var(--color-parchment-dim);
  }

  .declaration-canvas-link {
    display: inline-flex;
    align-items: center;
    font-weight: 700;
    color: var(--color-parchment-dim);
    text-decoration: none;
    transition: all 0.2s ease;
    margin-left: auto;
    font-size: 0.75rem;
  }

  .declaration-canvas-link:hover {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .declaration-sep {
    opacity: 0.3;
  }

  .declaration-status-wrap {
    display: inline-flex;
    align-items: center;
  }

  /* ===== 标题 ===== */
  .article-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 850;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-parchment);
    margin-bottom: 1rem;
  }

  /* ===== 标签（文末） ===== */
  .article-tags-end {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-parchment-dim) 8%, transparent);
  }

  .article-tag-end {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    opacity: 0.5;
  }

  /* ===== 封面 ===== */
  .article-cover {
    margin: 0 -2rem 2.5rem;
    aspect-ratio: 21/9;
    overflow: hidden;
    border-radius: 1rem;
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== 摘要 ===== */
  .article-summary {
    margin-bottom: 2.5rem;
    padding-left: 1.5rem;
    border-left: 3px solid color-mix(in srgb, var(--color-brand) 40%, transparent);
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-parchment-dim);
    font-style: italic;
  }

  /* ===== 分区（视频/资源）===== */
  .article-section {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
    font-weight: 700;
