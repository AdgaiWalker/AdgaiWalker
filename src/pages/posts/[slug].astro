---
/**
 * /posts/[slug] — 统一文章详情页
 * 沉浸式阅读：内容直接浮在空间里
 */
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import PromptBlock from '../../components/content/PromptBlock.astro';
import DialogueBubble from '../../components/content/DialogueBubble.astro';
import LikeCounter from '../../components/LikeCounter.astro';
import GiscusWidget from '../../components/GiscusWidget.astro';
import BilibiliVideo from '../../components/content/BilibiliVideo.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import { POSTS, buildPostPath } from '@/lib/routes';
import { getPublishedPosts } from '@/lib/content';
import { PLATFORM_ICON_MAP } from '@/lib/constants';
import { formatDateLocale } from '@/lib/format';

import { render } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getPublishedPosts();
  const articleList = entries.map(a => ({
    id: a.id,
    title: a.data.title,
    date: a.data.date,
    tags: a.data.tags,
    summary: a.data.summary,
  }));

  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry, articleList },
  }));
}

const { entry, articleList } = Astro.props;

if (!entry) {
  return Astro.redirect('/404');
}

const { Content, headings } = await render(entry);

const components = { PromptBlock, DialogueBubble, BilibiliVideo };

const rawBody = entry.body || '';
const cleanBody = rawBody
  .replace(/^---[\s\S]*?---/, '')
  .replace(/^import\s+.*$/gm, '')
  .replace(/<[^>]+>/g, '')
  .replace(/[#*_`\[\]()>|]/g, '')
  .trim();
const description = cleanBody.slice(0, 160);
const coverImage = entry.data.cover;
const ogImage = typeof coverImage === 'string' ? coverImage : coverImage?.src;

const videos = entry.data.videos || [];
const resources = entry.data.resources || [];
---

<ArticleLayout
  title={`${entry.data.title} — Walker`}
  description={description}
  ogTitle={entry.data.title}
  ogDescription={entry.data.summary ?? entry.data.description ?? description}
  ogImage={ogImage ?? '/images/hero-bg.png'}
  canonicalUrl={Astro.url.href}
  headings={headings}
  currentSlug={entry.id}
  articleList={articleList}
>
  <article data-pagefind-body>
    {/* 面包屑 — 方向感 */}
    <div class="article-breadcrumb">
      <a href={POSTS} class="breadcrumb-link">
        <Icon name="lucide:arrow-left" width={14} height={14} />
        文章
      </a>
      <span class="breadcrumb-sep">/</span>
      <time class="breadcrumb-date">{formatDateLocale(entry.data.date)}</time>
    </div>

    {/* 标题 — 文章的门面 */}
    <h1 class="article-title" data-pagefind-meta="title">
      {entry.data.title}
    </h1>

    {/* 标签 — 身份 */}
    <div class="article-tags">
      {entry.data.tags.map((tag: string) => (
        <span class="article-tag">{tag}</span>
      ))}
    </div>

    {/* 封面图 */}
    {coverImage && (
      <div class="article-cover">
        {typeof coverImage === 'string' ? (
          <Image src={coverImage} alt={entry.data.title} width={1280} height={549} class="cover-img" />
        ) : (
          <Image src={coverImage} alt={entry.data.title} class="cover-img" />
        )}
      </div>
    )}

    {/* 摘要 */}
    {entry.data.summary && (
      <div class="article-summary">
        {entry.data.summary}
      </div>
    )}

    {/* 正文 — 内容即主角 */}
    <div class="prose prose-walker max-w-none break-words">
      <Content components={components} />
    </div>

    {/* 配套视频 */}
    {videos.length > 0 && (
      <section class="article-section">
        <h2 class="section-heading">
          <Icon name="lucide:video" width={20} height={20} class="section-icon" />
          配套视频
        </h2>
        <div class="video-grid">
          {videos.map((vid: any) => (
            <a href={vid.url} target="_blank" rel="noopener noreferrer" class="video-card">
              <div class="video-card-inner">
                <div class="video-platform">
                  <Icon name={PLATFORM_ICON_MAP[vid.platform] || 'lucide:circle-play'} width={18} height={18} />
                </div>
                <div class="video-info">
                  <div class="video-title">{vid.title || '观看视频'}</div>
                  <div class="video-platform-name">{vid.platform}</div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* 相关资源 */}
    {resources.length > 0 && (
      <section class="article-section">
        <h2 class="section-heading">
          <Icon name="lucide:link-2" width={20} height={20} class="section-icon" />
          相关资源
        </h2>
        <div class="resource-list">
          {resources.map((res: any) => (
            <ResourceCard
              type={res.type}
              url={res.url}
              name={res.name}
              description={res.description}
            />
          ))}
        </div>
      </section>
    )}

    {/* 评论区 — 反馈闭环 */}
    <GiscusWidget />

    {/* 底部 — 阅读结束 */}
    <footer class="article-footer">
      <a href={POSTS} class="footer-back">
        <Icon name="lucide:arrow-left" width={14} height={14} />
        返回文章
      </a>
      <div class="scale-90 origin-right">
        <LikeCounter pagePath={buildPostPath(entry.id)} />
      </div>
    </footer>
  </article>
</ArticleLayout>

<style>
  /* ===== 面包屑 ===== */
  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-parchment-dim);
    opacity: 0.7;
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-parchment-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb-link:hover {
    color: var(--color-brand);
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  .breadcrumb-date {
    opacity: 0.6;
  }

  /* ===== 标题 ===== */
  .article-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 850;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-parchment);
    margin-bottom: 1rem;
  }

  /* ===== 标签 ===== */
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2.5rem;
  }

  .article-tag {
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-parchment-dim);
    opacity: 0.6;
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 15%, transparent);
  }

  /* ===== 封面 ===== */
  .article-cover {
    margin: 0 -2rem 2.5rem;
    aspect-ratio: 21/9;
    overflow: hidden;
    border-radius: 1rem;
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== 摘要 ===== */
  .article-summary {
    margin-bottom: 2.5rem;
    padding-left: 1.5rem;
    border-left: 3px solid color-mix(in srgb, var(--color-brand) 40%, transparent);
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-parchment-dim);
    font-style: italic;
  }

  /* ===== 分区（视频/资源）===== */
  .article-section {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-parchment);
    margin-bottom: 1rem;
  }

  .section-icon {
    color: var(--color-brand);
  }

  /* ===== 视频 ===== */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.75rem;
  }

  .video-card {
    text-decoration: none;
    display: block;
  }

  .video-card-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
    border-radius: 0.75rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .video-card:hover .video-card-inner {
    border-color: color-mix(in srgb, var(--color-brand) 25%, transparent);
    background: var(--color-brand-glow);
  }

  .video-platform {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-parchment-dim) 6%, transparent);
    color: var(--color-parchment-dim);
    flex-shrink: 0;
  }

  .video-card:hover .video-platform {
    color: var(--color-brand);
  }

  .video-info {
    min-width: 0;
  }

  .video-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-parchment);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .video-platform-name {
    font-size: 0.7rem;
    color: var(--color-parchment-dim);
    opacity: 0.6;
    text-transform: capitalize;
  }

  /* ===== 资源 ===== */
  .resource-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* ===== 底部 ===== */
  .article-footer {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-parchment-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-back:hover {
    color: var(--color-brand);
  }

  /* ===== 响应式 ===== */
  @media (max-width: 640px) {
    .article-cover {
      margin: 0 -1rem 2rem;
      border-radius: 0.75rem;
    }

    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
