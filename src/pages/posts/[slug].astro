    text-align: center;
  }

  .collab-canvas-link-btn:hover {
    border-color: var(--brand-purple, var(--color-brand, #6E5BFF));
    color: var(--brand-purple, var(--color-brand, #6E5BFF));
    background: color-mix(in srgb, var(--brand-purple, var(--color-brand, #6E5BFF)) 8%, transparent);
  }
</style>

<script>
  function setupCollaborate() {
    const bar = document.getElementById('collab-entry-bar');
    if (!bar) return;

    const contentId = bar.dataset.contentId;
    if (!contentId) return;

    const countText = document.getElementById('collab-count-text');
    const joinBtn = document.getElementById('collab-join-btn');
    const dialog = document.getElementById('collab-dialog') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('collab-dialog-close');
    const form = document.getElementById('collab-form') as HTMLFormElement | null;
    const formStatus = document.getElementById('collab-form-status');
    const submitBtn = document.getElementById('collab-submit-btn');
    
    const interactiveDots = document.getElementById('collab-dots-interactive');
    const ripple = document.getElementById('collab-ripple');

    // 0. 引力悬浮动效
    joinBtn?.addEventListener('mouseenter', () => {
      interactiveDots?.classList.add('attracted');
    });
    joinBtn?.addEventListener('mouseleave', () => {
      interactiveDots?.classList.remove('attracted');
    });

    // 1. 获取同频者数据
    async function loadCollaboratorCount() {
      try {
        const res = await fetch(`/api/posts/${encodeURIComponent(contentId)}/collaborate`);
        if (res.ok) {
          const data = await res.json();
          const count = data.count || 0;
          if (countText) {
            countText.textContent = count > 0 
              ? `当前有 ${count} 位同频者正在靠近` 
              : '目前尚无同频者靠近，成为第一个靠近的人';
          }
        }
      } catch (err) {
        console.error('Failed to load collaborator count:', err);
      }
    }

    loadCollaboratorCount();

    // 2. 弹窗控制
    joinBtn?.addEventListener('click', () => {
      dialog?.showModal();
    });

    closeBtn?.addEventListener('click', () => {
      dialog?.close();
    });

    // 点击背景关闭 dialog
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) {
        dialog.close();
      }
    });

    // 3. 提交表单
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!formStatus || !submitBtn) return;

      const formData = new FormData(form);
      const role = formData.get('role')?.toString().trim();
      const suggestion = formData.get('suggestion')?.toString().trim();

      formStatus.hidden = false;
      formStatus.textContent = '正在确认靠近...';
      formStatus.className = 'collab-form-status status-loading';
      
      const span = submitBtn.querySelector('span');
      if (span) span.textContent = '提交中...';
      const submitButton = submitBtn as HTMLButtonElement;
      submitButton.disabled = true;

      try {
        const res = await fetch(`/api/posts/${encodeURIComponent(contentId)}/collaborate`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ role, suggestion })
        });

        const result = await res.json();
        if (res.ok && result.ok) {
          formStatus.textContent = '靠近成功！同频信号已发送给创作者。';
          formStatus.className = 'collab-form-status status-success';
          form.reset();
          
          // 触发合并和涟漪动画
          if (interactiveDots) {
            interactiveDots.classList.remove('attracted');
            interactiveDots.classList.add('merged');
          }
          if (ripple) {
            ripple.classList.add('animate-ripple');
          }
          
          setTimeout(() => {
            dialog?.close();
            formStatus.hidden = true;
            loadCollaboratorCount();
            
            // 重置动画状态
            interactiveDots?.classList.remove('merged');
            ripple?.classList.remove('animate-ripple');
          }, 1800);
        } else {
          formStatus.textContent = result.error || '靠近失败，请稍后再试。';
          formStatus.className = 'collab-form-status status-error';
        }
      } catch (err) {
        formStatus.textContent = '网络错误，请检查网络连接。';
        formStatus.className = 'collab-form-status status-error';
      } finally {
        if (span) span.textContent = '确认靠近';
        submitButton.disabled = false;
      }
    });
  }

  // 挂载加载逻辑
  document.addEventListener('astro:page-load', setupCollaborate);
  setupCollaborate();
</script>


