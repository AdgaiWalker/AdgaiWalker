  }

  .collab-submit-btn:hover:not(:disabled) {
    background: color-mix(in srgb, var(--brand-purple, var(--color-brand, #6E5BFF)) 85%, #ffffff);
    box-shadow: 0 4px 15px rgba(110, 91, 255, 0.4);
