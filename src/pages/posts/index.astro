---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import { buildPostPath } from '@/shared/routes';
import { getPublishedPosts, getFrequentTags } from '@/knowledge/content';
import { formatDateCompact } from '@/shared/format';
import { Icon } from 'astro-icon/components';
import { getContentLabel, getStatusSymbol } from '@/knowledge/block-types';

export const prerender = true;

const allLogs = await getPublishedPosts();

const groupedLogs: Record<number, typeof allLogs> = {};
allLogs.forEach(log => {
  const year = log.data.date.getFullYear();
  if (!groupedLogs[year]) groupedLogs[year] = [];
  groupedLogs[year].push(log);
});
const years = Object.keys(groupedLogs).map(Number).sort((a, b) => b - a);

// 标签筛选：仅展示出现 ≥ 2 次的高频标签
const frequentTags = getFrequentTags(allLogs, 2);

---

<SidebarLayout
  title="文章 — Walker"
  description="Walker 的文章记录，涵盖 AI 探索与生活日志。"
  ogDescription="Walker 的文章记录，涵盖 AI 探索与生活日志。"
  pageTitle="文章"
  pageSubtitle="思我之思"
  pageIcon="pen-line"
  itemCount={allLogs.length}
  itemUnit="篇"
>
  <div class="timeline-shell">
    <!-- 🔭 哲理常驻引言 (epigraph card) -->
    <div class="reveal panel-glass p-5 rounded-[24px] border border-[var(--color-nav-border)] mb-7 relative overflow-hidden group/quote">
      <div class="absolute -right-16 -top-16 w-36 h-36 rounded-full bg-amber-400/10 blur-2xl group-hover/quote:bg-amber-400/20 transition-colors duration-500"></div>
      <div class="absolute -left-16 -bottom-16 w-36 h-36 rounded-full bg-[var(--color-brand-glow)] blur-2xl opacity-60"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex items-start gap-3.5">
          <div class="w-9 h-9 rounded-xl bg-amber-400/10 border border-amber-400/20 flex items-center justify-center text-amber-500 shrink-0 shadow-sm mt-0.5">
            <Icon name="lucide:compass" width={16} height={16} class="animate-spin-slow text-amber-500" />
          </div>
          <div>
            <p class="font-serif text-[14px] sm:text-[15px] text-parchment leading-relaxed tracking-wide font-medium italic">
              “ 最好的生活状态是，带着自己的目标，准备出发、正在出发、歇会再出发。 ”
            </p>
            <p class="text-[9px] font-mono tracking-widest text-parchment-dim opacity-50 uppercase mt-1.5">
              — WALKER'S LIFE PHRASE / 行者宣言
            </p>
          </div>
        </div>
      </div>
    </div>

    {/* 标签筛选栏 — 仅展示出现 ≥ 2 次的标签，低频标签保留在文章卡片上 */}
    <div class="tag-filter-bar" id="tag-filter-bar">
      <button class="filter-pill is-active" data-tag="all">
        全部<span class="filter-count">{allLogs.length}</span>
      </button>
      {frequentTags.map(({ tag, count }) => (
        <button class="filter-pill" data-tag={tag}>
          #{tag}<span class="filter-count">{count}</span>
        </button>
      ))}
    </div>

    <div id="timeline-container" class="space-y-12" data-stagger>
      {years.map(year => (
        <div class="year-group relative" data-year={year}>
          <div class="flex items-end gap-3 mb-5">
            <h2 class="font-heading text-2xl text-parchment">{year}</h2>
            <span class="text-parchment-dim text-xs font-mono mb-1">{groupedLogs[year].length} 篇</span>
          </div>

          <div class="reveal panel-glass rounded-2xl overflow-hidden border border-[var(--color-nav-border)]">
            <div class="flex flex-col divide-y divide-[var(--color-nav-border)]">
              {groupedLogs[year].map(log => {
                const contentLabel = getContentLabel(log.data.form, log.data.intent);
                const statusSymbol = log.data.status ? getStatusSymbol(log.data.status)?.symbol : '';

                return (
                  <a href={buildPostPath(log.id)} class="log-item group flex flex-col gap-1 px-5 py-4 transition-all no-underline" data-tags={log.data.tags.join(',')}>
                    <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6">
                      <time class="text-parchment-dim font-mono text-sm shrink-0 w-16 opacity-60">{formatDateCompact(log.data.date)}</time>
                      <div class="flex-1 min-w-0">
                        <h3 class="text-parchment text-[15px] font-body truncate group-hover:text-brand transition-colors opacity-90 flex items-center gap-2">
                          {statusSymbol && (
                            <span class="timeline-status-symbol" title={log.data.status}>
                              {statusSymbol}
                            </span>
                          )}
                          <span class="timeline-form-badge">
                            {contentLabel.emoji} {contentLabel.label}
                          </span>
                          <span class="timeline-title-text">{log.data.title}</span>
                        </h3>
                      </div>
                      <div class="flex items-center gap-2 shrink-0">
                        {log.data.tags.slice(0, 2).map((tag: string) => (
                          <span class="text-[11px] font-mono text-parchment-dim bg-brand/5 border border-brand/10 px-2 py-0.5 rounded-md opacity-80">#{tag}</span>
                        ))}
                      </div>
                    </div>
                    {log.data.summary && (
                      <p class="log-summary">{log.data.summary}</p>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div id="empty-state" class="hidden py-20 text-center text-parchment/30 text-sm">
      未找到匹配的文章
    </div>
  </div>
</SidebarLayout>

<style>
  .timeline-shell {
    max-width: 760px;
  }

  .tag-filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
    background: transparent;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.55));
    font-size: 0.76rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.18s ease;
  }

  .filter-pill:hover {
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.06);
    color: var(--color-brand);
  }

  .filter-pill.is-active {
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.2);
    color: var(--color-brand);
  }

  .filter-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    opacity: 0.48;
    margin-left: 0.25rem;
  }

  .year-group h2 {
    letter-spacing: 0;
  }

  #timeline-container .panel-glass {
    border-radius: 20px;
    box-shadow: 0 18px 48px rgba(25, 38, 40, 0.03) !important;
  }

  /* .log-item 弹性横移与流光反馈 */
  .log-item {
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .log-item:hover {
    background: rgba(255, 255, 255, 0.03) !important;
    transform: translateX(6px);
  }

  body.theme-nature .log-item:hover {
    background: rgba(0, 0, 0, 0.015) !important;
  }

  .log-summary {
    font-size: 0.78rem;
    color: var(--color-parchment-dim);
    opacity: 0.55;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    padding-left: 0;
    margin-left: 0;
  }

  @media (min-width: 640px) {
    .log-summary {
      padding-left: 4.75rem;
    }
  }

  @media (max-width: 640px) {
    .timeline-shell {
      max-width: none;
    }
  }

  /* ===== 列表页元数据与状态微标 ===== */
  .timeline-status-symbol {
    color: var(--brand-purple, var(--color-brand, #6E5BFF));
    font-weight: 800;
    font-size: 0.88rem;
    margin-right: 0.1rem;
    display: inline-flex;
    align-items: center;
  }

  .timeline-form-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-parchment-dim);
    opacity: 0.45;
    margin-right: 0.3rem;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
  }

  .timeline-title-text {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

<script>
  import { registerLifecycle } from '@/scripts/with-lifecycle';

  function initTagFilter() {
    const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
    const items = document.querySelectorAll<HTMLElement>('.log-item');
    const emptyState = document.getElementById('empty-state');
    const yearGroups = document.querySelectorAll<HTMLElement>('.year-group');
    if (!pills.length || !items.length) return;

    const abort = new AbortController();

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => p.classList.remove('is-active'));
        pill.classList.add('is-active');

        const tag = pill.dataset.tag || 'all';
        let visibleCount = 0;

        items.forEach(item => {
          const tags = (item.dataset.tags || '').split(',');
          const show = tag === 'all' || tags.includes(tag);
          item.classList.toggle('hidden', !show);
          if (show) visibleCount++;
        });

        // 隐藏空年份组
        yearGroups.forEach(group => {
          const visible = group.querySelectorAll<HTMLElement>('.log-item:not(.hidden)');
          group.classList.toggle('hidden', visible.length === 0);
        });

        if (emptyState) {
          emptyState.classList.toggle('hidden', visibleCount > 0);
        }
      }, { signal: abort.signal });
    });

    return () => abort.abort();
  }

  registerLifecycle(initTagFilter);
</script>
