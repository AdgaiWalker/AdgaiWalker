---
import Base from '@/layouts/Base.astro';
import { getPublishedThoughts, getFrequentTags, getPublishedLearnGuides } from '@/knowledge/content';
import { buildLearnGuidePath, buildLearnTrackPath, buildPostPath } from '@/shared/routes';
import { formatDateCompact } from '@/shared/format';
import { Icon } from 'astro-icon/components';
import {
  learningTracks,
  learningLayers,
  learningLayerMeta,
  trackStatusMeta,
  type LearningLayer,
  type LearningTrack,
} from '@/data/learning-tracks';
import '@/styles/learn.css';

export const prerender = true;

// ── Tab 1: 轨道 ──
const tracksByLayer: Record<LearningLayer, LearningTrack[]> = {
  cognition: learningTracks.filter(t => t.layer === 'cognition'),
  craft: learningTracks.filter(t => t.layer === 'craft'),
  exploration: learningTracks.filter(t => t.layer === 'exploration'),
};

// ── Tab 2: 思考 ──
const allLogs = await getPublishedThoughts();
const groupedLogs: Record<number, typeof allLogs> = {};
allLogs.forEach(log => {
  const year = log.data.date.getFullYear();
  if (!groupedLogs[year]) groupedLogs[year] = [];
  groupedLogs[year].push(log);
});
const years = Object.keys(groupedLogs).map(Number).sort((a, b) => b - a);
const frequentTags = getFrequentTags(allLogs, 2);

// ── Tab 3: 帮你学 ──
const learnTools = await getPublishedLearnGuides();

// ── Tab 路由 ──
const rawTab = Astro.url.searchParams.get('tab') || 'tracks';
const currentTab = rawTab === 'journal' ? 'tracks' : rawTab;
---

<Base title="学习 — Walker" description="以用促学，学有止，碰到在学。简单一点，学任何领域你所感兴趣的事。">

  <div class="learn-page">
    <!-- Header -->
    <header class="learn-pane-header">
      <h1>以用促学，学有止，碰到在学。</h1>
      <p>简单一点，学任何领域你所感兴趣的事。</p>
    </header>

    <!-- Tab Switcher -->
    <div class="learn-tabs">
      <button class:list={['learn-tab', { active: currentTab === 'tracks' }]} data-tab="tracks">
        <Icon name="lucide:route" width={14} height={14} class="inline-block mr-1.5 -mt-0.5" />
        轨道
      </button>
      <button class:list={['learn-tab', { active: currentTab === 'thoughts' }]} data-tab="thoughts">
        <Icon name="lucide:pen-line" width={14} height={14} class="inline-block mr-1.5 -mt-0.5" />
        思考
      </button>
      <button class:list={['learn-tab', { active: currentTab === 'guide' }]} data-tab="guide">
        <Icon name="lucide:rocket" width={14} height={14} class="inline-block mr-1.5 -mt-0.5" />
        帮你学
      </button>
    </div>

    <!-- ═══════ Tab 1: 轨道 ═══════ -->
    <div class:list={['learn-tab-content', { active: currentTab === 'tracks' }]} id="tab-tracks">
      {learningLayers.map(layer => {
        const meta = learningLayerMeta[layer];
        const tracks = tracksByLayer[layer];
        if (tracks.length === 0) return null;
        return (
          <section class="track-layer-section reveal">
            <div class="track-layer-header">
              <div class="track-layer-icon">
                <Icon name={meta.icon} width={16} height={16} />
              </div>
              <div class="track-layer-text">
                <h2 class="track-layer-title">{meta.label}</h2>
                <span class="track-layer-desc">{meta.description}</span>
              </div>
            </div>
            <div class="track-entry-list">
              {tracks.map(track => {
                const statusInfo = trackStatusMeta[track.status];
                const doneMilestones = track.milestones.filter(m => m.done).length;
                const hasMilestones = track.milestones.length > 0;
                return (
                  <a class="track-entry" href={buildLearnTrackPath(track.id)}>
                    <span class="track-entry-dot" style={`--badge-color: ${statusInfo.color}`} />
                    <div class="track-entry-main">
                      <span class="track-entry-title">{track.title}</span>
                      <span class="track-entry-motivation">{track.motivation}</span>
                    </div>
                    <span class="track-entry-progress">
                      {hasMilestones ? `${doneMilestones}/${track.milestones.length}` : statusInfo.label}
                    </span>
                    <Icon name="lucide:chevron-right" width={16} height={16} class="track-entry-arrow" />
                  </a>
                );
              })}
            </div>
          </section>
        );
      })}
    </div>

    <!-- ═══════ Tab 2: 思考 ═══════ -->
    <div class:list={['learn-tab-content', { active: currentTab === 'thoughts' }]} id="tab-thoughts">
      {/* 哲理引言 */}
      <div class="reveal panel-glass p-5 rounded-[24px] border border-[var(--color-nav-border)] mb-7 relative overflow-hidden group/quote">
        <div class="absolute -right-16 -top-16 w-36 h-36 rounded-full bg-amber-400/10 blur-2xl group-hover/quote:bg-amber-400/20 transition-colors duration-500"></div>
        <div class="absolute -left-16 -bottom-16 w-36 h-36 rounded-full bg-[var(--color-brand-glow)] blur-2xl opacity-60"></div>
        <div class="relative z-10 flex items-start gap-3.5">
          <div class="w-9 h-9 rounded-xl bg-amber-400/10 border border-amber-400/20 flex items-center justify-center text-amber-500 shrink-0 shadow-sm mt-0.5">
            <Icon name="lucide:compass" width={16} height={16} class="animate-spin-slow text-amber-500" />
          </div>
          <div>
            <p class="font-serif text-[14px] sm:text-[15px] text-parchment leading-relaxed tracking-wide font-medium italic">
              " 最好的生活状态是，带着自己的目标，准备出发、正在出发、歇会再出发。 "
            </p>
            <p class="text-[9px] font-mono tracking-widest text-parchment-dim opacity-50 uppercase mt-1.5">
              — WALKER'S LIFE PHRASE / 行者宣言
            </p>
          </div>
        </div>
      </div>

      {/* 标签筛选 */}
      <div class="thought-tag-bar" id="thought-tag-bar">
        <button class="filter-pill is-active" data-tag="all">
          全部<span class="filter-count">{allLogs.length}</span>
        </button>
        {frequentTags.map(({ tag, count }) => (
          <button class="filter-pill" data-tag={tag}>
            #{tag}<span class="filter-count">{count}</span>
          </button>
        ))}
      </div>

      {/* 时间线 */}
      <div id="thought-timeline" class="space-y-12" data-stagger>
        {years.map(year => (
          <div class="year-group relative" data-year={year}>
            <div class="flex items-end gap-3 mb-5">
              <h2 class="font-heading text-2xl text-parchment">{year}</h2>
              <span class="text-parchment-dim text-xs font-mono mb-1">{groupedLogs[year].length} 篇</span>
            </div>
            <div class="reveal panel-glass rounded-2xl overflow-hidden border border-[var(--color-nav-border)]">
              <div class="flex flex-col divide-y divide-[var(--color-nav-border)]">
                {groupedLogs[year].map(log => (
                  <a
                    href={buildPostPath(log.id)}
                    class="log-item group flex flex-col gap-1 px-5 py-4 transition-all no-underline"
                    data-tags={log.data.tags.join(',')}
                  >
                    <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6">
                      <time class="text-parchment-dim font-mono text-sm shrink-0 w-16 opacity-60">
                        {formatDateCompact(log.data.date)}
                      </time>
                      <div class="flex-1 min-w-0">
                        <h3 class="text-parchment text-[15px] font-body truncate group-hover:text-brand transition-colors opacity-90">
                          {log.data.title}
                        </h3>
                      </div>
                      <div class="flex items-center gap-2 shrink-0">
                        {log.data.tags.slice(0, 2).map((tag: string) => (
                          <span class="text-[11px] font-mono text-parchment-dim bg-brand/5 border border-brand/10 px-2 py-0.5 rounded-md opacity-80">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    </div>
                    {log.data.summary && (
                      <p class="log-summary">{log.data.summary}</p>
                    )}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div id="thought-empty" class="hidden py-20 text-center text-parchment/30 text-sm">
        未找到匹配的文章
      </div>
    </div>

    <!-- ═══════ Tab 3: 帮你学 ═══════ -->
    <div class:list={['learn-tab-content', { active: currentTab === 'guide' }]} id="tab-guide">
      <div class="learn-apple-cards-stack">
        {learnTools.map((tool) => (
          <a
            href={buildLearnGuidePath(tool.data.level || '入门', tool.id)}
            class="learn-tool-apple-card panel-glass reveal"
          >
            <span class="tool-emoji-large">{tool.data.emoji}</span>
            <div class="tool-content-wrap">
              <h3 class="tool-title-clean">{tool.data.title}</h3>
              <p class="tool-desc-clean">{tool.data.description}</p>
            </div>
            <Icon name="lucide:chevron-right" width={20} height={20} class="tool-arrow-chevron" />
          </a>
        ))}
      </div>
      {learnTools.length === 0 && (
        <div class="py-16 text-center text-parchment-dim opacity-40">
          <Icon name="lucide:rocket" width={32} height={32} class="mx-auto mb-2 opacity-50" />
          <p>教程正在路上</p>
        </div>
      )}
    </div>
  </div>

  <!-- Client-side Scripts -->
  <script>
    import { registerLifecycle } from '@/scripts/with-lifecycle';

    function initLearnPage() {
      const abort = new AbortController();
      const { signal } = abort;

      initTabSwitcher();
      initTagFilter();

      return () => abort.abort();

      function initTabSwitcher() {
        const tabs = document.querySelectorAll('.learn-tab');
        const contents = document.querySelectorAll('.learn-tab-content');

        tabs.forEach(tab => {
          tab.addEventListener('click', (e) => {
            e.preventDefault();
            const target = (tab as HTMLElement).dataset.tab;

            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');

            contents.forEach(c => c.classList.remove('active'));
            document.getElementById(`tab-${target}`)?.classList.add('active');

            const url = new URL(window.location.href);
            if (target === 'tracks') {
              url.searchParams.delete('tab');
            } else {
              url.searchParams.set('tab', target!);
            }
            window.history.replaceState({}, '', url.toString());
          }, { signal });
        });
      }

      function initTagFilter() {
        const pills = document.querySelectorAll<HTMLButtonElement>('#thought-tag-bar .filter-pill');
        const items = document.querySelectorAll<HTMLElement>('#thought-timeline .log-item');
        const emptyState = document.getElementById('thought-empty');
        const yearGroups = document.querySelectorAll<HTMLElement>('#thought-timeline .year-group');
        if (!pills.length || !items.length) return;

        pills.forEach(pill => {
          pill.addEventListener('click', () => {
            pills.forEach(p => p.classList.remove('is-active'));
            pill.classList.add('is-active');

            const tag = pill.dataset.tag || 'all';
            let visibleCount = 0;

            items.forEach(item => {
              const tags = (item.dataset.tags || '').split(',');
              const show = tag === 'all' || tags.includes(tag);
              item.classList.toggle('hidden', !show);
              if (show) visibleCount++;
            });

            yearGroups.forEach(group => {
              const visible = group.querySelectorAll<HTMLElement>('.log-item:not(.hidden)');
              group.classList.toggle('hidden', visible.length === 0);
            });

            if (emptyState) {
              emptyState.classList.toggle('hidden', visibleCount > 0);
            }
          }, { signal });
        });
      }
    }

    registerLifecycle(initLearnPage);
  </script>

</Base>

<style>
  /* ── 思考 Tab 内嵌样式 ── */
  .thought-tag-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
    background: transparent;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.55));
    font-size: 0.76rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.18s ease;
  }

  .filter-pill:hover {
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.06);
    color: var(--color-brand);
  }

  .filter-pill.is-active {
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.2);
    color: var(--color-brand);
  }

  .filter-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    opacity: 0.48;
    margin-left: 0.25rem;
  }

  #thought-timeline .panel-glass {
    border-radius: 20px;
    box-shadow: 0 18px 48px rgba(25, 38, 40, 0.03) !important;
  }

  .log-item {
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .log-item:hover {
    background: rgba(255, 255, 255, 0.03) !important;
    transform: translateX(6px);
  }

  body.theme-nature .log-item:hover {
    background: rgba(0, 0, 0, 0.015) !important;
  }

  .log-summary {
    font-size: 0.78rem;
    color: var(--color-parchment-dim);
    opacity: 0.55;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    padding-left: 0;
    margin-left: 0;
  }

  @media (min-width: 640px) {
    .log-summary {
      padding-left: 4.75rem;
    }
  }
</style>
