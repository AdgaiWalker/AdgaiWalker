---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getPublishedLearningPosts } from '@/knowledge/content';
import { buildLearnGuidePath, buildPostPath } from '@/shared/routes';
import { Icon } from 'astro-icon/components';
import '../../styles/learn.css';

export const prerender = true;

const learnTools = await getCollection('log', ({ data }) => data.published && data.type === 'learn');
const journalPosts = (await getPublishedLearningPosts()).filter(post => post.data.type !== 'learn');

const currentTab = Astro.url.searchParams.get('tab') || 'guide';
---

<Base title="学习 — Walker" description="以用促学，学有止，碰到在学。简单一点，学任何领域你所感兴趣的事。">

  <div class="learn-page">
    <!-- Header -->
    <header class="learn-pane-header">
      <h1>以用促学，学有止，碰到在学。</h1>
      <p>简单一点，学任何领域你所感兴趣的事。</p>
    </header>

    <!-- Elegant Tab Switcher (Apple Minimalist Styles) -->
    <div class="learn-tabs">
      <button class:list={['learn-tab', { active: currentTab === 'guide' }]} data-tab="guide">
        <Icon name="lucide:rocket" width={14} height={14} class="inline-block mr-1.5 -mt-0.5" />
        帮你学
      </button>
      <button class:list={['learn-tab', { active: currentTab === 'journal' }]} data-tab="journal">
        <Icon name="lucide:notebook-pen" width={14} height={14} class="inline-block mr-1.5 -mt-0.5" />
        我在学
      </button>
    </div>

    <!-- Tab Content 1: 帮你学 (Structured Guides) -->
    <div class:list={['learn-tab-content', { active: currentTab === 'guide' }]} id="tab-guide">
      <div class="learn-apple-cards-stack">
        {learnTools.map((tool) => (
          <a
            href={buildLearnGuidePath(tool.data.level || '入门', tool.id)}
            class="learn-tool-apple-card panel-glass reveal"
          >
            <span class="tool-emoji-large">{tool.data.emoji}</span>
            <div class="tool-content-wrap">
              <h3 class="tool-title-clean">{tool.data.title}</h3>
              <p class="tool-desc-clean">{tool.data.description}</p>
            </div>
            <span class="tool-arrow-chevron">›</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Tab Content 2: 我在学 (Learning Logs & Reflections) -->
    <div class:list={['learn-tab-content', { active: currentTab === 'journal' }]} id="tab-journal">
      {journalPosts.length > 0 ? (
        <div class="learn-journal">
          {journalPosts.map((post) => (
            <a href={buildPostPath(post.id)} class="learn-journal-item panel-glass">
              <span class="learn-journal-date">
                {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}
              </span>
              <div class="learn-journal-content">
                <h3 class="learn-journal-title">{post.data.title}</h3>
                {post.data.summary && <p class="learn-journal-summary">{post.data.summary}</p>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="learn-journal-empty py-16 text-center text-parchment-dim opacity-40">
          <Icon name="lucide:notebook" width={32} height={32} class="mx-auto mb-2 opacity-50" />
          <p>暂无日志与感悟发布</p>
        </div>
      )}
    </div>
  </div>

  <!-- Client-side Tab Switcher Script (Zero Page Reload) -->
  <script>
    function initLearnTabs() {
      const tabs = document.querySelectorAll('.learn-tab');
      const contents = document.querySelectorAll('.learn-tab-content');
      
      tabs.forEach(tab => {
        tab.addEventListener('click', (e) => {
          e.preventDefault();
          const target = (tab as HTMLElement).dataset.tab;
          
          // Update active tab buttons
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          
          // Update active contents
          contents.forEach(c => c.classList.remove('active'));
          document.getElementById(`tab-${target}`)?.classList.add('active');
          
          // Update URL query parameters without reloading the page
          const url = new URL(window.location.href);
          if (target === 'guide') {
            url.searchParams.delete('tab');
          } else {
            url.searchParams.set('tab', target!);
          }
          window.history.replaceState({}, '', url.toString());
        });
      });
    }

    initLearnTabs();
    document.addEventListener('astro:page-load', initLearnTabs);
  </script>

</Base>
