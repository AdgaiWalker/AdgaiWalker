---
import Base from '../../../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import {
  learningTracks,
  learningLayerMeta,
  trackStatusMeta,
  aiPlatformMeta,
  resourceTypeLabels,
  getTrackProgress,
} from '@/data/learning-tracks';
import { buildPostPath, buildLearnTrackPath } from '@/shared/routes';
import '../../../styles/learn.css';

export const prerender = true;

export async function getStaticPaths() {
  return learningTracks.map((track) => ({
    params: { id: track.id },
    props: { track },
  }));
}

const { track } = Astro.props;
const layer = learningLayerMeta[track.layer];
const statusInfo = trackStatusMeta[track.status];
const progress = getTrackProgress(track);
const doneMilestones = track.milestones.filter(m => m.done).length;
const hasMilestones = track.milestones.length > 0;

// 相关轨道：同层优先，再补其他层
const sameLayer = learningTracks.filter(t => t.layer === track.layer && t.id !== track.id);
const others = learningTracks.filter(t => t.layer !== track.layer && t.id !== track.id);
const relatedTracks = [...sameLayer, ...others].slice(0, 3);
---

<Base title={`${track.title} — 学习轨道 — Walker`} description={track.motivation}>
  <div class="learn-page track-detail-page">

    <!-- Breadcrumb -->
    <nav class="stage-breadcrumb">
      <a href="/learn">学习</a>
      <Icon name="lucide:chevron-right" width={14} height={14} />
      <a href="/learn?tab=tracks">轨道</a>
      <Icon name="lucide:chevron-right" width={14} height={14} />
      <span class="stage-breadcrumb-current">{track.title}</span>
    </nav>

    <!-- Track Header -->
    <header class="track-detail-header" style={`--badge-color: ${statusInfo.color}`}>
      <div class="track-detail-header-top">
        <span class="track-layer-pill">
          <Icon name={layer.icon} width={13} height={13} />
          {layer.label} · {layer.description}
        </span>
        <span class="track-status-badge">
          <Icon name={statusInfo.icon} width={12} height={12} />
          {statusInfo.label}
        </span>
      </div>
      <h1 class="track-detail-title">{track.title}</h1>
      <p class="track-detail-motivation">{track.motivation}</p>
      {hasMilestones && (
        <div class="track-detail-progress">
          <div class="track-progress-bar">
            <div class="track-progress-fill" style={`width: ${progress}%`} />
          </div>
          <span class="track-progress-text">{doneMilestones}/{track.milestones.length} 关卡</span>
        </div>
      )}
    </header>

    <!-- 路线图：里程碑 -->
    {hasMilestones && (
      <section class="track-detail-section">
        <h2 class="track-detail-section-title">
          <Icon name="lucide:map" width={16} height={16} />
          学习路线图
        </h2>
        <p class="track-detail-section-hint">我计划走这些关卡，打勾的是已经走过的。</p>
        <ol class="track-roadmap">
          {track.milestones.map((m, i) => (
            <li class:list={['roadmap-node', { done: m.done }]}>
              <span class="roadmap-index">{String(i + 1).padStart(2, '0')}</span>
              <span class="roadmap-marker">
                <Icon name={m.done ? 'lucide:check-circle-2' : 'lucide:circle'} width={16} height={16} />
              </span>
              <span class="roadmap-title">{m.title}</span>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- 脚印：学习单元（AI 对话） -->
    <section class="track-detail-section">
      <h2 class="track-detail-section-title">
        <Icon name="lucide:message-square" width={16} height={16} />
        学习脚印 · 我和 AI 的对话
      </h2>
      {track.notes.length > 0 ? (
        <div class="track-notes">
          {track.notes.map(note => (
            <a
              class="track-note-unit panel-glass"
              href={note.aiConversation?.url || '#'}
              target={note.aiConversation ? '_blank' : undefined}
              rel={note.aiConversation ? 'noopener noreferrer' : undefined}
            >
              <div class="note-unit-head">
                {note.aiConversation && (
                  <span class="note-platform">
                    <Icon name={aiPlatformMeta[note.aiConversation.platform].icon} width={13} height={13} />
                    {aiPlatformMeta[note.aiConversation.platform].label}
                  </span>
                )}
                <span class="note-date">{note.date}</span>
              </div>
              <p class="note-title">{note.title}</p>
              {note.takeaways && note.takeaways.length > 0 && (
                <ul class="note-takeaways">
                  {note.takeaways.map(tw => <li>{tw}</li>)}
                </ul>
              )}
              {note.aiConversation && (
                <span class="note-cta">
                  查看完整对话
                  <Icon name="lucide:external-link" width={12} height={12} />
                </span>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="track-empty-footprints panel-glass">
          <Icon name="lucide:footprints" width={28} height={28} />
          <p>这条路上还没有脚印——我正在走，对话会在路上一个个长出来。</p>
        </div>
      )}
    </section>

    <!-- 实践反思（文章） -->
    {track.articles.length > 0 && (
      <section class="track-detail-section">
        <h2 class="track-detail-section-title">
          <Icon name="lucide:pen-line" width={16} height={16} />
          实践反思 · 学完写出的
        </h2>
        <div class="track-article-list">
          {track.articles.map(slug => (
            <a class="track-article-item" href={buildPostPath(slug)}>
              <Icon name="lucide:file-text" width={13} height={13} />
              {slug}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 稀缺资料（供下载） -->
    {track.resources.length > 0 && (
      <section class="track-detail-section">
        <h2 class="track-detail-section-title">
          <Icon name="lucide:download" width={16} height={16} />
          资料
        </h2>
        <div class="track-resource-list">
          {track.resources.map(res => (
            res.url ? (
              <a class="track-resource-item" href={res.url} target="_blank" rel="noopener noreferrer">
                <Icon name="lucide:external-link" width={11} height={11} />
                {res.name}
                <span class="track-resource-type">{resourceTypeLabels[res.type]}</span>
              </a>
            ) : (
              <span class="track-resource-item">
                <Icon name="lucide:file-down" width={11} height={11} />
                {res.name}
                <span class="track-resource-type">{resourceTypeLabels[res.type]}</span>
              </span>
            )
          ))}
        </div>
      </section>
    )}

    <!-- 相关轨道 -->
    {relatedTracks.length > 0 && (
      <section class="track-detail-section">
        <h2 class="track-detail-section-title">
          <Icon name="lucide:route" width={16} height={16} />
          相关轨道
        </h2>
        <div class="track-related-list">
          {relatedTracks.map(rt => {
            const rtStatus = trackStatusMeta[rt.status];
            const rtDone = rt.milestones.filter(m => m.done).length;
            return (
              <a class="track-related-item" href={buildLearnTrackPath(rt.id)}>
                <span class="related-dot" style={`--badge-color: ${rtStatus.color}`} />
                <div class="related-text">
                  <span class="related-title">{rt.title}</span>
                  <span class="related-meta">{learningLayerMeta[rt.layer].label}{rt.milestones.length > 0 ? ` · ${rtDone}/${rt.milestones.length}` : ''}</span>
                </div>
                <Icon name="lucide:chevron-right" width={16} height={16} class="related-arrow" />
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Back -->
    <nav class="stage-next">
      <a href="/learn?tab=tracks" class="stage-next-link">
        <Icon name="lucide:arrow-left" width={16} height={16} />
        <div>
          <span class="next-label">返回</span>
          <span class="next-title">学习轨道</span>
        </div>
      </a>
    </nav>

  </div>
</Base>
