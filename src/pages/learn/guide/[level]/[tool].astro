---
import Base from '../../../../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render } from 'astro:content';
import { learnLevels } from '@/data/learn-data';
import { isPublicContentData } from '@/knowledge/content';
import '../../../../styles/learn.css';

export const prerender = true;

export async function getStaticPaths() {
  const activeGuides = await getCollection('log', ({ data }) => isPublicContentData(data) && data.type === 'learn');
  return activeGuides.map((guide) => ({
    params: { level: guide.data.level || '入门', tool: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const currentLevel = learnLevels.find(l => l.id === (guide.data.level || '入门'));

const { Content } = await render(guide);
---

<Base title={`${guide.data.title} — ${guide.data.level}学习 — Walker`} description={guide.data.description}>
  <div class="learn-page">
    <!-- Breadcrumb -->
    <nav class="stage-breadcrumb">
      <a href="/learn">学习</a>
      <Icon name="lucide:chevron-right" width={14} height={14} />
      <span class="stage-breadcrumb-current">{guide.data.title}</span>
    </nav>

    <!-- Stage Header -->
    <header class="stage-header" style={`--stage-color: ${currentLevel?.color || 'var(--color-brand)'}`}>
      <span class="stage-header-accent"></span>
      <div class="stage-header-top">
        <span class="stage-header-emoji">{guide.data.emoji}</span>
        <div>
          <h1>{guide.data.title}</h1>
          <span class="stage-header-subtitle">{guide.data.subtitle}</span>
        </div>
        <span class="stage-y-badge">{guide.data.yValue}</span>
      </div>
      <p class="stage-header-goal">
        <Icon name="lucide:target" width={16} height={16} />
        <strong>介绍：</strong>{guide.data.description}
      </p>
    </header>

    <!-- Content Card (Native Markdown Rendering) -->
    <div class="stage-markdown-body panel-glass" style={`--stage-color: ${currentLevel?.color || 'var(--color-brand)'}`}>
      <Content />
    </div>

    <!-- Safety, Graduation & Share -->
    <div class="stage-meta-grid">
      {guide.data.safetyNote && (
        <div class="stage-safety panel-glass">
          <div class="safety-icon">
            <Icon name="lucide:shield-check" width={18} height={18} />
          </div>
          <div>
            <strong>安全提醒：</strong>{guide.data.safetyNote}
          </div>
        </div>
      )}

      {guide.data.graduation && (
        <div class="stage-graduation panel-glass" style={`--stage-color: ${currentLevel?.color || 'var(--color-brand)'}`}>
          <span class="graduation-label">
            <Icon name="lucide:trophy" width={14} height={14} />
            毕业任务
          </span>
          <p class="graduation-desc">{guide.data.graduation}</p>
        </div>
      )}
    </div>

    {guide.data.shareAction && (
      <div class="stage-share panel-glass">
        <Icon name="lucide:share-2" width={14} height={14} />
        <span><strong>分享动作：</strong>{guide.data.shareAction}</span>
      </div>
    )}

    <!-- Back Link -->
    <nav class="stage-next">
      <a href="/learn" class="stage-next-link stage-next-link--prev">
        <Icon name="lucide:arrow-left" width={16} height={16} />
        <div>
          <span class="stage-next-hint">返回</span>
          <span class="stage-next-name">学习板块总览</span>
        </div>
      </a>
    </nav>
  </div>
</Base>
