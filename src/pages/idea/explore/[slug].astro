---
import { getCollection, render } from 'astro:content';
import DockLayout from '../../../layouts/DockLayout.astro';
import { Icon } from 'astro-icon/components';

export const prerender = true;

export async function getStaticPaths() {
  const items = await getCollection('dockItem', ({ data }) => data.published);
  return items.map(item => ({
    params: { slug: item.id },
  }));
}

const { slug } = Astro.params;
const items = await getCollection('dockItem', ({ data }) => data.published);
const item = items.find(i => i.id === slug);
if (!item) return Astro.redirect('/404');

const { Content } = await render(item);

const categoryConfig: Record<string, { label: string; icon: string; badgeClass: string }> = {
  skill: { label: 'Skill', icon: 'lucide:wand-sparkles', badgeClass: 'badge-skill' },
  tool: { label: '工具', icon: 'lucide:wrench', badgeClass: 'badge-tool' },
  'info-source': { label: '信息源', icon: 'lucide:radio', badgeClass: 'badge-source' },
  community: { label: '社群', icon: 'lucide:users', badgeClass: 'badge-community' },
};

const config = categoryConfig[item.data.category] ?? categoryConfig.tool;
const isCommunity = item.data.category === 'community';
const hasMultipleCommunities = item.data.communities && item.data.communities.length > 0;
---

<DockLayout
  title={`${item.data.name} — Walker`}
  description={item.data.description}
  currentSlug={item.id}
>
  <article class="dock-item-detail">
    {isCommunity ? (
      /* --- 社区/社群专用：高全息通行证舱 (ACCELERATOR HUB) --- */
      <div class="community-entry-wrapper">
        {hasMultipleCommunities ? (
          /* --- A. 多社区卡片网格布局（如：常用交流群） --- */
          <>
            {/* 核心金句 */}
            <div class="mb-8 text-center max-w-2xl mx-auto">
              <blockquote class="manifesto-blockquote">
                “用点子连接人与 AI。独自前行中，因为一个有趣的点子成为同行者 —— 用点子驱动 AI，点石成金，最终去到一个没有重复工作的地方。”
              </blockquote>
            </div>

            {/* 通行证网格 */}
            <div class="community-grid">
              {item.data.communities.map((comm) => (
                <div class="community-card panel-glass reveal">
                  {/* 票头 */}
                  <div class="ticket-header">
                    <div class="flex items-center gap-1.5">
                      <span class="pulse-dot"></span>
                      <span class="ticket-badge">{comm.badge}</span>
                    </div>
                    <span class="ticket-id">#{comm.tag}</span>
                  </div>

                  {/* 标题 */}
                  <h2 class="ticket-title">{comm.name}</h2>

                  {/* 激光全息扫码框 */}
                  <div class="qr-scanner-frame">
                    <div class="scanner-laser"></div>
                    <img src={comm.qrCode} alt={`${comm.name}二维码`} class="qr-image" />
                  </div>

                  {/* 一句话描述作用 */}
                  <div class="ticket-caption">
                    <p class="manifesto-line">{comm.description}</p>
                  </div>

                  {/* 底部虚线卡券尾 */}
                  <div class="ticket-footer">
                    <span>微信扫码 · 限时通道</span>
                    <span class="exp-date">限时有效</span>
                  </div>
                </div>
              ))}
            </div>
          </>
        ) : (
          /* --- B. 单个旗舰社区（如：点子共促群）巨幕通行证 --- */
          <div class="single-ticket-container">
            <div class="community-card single-card panel-glass reveal">
              {/* 票头 */}
              <div class="ticket-header">
                <div class="flex items-center gap-2">
                  <span class="pulse-dot animate-pulse"></span>
                  <span class="ticket-badge">Flagship Pass</span>
                </div>
                <span class="ticket-id">#WALK-IDEA</span>
              </div>

              {/* 标题 */}
              <h1 class="ticket-title-large">{item.data.name}</h1>

              {/* 激光全息扫码框 (放大版) */}
              <div class="qr-scanner-frame large-frame">
                <div class="scanner-laser large-laser"></div>
                <img src={item.data.qrCode || '/images/aigc-wechat-qr.jpg'} alt={`${item.data.name}二维码`} class="qr-image" />
              </div>

              {/* 核心金句与一句话作用 */}
              <div class="ticket-caption">
                <p class="manifesto-line-large">“用点子驱动 AI，点石成金，最终去到一个没有重复工作的地方。”</p>
                <div class="divider"></div>
                <p class="sub-caption-large">有点子，先动手，再开口。让我们用 AI 换取更多自由！</p>
              </div>

              {/* 底部虚线卡券尾 */}
              <div class="ticket-footer">
                <span>微信扫码 · 旗舰特许入口</span>
                <span class="exp-date">限时有效</span>
              </div>
            </div>
          </div>
        )}
      </div>
    ) : (
      /* --- 标准工具/Skill资源详情页 (Product Hunt 新闻式极简布局) --- */
      <>
        <header class="detail-header">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
            <div class="flex items-center gap-3">
              <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-mono font-semibold ${config.badgeClass}`}>
                <Icon name={config.icon} width={12} height={12} />
                {config.label}
              </span>
              {item.data.rating && (
                <div class="flex gap-0.5" aria-label={`评分 ${item.data.rating} 星`}>
                  {Array.from({ length: 5 }).map((_, i) => (
                    <Icon name="lucide:star"
                      width={12}
                      height={12}
                      class={i < item.data.rating ? 'text-brand/80' : 'text-parchment/10'} />
                  ))}
                </div>
              )}
            </div>

            {item.data.url && (
              <a
                href={item.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="visit-btn"
              >
                <Icon name="lucide:external-link" width={14} height={14} />
                访问资源网站
              </a>
            )}
          </div>

          <h1 class="detail-title">{item.data.name}</h1>
          <p class="detail-desc">{item.data.description}</p>

          <div class="flex flex-wrap gap-2 mt-4">
            {item.data.tags.map(tag => (
              <span class="tag-pill">{tag}</span>
            ))}
          </div>
        </header>

        <div class="panel-glass p-6 md:p-10 rounded-[24px] mt-8 shadow-xl">
          <div class="prose prose-walker max-w-none">
            <Content />
          </div>
        </div>
      </>
    )}
  </article>
</DockLayout>

<style>
  .dock-item-detail {
    max-width: 860px;
    margin: 0 auto;
  }

  /* --- 1. 社区通行证卡片独占样式 (Community Ticket) --- */
  .community-entry-wrapper {
    padding: 1.5rem 0 4rem;
  }

  .manifesto-blockquote {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.65;
    color: var(--color-parchment);
    padding: 1.25rem 1.75rem;
    background: var(--color-brand-glow);
    border-left: 4px solid var(--color-brand);
    border-radius: 16px;
    margin: 0;
    text-align: left;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.01);
  }

  .community-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    width: 100%;
    margin-top: 1.5rem;
  }

  .community-card {
    position: relative;
    padding: 1.6rem 1.6rem 1.25rem;
    border-radius: 24px !important;
    text-align: center;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--color-border) !important;
    box-shadow: 
      inset 0 1px 2px rgba(255, 255, 255, 0.08),
      0 12px 30px rgba(0, 0, 0, 0.15),
      0 0 16px var(--color-brand-glow) !important;
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), border-color 0.4s, box-shadow 0.4s ease;
  }

  .community-card:hover {
    transform: translateY(-5px);
    box-shadow: 
      inset 0 1px 3px rgba(255, 255, 255, 0.12),
      0 16px 40px rgba(0, 0, 0, 0.25),
      0 0 24px var(--color-brand-glow) !important;
    border-color: var(--color-brand) !important;
  }

  /* 单个旗舰群聊专用放大容器 */
  .single-ticket-container {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1rem 0;
  }

  .community-card.single-card {
    max-width: 440px;
    padding: 2.5rem;
    border-radius: 32px !important;
    box-shadow: 
      inset 0 1.5px 3.5px rgba(255, 255, 255, 0.12),
      0 30px 80px rgba(0, 0, 0, 0.22),
      0 0 45px var(--color-brand-glow) !important;
  }

  .community-card.single-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 
      inset 0 2px 4.5px rgba(255, 255, 255, 0.15),
      0 40px 100px rgba(0, 0, 0, 0.32),
      0 0 60px var(--color-brand-glow) !important;
  }

  .ticket-title-large {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-parchment);
    margin: 0 0 1.75rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--color-parchment) 30%, var(--color-brand) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .qr-scanner-frame.large-frame {
    width: 205px;
    height: 205px;
    margin: 0 auto 1.85rem;
    padding: 8px;
    border-radius: 20px;
  }

  .scanner-laser.large-laser {
    animation: qr-scan-large 2.6s linear infinite;
  }

  @keyframes qr-scan-large {
    0% { top: 8px; }
    50% { top: 195px; }
    100% { top: 8px; }
  }

  .manifesto-line-large {
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.6;
    color: var(--color-parchment);
    margin: 0 auto 0.75rem;
    max-width: 320px;
  }

  .sub-caption-large {
    font-size: 0.8rem;
    color: var(--color-parchment-dim);
    opacity: 0.85;
    line-height: 1.55;
    margin: 0;
  }

  .ticket-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.6rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-parchment-dim);
    opacity: 0.7;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .pulse-dot {
    width: 5px;
    height: 5px;
    background: var(--color-brand);
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 6px var(--color-brand);
    animation: ticket-pulse 1.8s infinite ease-in-out;
  }

  @keyframes ticket-pulse {
    0%, 100% { transform: scale(0.9); opacity: 0.6; }
    50% { transform: scale(1.3); opacity: 1; }
  }

  .ticket-badge {
    font-weight: 700;
  }

  .ticket-title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-parchment);
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
    transition: color 0.4s ease;
  }

  /* 激光全息扫码框 - 更小巧紧凑 */
  .qr-scanner-frame {
    position: relative;
    width: 140px;
    height: 140px;
    margin: 0 auto 1.15rem;
    padding: 6px;
    background: var(--color-inner-bg);
    border: 1px solid var(--color-nav-border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.08);
  }

  .qr-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
    filter: contrast(1.02);
  }

  /* 全息扫描线动画 */
  .scanner-laser {
    position: absolute;
    left: 6px;
    right: 6px;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--color-brand), transparent);
    box-shadow: 0 0 6px var(--color-brand), 0 0 12px var(--color-brand);
    z-index: 10;
    animation: qr-scan 2.6s linear infinite;
  }

  @keyframes qr-scan {
    0% { top: 6px; }
    50% { top: 130px; }
    100% { top: 6px; }
  }

  .ticket-caption {
    margin-bottom: 1.15rem;
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }

  .manifesto-line {
    font-size: 0.82rem;
    font-weight: 550;
    line-height: 1.5;
    color: var(--color-parchment-dim);
    margin: 0 auto;
    max-width: 260px;
  }

  .ticket-caption .divider {
    height: 1px;
    background: var(--color-nav-border);
    margin: 0.85rem auto;
    width: 60px;
  }

  .ticket-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px dashed var(--color-nav-border);
    padding-top: 0.75rem;
    font-size: 0.65rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-parchment-dim);
    opacity: 0.65;
  }

  .exp-date {
    color: var(--color-brand);
    font-weight: 700;
  }


  /* --- 2. 标准新闻式资源详情样式 (Standard PH Layout) --- */
  .detail-header {
    border-bottom: 1px solid var(--color-nav-border);
    padding-bottom: 1.75rem;
    margin-bottom: 1.75rem;
  }

  .detail-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.35rem);
    font-weight: 800;
    color: var(--color-parchment);
    line-height: 1.15;
    margin: 0.5rem 0;
    letter-spacing: -0.02em;
    transition: color 0.4s ease;
  }

  .detail-desc {
    font-size: 0.95rem;
    color: var(--color-parchment-dim);
    opacity: 0.85;
    line-height: 1.6;
    margin: 0.5rem 0 1rem;
    max-width: 680px;
    transition: color 0.4s ease;
  }

  .visit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.15rem;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #ffffff !important;
    background: var(--color-brand);
    box-shadow: 0 4px 14px var(--color-brand-glow);
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1.2);
  }

  .visit-btn:hover {
    transform: translateY(-2px);
    background: var(--color-brand-secondary);
    box-shadow: 0 6px 18px var(--color-brand-glow);
  }

  /* Badge Categories styling */
  .badge-skill {
    background: var(--color-brand-glow);
    color: var(--color-brand);
    border: 1px solid rgba(53, 191, 171, 0.2);
  }
  .badge-tool {
    background: var(--color-brand-glow);
    color: var(--color-brand);
    border: 1px solid rgba(53, 191, 171, 0.2);
  }
  .badge-source {
    background: rgba(231, 111, 81, 0.1);
    color: #e76f51;
    border: 1px solid rgba(231, 111, 81, 0.2);
  }
  .badge-community {
    background: rgba(209, 250, 229, 0.1);
    color: var(--color-parchment-dim);
    border: 1px solid rgba(209, 250, 229, 0.2);
  }
</style>
