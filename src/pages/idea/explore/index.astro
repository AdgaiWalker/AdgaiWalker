---
import DockLayout from '../../../layouts/DockLayout.astro';
import { Icon } from 'astro-icon/components';

export const prerender = true;
---

<DockLayout 
  title="AI探索 — Walker"
  description="Walker 的工具箱、技能、信息源和社群推荐。"
>
  <div class="dock-index-empty">
    <div class="empty-icon">
      <Icon name="lucide:package-open" width={48} height={48} />
    </div>
    <h1>AI探索</h1>
    <p>这里收录了我日常使用的工具、工作流（Skill）、信息源和社群。</p>
    <p class="hint">👈 请在左侧列表中选择一项查看详情。</p>
  </div>
</DockLayout>

<style>
  .dock-index-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 60vh;
    color: var(--color-parchment-dim);
  }

  .empty-icon {
    color: var(--color-brand);
    opacity: 0.6;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-parchment);
    margin: 0 0 1rem;
  }

  p {
    margin: 0 0 0.5rem;
    line-height: 1.6;
    opacity: 0.85;
  }

  .hint {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-brand);
    background: var(--color-brand-glow);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid rgba(53, 191, 171, 0.15);
  }
</style>
