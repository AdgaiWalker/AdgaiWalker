---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import { Icon } from 'astro-icon/components';
import { communities, aiResources, aiTools, infra, bloggers, skills } from '@/data/tools-data';
import ToolMatchChat from '@/components/tools/ToolMatchChat.astro';

export const prerender = true;
---

<SidebarLayout
  title="资源 — Walker"
  description="秋知实际在用的 AI 资源。"
  pageTitle="资源"
  pageSubtitle="Resources"
  pageIcon="wrench"
  itemCount={aiTools.length + infra.length + bloggers.length + communities.length + aiResources.length}
  itemUnit="个"
>
  <div class="resource-page">
    {/* 顶部声明 */}
    <div class="page-intro panel-glass">
      <p class="intro-text">秋知实际在用的 AI 资源。<strong>以下群/服务/产品与本人无任何利益关系</strong>，我只是用户，分享出来是因为自己觉得有用。</p>
    </div>

    {/* 需求索引匹配器 */}
    <ToolMatchChat />

    {/* 章节快速导航 */}
    <nav class="section-nav" id="section-nav">
      <a href="#info-source" class="section-nav-tab is-active" data-target="info-source">
        <Icon name="lucide:users" width={14} height={14} /> 信息源
      </a>
      <a href="#ai-tools" class="section-nav-tab" data-target="ai-tools">
        <Icon name="lucide:bot" width={14} height={14} /> AI 工具
      </a>
      <a href="#skill" class="section-nav-tab" data-target="skill">
        <Icon name="lucide:zap" width={14} height={14} /> Skill
      </a>
      <a href="#infra" class="section-nav-tab" data-target="infra">
        <Icon name="lucide:server" width={14} height={14} /> 基础设施
      </a>
      <a href="#bloggers" class="section-nav-tab" data-target="bloggers">
        <Icon name="lucide:heart" width={14} height={14} /> 博主推荐
      </a>
    </nav>

    {/* ===== 1. 信息源（群聊）===== */}
    <section id="info-source" class="resource-section reveal">
      <h2 class="section-title">
        <Icon name="lucide:users" width={20} height={20} class="section-icon" />
        信息源
      </h2>

      <h3 class="sub-title">AI 学习氛围群</h3>
      <p class="section-hint">有二维码的直接扫。博主维护的群，关注他们加入。</p>
      <div class="communities-list">
        {communities.map(community => (
          <div class:list={['community-row', community.featured && 'community-featured']}>
            {community.qrCode ? (
              <img src={community.qrCode} alt={`${community.name} 二维码`} class="qr-code" width="120" height="120" loading="lazy" />
            ) : community.blogger ? (
              <a href="#bloggers" class="community-blogger">
                <Icon name="lucide:user-plus" width={13} height={13} />
                关注 {community.blogger}
              </a>
            ) : null}
            <div class="community-detail">
              <div class="community-top">
                <span class="community-name">{community.name}</span>
                <span class="community-badge">{community.badge}</span>
              </div>
              <span class="community-desc">{community.desc}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="referral-note">
        <Icon name="lucide:arrow-down" width={14} height={14} />
        <span>博主维护的群 → 关注对应博主，通过他们的渠道加入。见下方「<a href="#bloggers">博主推荐</a>」。</span>
      </div>

      <h3 class="sub-title">省钱用 AI</h3>
      <p class="section-hint">获取低价 AI 额度的渠道。QQ 群，直接扫。</p>
      <div class="resources-grid">
        {aiResources.map(resource => (
          <div class="resource-item">
            {resource.qrCode && (
              <img src={resource.qrCode} alt={`${resource.name} 二维码`} class="qr-code" width="120" height="120" loading="lazy" />
            )}
            <div class="resource-detail">
              <div class="resource-top">
                <span class="resource-name">{resource.name}</span>
                <span class="resource-badge">{resource.badge}</span>
              </div>
              <span class="resource-desc">{resource.desc}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* ===== 2. AI 工具 ===== */}
    <section id="ai-tools" class="resource-section reveal">
      <h2 class="section-title">
        <Icon name="lucide:bot" width={20} height={20} class="section-icon" />
        AI 工具
      </h2>
      <p class="section-hint">我按场景用的 AI 工具，不是全面测评，只是我用什么。</p>
      <div class="tool-grid">
        {aiTools.map(tool => (
          <div class="tool-card">
            <span class="tool-category">{tool.category}</span>
            <span class="tool-value">{tool.tools}</span>
          </div>
        ))}
      </div>
    </section>

    {/* ===== 3. Skill ===== */}
    <section id="skill" class="resource-section reveal">
      <h2 class="section-title">
        <Icon name="lucide:zap" width={20} height={20} class="section-icon" />
        Skill
      </h2>
      <p class="section-hint">实战中积累的方法，帮我省时间的东西。</p>
      <div class="skill-list">
        {skills.map(skill => (
          <a href={skill.url} target="_blank" rel="noopener noreferrer" class="skill-item panel-glass no-underline">
            <div class="skill-top">
              <strong class="skill-name">{skill.name}</strong>
              <Icon name="lucide:external-link" width={12} height={12} class="skill-link" />
            </div>
            <span class="skill-desc">{skill.desc}</span>
          </a>
        ))}
      </div>
    </section>

    {/* ===== 4. 基础设施 ===== */}
    <section id="infra" class="resource-section reveal">
      <h2 class="section-title">
        <Icon name="lucide:server" width={20} height={20} class="section-icon" />
        基础设施
      </h2>
      <p class="section-hint">服务器、域名、部署——建站相关的工具。</p>
      <div class="infra-list">
        {infra.map(infraItem => (
          <div class="infra-item">
            {infraItem.url ? (
              <a href={infraItem.url} target="_blank" rel="noopener noreferrer" class="infra-name">{infraItem.name}</a>
            ) : (
              <span class="infra-name">{infraItem.name}</span>
            )}
            <span class="infra-desc">{infraItem.desc}</span>
          </div>
        ))}
      </div>
    </section>

    {/* ===== 5. 博主推荐 ===== */}
    <section id="bloggers" class="resource-section reveal">
      <h2 class="section-title">
        <Icon name="lucide:heart" width={20} height={20} class="section-icon" />
        博主推荐
      </h2>
      <p class="section-hint">切实帮到我的 AI 圈博主。关注他们，通过他们的渠道加入学习群。</p>
      <div class="blogger-list">
        {bloggers.map(blogger => blogger.url ? (
          <a href={blogger.url} target="_blank" rel="noopener noreferrer" class="blogger-item panel-glass no-underline">
            {blogger.avatar ? (
              <img src={blogger.avatar} alt={blogger.name} class="blogger-avatar" width="56" height="56" loading="lazy" />
            ) : (
              <div class="blogger-avatar-placeholder">{blogger.initial}</div>
            )}
            <div class="blogger-info">
              <div class="blogger-top">
                <span class="blogger-name">{blogger.name}</span>
                <span class="blogger-platform">{blogger.platform}</span>
              </div>
              <span class="blogger-desc">{blogger.desc}</span>
            </div>
          </a>
        ) : (
          <div class="blogger-item panel-glass">
            {blogger.avatar ? (
              <img src={blogger.avatar} alt={blogger.name} class="blogger-avatar" width="56" height="56" loading="lazy" />
            ) : (
              <div class="blogger-avatar-placeholder">{blogger.initial}</div>
            )}
            <div class="blogger-info">
              <div class="blogger-top">
                <span class="blogger-name">{blogger.name}</span>
                <span class="blogger-platform">{blogger.platform}</span>
              </div>
              <span class="blogger-desc">{blogger.desc}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* 底部 */}
    <div class="page-disclaimer">
      <Icon name="lucide:info" width={14} height={14} />
      <span>只列我实际在用的。不带货、不收费、不担保。按需判断。二维码有时效，扫不了加我微信备注来意。</span>
    </div>
  </div>
</SidebarLayout>

<style>
  .resource-page {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* 顶部声明 */
  .page-intro {
    padding: 1.25rem 1.5rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.12);
    border-radius: 1rem;
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.5);
  }
  .intro-text {
    color: var(--color-text-muted, rgba(63, 48, 39, 0.68));
    font-size: 0.88rem;
    line-height: 1.8;
  }
  .intro-text strong { color: var(--color-brand, #c4704a); }

  /* 分区标题 */
  .resource-section { display: flex; flex-direction: column; gap: 0.75rem; }
  .section-title {
    display: flex; align-items: center; gap: 0.5rem;
    color: var(--color-heading, var(--color-text, #3f3027));
    font-size: 1.25rem; font-weight: 800;
  }
  .section-icon { color: var(--color-brand, #c4704a); }
  .sub-title {
    color: var(--color-heading, var(--color-text, #3f3027));
    font-size: 0.95rem; font-weight: 700;
    margin-top: 0.5rem;
  }
  .section-hint {
    color: var(--color-text-muted, rgba(63, 48, 39, 0.55));
    font-size: 0.82rem; line-height: 1.6; margin: -0.25rem 0 0;
  }

  /* 二维码直接展示 */
  .qr-code {
    width: 120px; height: 120px; flex-shrink: 0;
    border-radius: 0.75rem; object-fit: cover;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.06);
  }

  /* 博主引荐标签 */
  .community-blogger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 0;
    padding: 0.5rem 0.85rem;
    border-radius: 0.75rem;
    border: 1px dashed rgba(var(--color-brand-rgb, 196, 112, 74), 0.25);
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.04);
    color: var(--color-brand, #c4704a);
    font-size: 0.76rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .community-blogger:hover {
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
  }

  /* 引荐说明 */
  .referral-note {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.5));
    font-size: 0.78rem;
    line-height: 1.5;
  }
  .referral-note a {
    color: var(--color-brand, #c4704a);
    font-weight: 600;
    text-decoration: none;
  }
  .referral-note a:hover { text-decoration: underline; }

  /* 氛围群 */
  .communities-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .community-row {
    display: flex; align-items: center; gap: 1rem;
    padding: 1rem; border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    border-radius: 1rem; background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.4);
    transition: background 150ms ease;
  }
  .community-row:hover { background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.65); }
  .community-featured {
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.2);
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.04);
  }
  .community-detail { display: flex; flex-direction: column; gap: 0.35rem; min-width: 0; }
  .community-top { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .community-name { color: var(--color-heading, var(--color-text, #3f3027)); font-size: 0.92rem; font-weight: 700; }
  .community-badge {
    display: inline-flex; padding: 0.18rem 0.5rem; border-radius: 999px;
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
    color: var(--color-brand, #c4704a); font-size: 0.68rem; font-weight: 700;
  }
  .community-desc { color: var(--color-text-muted, rgba(63, 48, 39, 0.55)); font-size: 0.8rem; line-height: 1.6; }

  /* 资源网格 */
  .resources-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 0.75rem; }
  .resource-item {
    display: flex; align-items: flex-start; gap: 0.85rem;
    padding: 1rem; border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    border-radius: 1rem; background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.4);
    transition: background 150ms ease;
  }
  .resource-item:hover { background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.65); }
  .resource-detail { display: flex; flex-direction: column; gap: 0.3rem; min-width: 0; }
  .resource-top { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .resource-name { color: var(--color-heading, var(--color-text, #3f3027)); font-size: 0.85rem; font-weight: 700; }
  .resource-badge {
    display: inline-flex; padding: 0.18rem 0.5rem; border-radius: 999px;
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
    color: var(--color-brand, #c4704a); font-size: 0.68rem; font-weight: 700;
  }
  .resource-desc { color: var(--color-text-muted, rgba(63, 48, 39, 0.55)); font-size: 0.75rem; line-height: 1.6; }

  /* AI 工具卡片网格 */
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.6rem;
  }
  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    border-radius: 0.75rem;
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.4);
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .tool-card:hover {
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.65);
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.15);
  }
  .tool-category {
    color: var(--color-brand, #c4704a);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .tool-value {
    color: var(--color-text, #3f3027);
    font-size: 0.82rem;
    font-weight: 600;
  }

  /* Skill */
  .skill-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .skill-item {
    padding: 1rem 1.25rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    border-radius: 1rem;
    display: flex; flex-direction: column; gap: 0.3rem;
  }
  .skill-name { color: var(--color-heading, var(--color-text, #3f3027)); font-size: 0.9rem; }
  .skill-top { display: flex; align-items: center; gap: 0.4rem; }
  .skill-link { color: var(--color-brand, #c4704a); opacity: 0.5; }
  .skill-desc { color: var(--color-text-muted, rgba(63, 48, 39, 0.55)); font-size: 0.8rem; line-height: 1.6; }

  /* 基础设施 */
  .infra-list { display: flex; flex-direction: column; gap: 0; border-radius: 1rem; overflow: hidden; border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08); }
  .infra-item {
    display: flex; align-items: baseline; gap: 1rem;
    padding: 0.75rem 1.15rem;
    border-bottom: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.06);
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.4);
  }
  .infra-item:last-child { border-bottom: none; }
  .infra-name {
    flex-shrink: 0; min-width: 5.5rem;
    color: var(--color-brand, #c4704a); font-size: 0.82rem; font-weight: 700;
    text-decoration: none;
  }
  a.infra-name:hover { text-decoration: underline; }
  .infra-desc { color: var(--color-text-muted, rgba(63, 48, 39, 0.55)); font-size: 0.78rem; line-height: 1.5; }

  /* 博主 */
  .blogger-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .blogger-item {
    padding: 1rem 1.25rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    border-radius: 1rem;
    display: flex; flex-direction: row; align-items: center; gap: 1rem;
    transition: background 150ms ease;
    color: inherit;
  }
  .blogger-item:hover {
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.65);
  }
  .blogger-avatar {
    width: 56px; height: 56px;
    border-radius: 50%; object-fit: cover; flex-shrink: 0;
    border: 2px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
  }
  .blogger-avatar-placeholder {
    width: 56px; height: 56px;
    border-radius: 50%; flex-shrink: 0;
    border: 2px solid rgba(var(--color-brand-rgb, 196, 112, 74), 0.15);
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.08);
    color: var(--color-brand, #c4704a);
    font-size: 1.25rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
  }
  .blogger-info { display: flex; flex-direction: column; gap: 0.3rem; min-width: 0; }
  .blogger-top { display: flex; align-items: center; gap: 0.5rem; }
  .blogger-name { color: var(--color-heading, var(--color-text, #3f3027)); font-size: 0.9rem; font-weight: 700; }
  .blogger-platform {
    padding: 0.15rem 0.45rem; border-radius: 999px;
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
    color: var(--color-brand, #c4704a); font-size: 0.65rem; font-weight: 700;
  }
  .blogger-desc { color: var(--color-text-muted, rgba(63, 48, 39, 0.55)); font-size: 0.8rem; line-height: 1.6; }

  /* 底部 */
  .page-disclaimer {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.15rem; border-radius: 0.75rem;
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.35);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.5));
    font-size: 0.78rem; line-height: 1.6;
  }

  /* 章节锚点导航 */
  .section-nav {
    display: flex;
    gap: 0.4rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    margin: 0 -1.5rem;
    padding: 0.6rem 1.5rem;
  }
  .section-nav-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    background: transparent;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.55));
    font-size: 0.76rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.18s ease;
  }
  .section-nav-tab:hover {
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.06);
    color: var(--color-brand);
  }
  .section-nav-tab.is-active {
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.2);
    color: var(--color-brand);
  }

  @media (max-width: 640px) {
    .qr-code { width: 100px; height: 100px; }
    .resources-grid { grid-template-columns: 1fr; }
    .tool-row { flex-direction: column; align-items: flex-start; gap: 0.2rem; }
    .tool-category { width: auto; }
  }
</style>

  <script>
    import { registerLifecycle } from '@/scripts/with-lifecycle';

    function initSectionNav(): (() => void) | void {
      const tabs = document.querySelectorAll<HTMLAnchorElement>('.section-nav-tab');
      const sections = document.querySelectorAll<HTMLElement>('.resource-section');
      if (!tabs.length || !sections.length) return;

      const abort = new AbortController();
      const { signal } = abort;

      // 点击跳转
      tabs.forEach(tab => {
        tab.addEventListener('click', (e) => {
          e.preventDefault();
          const id = tab.getAttribute('data-target');
          const target = document.getElementById(id || '');
          target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, { signal });
      });

      // 滚动高亮
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tabs.forEach(t => t.classList.remove('is-active'));
            const activeTab = document.querySelector(`.section-nav-tab[data-target="${entry.target.id}"]`);
            activeTab?.classList.add('is-active');
          }
        });
      }, { rootMargin: '-20% 0px -60% 0px' });

      sections.forEach(s => observer.observe(s));

      // registerLifecycle 在 astro:page-load / astro:before-swap 统一触发清理
      return () => {
        observer.disconnect();
        abort.abort();
      };
    }

    registerLifecycle(initSectionNav);
  </script>
