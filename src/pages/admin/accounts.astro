---
/**
 * /admin/accounts — 账号管理后台
 *
 * 列表 + 重置密码 + 封禁/解封 +（仅 owner）指派角色。SSR，isAdmin gate（admin+owner 可进）。
 * 角色指派 + 不能改自己（防站主自降级后无人能指派）。
 */
import AdminLayout from '@/components/admin/AdminLayout.astro';
import { isAdmin } from '@/lib/admin-auth';
import { readSessionPayload } from '@/lib/account-auth';
import { createUserContextService } from '@/services/user-context.service';
import { createAccountStore } from '@/stores/account.store';
import { createSessionStore } from '@/stores/session.store';
import { createUserProfileStore } from '@/stores/user-profile.store';

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/login');
}

// 是否站主（唯一可指派角色）+ 当前用户名（防自改）
const sessionPayload = readSessionPayload(Astro.request);
const canAssignRoles = sessionPayload?.role === 'owner';
let myUsername: string | null = null;
if (canAssignRoles && sessionPayload?.sid) {
  const ucs = createUserContextService({
    sessionStore: createSessionStore(),
    accountStore: createAccountStore(),
    profileStore: createUserProfileStore(),
  });
  const me = await ucs.resolve({ sessionId: sessionPayload.sid, isAdmin: false });
  myUsername = me.username;
}

interface AccountView {
  username: string;
  role: 'user' | 'admin' | 'owner';
  status: 'active' | 'banned' | 'deleteRequested';
  createdAt: string;
  lastLoginAt?: string;
  inviteCodeHash?: string;
}
const roleLabel = (r: string) => (r === 'owner' ? '站主' : r === 'admin' ? '管理员' : '用户');

const origin = Astro.url.origin;
let accounts: AccountView[] = [];
try {
  const res = await fetch(`${origin}/api/admin/accounts`, {
    headers: { cookie: Astro.request.headers.get('cookie') ?? '' },
  });
  if (res.ok) {
    const data = await res.json() as { accounts: AccountView[] };
    accounts = data.accounts;
  }
} catch {
  /* 降级空列表 */
}
---

<AdminLayout active="/admin/accounts" title="用户" subtitle="身份、访问状态与最近活动">
  <main class="accounts-wrap">

    <section class="panel-glass">
      {accounts.length === 0 ? (
        <p class="empty">还没有注册账号。</p>
      ) : (
        <div class="accounts-toolbar">
          <input type="search" id="accounts-search" placeholder="搜索用户名…" class="search-input" />
        </div>
        <div class="table-scroll">
          <table class="accounts-table">
            <thead>
              <tr>
                <th>用户名</th>
                <th>角色</th>
                <th>状态</th>
                <th>注册时间</th>
                <th>最后登录</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody>
              {accounts.map((a) => (
                <tr data-username={a.username}>
                  <td class="mono"><a href={`/admin/accounts/${a.username}`} class="user-link">{a.username}</a>{a.username === myUsername && <span class="me">（你）</span>}</td>
                  <td><span class={`badge role-${a.role}`}>{roleLabel(a.role)}</span></td>
                  <td><span class={`badge status-${a.status}`}>{a.status}</span></td>
                  <td class="muted">{a.createdAt?.slice(0, 10) ?? '-'}</td>
                  <td class="muted">{a.lastLoginAt?.slice(0, 10) ?? '-'}</td>
                  <td class="actions">
                    {a.role !== 'owner' && (
                      <>
                        <button class="mini" data-action="reset">重置密码</button>
                        <button class="mini" data-action="toggle-status" data-status={a.status}>
                          {a.status === 'banned' ? '解封' : '封禁'}
                        </button>
                      </>
                    )}
                    {canAssignRoles && a.username !== myUsername && (
                      <span class="role-set">
                        {a.role !== 'user' && <button class="mini" data-action="set-role" data-role="user">设为用户</button>}
                        {a.role !== 'admin' && <button class="mini" data-action="set-role" data-role="admin">设为管理员</button>}
                        {a.role !== 'owner' && <button class="mini" data-action="set-role" data-role="owner">设为站主</button>}
                      </span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
      {canAssignRoles && <p class="hint">你是站主，可指派角色。改角色后该用户需重新登录才生效。</p>}
    </section>

    <dialog id="reset-dialog" aria-labelledby="reset-title">
      <form method="dialog">
        <h3 id="reset-title">重置密码</h3>
        <p>已为 <strong id="reset-username"></strong> 生成新临时密码（仅显示一次）：</p>
        <code id="reset-password" class="reset-code"></code>
        <div class="dialog-actions">
          <button type="button" id="copy-btn">复制</button>
          <button type="submit" class="primary">关闭</button>
        </div>
      </form>
    </dialog>
  </main>
</AdminLayout>

<style>
  .accounts-wrap { max-width: 1180px; margin: 0 auto; }
  .accounts-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .accounts-head h1 { font-size: 1.4rem; margin: 0; color: var(--color-parchment, #1a2325); }
  .back { color: var(--color-parchment-dim, #64748b); text-decoration: none; font-size: 0.9rem; }
  .panel-glass { padding: 1.25rem; border: 1px solid var(--adm-border); border-radius: var(--adm-radius-card); background: var(--adm-surface); box-shadow: 0 16px 46px rgba(39,62,58,.08); }
  .empty { color: var(--color-parchment-dim, #888); }
  .hint { margin: 1rem 0 0; font-size: 0.78rem; color: var(--color-parchment-dim, #888); }
  .accounts-toolbar { margin-bottom: 0.75rem; }
  .search-input { padding: 0.45rem 0.7rem; border-radius: 8px; border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent); background: color-mix(in srgb, var(--color-parchment, #1a2325) 4%, transparent); color: var(--color-parchment, #1a2325); font-size: 0.85rem; width: 100%; max-width: 240px; }
  .user-link { color: var(--color-brand, #35bfab); text-decoration: none; font-family: var(--font-mono, monospace); }
  .user-link:hover { text-decoration: underline; }
  .table-scroll { overflow-x: auto; }
  .accounts-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .accounts-table th, .accounts-table td { padding: 0.6rem 0.7rem; text-align: left; border-bottom: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 12%, transparent); white-space: nowrap; }
  .accounts-table th { color: var(--color-parchment-dim, #64748b); font-weight: 500; }
  .mono { font-family: var(--font-mono, monospace); color: var(--color-parchment, #1a2325); }
  .me { color: var(--color-parchment-dim, #888); font-size: 0.75rem; }
  .muted { color: var(--color-parchment-dim, #888); }
  .badge { padding: 0.15rem 0.5rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
  .role-owner { background: var(--color-brand-glow, rgba(53,191,171,0.18)); color: var(--color-brand, #35bfab); }
  .role-admin { background: rgba(79,140,255,0.18); color: #4f8cff; }
  .role-user { background: color-mix(in srgb, var(--color-parchment, #1a2325) 10%, transparent); color: var(--color-parchment-dim, #888); }
  .status-active { background: rgba(72,199,116,0.18); color: #48c774; }
  .status-banned { background: rgba(255,107,107,0.18); color: #ff6b6b; }
  .status-deleteRequested { background: rgba(255,165,2,0.18); color: #ffa502; }
  .actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .role-set { display: inline-flex; gap: 0.3rem; }
  .mini { padding: 0.3rem 0.6rem; border-radius: 6px; border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent); background: transparent; color: var(--color-parchment, #1a2325); cursor: pointer; font-size: 0.8rem; }
  .mini:hover { border-color: var(--color-brand, #35bfab); color: var(--color-brand, #35bfab); }
  dialog { border-radius: 12px; border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 14%, transparent); background: var(--color-card, #fff); color: var(--color-parchment, #1a2325); padding: 1.5rem; max-width: 90vw; }
  dialog::backdrop { background: rgba(0,0,0,0.5); }
  .reset-code { display: block; margin: 0.75rem 0; padding: 0.6rem; background: color-mix(in srgb, var(--color-parchment, #1a2325) 6%, transparent); border-radius: 6px; font-family: var(--font-mono, monospace); font-size: 1.05rem; user-select: all; }
  .dialog-actions { display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 0.5rem; }
  .dialog-actions button { padding: 0.45rem 0.9rem; border-radius: 6px; border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent); background: transparent; color: var(--color-parchment, #1a2325); cursor: pointer; }
  .dialog-actions button.primary { background: var(--color-brand, #35bfab); color: #fff; border-color: transparent; }
</style>

<script>
  import { registerLifecycle } from '@/scripts/with-lifecycle';

  registerLifecycle(() => {
    const dialog = document.getElementById('reset-dialog') as HTMLDialogElement | null;
    const resetUsername = document.getElementById('reset-username');
    const resetPassword = document.getElementById('reset-password');
    const copyBtn = document.getElementById('copy-btn');
    const roleLabel = (r: string) => (r === 'owner' ? '站主' : r === 'admin' ? '管理员' : '用户');
    const ask = (message: string, title = '确认账号操作') => window.WalkerAdminUI?.confirm({ title, message, tone: 'danger', confirmText: '确认执行' }) ?? Promise.resolve(false);
    const tell = (message: string, title = '操作结果') => window.WalkerAdminUI?.notify({ title, message }) ?? Promise.resolve();

    document.querySelectorAll<HTMLTableSectionElement>('tbody').forEach((tbody) => {
      tbody.addEventListener('click', async (e) => {
        const target = e.target as HTMLButtonElement;
        if (target.tagName !== 'BUTTON') return;
        const row = target.closest('tr');
        if (!row) return;
        const username = row.dataset.username ?? '';
        const action = target.dataset.action;

        if (action === 'reset') {
          if (!(await ask(`确定重置 ${username} 的密码？新临时密码只会显示一次。`))) return;
          const res = await fetch('/api/admin/accounts/reset', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username }),
          });
          const json = await res.json();
          if (res.ok && json.ok && resetUsername && resetPassword && dialog) {
            resetUsername.textContent = username;
            resetPassword.textContent = json.newPassword ?? '';
            dialog.showModal();
          } else {
            await tell(json.reason || '重置失败。');
          }
        } else if (action === 'toggle-status') {
          const current = target.dataset.status;
          const next = current === 'banned' ? 'active' : 'banned';
          if (!(await ask(`确定${next === 'banned' ? '封禁' : '解封'} ${username}？该操作会影响其后台访问。`))) return;
          const res = await fetch('/api/admin/accounts/status', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, status: next }),
          });
          if (res.ok) window.location.reload();
          else { const j = await res.json(); await tell(j.reason || '操作失败。'); }
        } else if (action === 'set-role') {
          const role = target.dataset.role ?? '';
          if (!(await ask(`确定将 ${username} 设为「${roleLabel(role)}」？该用户需重新登录才生效。`))) return;
          const res = await fetch('/api/admin/accounts/role', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, role }),
          });
          if (res.ok) window.location.reload();
          else { const j = await res.json(); await tell(j.reason || '操作失败。'); }
        }
      });
    });

    copyBtn?.addEventListener('click', async () => {
      const text = resetPassword?.textContent ?? '';
      try { await navigator.clipboard.writeText(text); copyBtn.textContent = '已复制'; } catch { /* ignore */ }
    });

    const search = document.getElementById('accounts-search') as HTMLInputElement | null;
    search?.addEventListener('input', () => {
      const q = search.value.trim().toLowerCase();
      document.querySelectorAll<HTMLTableRowElement>('tbody tr').forEach((row) => {
        const name = (row.dataset.username ?? '').toLowerCase();
        row.style.display = (!q || name.includes(q)) ? '' : 'none';
      });
    });
  });
</script>
