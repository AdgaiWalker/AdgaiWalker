---
/**
 * /admin/accounts/[username] — 单用户详情（admin+owner）
 *
 * 基本信息 + 画像锚点 + 在线会话 + 提过的需求 + 操作（改角色/重置/封禁/删除）。
 * 删除仅 owner、不能删自己。
 */
import AdminLayout from '@/components/admin/AdminLayout.astro';
import { isAdmin } from '@/lib/admin-auth';
import { readSessionPayload } from '@/lib/account-auth';
import { createUserContextService } from '@/services/user-context.service';
import { createAccountStore } from '@/stores/account.store';
import { createSessionStore } from '@/stores/session.store';
import { createUserProfileStore } from '@/stores/user-profile.store';
import { roleLabel } from '@/shared/account-labels';

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/login');
}

const username = Astro.params.username ?? '';
const sessionPayload = readSessionPayload(Astro.request);
const canAssignRoles = sessionPayload?.role === 'owner';
let myUsername: string | null = null;
if (sessionPayload?.sid) {
  const ucs = createUserContextService({
    sessionStore: createSessionStore(),
    accountStore: createAccountStore(),
    profileStore: createUserProfileStore(),
  });
  const me = await ucs.resolve({ sessionId: sessionPayload.sid, isAdmin: false });
  myUsername = me.username;
}

interface DetailData {
  account: { username: string; role: 'user' | 'admin' | 'owner'; status: string; createdAt: string; lastLoginAt?: string };
  profile: { personaAnchor?: string; nickname?: string } | null;
  sessions: { sessionId: string; createdAt: string; expiresAt: string }[];
  needCases: { needCaseId: string; needSummary: string; feedbackStatus: string; adminReviewStatus: string; createdAt: string }[];
}

const origin = Astro.url.origin;
let detail: DetailData | null = null;
let errMsg = '';
try {
  const res = await fetch(`${origin}/api/admin/accounts/${encodeURIComponent(username)}`, {
    headers: { cookie: Astro.request.headers.get('cookie') ?? '' },
  });
  if (res.ok) detail = (await res.json()) as DetailData;
  else if (res.status === 404) errMsg = '用户不存在';
  else errMsg = '加载失败';
} catch {
  errMsg = '加载失败';
}
---

<AdminLayout active="/admin/accounts" domain="needs" title={username || '用户详情'} subtitle="身份、需求、会话与访问状态">
  <main class="detail-wrap">
    <a href="/admin/accounts" class="back">← 账号列表</a>

    {errMsg ? (
      <p class="err">{errMsg}</p>
    ) : detail ? (
      <>
        <header class="detail-head">
          <h1>{detail.account.username}{detail.account.username === myUsername && <span class="me">（你）</span>}</h1>
          <span class={`badge role-${detail.account.role}`}>{roleLabel(detail.account.role)}</span>
          <span class={`badge status-${detail.account.status}`}>{detail.account.status}</span>
        </header>

        <section class="adm-card">
          <h2>基本信息</h2>
          <dl class="info-grid">
            <dt>角色</dt><dd>{roleLabel(detail.account.role)}</dd>
            <dt>状态</dt><dd>{detail.account.status}</dd>
            <dt>注册时间</dt><dd>{detail.account.createdAt?.slice(0, 10) ?? '-'}</dd>
            <dt>最后登录</dt><dd>{detail.account.lastLoginAt?.slice(0, 10) ?? '-'}</dd>
            <dt>身份锚点</dt><dd>{detail.profile?.personaAnchor || '-'}</dd>
            <dt>昵称</dt><dd>{detail.profile?.nickname || '-'}</dd>
          </dl>
        </section>

        <section class="adm-card">
          <h2>在线会话（{detail.sessions.length}）</h2>
          {detail.sessions.length === 0 ? (
            <p class="muted">无在线会话。</p>
          ) : (
            <ul class="session-list">
              {detail.sessions.map((s) => (
                <li><span class="mono">{s.sessionId.slice(0, 8)}…</span><span class="muted">创建 {s.createdAt?.slice(0, 16)?.replace('T', ' ')} · 到期 {s.expiresAt?.slice(0, 10)}</span></li>
              ))}
            </ul>
          )}
        </section>

        <section class="adm-card">
          <h2>提过的需求（{detail.needCases.length}）</h2>
          {detail.needCases.length === 0 ? (
            <p class="muted">还没有需求记录。</p>
          ) : (
            <ul class="need-list">
              {detail.needCases.map((c) => (
                <li>
                  <span class="need-summary">{c.needSummary}</span>
                  <span class="badge fb">{c.feedbackStatus}</span>
                  <span class="muted">{c.createdAt?.slice(0, 10)}</span>
                </li>
              ))}
            </ul>
          )}
        </section>

        <section class="adm-card actions-card">
          <h2>操作</h2>
          <div class="actions" data-username={detail.account.username}>
            <button class="btn" data-action="reset">重置密码</button>
            <button class="btn" data-action="toggle-status" data-status={detail.account.status}>
              {detail.account.status === 'banned' ? '解封' : '封禁'}
            </button>
            {canAssignRoles && detail.account.username !== myUsername && (
              <>
                {detail.account.role !== 'user' && <button class="btn" data-action="set-role" data-role="user">设为用户</button>}
                {detail.account.role !== 'admin' && <button class="btn" data-action="set-role" data-role="admin">设为管理员</button>}
                {detail.account.role !== 'owner' && <button class="btn" data-action="set-role" data-role="owner">设为站主</button>}
                <button class="btn danger" data-action="delete">删除账号</button>
              </>
            )}
          </div>
        </section>
      </>
    ) : (
      <p class="err">加载失败</p>
    )}
  </main>
</AdminLayout>

<style>
  .detail-wrap { max-width: 880px; margin: 0 auto; display: flex; flex-direction: column; gap: 1.25rem; }
  .back { color: var(--color-parchment-dim, #64748b); text-decoration: none; font-size: 0.88rem; }
  .detail-head { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .detail-head h1 { margin: 0; font-size: 1.5rem; color: var(--color-parchment, #1a2325); }
  .me { font-size: 0.85rem; color: var(--color-parchment-dim, #888); font-weight: 400; }
  .card h2 { margin: 0 0 0.8rem; font-size: 1rem; color: var(--color-parchment, #1a2325); }
  .info-grid { display: grid; grid-template-columns: auto 1fr; gap: 0.4rem 1rem; margin: 0; }
  .info-grid dt { color: var(--color-parchment-dim, #64748b); font-size: 0.82rem; }
  .info-grid dd { margin: 0; color: var(--color-parchment, #1a2325); font-size: 0.88rem; }
  .muted { color: var(--color-parchment-dim, #888); font-size: 0.8rem; }
  .mono { font-family: var(--font-mono, monospace); color: var(--color-parchment, #1a2325); }
  .session-list, .need-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .session-list li { display: flex; gap: 0.75rem; align-items: baseline; font-size: 0.82rem; }
  .need-list li { display: flex; gap: 0.6rem; align-items: baseline; font-size: 0.85rem; padding-bottom: 0.5rem; border-bottom: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 8%, transparent); }
  .need-list li:last-child { border-bottom: none; }
  .need-summary { flex: 1; color: var(--color-parchment, #1a2325); }
  .badge { padding: 0.12rem 0.45rem; border-radius: 999px; font-size: 0.72rem; font-weight: 600; }
  .role-owner { background: var(--color-brand-glow, rgba(53,191,171,0.18)); color: var(--color-brand, #35bfab); }
  .role-admin { background: rgba(79,140,255,0.18); color: #4f8cff; }
  .role-user { background: color-mix(in srgb, var(--color-parchment, #1a2325) 10%, transparent); color: var(--color-parchment-dim, #888); }
  .status-active { background: rgba(72,199,116,0.18); color: #48c774; }
  .status-banned { background: rgba(255,107,107,0.18); color: #ff6b6b; }
  .fb { background: color-mix(in srgb, var(--color-parchment, #1a2325) 8%, transparent); color: var(--color-parchment-dim, #888); }
  .actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn { padding: 0.5rem 0.9rem; border-radius: 8px; border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent); background: transparent; color: var(--color-parchment, #1a2325); cursor: pointer; font-size: 0.85rem; font-weight: 600; }
  .btn:hover { border-color: var(--color-brand, #35bfab); color: var(--color-brand, #35bfab); }
  .btn.danger { color: #ef4444; border-color: #ef4444; }
  .err { color: #ef4444; }
</style>

<script>
  import { registerLifecycle } from '@/scripts/with-lifecycle';
  import { roleLabel } from '@/shared/account-labels';
  import { confirmAdminAction, notifyAdminResult } from '@/scripts/admin-dialog';

  registerLifecycle(() => {
    const abort = new AbortController();
    const { signal } = abort;

    const actions = document.querySelector<HTMLElement>('.actions');
    if (!actions) return () => abort.abort();
    const username = actions.dataset.username ?? '';

    actions.addEventListener('click', async (e) => {
      const btn = e.target as HTMLButtonElement;
      if (btn.tagName !== 'BUTTON') return;
      const action = btn.dataset.action;

      if (action === 'reset') {
        if (!(await confirmAdminAction(`确定重置 ${username} 的密码？新临时密码只会显示一次。`))) return;
        const res = await fetch('/api/admin/accounts/reset', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username }) });
        const j = await res.json();
        if (res.ok && j.ok) await notifyAdminResult(`${username} 的新临时密码（仅显示一次）：\n${j.newPassword}`, { title: '临时密码' });
        else await notifyAdminResult(j.reason || '重置失败');
      } else if (action === 'toggle-status') {
        const next = btn.dataset.status === 'banned' ? 'active' : 'banned';
        if (!(await confirmAdminAction(`确定${next === 'banned' ? '封禁' : '解封'} ${username}？该操作会影响其后台访问。`))) return;
        const res = await fetch('/api/admin/accounts/status', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, status: next }) });
        if (res.ok) window.location.reload();
        else { const j = await res.json(); await notifyAdminResult(j.reason || '失败'); }
      } else if (action === 'set-role') {
        const role = btn.dataset.role ?? '';
        if (!(await confirmAdminAction(`确定将 ${username} 设为「${roleLabel(role)}」？需重新登录生效。`))) return;
        const res = await fetch('/api/admin/accounts/role', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, role }) });
        if (res.ok) window.location.reload();
        else { const j = await res.json(); await notifyAdminResult(j.reason || '失败'); }
      } else if (action === 'delete') {
        if (!(await confirmAdminAction(`确定删除账号 ${username}？会撤销其会话、删画像、脱敏其需求记录，不可恢复。`, { title: '删除账号' }))) return;
        const res = await fetch('/api/admin/accounts/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username }) });
        if (res.ok) window.location.href = '/admin/accounts';
        else { const j = await res.json(); await notifyAdminResult(j.reason || '删除失败'); }
      }
    }, { signal });

    return () => abort.abort();
  });
</script>
