---
import { Icon } from 'astro-icon/components';
import { isAdmin } from '@/lib/admin-auth';
import {
  findRecentContentFeedback,
  findLearningRequestsByStatus,
  getRedis,
  getNeedCaseStats,
  getPendingReviewNeedCases,
  getUnresolvedIncidents,
} from '@/conversation/store';
import { getGatewayConfig, getGatewayStats } from '@/agent/gateway-config';
import AdminLayout from '@/components/admin/AdminLayout.astro';
import { deriveAdminSystemHealth } from '@/components/admin/admin-shell-state';
import { createWorkbenchService, suggestNextAction } from '@/services/workbench.service';
import { resolveStorageMode } from '@/lib/storage-mode';
import type { EvidenceRef, WorkItem as WorkItemEntity, WorkItemAction } from '@/stores/ports';

export const prerender = false;
if (!isAdmin(Astro.request)) return Astro.redirect('/admin/login');

const stats = await getNeedCaseStats({ days: 7 });
const pendingNeeds = await getPendingReviewNeedCases({ limit: 4 });
const incidents = await getUnresolvedIncidents(20);
const gatewayIncident = incidents.find(item => item.scope.toLowerCase().includes('gateway'));

// P0-A02：系统健康从真实事实推导（Gateway 配置 + 调用统计 + Gateway 事件）。
// 不再硬编码"系统可用"；零数据落 unknown，缺配置落 unavailable。
const [gatewayConfig, gatewayStats] = await Promise.all([getGatewayConfig(), getGatewayStats()]);
const gatewayConfigured = Boolean(gatewayConfig.apiKey) && Boolean(gatewayConfig.provider);
const systemHealth = deriveAdminSystemHealth({
  configured: gatewayConfigured,
  stats: gatewayStats,
  hasGatewayIncident: Boolean(gatewayIncident),
});
const systemHealthCheckedAt = new Date().toISOString();

const dateLabel = new Intl.DateTimeFormat('zh-CN', { month: 'long', day: 'numeric', weekday: 'long' }).format(new Date());
const workbenchService = createWorkbenchService();

// P0-D02：显示卡片用统一结构；state 映射真实 WorkItem 状态机，不在前端自定义另一个"进行中"字段。
type WorkItem = {
  id: string;
  /** 关联的持久化 WorkItem ID（若已创建）；用于前端调用 API */
  workItemId?: string;
  source: string;
  title: string;
  summary: string;
  evidence: string;
  evidenceTitle: string;
  evidenceBody: string;
  action: string;
  href: string;
  /** 显示状态：从真实 WorkItem.status 派生 */
  state: 'pending' | 'ai' | 'paused' | 'acting' | 'awaiting-verification' | 'ignored';
  icon: string;
  evidenceSourceType?: EvidenceRef['sourceType'];
  evidenceSourceId?: string;
  evidenceOccurredAt?: string;
  actionType?: WorkItemAction['actionType'];
  targetType?: string;
  targetId?: string;
  actions?: WorkItemAction[];
  outcomes?: WorkItemEntity['outcomes'];
  history?: WorkItemEntity['history'];
  uncertainty?: string[];
  priorityReasons?: string[];
  nextActionReason?: string;
  nextActionType?: WorkItemAction['actionType'];
};

const QUEUE_LABEL: Record<WorkItemEntity['queue'], string> = {
  'user-demand': '用户需求',
  'walker-thesis': 'Walker 主张',
  'system-event': '系统事件',
  'ai-asset': 'AI 资产',
};

const STATUS_TO_STATE: Record<WorkItemEntity['status'], WorkItem['state']> = {
  proposal: 'ai',
  pending: 'pending',
  accepted: 'pending',
  rejected: 'ignored',
  paused: 'paused',
  acting: 'acting',
  'awaiting-verification': 'awaiting-verification',
  resolved: 'ignored',
};

const needs: WorkItem[] = pendingNeeds.map((item, index) => ({
  id: `need-${item.needCaseId}`,
  source: '用户需求',
  title: item.needSummary || item.rawNeedRedacted || '一条尚未归纳的需求',
  summary: item.rawNeedRedacted || '这条需求需要你先判断：是个别问题，还是值得进入选题或功能决策。',
  evidence: `1 条原始需求 · ${item.sourcePage || '来源页未记录'}`,
  evidenceTitle: '原始需求',
  evidenceBody: item.rawNeedRedacted || '原始文本已脱敏或未保留。',
  action: index === 0 ? '开始判断' : '查看需求',
  href: `/admin/review?needCaseId=${encodeURIComponent(item.needCaseId)}`,
  state: 'pending',
  icon: 'circle-dot',
  evidenceSourceType: 'need-case',
  evidenceSourceId: item.needCaseId,
}));

// P0-D02：从服务端投影真实 WorkItem（已创建的工作项），按真实状态显示责任方。
// 这些是 Walker 已经操作过、持久化在服务端的事项；刷新/重启不丢失。
const persistedWorkItems = await workbenchService.getTodayProjection({ limit: 8 });
const persistedItems: WorkItem[] = persistedWorkItems
  .filter(item => item.status !== 'rejected' && item.status !== 'resolved')
  .map(item => {
    const latestAction = item.actions[item.actions.length - 1];
    const latestOutcome = item.outcomes[item.outcomes.length - 1];
    const nextSuggestion = latestOutcome ? suggestNextAction({ result: latestOutcome.result, outcomeSummary: latestOutcome.summary }) : null;
    const assignee = latestAction?.assignee === 'ai' ? 'AI' : latestAction?.assignee === 'shared' ? '共同' : '你';
    return {
      id: `workitem-${item.workItemId}`,
      workItemId: item.workItemId,
      source: QUEUE_LABEL[item.queue],
      title: item.title,
      summary: item.summary,
      evidence: `${item.evidenceRefs.length} 条证据 · 责任方：${assignee}`,
      evidenceTitle: '决定理由',
      evidenceBody: item.decision.reason || item.summary,
      action: item.status === 'acting' ? '查看执行' : item.status === 'awaiting-verification' ? '验证结果' : '继续处理',
      href: '/admin',
      state: STATUS_TO_STATE[item.status],
      icon: item.queue === 'system-event' ? 'triangle-alert' : item.queue === 'walker-thesis' ? 'lightbulb' : 'circle-dot',
      evidenceSourceType: item.evidenceRefs[0]?.sourceType,
      evidenceSourceId: item.evidenceRefs[0]?.sourceId,
      evidenceOccurredAt: item.evidenceRefs[0]?.occurredAt,
      actionType: latestAction?.actionType,
      targetType: latestAction?.targetType,
      targetId: latestAction?.targetId,
      actions: item.actions,
      outcomes: item.outcomes,
      history: item.history,
      uncertainty: item.uncertainty,
      priorityReasons: item.priorityReasons,
      nextActionReason: nextSuggestion?.reason,
      nextActionType: nextSuggestion?.suggestedActionType,
    };
  });

// 只把明确要求行动的内容反馈带入工作台；useful 作为结果证据，不制造待办。
// 同一内容只展示最近一条，已进入 WorkItem 的反馈不重复出现。
const representedEvidenceIds = new Set(
  persistedWorkItems.flatMap(item => item.evidenceRefs.map(ref => ref.sourceId)),
);
const recentContentFeedback = await findRecentContentFeedback(undefined, 20);
const actionableFeedbackByContent = new Map<string, (typeof recentContentFeedback)[number]>();
for (const feedback of recentContentFeedback) {
  if (!feedback.consentForAnalysis || feedback.signal === 'useful' || representedEvidenceIds.has(feedback.feedbackId)) continue;
  if (!actionableFeedbackByContent.has(feedback.contentId)) actionableFeedbackByContent.set(feedback.contentId, feedback);
}
const contentFeedbackItems: WorkItem[] = [...actionableFeedbackByContent.values()].map(feedback => ({
  id: `content-feedback-${feedback.feedbackId}`,
  source: '内容反馈',
  title: feedback.signal === 'outdated' ? `复核《${feedback.contentId}》的时效性` : `补充《${feedback.contentId}》`,
  summary: feedback.note || (feedback.signal === 'outdated' ? '访客认为内容可能已经过时，需要确认事实与更新时间。' : '访客认为内容还不足以解决问题，需要补充边界、步骤或案例。'),
  evidence: `1 条内容反馈 · ${new Date(feedback.createdAt).toLocaleDateString('zh-CN')}`,
  evidenceTitle: feedback.signal === 'outdated' ? '访客反馈：已过时' : '访客反馈：需补充',
  evidenceBody: feedback.note || '访客没有补充文字说明。',
  action: '修改内容',
  href: `/admin/content/edit?slug=${encodeURIComponent(feedback.contentId)}`,
  state: 'pending',
  icon: 'message-circle-more',
  evidenceSourceType: 'content-feedback',
  evidenceSourceId: feedback.feedbackId,
  evidenceOccurredAt: feedback.createdAt,
  actionType: 'update-content',
  targetType: 'content',
  targetId: feedback.contentId,
}));

const learningRequests = await findLearningRequestsByStatus('open');
const learningGapLabel = {
  practice: '实践',
  'counter-example': '反例',
  interview: '访谈',
  outcome: '结果',
  boundary: '边界',
} as const;
const learningItems: WorkItem[] = learningRequests
  .filter(request => !request.workItemId || !persistedWorkItems.some(item => item.workItemId === request.workItemId))
  .slice(0, 4)
  .map(request => ({
    id: `learning-${request.requestId}`,
    source: '学习任务',
    title: `补齐${learningGapLabel[request.evidenceGap]}证据`,
    summary: request.context,
    evidence: `完成条件：${request.expectedEvidence}`,
    evidenceTitle: '证据缺口',
    evidenceBody: request.context,
    action: '记录补证结果',
    href: `/admin/assets?view=learning&requestId=${encodeURIComponent(request.requestId)}`,
    state: 'pending',
    icon: 'graduation-cap',
  }));

const systemItem: WorkItem | null = gatewayIncident ? {
  id: `incident-${gatewayIncident.incidentId}`,
  source: '系统事件',
  title: gatewayIncident.message || 'AI Gateway 需要复盘',
  summary: '真实系统事件优先于一般优化，先确认影响范围，再决定是否降级或修复。',
  evidence: `${gatewayIncident.severity === 'high' ? '高' : gatewayIncident.severity === 'medium' ? '中' : '低'}严重度 · 未解决`,
  evidenceTitle: '事件记录',
  evidenceBody: gatewayIncident.message,
  action: '查看事件',
  href: '/admin/incidents',
  state: 'pending',
  icon: 'triangle-alert',
  evidenceSourceType: 'incident',
  evidenceSourceId: gatewayIncident.incidentId,
  actionType: 'review-incident',
  targetType: 'incident',
  targetId: gatewayIncident.incidentId,
} : null;

// 持久化 WorkItem 排在最前，其后是尚未进入流程的真实需求和系统事件。
// Walker 主张必须由持久化 WorkItem/Thesis 提供；这里不制造默认事项。
const queue: WorkItem[] = [...persistedItems, ...contentFeedbackItems, ...learningItems, ...needs, ...(systemItem ? [systemItem] : [])];
const focusQueue = queue.slice(0, 3);
const backlogQueue = queue.slice(1);
const hiddenBacklogCount = Math.max(0, queue.length - focusQueue.length);
const focus = focusQueue[0];
const pendingCount = queue.filter(item => item.state === 'pending').length;
const actingCount = queue.filter(item => item.state === 'acting').length;
const awaitingCount = queue.filter(item => item.state === 'awaiting-verification').length;
const navCounts = {
  today: queue.length,
  decisions: queue.filter(item => item.state === 'pending' || item.state === 'ai' || item.state === 'paused').length,
  actions: actingCount + awaitingCount,
  outcomes: persistedWorkItems.filter(item => item.status === 'resolved' && item.outcomes.length > 0).length,
  assetsLearning: learningRequests.filter(request => request.status === 'open' || request.status === 'in-progress').length,
  incidents: incidents.length,
};
const storageModeInfo = resolveStorageMode({ hasRedis: Boolean(getRedis()) });
const storageModeLabel = storageModeInfo === 'memory-development' ? '开发内存模式（重启丢失）' : storageModeInfo === 'redis' ? 'Redis 持久化' : '存储不可用';
const showDemoScenario = import.meta.env.DEV;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>工作台 · Walker</title>
</head>
<body>
  <AdminLayout
    active="/admin"
    title="工作台"
    subtitle={dateLabel}
    immersive
    showBanner={Boolean(gatewayIncident)}
    systemHealth={systemHealth}
    systemHealthCheckedAt={systemHealthCheckedAt}
    navCounts={navCounts}
  >
    <div class="workbench" data-workbench>
      <header class="workbench-head">
        <div>
          <h1>今天需要你决定的事</h1>
          <p>{pendingCount > 0 ? `共有 ${pendingCount} 项等待判断；AI 只整理证据和提出草案。` : '当前没有等待判断的真实事项。'}</p>
        </div>
        <div class="workbench-updated"><Icon name="lucide:clock-3" width={14} height={14} /><span>{dateLabel}</span></div>
      </header>

      <form class="command-bar" data-command-form>
        <Icon name="lucide:sparkles" width={21} height={21} />
        <label class="sr-only" for="admin-command">告诉 AI 你想推进什么</label>
        <input id="admin-command" name="command" autocomplete="off" placeholder="告诉 AI：我今天想推进什么？" />
        <button type="submit" aria-label="解析命令"><Icon name="lucide:arrow-up" width={21} height={21} /></button>
      </form>

      <section class="command-preview" data-command-preview hidden aria-live="polite">
        <div>
          <span class="preview-label">命令解析预览</span>
          <strong data-command-title></strong>
          <p>这是本地生成的提案草稿，尚未调用 AI，也没有写入后台。</p>
        </div>
        <div class="preview-chips" data-command-chips></div>
        <div class="preview-actions">
          <button type="button" data-command-cancel>取消</button>
          <button type="button" class="is-primary" data-command-keep>保留为 AI 提案草稿</button>
        </div>
      </section>

      <nav class="workbench-filters" aria-label="决定状态">
        <button class="is-active" type="button" data-filter="all">全部 <span>{queue.length}</span></button>
        <button type="button" data-filter="pending">待你决定 <span>{pendingCount}</span></button>
        <button type="button" data-filter="ai">AI 提案 <span data-ai-count>0</span></button>
        <button type="button" data-filter="paused">已暂缓</button>
        <button type="button" data-filter="ignored">已忽略</button>
      </nav>

      <div class="workbench-layout">
        <section class="decision-column" aria-label="决定队列">
          {focus ? <article
            class="focus-card is-selected"
            data-decision-item
            data-id={focus.id}
            data-work-item-id={focus.workItemId}
            data-state={focus.state}
            data-source={focus.source}
            data-title={focus.title}
            data-summary={focus.summary}
            data-evidence={focus.evidence}
            data-evidence-title={focus.evidenceTitle}
            data-evidence-body={focus.evidenceBody}
            data-action={focus.action}
            data-href={focus.href}
            data-evidence-source-type={focus.evidenceSourceType}
            data-evidence-source-id={focus.evidenceSourceId}
            data-evidence-occurred-at={focus.evidenceOccurredAt}
            data-action-type={focus.actionType}
            data-target-type={focus.targetType}
            data-target-id={focus.targetId}
            data-actions={JSON.stringify(focus.actions ?? [])}
            data-outcomes={JSON.stringify(focus.outcomes ?? [])}
            data-history={JSON.stringify(focus.history ?? [])}
            data-uncertainty={JSON.stringify(focus.uncertainty ?? [])}
            data-priority-reasons={JSON.stringify(focus.priorityReasons ?? [])}
            data-next-action-reason={focus.nextActionReason}
            data-next-action-type={focus.nextActionType}
            tabindex="0"
          >
            <div class="focus-topline">
              <span class="focus-label"><Icon name={`lucide:${focus.icon}`} width={16} height={16} />当前焦点 · {focus.source}</span>
              <span class="status-pill">待你决定</span>
            </div>
            <h2>{focus.title}</h2>
            <p>{focus.summary}</p>
            <button class="evidence-link" type="button" data-evidence-focus><Icon name="lucide:paperclip" width={14} height={14} />{focus.evidence}</button>
            <div class="focus-actions">
              <button class="primary-action" type="button" data-start-decision>开始处理</button>
              <button type="button" data-pause>暂缓</button>
              <button class="icon-action" type="button" aria-label="更多操作" data-more><Icon name="lucide:ellipsis" width={20} height={20} /></button>
            </div>
          </article> : <section class="workbench-empty" data-workbench-empty>
            <span class="workbench-empty-icon"><Icon name="lucide:inbox" width={22} height={22} /></span>
            <div>
              <strong>当前没有需要你决定的真实事项</strong>
              <p>新的用户需求、内容反馈、待验证结果或系统事件出现后，会进入这里。</p>
            </div>
          </section>}

          {focus && <section class="decision-confirm" data-decision-confirm hidden>
            <div class="confirm-head">
              <span><Icon name="lucide:shield-check" width={17} height={17} />执行前确认</span>
              <button type="button" aria-label="关闭" data-confirm-close><Icon name="lucide:x" width={17} height={17} /></button>
            </div>
            <div class="confirm-grid">
              <div><small>将要做什么</small><strong data-confirm-action>建立一个可验证的处理任务</strong></div>
              <div><small>影响范围</small><strong>仅后台草稿，不自动发布</strong></div>
              <div><small>如何撤回</small><strong>执行结束前可随时取消</strong></div>
            </div>
            <label><input type="checkbox" data-confirm-check />我已检查证据，允许 AI 按步骤生成草稿</label>
            <button class="confirm-submit" type="button" data-confirm-submit disabled>确认并执行</button>
          </section>}

          {focus && <form class="decision-inline-form" data-pause-form hidden>
            <div class="inline-form-head">
              <div><strong>暂缓当前事项</strong><span>说明什么时候重新打开，避免事项永久消失。</span></div>
              <button type="button" aria-label="关闭暂缓表单" data-pause-cancel><Icon name="lucide:x" width={17} height={17} /></button>
            </div>
            <label for="pause-reason">复查条件或暂缓原因</label>
            <textarea id="pause-reason" name="reason" rows="3" required placeholder="例如：等待另外两条真实反馈后复查"></textarea>
            <p class="inline-form-status" data-pause-status hidden role="status"></p>
            <div class="inline-form-actions">
              <button type="button" data-pause-cancel>取消</button>
              <button class="is-primary" type="submit">确认暂缓</button>
            </div>
          </form>}

          {focus && <section class="execution-card" data-execution hidden aria-live="polite">
            <div class="execution-head">
              <span><Icon name="lucide:loader-circle" width={17} height={17} data-spinner />当前会话正在执行</span>
              <button type="button" data-stop-execution>停止</button>
            </div>
            <ol>
              <li data-step="0"><i></i><span>读取当前事项与关联证据</span><small>等待</small></li>
              <li data-step="1"><i></i><span>生成可编辑的行动草稿</span><small>等待</small></li>
              <li data-step="2"><i></i><span>建立结果验证条件</span><small>等待</small></li>
            </ol>
          </section>}

          <div class="queue-label"><span>接下来</span><small>{hiddenBacklogCount > 0 ? `另有 ${hiddenBacklogCount} 项进入分类队列` : '首屏最多突出前三项真实重点'}</small></div>
          <div class="decision-queue" data-decision-list>
            {backlogQueue.map(item => (
              <article
                class="queue-item"
                data-decision-item
                data-id={item.id}
                data-work-item-id={item.workItemId}
                data-state={item.state}
                data-source={item.source}
                data-title={item.title}
                data-summary={item.summary}
                data-evidence={item.evidence}
                data-evidence-title={item.evidenceTitle}
                data-evidence-body={item.evidenceBody}
                data-action={item.action}
                data-href={item.href}
                data-evidence-source-type={item.evidenceSourceType}
                data-evidence-source-id={item.evidenceSourceId}
                data-evidence-occurred-at={item.evidenceOccurredAt}
                data-action-type={item.actionType}
                data-target-type={item.targetType}
                data-target-id={item.targetId}
                data-actions={JSON.stringify(item.actions ?? [])}
                data-outcomes={JSON.stringify(item.outcomes ?? [])}
                data-history={JSON.stringify(item.history ?? [])}
                data-uncertainty={JSON.stringify(item.uncertainty ?? [])}
                data-priority-reasons={JSON.stringify(item.priorityReasons ?? [])}
                data-next-action-reason={item.nextActionReason}
                data-next-action-type={item.nextActionType}
                tabindex="0"
              >
                <span class="queue-icon"><Icon name={`lucide:${item.icon}`} width={18} height={18} /></span>
                <div><small>{item.source}</small><h3>{item.title}</h3><p>{item.evidence}</p></div>
                <Icon name="lucide:chevron-right" width={18} height={18} />
              </article>
            ))}
            <template data-ai-template>
              <article class="queue-item" data-decision-item data-state="ai" tabindex="0">
                <span class="queue-icon"><Icon name="lucide:sparkles" width={18} height={18} /></span>
                <div><small>AI 提案 · 未保存</small><h3></h3><p>来自命令栏 · 等待你检查</p></div>
                <Icon name="lucide:chevron-right" width={18} height={18} />
              </article>
            </template>
            <div class="queue-empty" data-queue-empty hidden>
              <Icon name="lucide:inbox" width={24} height={24} />
              <strong>这个状态下还没有事项</strong>
              <span>命令栏生成的草稿会出现在“AI 提案”中。</span>
            </div>
          </div>
        </section>

        <aside class="decision-detail" data-detail-panel hidden={!focus}>
          <div class="detail-head">
            <span class="detail-source" data-detail-source>{focus?.source}</span>
            <button type="button" aria-label="收起详情" data-detail-close><Icon name="lucide:x" width={19} height={19} /></button>
          </div>
          <h2 data-detail-title>{focus?.title}</h2>
          <div class="detail-tabs">
            <button class="is-active" type="button" data-detail-tab="why">为什么现在</button>
            <button type="button" data-detail-tab="evidence">原始证据</button>
            <button type="button" data-detail-tab="history">历史</button>
            <button type="button" data-detail-tab="next">下一步</button>
          </div>
          <div class="detail-view" data-detail-view="why">
            <p data-detail-summary>{focus?.summary}</p>
            <ul>
              <li><Icon name="lucide:check-circle-2" width={16} height={16} /><span>来源已标明，不把站主判断伪装成用户需求</span></li>
              <li><Icon name="lucide:check-circle-2" width={16} height={16} /><span>必须由你确认后，才进入执行步骤</span></li>
              <li><Icon name="lucide:check-circle-2" width={16} height={16} /><span>执行只生成草稿，不自动发布或删除</span></li>
            </ul>
          </div>
          <div class="detail-view" data-detail-view="evidence" hidden>
            <div class="evidence-card" data-evidence-card>
              <span data-detail-evidence-title>{focus?.evidenceTitle}</span>
              <blockquote data-detail-evidence-body>{focus?.evidenceBody}</blockquote>
              <small data-detail-evidence>{focus?.evidence}</small>
            </div>
          </div>
          <div class="detail-view" data-detail-view="history" hidden>
            <div class="history-list" data-detail-history></div>
          </div>
          <div class="detail-view" data-detail-view="next" hidden>
            <ol class="next-steps" data-next-steps>
              <li><i>1</i><span>确认问题是否真实且值得处理</span></li>
              <li><i>2</i><span>让 AI 生成内容、功能或验证任务草稿</span></li>
              <li><i>3</i><span>你检查并授权，再进入真实执行</span></li>
            </ol>
            <form class="outcome-inline-form" data-outcome-form hidden>
              <label for="outcome-result">记录执行结果</label>
              <select id="outcome-result" name="result" required>
                <option value="successful">successful · 已解决</option>
                <option value="partial">partial · 部分有效</option>
                <option value="failed">failed · 未解决</option>
                <option value="inconclusive">inconclusive · 证据不足</option>
              </select>
              <textarea name="summary" rows="3" required placeholder="记录现实结果、证据和边界"></textarea>
              <p class="inline-form-status" data-outcome-status hidden role="status"></p>
              <button class="detail-primary" type="submit">保存 Outcome</button>
            </form>
          </div>
          <div class="detail-footer">
            <button class="detail-primary" type="button" data-detail-start>{focus?.action || '开始处理'}</button>
            <a href={focus?.href || '#'} data-detail-href>打开原始记录<Icon name="lucide:arrow-up-right" width={14} height={14} /></a>
          </div>
        </aside>
      </div>

      <p class="truth-note"><Icon name="lucide:database" width={13} height={13} />7 天内记录 {stats.totalCases} 条需求；决定/行动/结果存储于 {storageModeLabel}；未采集的数据不会显示成指标。</p>

      {showDemoScenario && <section class="demo-scenario" data-demo-scenario>
        <div>
          <strong>开发演示场景</strong>
          <p>仅本机开发环境可用。生成带“模拟数据”标记的内容反馈 → WorkItem → Action，不进入生产；可一键清理。</p>
        </div>
        <div class="demo-actions">
          <button type="button" data-demo-create>生成模拟闭环</button>
          <button type="button" data-demo-clear>清理模拟数据</button>
        </div>
        <span data-demo-status role="status" aria-live="polite"></span>
      </section>}
    </div>
  </AdminLayout>

  <script>
    const root = document.querySelector('[data-workbench]') as HTMLElement | null;
    if (root) {
      const detail = root.querySelector('[data-detail-panel]') as HTMLElement;
      const items = () => [...root.querySelectorAll<HTMLElement>('[data-decision-item]')];
      let selected = root.querySelector<HTMLElement>('[data-decision-item].is-selected') || items()[0];
      let executionTimer: number | undefined;

      const setText = (selector: string, value = '') => {
        const node = root.querySelector(selector);
        if (node) node.textContent = value;
      };

      const parseJsonData = <T,>(value: string | undefined, fallback: T): T => {
        if (!value) return fallback;
        try { return JSON.parse(value) as T; } catch { return fallback; }
      };

      const renderDetailLists = (d: DOMStringMap) => {
        const history = parseJsonData<Array<{ kind: string; actor: string; reason?: string; occurredAt: string }>>(d.history, []);
        const actions = parseJsonData<Array<{ actionId: string; actionType: string; status: string; expectedOutcome: string }>>(d.actions, []);
        const outcomes = parseJsonData<Array<{ result: string; summary: string; observedAt: string }>>(d.outcomes, []);
        const uncertainty = parseJsonData<string[]>(d.uncertainty, []);
        const reasons = parseJsonData<string[]>(d.priorityReasons, []);
        const historyBox = root.querySelector<HTMLElement>('[data-detail-history]');
        if (historyBox) {
          const rows = history.slice(-5).reverse().map(entry => `<article><strong>${entry.kind}</strong><span>${entry.reason || '无补充说明'}</span><small>${entry.actor} · ${new Date(entry.occurredAt).toLocaleString('zh-CN')}</small></article>`);
          historyBox.innerHTML = rows.length ? rows.join('') : '<p>还没有持久化历史；待你作出决定后会写入这里。</p>';
        }
        const nextSteps = root.querySelector<HTMLElement>('[data-next-steps]');
        if (nextSteps) {
          const actionText = actions.length ? `当前行动：${actions.at(-1)!.actionType} · ${actions.at(-1)!.status} · ${actions.at(-1)!.expectedOutcome}` : '还没有 Action：先接受或暂缓当前决定。';
          const outcomeText = outcomes.length ? `最近结果：${outcomes.at(-1)!.result} · ${outcomes.at(-1)!.summary}` : '还没有 Outcome：执行完成后在这里记录现实结果。';
          const nextText = d.nextActionReason || (uncertainty.length ? `不确定性：${uncertainty.join('；')}` : reasons[0] || '下一步会由真实状态和结果派生，不自动执行。');
          nextSteps.innerHTML = `<li><i>1</i><span>${actionText}</span></li><li><i>2</i><span>${outcomeText}</span></li><li><i>3</i><span>${nextText}</span></li>`;
        }
        const outcomeForm = root.querySelector<HTMLFormElement>('[data-outcome-form]');
        if (outcomeForm) {
          const latest = actions.at(-1);
          outcomeForm.hidden = !(d.workItemId && latest && (latest.status === 'completed' || latest.status === 'awaiting-verification'));
          outcomeForm.dataset.workItemId = d.workItemId || '';
          outcomeForm.dataset.actionId = latest?.actionId || '';
          outcomeForm.dataset.evidenceSourceType = d.evidenceSourceType || '';
          outcomeForm.dataset.evidenceSourceId = d.evidenceSourceId || '';
          outcomeForm.dataset.evidenceSummary = d.evidenceBody || d.summary || '';
        }
      };

      const selectItem = (item: HTMLElement) => {
        selected?.classList.remove('is-selected');
        item.classList.add('is-selected');
        selected = item;
        const d = item.dataset;
        setText('[data-detail-source]', d.source);
        setText('[data-detail-title]', d.title);
        setText('[data-detail-summary]', d.summary);
        setText('[data-detail-evidence]', d.evidence);
        setText('[data-detail-evidence-title]', d.evidenceTitle);
        setText('[data-detail-evidence-body]', d.evidenceBody);
        setText('[data-detail-start]', d.action || '开始处理');
        setText('[data-confirm-action]', d.action || '建立一个可验证的处理任务');
        renderDetailLists(d);
        const href = root.querySelector<HTMLAnchorElement>('[data-detail-href]');
        if (href) href.href = d.href || '#';
        detail.hidden = false;
        detail.animate([{ opacity: .55, transform: 'translateX(12px)' }, { opacity: 1, transform: 'translateX(0)' }], { duration: 210, easing: 'ease-out' });
      };

      const bindItem = (item: HTMLElement) => {
        item.addEventListener('click', event => {
          if ((event.target as HTMLElement).closest('button, a')) return;
          selectItem(item);
        });
        item.addEventListener('keydown', event => {
          if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); selectItem(item); }
        });
      };
      items().forEach(bindItem);
      if (selected) renderDetailLists(selected.dataset);

      root.querySelector('[data-detail-close]')?.addEventListener('click', () => { detail.hidden = true; });
      root.querySelector('[data-evidence-focus]')?.addEventListener('click', () => {
        (root.querySelector('[data-detail-tab="evidence"]') as HTMLButtonElement)?.click();
        detail.animate([{ transform: 'scale(.995)' }, { transform: 'scale(1)' }], { duration: 180 });
      });

      root.querySelectorAll<HTMLButtonElement>('[data-detail-tab]').forEach(button => button.addEventListener('click', () => {
        root.querySelectorAll('[data-detail-tab]').forEach(tab => tab.classList.toggle('is-active', tab === button));
        root.querySelectorAll<HTMLElement>('[data-detail-view]').forEach(view => { view.hidden = view.dataset.detailView !== button.dataset.detailTab; });
      }));

      root.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach(button => button.addEventListener('click', () => {
        root.querySelectorAll('[data-filter]').forEach(tab => tab.classList.toggle('is-active', tab === button));
        const filter = button.dataset.filter;
        let visible = 0;
        items().forEach(item => {
          const show = filter === 'all' || item.dataset.state === filter;
          item.hidden = !show;
          if (show) visible += 1;
        });
        const empty = root.querySelector<HTMLElement>('[data-queue-empty]');
        if (empty) empty.hidden = visible > 0;
      }));

      const confirm = root.querySelector<HTMLElement>('[data-decision-confirm]');
      const openConfirm = () => {
        if (!confirm) return;
        confirm.hidden = false;
        confirm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        confirm.animate([{ opacity: 0, transform: 'translateY(-8px)' }, { opacity: 1, transform: 'translateY(0)' }], { duration: 220, easing: 'ease-out' });
      };
      root.querySelector('[data-start-decision]')?.addEventListener('click', openConfirm);
      root.querySelector('[data-detail-start]')?.addEventListener('click', openConfirm);
      root.querySelector('[data-confirm-close]')?.addEventListener('click', () => { if (confirm) confirm.hidden = true; });
      const check = root.querySelector<HTMLInputElement>('[data-confirm-check]');
      const submit = root.querySelector<HTMLButtonElement>('[data-confirm-submit]');
      check?.addEventListener('change', () => { if (submit) submit.disabled = !check.checked; });

      submit?.addEventListener('click', () => {
        if (confirm) confirm.hidden = true;
        const execution = root.querySelector<HTMLElement>('[data-execution]');
        if (!execution) return;
        execution.hidden = false;
        execution.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 200 });
        const steps = [...execution.querySelectorAll<HTMLElement>('[data-step]')];
        let step = 0;
        steps.forEach(node => { node.className = ''; node.querySelector('small')!.textContent = '等待'; });
        const run = async () => {
          steps.forEach((node, index) => {
            node.classList.toggle('is-done', index < step);
            node.classList.toggle('is-running', index === step);
            node.querySelector('small')!.textContent = index < step ? '完成' : index === step ? '进行中' : '等待';
          });
          if (step >= steps.length) {
            clearInterval(executionTimer);
            // P0-D：完成后把真实 NeedCase 作为证据创建并接受 WorkItem，再创建行动。
            // 失败时明确提示，不伪造"草稿已生成"成功状态。
            setText('.execution-head span', '正在写入工作项…');
            const result = await ensureWorkItemForSelected({ outcome: 'accepted', reason: '确认证据，开始执行' });
            if (!result.ok || !result.workItemId) {
              execution.classList.add('is-complete');
              setText('.execution-head span', `写入失败：${result.error}`);
              return;
            }
            // 创建行动（产出内容/改功能由事项来源决定）
            const d = selected?.dataset;
            const actionType = d?.actionType || (d?.source === '系统事件' ? 'review-incident' : 'create-content');
            const actionRes = await fetch('/api/admin/actions', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({
                workItemId: result.workItemId,
                actionType,
                targetType: d?.targetType || (actionType === 'review-incident' ? 'incident' : 'content'),
                targetId: d?.targetId || undefined,
                expectedOutcome: d?.title ? `基于"${d.title}"产出可验证的方案` : '产出可验证的方案',
              }),
            });
            if (!actionRes.ok) {
              const err = await actionRes.json().catch(() => ({}));
              execution.classList.add('is-complete');
              setText('.execution-head span', `行动创建失败：${err.error || actionRes.status}`);
              return;
            }
            execution.classList.add('is-complete');
            if (selected) {
              selected.dataset.workItemId = result.workItemId;
              const actionData = await actionRes.json().catch(() => ({}));
              if (actionData.item) {
                selected.dataset.state = actionData.item.status === 'awaiting-verification' ? 'awaiting-verification' : 'acting';
                selected.dataset.actions = JSON.stringify(actionData.item.actions || []);
                selected.dataset.history = JSON.stringify(actionData.item.history || []);
                renderDetailLists(selected.dataset);
              }
            }
            setText('.execution-head span', '工作项已建立，等待你执行并验证');
          }
          step += 1;
        };
        run();
        executionTimer = window.setInterval(run, 850);
      });

      root.querySelector('[data-stop-execution]')?.addEventListener('click', () => {
        clearInterval(executionTimer);
        const execution = root.querySelector<HTMLElement>('[data-execution]');
        if (execution) execution.hidden = true;
      });

      // P0-D：把真实 NeedCase 作为证据创建 WorkItem 提案（不写 localStorage 业务状态）。
      // 失败时保留当前输入并明确提示，不伪造"已暂缓"成功。
      const ensureWorkItemForSelected = async (decide?: { outcome: 'accepted' | 'paused' | 'rejected'; reason: string }) => {
        if (!selected) return { ok: false as const, error: '未选择事项' };
        const d = selected.dataset;
        if (d.workItemId) {
          if (!decide) return { ok: true as const, workItemId: d.workItemId };
          const decideRes = await fetch(`/api/admin/decisions/${d.workItemId}`, {
            method: 'PATCH',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ decide }),
          });
          if (!decideRes.ok) {
            const err = await decideRes.json().catch(() => ({}));
            return { ok: false as const, error: err.error || `决定失败（${decideRes.status}）`, workItemId: d.workItemId };
          }
          const decided = await decideRes.json();
          return { ok: true as const, workItemId: d.workItemId, item: decided.item };
        }
        const sourceNeedCaseId = (d.id || '').replace(/^need-/, '');
        const isNeedCase = d.id?.startsWith('need-') && sourceNeedCaseId.length > 0;
        const sourceType = d.evidenceSourceType || (isNeedCase ? 'need-case' : undefined);
        const sourceId = d.evidenceSourceId || (isNeedCase ? sourceNeedCaseId : undefined);
        const evidenceRefs = sourceType && sourceId ? [{
          evidenceId: `ev_${sourceType.replace(/-/g, '_')}_${sourceId}`,
          sourceType,
          sourceId,
          occurredAt: d.evidenceOccurredAt || new Date().toISOString(),
          summary: d.evidenceBody || d.summary || '原始需求',
          qualityStatus: 'verified-source' as const,
        }] : [];
        // 命令栏 AI 草稿无真实证据，按 hai-razor 只能是 proposal，不允许直接决定。
        if (evidenceRefs.length === 0 && decide) {
          return { ok: false as const, error: '该事项无现实证据，不能直接作出决定。' };
        }
        const queue = d.source === '用户需求' || d.source === '内容反馈' ? 'user-demand'
          : d.source === 'Walker 主张' ? 'walker-thesis'
          : d.source === '系统事件' ? 'system-event' : 'ai-asset';
        const createRes = await fetch('/api/admin/decisions', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            queue,
            title: d.title || '未命名事项',
            summary: d.summary || '',
            priorityBand: 'now',
            evidenceRefs,
            topicId: isNeedCase ? undefined : undefined,
            requestDecision: Boolean(decide),
          }),
        });
        if (!createRes.ok) {
          const err = await createRes.json().catch(() => ({}));
          return { ok: false as const, error: err.error || `创建工作项失败（${createRes.status}）` };
        }
        const created = await createRes.json();
        const workItemId = created.item?.workItemId;
        if (!workItemId) return { ok: false as const, error: '未返回工作项 ID' };
        if (decide) {
          const decideRes = await fetch(`/api/admin/decisions/${workItemId}`, {
            method: 'PATCH',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ decide }),
          });
          if (!decideRes.ok) {
            const err = await decideRes.json().catch(() => ({}));
            return { ok: false as const, error: err.error || `决定失败（${decideRes.status}）`, workItemId };
          }
          const decided = await decideRes.json();
          return { ok: true as const, workItemId, item: decided.item };
        }
        return { ok: true as const, workItemId, item: created.item };
      };

      const outcomeForm = root.querySelector<HTMLFormElement>('[data-outcome-form]');
      outcomeForm?.addEventListener('submit', async event => {
        event.preventDefault();
        const status = outcomeForm.querySelector<HTMLElement>('[data-outcome-status]');
        const submit = outcomeForm.querySelector<HTMLButtonElement>('button[type="submit"]');
        const result = (outcomeForm.elements.namedItem('result') as HTMLSelectElement).value;
        const summaryInput = outcomeForm.elements.namedItem('summary') as HTMLTextAreaElement;
        const summary = summaryInput.value.trim();
        if (!summary) return summaryInput.focus();
        if (submit) submit.disabled = true;
        if (status) status.hidden = true;
        try {
          const evidenceSourceType = outcomeForm.dataset.evidenceSourceType || 'content-feedback';
          const evidenceSourceId = outcomeForm.dataset.evidenceSourceId || outcomeForm.dataset.actionId || 'manual-outcome';
          const res = await fetch('/api/admin/outcomes', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              workItemId: outcomeForm.dataset.workItemId,
              actionId: outcomeForm.dataset.actionId,
              result,
              summary,
              evidenceRefs: [{
                evidenceId: `ev_outcome_${Date.now()}`,
                sourceType: evidenceSourceType,
                sourceId: evidenceSourceId,
                occurredAt: new Date().toISOString(),
                summary: outcomeForm.dataset.evidenceSummary || summary,
                qualityStatus: 'verified-source',
              }],
              nextDecisionSuggested: true,
            }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            if (status) { status.textContent = `保存失败：${data.error || res.status}。输入已保留。`; status.hidden = false; }
            return;
          }
          if (selected) {
            selected.dataset.state = 'ignored';
            selected.dataset.outcomes = JSON.stringify(data.item?.outcomes || []);
            selected.dataset.history = JSON.stringify(data.item?.history || []);
            selected.dataset.nextActionReason = '结果已记录，可继续创建下一步或结束观察。';
            renderDetailLists(selected.dataset);
          }
          summaryInput.value = '';
          if (status) { status.textContent = 'Outcome 已保存，当前事项已进入结果历史。'; status.hidden = false; }
        } catch {
          if (status) { status.textContent = '网络异常，请重试。输入已保留。'; status.hidden = false; }
        } finally {
          if (submit) submit.disabled = false;
        }
      });

      const pauseForm = root.querySelector<HTMLFormElement>('[data-pause-form]');
      const pauseStatus = root.querySelector<HTMLElement>('[data-pause-status]');
      const closePauseForm = () => {
        if (pauseForm) pauseForm.hidden = true;
        if (pauseStatus) pauseStatus.hidden = true;
      };
      root.querySelector('[data-pause]')?.addEventListener('click', () => {
        if (!pauseForm || !selected) return;
        pauseForm.hidden = false;
        const input = pauseForm.elements.namedItem('reason') as HTMLTextAreaElement;
        input.focus();
      });
      root.querySelectorAll('[data-pause-cancel]').forEach(button => button.addEventListener('click', closePauseForm));
      pauseForm?.addEventListener('submit', async event => {
        event.preventDefault();
        if (!selected) return;
        const input = pauseForm.elements.namedItem('reason') as HTMLTextAreaElement;
        const reason = input.value.trim();
        if (!reason) return input.focus();
        const submit = pauseForm.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (submit) submit.disabled = true;
        if (pauseStatus) pauseStatus.hidden = true;
        const result = await ensureWorkItemForSelected({ outcome: 'paused', reason });
        if (submit) submit.disabled = false;
        if (!result.ok) {
          if (pauseStatus) {
            pauseStatus.textContent = `暂缓失败：${result.error}。你的输入仍在，可以直接重试。`;
            pauseStatus.hidden = false;
          }
          return;
        }
        if (selected) {
          selected.dataset.state = 'paused';
          selected.dataset.workItemId = result.workItemId;
          if (result.item) {
            selected.dataset.history = JSON.stringify(result.item.history || []);
            selected.dataset.priorityReasons = JSON.stringify(result.item.priorityReasons || []);
          }
          renderDetailLists(selected.dataset);
        }
        selected?.classList.add('is-paused');
        setText('.status-pill', '已暂缓');
        input.value = '';
        closePauseForm();
      });

      const commandForm = root.querySelector<HTMLFormElement>('[data-command-form]');
      const commandPreview = root.querySelector<HTMLElement>('[data-command-preview]');
      commandForm?.addEventListener('submit', event => {
        event.preventDefault();
        const input = commandForm.elements.namedItem('command') as HTMLInputElement;
        const value = input.value.trim();
        if (!value || !commandPreview) return;
        setText('[data-command-title]', value);
        const chips = root.querySelector<HTMLElement>('[data-command-chips]');
        const tags = [value.includes('文章') || value.includes('内容') ? '内容' : value.includes('功能') ? '功能' : '待判断', value.includes('今天') ? '今天' : '未设期限', '需你授权'];
        if (chips) chips.innerHTML = tags.map(tag => `<span>${tag}</span>`).join('');
        commandPreview.hidden = false;
        commandPreview.animate([{ opacity: 0, transform: 'translateY(-8px)' }, { opacity: 1, transform: 'translateY(0)' }], { duration: 200 });
      });
      root.querySelector('[data-command-cancel]')?.addEventListener('click', () => { if (commandPreview) commandPreview.hidden = true; });
      root.querySelector('[data-command-keep]')?.addEventListener('click', () => {
        if (!commandPreview || !commandForm) return;
        const command = (commandForm.elements.namedItem('command') as HTMLInputElement).value.trim();
        commandPreview.hidden = true;
        const count = root.querySelector('[data-ai-count]');
        if (count) count.textContent = '1';
        const existing = root.querySelector<HTMLElement>('[data-id="ai-command-draft"]');
        const template = root.querySelector<HTMLTemplateElement>('[data-ai-template]');
        const draft = existing || template?.content.firstElementChild?.cloneNode(true) as HTMLElement | undefined;
        if (draft && !existing) {
          draft.dataset.id = 'ai-command-draft';
          draft.dataset.source = 'AI 提案 · 未保存';
          draft.dataset.state = 'ai';
          draft.dataset.evidence = '0 条现实证据 · 来自你的命令';
          draft.dataset.evidenceTitle = '生成依据';
          draft.dataset.evidenceBody = `命令：${command}`;
          draft.dataset.action = '检查提案';
          draft.dataset.href = '/admin';
          root.querySelector('[data-decision-list]')?.insertBefore(draft, root.querySelector('[data-queue-empty]'));
          bindItem(draft);
        }
        if (draft) {
          draft.dataset.title = command;
          draft.dataset.summary = 'AI 只把你的自然语言整理成待检查的行动草稿；它尚未引用现实证据，也没有写入后台。选择"检查提案"后，需绑定真实证据才能创建正式工作项。';
          const title = draft.querySelector('h3');
          if (title) title.textContent = command;
          selectItem(draft);
        }
        // P0-D：AI 命令草稿无真实证据，按 hai-razor 只能是 proposal，且必须在绑定证据后才持久化。
        // 这里不再写 localStorage 伪造持久化；草稿仅停留在当前会话，刷新后清空。
      });
      root.querySelectorAll<HTMLButtonElement>('[data-demo-create], [data-demo-clear]').forEach(button => {
        button.addEventListener('click', async () => {
          const status = root.querySelector<HTMLElement>('[data-demo-status]');
          const isCreate = button.hasAttribute('data-demo-create');
          button.disabled = true;
