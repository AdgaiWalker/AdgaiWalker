---
import { Icon } from 'astro-icon/components';
import { isAdmin } from '@/lib/admin-auth';
import { getNeedCaseStats, getPendingReviewNeedCases, getUnresolvedIncidents } from '@/conversation/store';
import { getGatewayConfig, getGatewayStats } from '@/agent/gateway-config';
import AdminLayout from '@/components/admin/AdminLayout.astro';
import { deriveAdminSystemHealth } from '@/components/admin/admin-shell-state';
import { createWorkbenchService } from '@/services/workbench.service';
import type { WorkItem as WorkItemEntity } from '@/stores/ports';

export const prerender = false;
if (!isAdmin(Astro.request)) return Astro.redirect('/admin/login');

const stats = await getNeedCaseStats({ days: 7 });
const pendingNeeds = await getPendingReviewNeedCases({ limit: 4 });
const incidents = await getUnresolvedIncidents(20);
const gatewayIncident = incidents.find(item => item.scope.toLowerCase().includes('gateway'));

// P0-A02：系统健康从真实事实推导（Gateway 配置 + 调用统计 + Gateway 事件）。
// 不再硬编码"系统可用"；零数据落 unknown，缺配置落 unavailable。
const [gatewayConfig, gatewayStats] = await Promise.all([getGatewayConfig(), getGatewayStats()]);
const gatewayConfigured = Boolean(gatewayConfig.apiKey) && Boolean(gatewayConfig.provider);
const systemHealth = deriveAdminSystemHealth({
  configured: gatewayConfigured,
  stats: gatewayStats,
  hasGatewayIncident: Boolean(gatewayIncident),
});
const systemHealthCheckedAt = new Date().toISOString();

const dateLabel = new Intl.DateTimeFormat('zh-CN', { month: 'long', day: 'numeric', weekday: 'long' }).format(new Date());

// P0-D02：显示卡片用统一结构；state 映射真实 WorkItem 状态机，不在前端自定义另一个"进行中"字段。
type WorkItem = {
  id: string;
  /** 关联的持久化 WorkItem ID（若已创建）；用于前端调用 API */
  workItemId?: string;
  source: string;
  title: string;
  summary: string;
  evidence: string;
  evidenceTitle: string;
  evidenceBody: string;
  action: string;
  href: string;
  /** 显示状态：从真实 WorkItem.status 派生 */
  state: 'pending' | 'ai' | 'paused' | 'acting' | 'awaiting-verification' | 'ignored';
  icon: string;
};

const QUEUE_LABEL: Record<WorkItemEntity['queue'], string> = {
  'user-demand': '用户需求',
  'walker-thesis': 'Walker 主张',
  'system-event': '系统事件',
  'ai-asset': 'AI 资产',
};

const STATUS_TO_STATE: Record<WorkItemEntity['status'], WorkItem['state']> = {
  proposal: 'ai',
  pending: 'pending',
  accepted: 'pending',
  rejected: 'ignored',
  paused: 'paused',
  acting: 'acting',
  'awaiting-verification': 'awaiting-verification',
  resolved: 'ignored',
};

const needs: WorkItem[] = pendingNeeds.map((item, index) => ({
  id: `need-${item.needCaseId}`,
  source: '用户需求',
  title: item.needSummary || item.rawNeedRedacted || '一条尚未归纳的需求',
  summary: item.rawNeedRedacted || '这条需求需要你先判断：是个别问题，还是值得进入选题或功能决策。',
  evidence: `1 条原始需求 · ${item.sourcePage || '来源页未记录'}`,
  evidenceTitle: '原始需求',
  evidenceBody: item.rawNeedRedacted || '原始文本已脱敏或未保留。',
  action: index === 0 ? '开始判断' : '查看需求',
  href: `/admin/review?needCaseId=${encodeURIComponent(item.needCaseId)}`,
  state: 'pending',
  icon: 'circle-dot',
}));

// P0-D02：从服务端投影真实 WorkItem（已创建的工作项），按真实状态显示责任方。
// 这些是 Walker 已经操作过、持久化在服务端的事项；刷新/重启不丢失。
const persistedWorkItems = await createWorkbenchService().getTodayProjection({ limit: 8 });
const persistedItems: WorkItem[] = persistedWorkItems
  .filter(item => item.status !== 'rejected' && item.status !== 'resolved')
  .map(item => {
    const latestAction = item.actions[item.actions.length - 1];
    const assignee = latestAction?.assignee === 'ai' ? 'AI' : latestAction?.assignee === 'shared' ? '共同' : '你';
    return {
      id: `workitem-${item.workItemId}`,
      workItemId: item.workItemId,
      source: QUEUE_LABEL[item.queue],
      title: item.title,
      summary: item.summary,
      evidence: `${item.evidenceRefs.length} 条证据 · 责任方：${assignee}`,
      evidenceTitle: '决定理由',
      evidenceBody: item.decision.reason || item.summary,
      action: item.status === 'acting' ? '查看执行' : item.status === 'awaiting-verification' ? '验证结果' : '继续处理',
      href: '/admin',
      state: STATUS_TO_STATE[item.status],
      icon: item.queue === 'system-event' ? 'triangle-alert' : item.queue === 'walker-thesis' ? 'lightbulb' : 'circle-dot',
    };
  });

const ownerIdea: WorkItem = {
  id: 'owner-ai-boundary',
  source: 'Walker 主张',
  title: '明确后台中 AI 与人的决策边界',
  summary: '这是站主主动提出、尚未由用户需求验证的方向。保留它，但不要把它伪装成市场结论。',
  evidence: '0 条用户证据 · 等待现实验证',
  evidenceTitle: '站主判断',
  evidenceBody: 'AI 可以收集、归纳和提出行动草案；涉及发布、删除、权限与资产准入的决定必须由人授权。',
  action: '建立验证任务',
  href: '/admin/topics',
  state: 'pending',
  icon: 'lightbulb',
};

const systemItem: WorkItem | null = gatewayIncident ? {
  id: `incident-${gatewayIncident.incidentId}`,
  source: '系统事件',
  title: gatewayIncident.message || 'AI Gateway 需要复盘',
  summary: '真实系统事件优先于一般优化，先确认影响范围，再决定是否降级或修复。',
  evidence: `${gatewayIncident.severity === 'high' ? '高' : gatewayIncident.severity === 'medium' ? '中' : '低'}严重度 · 未解决`,
  evidenceTitle: '事件记录',
  evidenceBody: gatewayIncident.message,
  action: '查看事件',
  href: '/admin/incidents',
  state: 'pending',
  icon: 'triangle-alert',
} : null;

// 持久化 WorkItem 排在最前（这些是已进入流程的真实事项），其后是待判断的需求与主张。
const queue: WorkItem[] = [...persistedItems, ...needs, ownerIdea, ...(systemItem ? [systemItem] : [])];
const focus = queue[0];
const pendingCount = queue.filter(item => item.state === 'pending').length;
const storageMode = import.meta.env.PROD ? 'production' : (import.meta.env.DEV ? 'development' : 'production');
const storageModeLabel = storageMode === 'development' ? '开发内存模式（重启丢失）' : '生产持久化';
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>工作台 · Walker</title>
</head>
<body>
  <AdminLayout
    active="/admin"
    title="工作台"
    subtitle={dateLabel}
    immersive
    showBanner={Boolean(gatewayIncident)}
    systemHealth={systemHealth}
    systemHealthCheckedAt={systemHealthCheckedAt}
  >
    <div class="workbench" data-workbench>
      <header class="workbench-head">
        <div>
          <h1>今天需要你决定的事</h1>
          <p>{pendingCount > 0 ? `共有 ${pendingCount} 项等待判断；AI 只整理证据和提出草案。` : '当前没有等待判断的真实事项。'}</p>
        </div>
        <div class="workbench-updated"><Icon name="lucide:clock-3" width={14} height={14} /><span>{dateLabel}</span></div>
      </header>

      <form class="command-bar" data-command-form>
        <Icon name="lucide:sparkles" width={21} height={21} />
        <label class="sr-only" for="admin-command">告诉 AI 你想推进什么</label>
        <input id="admin-command" name="command" autocomplete="off" placeholder="告诉 AI：我今天想推进什么？" />
        <button type="submit" aria-label="解析命令"><Icon name="lucide:arrow-up" width={21} height={21} /></button>
      </form>

      <section class="command-preview" data-command-preview hidden aria-live="polite">
        <div>
          <span class="preview-label">命令解析预览</span>
          <strong data-command-title></strong>
          <p>这是本地生成的提案草稿，尚未调用 AI，也没有写入后台。</p>
        </div>
        <div class="preview-chips" data-command-chips></div>
        <div class="preview-actions">
          <button type="button" data-command-cancel>取消</button>
          <button type="button" class="is-primary" data-command-keep>保留为 AI 提案草稿</button>
        </div>
      </section>

      <nav class="workbench-filters" aria-label="决定状态">
        <button class="is-active" type="button" data-filter="all">全部 <span>{queue.length}</span></button>
        <button type="button" data-filter="pending">待你决定 <span>{pendingCount}</span></button>
        <button type="button" data-filter="ai">AI 提案 <span data-ai-count>0</span></button>
        <button type="button" data-filter="paused">已暂缓</button>
        <button type="button" data-filter="ignored">已忽略</button>
      </nav>

      <div class="workbench-layout">
        <section class="decision-column" aria-label="决定队列">
          <article
            class="focus-card is-selected"
            data-decision-item
            data-id={focus.id}
            data-state={focus.state}
            data-source={focus.source}
            data-title={focus.title}
            data-summary={focus.summary}
            data-evidence={focus.evidence}
            data-evidence-title={focus.evidenceTitle}
            data-evidence-body={focus.evidenceBody}
            data-action={focus.action}
            data-href={focus.href}
            tabindex="0"
          >
            <div class="focus-topline">
              <span class="focus-label"><Icon name={`lucide:${focus.icon}`} width={16} height={16} />当前焦点 · {focus.source}</span>
              <span class="status-pill">待你决定</span>
            </div>
            <h2>{focus.title}</h2>
            <p>{focus.summary}</p>
            <button class="evidence-link" type="button" data-evidence-focus><Icon name="lucide:paperclip" width={14} height={14} />{focus.evidence}</button>
            <div class="focus-actions">
              <button class="primary-action" type="button" data-start-decision>开始处理</button>
              <button type="button" data-pause>暂缓</button>
              <button class="icon-action" type="button" aria-label="更多操作" data-more><Icon name="lucide:ellipsis" width={20} height={20} /></button>
            </div>
          </article>

          <section class="decision-confirm" data-decision-confirm hidden>
            <div class="confirm-head">
              <span><Icon name="lucide:shield-check" width={17} height={17} />执行前确认</span>
              <button type="button" aria-label="关闭" data-confirm-close><Icon name="lucide:x" width={17} height={17} /></button>
            </div>
            <div class="confirm-grid">
              <div><small>将要做什么</small><strong data-confirm-action>建立一个可验证的处理任务</strong></div>
              <div><small>影响范围</small><strong>仅后台草稿，不自动发布</strong></div>
              <div><small>如何撤回</small><strong>执行结束前可随时取消</strong></div>
            </div>
            <label><input type="checkbox" data-confirm-check />我已检查证据，允许 AI 按步骤生成草稿</label>
            <button class="confirm-submit" type="button" data-confirm-submit disabled>确认并执行</button>
          </section>

          <section class="execution-card" data-execution hidden aria-live="polite">
            <div class="execution-head">
              <span><Icon name="lucide:loader-circle" width={17} height={17} data-spinner />当前会话正在执行</span>
              <button type="button" data-stop-execution>停止</button>
            </div>
            <ol>
              <li data-step="0"><i></i><span>读取当前事项与关联证据</span><small>等待</small></li>
              <li data-step="1"><i></i><span>生成可编辑的行动草稿</span><small>等待</small></li>
              <li data-step="2"><i></i><span>建立结果验证条件</span><small>等待</small></li>
            </ol>
          </section>

          <div class="queue-label"><span>接下来</span><small>选择任意事项查看具体证据</small></div>
          <div class="decision-queue" data-decision-list>
            {queue.slice(1).map(item => (
              <article
                class="queue-item"
                data-decision-item
                data-id={item.id}
                data-state={item.state}
                data-source={item.source}
                data-title={item.title}
                data-summary={item.summary}
                data-evidence={item.evidence}
                data-evidence-title={item.evidenceTitle}
                data-evidence-body={item.evidenceBody}
                data-action={item.action}
                data-href={item.href}
                tabindex="0"
              >
                <span class="queue-icon"><Icon name={`lucide:${item.icon}`} width={18} height={18} /></span>
                <div><small>{item.source}</small><h3>{item.title}</h3><p>{item.evidence}</p></div>
                <Icon name="lucide:chevron-right" width={18} height={18} />
              </article>
            ))}
            <template data-ai-template>
              <article class="queue-item" data-decision-item data-state="ai" tabindex="0">
                <span class="queue-icon"><Icon name="lucide:sparkles" width={18} height={18} /></span>
                <div><small>AI 提案 · 未保存</small><h3></h3><p>来自命令栏 · 等待你检查</p></div>
                <Icon name="lucide:chevron-right" width={18} height={18} />
              </article>
            </template>
            <div class="queue-empty" data-queue-empty hidden>
              <Icon name="lucide:inbox" width={24} height={24} />
              <strong>这个状态下还没有事项</strong>
              <span>命令栏生成的草稿会出现在“AI 提案”中。</span>
            </div>
          </div>
        </section>

        <aside class="decision-detail" data-detail-panel>
          <div class="detail-head">
            <span class="detail-source" data-detail-source>{focus.source}</span>
            <button type="button" aria-label="收起详情" data-detail-close><Icon name="lucide:x" width={19} height={19} /></button>
          </div>
          <h2 data-detail-title>{focus.title}</h2>
          <div class="detail-tabs">
            <button class="is-active" type="button" data-detail-tab="why">为什么现在</button>
            <button type="button" data-detail-tab="evidence">原始证据</button>
            <button type="button" data-detail-tab="next">下一步</button>
          </div>
          <div class="detail-view" data-detail-view="why">
            <p data-detail-summary>{focus.summary}</p>
            <ul>
              <li><Icon name="lucide:check-circle-2" width={16} height={16} /><span>来源已标明，不把站主判断伪装成用户需求</span></li>
              <li><Icon name="lucide:check-circle-2" width={16} height={16} /><span>必须由你确认后，才进入执行步骤</span></li>
              <li><Icon name="lucide:check-circle-2" width={16} height={16} /><span>执行只生成草稿，不自动发布或删除</span></li>
            </ul>
          </div>
          <div class="detail-view" data-detail-view="evidence" hidden>
            <div class="evidence-card" data-evidence-card>
              <span data-detail-evidence-title>{focus.evidenceTitle}</span>
              <blockquote data-detail-evidence-body>{focus.evidenceBody}</blockquote>
              <small data-detail-evidence>{focus.evidence}</small>
            </div>
          </div>
          <div class="detail-view" data-detail-view="next" hidden>
            <ol class="next-steps">
              <li><i>1</i><span>确认问题是否真实且值得处理</span></li>
              <li><i>2</i><span>让 AI 生成内容、功能或验证任务草稿</span></li>
              <li><i>3</i><span>你检查并授权，再进入真实执行</span></li>
            </ol>
          </div>
          <div class="detail-footer">
            <button class="detail-primary" type="button" data-detail-start>{focus.action}</button>
            <a href={focus.href} data-detail-href>打开原始记录<Icon name="lucide:arrow-up-right" width={14} height={14} /></a>
          </div>
        </aside>
      </div>

      <p class="truth-note"><Icon name="lucide:database" width={13} height={13} />7 天内记录 {stats.totalCases} 条需求；决定/行动/结果存储于 {storageModeLabel}；未采集的数据不会显示成指标。</p>
    </div>
  </AdminLayout>

  <script>
    const root = document.querySelector('[data-workbench]') as HTMLElement | null;
    if (root) {
      const detail = root.querySelector('[data-detail-panel]') as HTMLElement;
      const items = () => [...root.querySelectorAll<HTMLElement>('[data-decision-item]')];
      let selected = root.querySelector<HTMLElement>('[data-decision-item].is-selected') || items()[0];
      let executionTimer: number | undefined;

      const setText = (selector: string, value = '') => {
        const node = root.querySelector(selector);
        if (node) node.textContent = value;
      };

      const selectItem = (item: HTMLElement) => {
        selected?.classList.remove('is-selected');
        item.classList.add('is-selected');
        selected = item;
        const d = item.dataset;
        setText('[data-detail-source]', d.source);
        setText('[data-detail-title]', d.title);
        setText('[data-detail-summary]', d.summary);
        setText('[data-detail-evidence]', d.evidence);
        setText('[data-detail-evidence-title]', d.evidenceTitle);
        setText('[data-detail-evidence-body]', d.evidenceBody);
        setText('[data-detail-start]', d.action || '开始处理');
        setText('[data-confirm-action]', d.action || '建立一个可验证的处理任务');
        const href = root.querySelector<HTMLAnchorElement>('[data-detail-href]');
        if (href) href.href = d.href || '#';
        detail.hidden = false;
        detail.animate([{ opacity: .55, transform: 'translateX(12px)' }, { opacity: 1, transform: 'translateX(0)' }], { duration: 210, easing: 'ease-out' });
      };

      const bindItem = (item: HTMLElement) => {
        item.addEventListener('click', event => {
          if ((event.target as HTMLElement).closest('button, a')) return;
          selectItem(item);
        });
        item.addEventListener('keydown', event => {
          if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); selectItem(item); }
        });
      };
      items().forEach(bindItem);

      root.querySelector('[data-detail-close]')?.addEventListener('click', () => { detail.hidden = true; });
      root.querySelector('[data-evidence-focus]')?.addEventListener('click', () => {
        (root.querySelector('[data-detail-tab="evidence"]') as HTMLButtonElement)?.click();
        detail.animate([{ transform: 'scale(.995)' }, { transform: 'scale(1)' }], { duration: 180 });
      });

      root.querySelectorAll<HTMLButtonElement>('[data-detail-tab]').forEach(button => button.addEventListener('click', () => {
        root.querySelectorAll('[data-detail-tab]').forEach(tab => tab.classList.toggle('is-active', tab === button));
        root.querySelectorAll<HTMLElement>('[data-detail-view]').forEach(view => { view.hidden = view.dataset.detailView !== button.dataset.detailTab; });
      }));

      root.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach(button => button.addEventListener('click', () => {
        root.querySelectorAll('[data-filter]').forEach(tab => tab.classList.toggle('is-active', tab === button));
        const filter = button.dataset.filter;
        let visible = 0;
        items().forEach(item => {
          const show = filter === 'all' || item.dataset.state === filter;
          item.hidden = !show;
          if (show) visible += 1;
        });
        const empty = root.querySelector<HTMLElement>('[data-queue-empty]');
        if (empty) empty.hidden = visible > 0;
      }));

      const confirm = root.querySelector<HTMLElement>('[data-decision-confirm]');
      const openConfirm = () => {
        if (!confirm) return;
        confirm.hidden = false;
        confirm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        confirm.animate([{ opacity: 0, transform: 'translateY(-8px)' }, { opacity: 1, transform: 'translateY(0)' }], { duration: 220, easing: 'ease-out' });
      };
      root.querySelector('[data-start-decision]')?.addEventListener('click', openConfirm);
      root.querySelector('[data-detail-start]')?.addEventListener('click', openConfirm);
      root.querySelector('[data-confirm-close]')?.addEventListener('click', () => { if (confirm) confirm.hidden = true; });
      const check = root.querySelector<HTMLInputElement>('[data-confirm-check]');
      const submit = root.querySelector<HTMLButtonElement>('[data-confirm-submit]');
      check?.addEventListener('change', () => { if (submit) submit.disabled = !check.checked; });

      submit?.addEventListener('click', () => {
        if (confirm) confirm.hidden = true;
        const execution = root.querySelector<HTMLElement>('[data-execution]');
        if (!execution) return;
        execution.hidden = false;
        execution.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 200 });
        const steps = [...execution.querySelectorAll<HTMLElement>('[data-step]')];
        let step = 0;
        steps.forEach(node => { node.className = ''; node.querySelector('small')!.textContent = '等待'; });
        const run = async () => {
          steps.forEach((node, index) => {
            node.classList.toggle('is-done', index < step);
            node.classList.toggle('is-running', index === step);
            node.querySelector('small')!.textContent = index < step ? '完成' : index === step ? '进行中' : '等待';
          });
          if (step >= steps.length) {
            clearInterval(executionTimer);
            // P0-D：完成后把真实 NeedCase 作为证据创建并接受 WorkItem，再创建行动。
            // 失败时明确提示，不伪造"草稿已生成"成功状态。
            setText('.execution-head span', '正在写入工作项…');
            const result = await ensureWorkItemForSelected({ outcome: 'accepted', reason: '确认证据，开始执行' });
            if (!result.ok || !result.workItemId) {
              execution.classList.add('is-complete');
              setText('.execution-head span', `写入失败：${result.error}`);
              return;
            }
            // 创建行动（产出内容/改功能由事项来源决定）
            const d = selected?.dataset;
            const actionType = d?.source === '系统事件' ? 'review-incident' : 'create-content';
            const actionRes = await fetch('/api/admin/actions', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({
                workItemId: result.workItemId,
                actionType,
                targetType: actionType === 'review-incident' ? 'incident' : 'content',
                expectedOutcome: d?.title ? `基于"${d.title}"产出可验证的方案` : '产出可验证的方案',
              }),
            });
            if (!actionRes.ok) {
              const err = await actionRes.json().catch(() => ({}));
              execution.classList.add('is-complete');
              setText('.execution-head span', `行动创建失败：${err.error || actionRes.status}`);
              return;
            }
            execution.classList.add('is-complete');
            if (selected) selected.dataset.workItemId = result.workItemId;
            setText('.execution-head span', '工作项已建立，等待你执行并验证');
          }
          step += 1;
        };
        run();
        executionTimer = window.setInterval(run, 850);
      });

      root.querySelector('[data-stop-execution]')?.addEventListener('click', () => {
        clearInterval(executionTimer);
        const execution = root.querySelector<HTMLElement>('[data-execution]');
        if (execution) execution.hidden = true;
      });

      // P0-D：把真实 NeedCase 作为证据创建 WorkItem 提案（不写 localStorage 业务状态）。
      // 失败时保留当前输入并明确提示，不伪造"已暂缓"成功。
      const ensureWorkItemForSelected = async (decide?: { outcome: 'accepted' | 'paused' | 'rejected'; reason: string }) => {
        if (!selected) return { ok: false as const, error: '未选择事项' };
        const d = selected.dataset;
        const sourceNeedCaseId = (d.id || '').replace(/^need-/, '');
        const isNeedCase = d.id?.startsWith('need-') && sourceNeedCaseId.length > 0;
        const evidenceRefs = isNeedCase ? [{
          evidenceId: `ev_nc_${sourceNeedCaseId}`,
          sourceType: 'need-case' as const,
          sourceId: sourceNeedCaseId,
          occurredAt: new Date().toISOString(),
          summary: d.evidenceBody || d.summary || '原始需求',
          qualityStatus: 'verified-source' as const,
        }] : [];
        // 命令栏 AI 草稿无真实证据，按 hai-razor 只能是 proposal，不允许直接决定。
        if (evidenceRefs.length === 0 && decide) {
          return { ok: false as const, error: '该事项无现实证据，不能直接作出决定。' };
        }
        const queue = d.source === '用户需求' ? 'user-demand'
          : d.source === 'Walker 主张' ? 'walker-thesis'
          : d.source === '系统事件' ? 'system-event' : 'ai-asset';
        const createRes = await fetch('/api/admin/decisions', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            queue,
            title: d.title || '未命名事项',
            summary: d.summary || '',
            priorityBand: 'now',
            evidenceRefs,
            topicId: isNeedCase ? undefined : undefined,
            requestDecision: Boolean(decide),
          }),
        });
        if (!createRes.ok) {
          const err = await createRes.json().catch(() => ({}));
          return { ok: false as const, error: err.error || `创建工作项失败（${createRes.status}）` };
        }
        const created = await createRes.json();
        const workItemId = created.item?.workItemId;
        if (!workItemId) return { ok: false as const, error: '未返回工作项 ID' };
        if (decide) {
          const decideRes = await fetch(`/api/admin/decisions/${workItemId}`, {
            method: 'PATCH',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ decide }),
          });
          if (!decideRes.ok) {
            const err = await decideRes.json().catch(() => ({}));
            return { ok: false as const, error: err.error || `决定失败（${decideRes.status}）`, workItemId };
          }
          const decided = await decideRes.json();
          return { ok: true as const, workItemId, item: decided.item };
        }
        return { ok: true as const, workItemId, item: created.item };
      };

      root.querySelector('[data-pause]')?.addEventListener('click', async () => {
        if (!selected) return;
        const reason = window.prompt('暂缓需要说明复查条件或原因：', '证据不足，暂缓观察');
        if (!reason || !reason.trim()) return; // 取消则不伪造暂缓
        const result = await ensureWorkItemForSelected({ outcome: 'paused', reason: reason.trim() });
        if (!result.ok) {
          window.alert(`暂缓失败：${result.error}\n你的输入已保留，请重试或检查系统状态。`);
          return;
        }
        selected.dataset.state = 'paused';
        selected.dataset.workItemId = result.workItemId;
        selected.classList.add('is-paused');
        setText('.status-pill', '已暂缓');
      });

      const commandForm = root.querySelector<HTMLFormElement>('[data-command-form]');
      const commandPreview = root.querySelector<HTMLElement>('[data-command-preview]');
      commandForm?.addEventListener('submit', event => {
        event.preventDefault();
        const input = commandForm.elements.namedItem('command') as HTMLInputElement;
        const value = input.value.trim();
        if (!value || !commandPreview) return;
        setText('[data-command-title]', value);
        const chips = root.querySelector<HTMLElement>('[data-command-chips]');
        const tags = [value.includes('文章') || value.includes('内容') ? '内容' : value.includes('功能') ? '功能' : '待判断', value.includes('今天') ? '今天' : '未设期限', '需你授权'];
        if (chips) chips.innerHTML = tags.map(tag => `<span>${tag}</span>`).join('');
        commandPreview.hidden = false;
        commandPreview.animate([{ opacity: 0, transform: 'translateY(-8px)' }, { opacity: 1, transform: 'translateY(0)' }], { duration: 200 });
      });
      root.querySelector('[data-command-cancel]')?.addEventListener('click', () => { if (commandPreview) commandPreview.hidden = true; });
      root.querySelector('[data-command-keep]')?.addEventListener('click', () => {
        if (!commandPreview || !commandForm) return;
        const command = (commandForm.elements.namedItem('command') as HTMLInputElement).value.trim();
        commandPreview.hidden = true;
        const count = root.querySelector('[data-ai-count]');
        if (count) count.textContent = '1';
        const existing = root.querySelector<HTMLElement>('[data-id="ai-command-draft"]');
        const template = root.querySelector<HTMLTemplateElement>('[data-ai-template]');
        const draft = existing || template?.content.firstElementChild?.cloneNode(true) as HTMLElement | undefined;
        if (draft && !existing) {
          draft.dataset.id = 'ai-command-draft';
          draft.dataset.source = 'AI 提案 · 未保存';
          draft.dataset.state = 'ai';
          draft.dataset.evidence = '0 条现实证据 · 来自你的命令';
          draft.dataset.evidenceTitle = '生成依据';
          draft.dataset.evidenceBody = `命令：${command}`;
          draft.dataset.action = '检查提案';
          draft.dataset.href = '/admin';
          root.querySelector('[data-decision-list]')?.insertBefore(draft, root.querySelector('[data-queue-empty]'));
          bindItem(draft);
        }
        if (draft) {
          draft.dataset.title = command;
          draft.dataset.summary = 'AI 只把你的自然语言整理成待检查的行动草稿；它尚未引用现实证据，也没有写入后台。选择"检查提案"后，需绑定真实证据才能创建正式工作项。';
          const title = draft.querySelector('h3');
          if (title) title.textContent = command;
          selectItem(draft);
        }
        // P0-D：AI 命令草稿无真实证据，按 hai-razor 只能是 proposal，且必须在绑定证据后才持久化。
        // 这里不再写 localStorage 伪造持久化；草稿仅停留在当前会话，刷新后清空。
      });
    }
  </script>
</body>
</html>

