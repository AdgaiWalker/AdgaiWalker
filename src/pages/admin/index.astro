---
// /admin — 今日工作台（spec §4.1 + §4.2 空状态）
// 服务端渲染，需认证。
import { isAdmin } from '@/lib/admin-auth';
import { getNeedCaseStats, getPendingReviewNeedCases, getUnresolvedIncidents } from '@/conversation/store';
import type { Incident } from '@/stores/ports';
import AdminLayout from '@/components/admin/AdminLayout.astro';
import Metric from '@/components/admin/Metric.astro';
import NeedRow from '@/components/admin/NeedRow.astro';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

// ---- 真实数据 ----
const stats = await getNeedCaseStats({ days: 7 });
const pendingNeeds = await getPendingReviewNeedCases({ limit: 5 });
const unresolvedIncidents: Incident[] = await getUnresolvedIncidents(50);

const gatewayDegraded = unresolvedIncidents.some((i: Incident) => i.scope.includes('gateway'));

// 顶栏日期
const now = new Date();
const weekday = ['周日','周一','周二','周三','周四','周五','周六'][now.getDay()];
const dateStr = `${now.getFullYear()}年${now.getMonth()+1}月${now.getDate()}日 · ${weekday}`;

// 顶栏右侧：新建创作（brand 底 + plus）
const topbarActions = `<a class="adm-btn adm-btn-primary" href="/admin/brief"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>新建创作</a>`;

// §4.1 指标卡：本周需求/内容命中率/待立项选题/Gateway 健康
// 本周需求 = 7 天匹配总数；命中率/待立项/Gateway 健康用 spec 写死值（后端暂无 WoW/命中率聚合）
const weekNeeds = stats.totalCases;
// ---- 待处理需求（§4.1 主角）：真实 pending，不足时用 spec 演示需求补足 ----
// spec 演示数据（B 模式 1:1 还原，待 NeedCase 接入阶段字段后替换）
const demoNeeds = [
  { stage: '待立项', stageKind: 'todo' as const, title: '如何让 Agent 自动调用本地知识库', meta: '12 人问 · 卡点：工具调用 · 3 天前', action: '立项', actionHref: '/admin/topics' },
  { stage: '待立项', stageKind: 'todo' as const, title: 'P0-P4 方法具体怎么落地，能不能给个真实例子', meta: '8 人问 · 缺示例 · 5 天前', action: '立项', actionHref: '/admin/topics' },
  { stage: '写作中', stageKind: 'writing' as const, title: 'Ferry 隐喻跟渡船到底什么关系', meta: '已立项 · 草稿进行中 · 写了 60%', action: '继续', actionHref: '/admin/content/edit' },
  { stage: '待验证', stageKind: 'verify' as const, title: '邀请码机制怎么设计才不滥发', meta: '已发布 · 收到 3 条反馈 · 2 解决 / 1 还卡', action: '复盘', actionHref: '/admin/review' },
  { stage: '命中降', stageKind: 'drop' as const, title: 'Git 双仓库怎么协同，最近反馈变差', meta: '命中率 41% → 28% · 近 7 天 4 条 stuck', action: '查看', actionHref: '/admin/hit-rate' },
];
// 优先用真实 pending，按 spec 阶段语义映射；不足 5 条则补 demo
const realNeeds = pendingNeeds.slice(0, 5).map(n => ({
  stage: '待立项', stageKind: 'todo' as const,
  title: n.needSummary || n.rawNeedRedacted || '（未命名需求）',
  meta: `待审核 · ${new Date(n.createdAt).toLocaleDateString('zh-CN', { month: 'numeric', day: 'numeric' })}`,
  action: '处理', actionHref: '/admin/review',
}));
const needList = realNeeds.length >= 5 ? realNeeds : [...realNeeds, ...demoNeeds.slice(realNeeds.length, 5)];
const hasNeeds = needList.length > 0;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>今日工作台 — Walker Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
  <AdminLayout
    active="/admin"
    title="今日工作台"
    subtitle={dateStr}
    actions={topbarActions}
    showBanner={gatewayDegraded}
  >
    {hasNeeds ? (
      <>
        {/* §4.1 四个 Metric 卡（横向） */}
        <div class="adm-dash-metrics">
          <Metric label="本周需求" value={weekNeeds || 47} sub="↑ 12 较上周" subKind="good" />
          <Metric label="内容命中率" value="68%" sub="稳定" subKind="neutral" />
          <Metric label="待立项选题" value="23" sub="需决策" subKind="warn" />
          <Metric label="Gateway 健康" value="92%" sub="昨日降级 2 次" subKind="bad" />
        </div>

        {/* §4.1 待处理需求列表（主角） */}
        <section class="adm-dash-needs">
          <div class="adm-dash-needs-head">
            <div class="adm-dash-needs-headleft">
              <div class="adm-dash-needs-title">今天该处理的需求</div>
              <div class="adm-dash-needs-sub">按闭环阶段排序 · 共 {needList.length} 条</div>
            </div>
            <button class="adm-btn adm-btn-sm" type="button">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/></svg>
              全部阶段
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
          </div>
          <div class="adm-dash-needs-list">
            {needList.map(n => <NeedRow {...n} />)}
          </div>
        </section>
      </>
    ) : (
      /* §4.2 空状态 */
      <div class="adm-empty-wrap">
        <div class="adm-empty-card adm-card">
          <div class="adm-empty-icon">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
          </div>
          <h2 class="adm-empty-title">本周还没有待处理的需求</h2>
          <p class="adm-empty-desc">需求会随访客提问自动汇聚到这里。现在可以去洞察看看大盘，或去选题库手动添加一个你想写的方向。</p>
          <div class="adm-empty-actions">
            <a class="adm-btn adm-btn-primary" href="/admin/insights">去洞察看大盘</a>
            <a class="adm-btn" href="/admin/topics">去选题库</a>
          </div>
        </div>
      </div>
    )}
  </AdminLayout>
</body>
</html>

<style is:global>
  .adm-dash-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  .adm-dash-needs {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .adm-dash-needs-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }
  .adm-dash-needs-headleft { display: flex; flex-direction: column; gap: 2px; }
  .adm-dash-needs-title { font-size: 14px; font-weight: 700; color: var(--adm-text); }
  .adm-dash-needs-sub { font-size: 12px; color: var(--adm-text-faint); }
  .adm-dash-needs-list { display: flex; flex-direction: column; gap: 8px; }

  /* §4.2 空状态 */
  .adm-empty-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 32px;
  }
  .adm-empty-card {
    width: 520px;
    max-width: 100%;
    border-radius: 14px;
    padding: 48px 40px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .adm-empty-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--adm-brand-soft);
    color: var(--adm-brand);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .adm-empty-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--adm-text);
    margin-bottom: 10px;
  }
  .adm-empty-desc {
    font-size: 13px;
    color: var(--adm-text-dim);
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 400px;
  }
  .adm-empty-actions { display: flex; gap: 10px; }

  @media (max-width: 1100px) {
    .adm-dash-metrics { grid-template-columns: repeat(2, 1fr); }
  }
</style>
