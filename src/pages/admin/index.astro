        <span data-demo-status role="status" aria-live="polite"></span>
      </section>}
    </div>
  </AdminLayout>

  <script>
    import { registerLifecycle } from '@/scripts/with-lifecycle';
    import { mountWorkbench } from '@/scripts/workbench-shell';

    registerLifecycle(() => {
      const root = document.querySelector<HTMLElement>('[data-workbench]');
      if (!root) return;
      return mountWorkbench(root);
    });
  </script>

