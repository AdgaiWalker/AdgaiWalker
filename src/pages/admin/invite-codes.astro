---
/**
 * /admin/invite-codes — 邀请码管理（admin+owner 看，owner 生成/禁用/删）
 *
 * 列表 + 生成表单（一人一码为默认）+ 禁用/删除。生成后码仅显示一次。
 */
import AdminLayout from '@/components/admin/AdminLayout.astro';
import { isAdmin } from '@/lib/admin-auth';
import { readSessionPayload } from '@/lib/account-auth';

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/login');
}

const canManage = readSessionPayload(Astro.request)?.role === 'owner';

interface CodeView {
  code: string;
  label: string;
  maxUses: number;
  usedCount: number;
  createdAt: string;
  createdBy: string;
  status: 'active' | 'disabled';
  usedBy: string[];
}

const origin = Astro.url.origin;
let codes: CodeView[] = [];
try {
  const res = await fetch(`${origin}/api/admin/invite-codes`, {
    headers: { cookie: Astro.request.headers.get('cookie') ?? '' },
  });
  if (res.ok) {
    const data = await res.json() as { codes: CodeView[] };
    codes = data.codes.sort((a, b) => b.createdAt.localeCompare(a.createdAt));
  }
} catch {
  /* 降级空列表 */
}
---

<Base title="邀请码管理 — iwalk.pro">
  <main class="ic-wrap">
    <header class="ic-head">
      <h1>邀请码管理</h1>
      <a class="back" href="/admin">← 返回后台</a>
    </header>

    {canManage && (
      <section class="panel-glass card gen-card">
        <h2>生成邀请码</h2>
        <p class="hint">默认<b>一人一码</b>（count 个码、每个 1 次）；改 maxUses > 1 为共享码。</p>
        <form id="gen-form" class="gen-form">
          <label class="field">
            <span>标签</span>
            <input name="label" placeholder="如：知乎粉丝-6月" />
          </label>
          <label class="field">
            <span>数量（码个数）</span>
            <input name="count" type="number" min="1" max="500" value="1" />
          </label>
          <label class="field">
            <span>每码可用次数</span>
            <input name="maxUses" type="number" min="1" value="1" />
          </label>
          <button class="btn primary" type="submit">生成</button>
        </form>
        <div id="gen-result" class="gen-result" hidden></div>
      </section>
    )}

    <section class="panel-glass card">
      <h2>邀请码列表（{codes.length}）</h2>
      {codes.length === 0 ? (
        <p class="muted">还没有后台生成的邀请码。</p>
      ) : (
        <div class="table-scroll">
          <table class="ic-table">
            <thead>
              <tr><th>邀请码</th><th>标签</th><th>已用/总量</th><th>状态</th><th>创建者</th><th>创建时间</th><th>使用者</th>{canManage && <th>操作</th>}</tr>
            </thead>
            <tbody>
              {codes.map((c) => (
                <tr data-code={c.code}>
                  <td class="mono code-cell">{c.code}</td>
                  <td>{c.label}</td>
                  <td>{c.usedCount}/{c.maxUses}</td>
                  <td><span class={`badge ${c.status === 'active' ? 'st-active' : 'st-disabled'}`}>{c.status === 'active' ? '有效' : '已禁用'}</span></td>
                  <td class="muted">{c.createdBy}</td>
                  <td class="muted">{c.createdAt?.slice(0, 10)}</td>
                  <td class="muted">{c.usedBy.length > 0 ? c.usedBy.join('、') : '-'}</td>
                  {canManage && (
                    <td class="actions">
                      {c.status === 'active' && <button class="mini" data-action="disable">禁用</button>}
                      <button class="mini danger" data-action="delete">删除</button>
                    </td>
                  )}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </main>
</AdminLayout>

<style>
  .ic-wrap { max-width: 1180px; margin: 0 auto; display: flex; flex-direction: column; gap: 1.25rem; }
  .ic-head { display: flex; align-items: center; justify-content: space-between; }
  .ic-head h1 { font-size: 1.4rem; margin: 0; color: var(--color-parchment, #1a2325); }
  .back { color: var(--color-parchment-dim, #64748b); text-decoration: none; font-size: 0.9rem; }
  .card { padding: 1.25rem 1.4rem; border: 1px solid var(--adm-border); border-radius: var(--adm-radius-card); background: var(--adm-surface); box-shadow: 0 16px 46px rgba(39,62,58,.08); }
  .card h2 { margin: 0 0 0.8rem; font-size: 1rem; color: var(--color-parchment, #1a2325); }
  .hint { margin: 0 0 0.8rem; font-size: 0.78rem; color: var(--color-parchment-dim, #888); }
  .gen-form { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: flex-end; }
  .field { display: flex; flex-direction: column; gap: 0.25rem; }
  .field > span { font-size: 0.75rem; color: var(--color-parchment-dim, #64748b); font-weight: 600; }
  .field input { padding: 0.45rem 0.6rem; border-radius: 8px; border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent); background: color-mix(in srgb, var(--color-parchment, #1a2325) 4%, transparent); color: var(--color-parchment, #1a2325); font-size: 0.85rem; width: 160px; }
  .gen-result { margin-top: 1rem; padding: 0.8rem; border-radius: 8px; background: color-mix(in srgb, var(--color-parchment, #1a2325) 5%, transparent); }
  .gen-result-title { font-size: 0.82rem; color: var(--color-parchment, #1a2325); font-weight: 700; margin-bottom: 0.4rem; }
  .gen-code-line { font-family: var(--font-mono, monospace); font-size: 0.9rem; color: var(--color-brand, #35bfab); padding: 0.2rem 0; cursor: pointer; }
  .gen-code-line:hover { text-decoration: underline; }
  .table-scroll { overflow-x: auto; }
  .ic-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  .ic-table th, .ic-table td { padding: 0.55rem 0.6rem; text-align: left; border-bottom: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 10%, transparent); white-space: nowrap; }
  .ic-table th { color: var(--color-parchment-dim, #64748b); font-weight: 500; }
  .mono { font-family: var(--font-mono, monospace); }
  .code-cell { color: var(--color-brand, #35bfab); }
  .muted { color: var(--color-parchment-dim, #888); font-size: 0.8rem; }
  .badge { padding: 0.1rem 0.45rem; border-radius: 999px; font-size: 0.7rem; font-weight: 600; }
  .st-active { background: rgba(72,199,116,0.18); color: #48c774; }
  .st-disabled { background: rgba(148,163,184,0.18); color: #94a3b8; }
  .actions { display: flex; gap: 0.3rem; }
  .btn { padding: 0.5rem 0.9rem; border-radius: 8px; border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent); background: transparent; color: var(--color-parchment, #1a2325); cursor: pointer; font-size: 0.85rem; font-weight: 600; }
  .btn.primary { background: var(--color-brand, #35bfab); color: #fff; border-color: transparent; }
  .mini { padding: 0.25rem 0.55rem; border-radius: 6px; border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent); background: transparent; color: var(--color-parchment, #1a2325); cursor: pointer; font-size: 0.75rem; }
  .mini:hover { border-color: var(--color-brand, #35bfab); color: var(--color-brand, #35bfab); }
  .mini.danger { color: #ef4444; border-color: #ef4444; }
</style>

<script>
  import { registerLifecycle } from '@/scripts/with-lifecycle';

  registerLifecycle(() => {
    const genForm = document.querySelector<HTMLFormElement>('#gen-form');
    const genResult = document.getElementById('gen-result');
    const ask = (message: string, title = '确认邀请码操作') => window.WalkerAdminUI?.confirm({ title, message, tone: 'danger', confirmText: '确认执行' }) ?? Promise.resolve(false);
    const tell = (message: string, title = '操作结果') => window.WalkerAdminUI?.notify({ title, message }) ?? Promise.resolve();

    genForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(genForm).entries());
      const btn = genForm.querySelector<HTMLButtonElement>('button[type=submit]');
      if (btn) btn.disabled = true;
      try {
        const res = await fetch('/api/admin/invite-codes', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        const json = await res.json();
        if (res.ok && json.ok && genResult) {
          genResult.innerHTML = '<div class="gen-result-title">已生成（仅显示一次，点击复制）：</div>' + json.codes.map((c: string) => `<div class="gen-code-line" data-code="${c}">${c}</div>`).join('');
          genResult.hidden = false;
        } else {
          await tell(json.reason || '生成失败');
        }
      } catch { await tell('网络错误'); }
      finally { if (btn) btn.disabled = false; }
    });

    genResult?.addEventListener('click', (e) => {
      const line = (e.target as HTMLElement).closest('.gen-code-line') as HTMLElement | null;
      if (line?.dataset.code) {
        navigator.clipboard.writeText(line.dataset.code).then(() => { line.textContent = line.dataset.code + ' ✓'; });
      }
    });

    document.querySelectorAll<HTMLTableSectionElement>('tbody').forEach((tbody) => {
      tbody.addEventListener('click', async (e) => {
        const target = e.target as HTMLButtonElement;
        if (target.tagName !== 'BUTTON') return;
        const row = target.closest('tr');
        if (!row) return;
        const code = row.dataset.code ?? '';
        const action = target.dataset.action;
        if (action === 'disable') {
          if (!(await ask(`确定禁用 ${code}？已发放的仍有效，但不能新用。`))) return;
          const res = await fetch('/api/admin/invite-codes/disable', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code }) });
          if (res.ok) window.location.reload(); else { const j = await res.json(); await tell(j.reason || '失败'); }
        } else if (action === 'delete') {
          if (!(await ask(`确定删除 ${code}？删除后不能用于新访问。`))) return;
          const res = await fetch('/api/admin/invite-codes', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code }) });
          if (res.ok) window.location.reload(); else { const j = await res.json(); await tell(j.reason || '失败'); }
        }
      });
    });
  });
</script>
