---
import AdminLayout from '@/components/admin/AdminLayout.astro';
// /admin/hit-rate — 内容命中率仪表盘，需认证
import { isAdmin } from '@/lib/admin-auth';
import { getRecentNeedCases, getTopicCandidates, findRecentContentFeedback } from '@/conversation/store';
import { getPublishedContentItems } from '@/knowledge/content';
import {
  buildContentOutcomeSummaries,
  calculateContentHitRates,
  getLikeLeaderboard,
  FEEDBACK_LABEL,
  FEEDBACK_DIMENSIONS,
} from '@/services/hit-rate.service';
import type { ContentFeedbackEvent } from '@/stores/ports';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const view = Astro.url.searchParams.get('view') === 'popular'
  ? 'popular'
  : Astro.url.searchParams.get('view') === 'outcome'
    ? 'outcome'
    : 'matrix';

const [contents, topics, needCases, likeLeaderboard, contentFeedback] = await Promise.all([
  getPublishedContentItems(),
  getTopicCandidates({ limit: 500 }),
  getRecentNeedCases(2000),
  getLikeLeaderboard(100),
  findRecentContentFeedback(undefined, 2000),
]);

const hitRates = calculateContentHitRates({ contents, topics, needCases });

// P1-C02：双信号结果分组 —— matchOutcome（需求匹配）与 contentOutcome（内容阅读）分开，不合并分母
const contentFeedbackByContent = new Map<string, ContentFeedbackEvent[]>();
for (const fb of contentFeedback) {
  const list = contentFeedbackByContent.get(fb.contentId) ?? [];
  list.push(fb);
  contentFeedbackByContent.set(fb.contentId, list);
}
const outcomeSummaries = buildContentOutcomeSummaries({
  contents,
  topics,
  needCases,
  contentFeedbackByContent,
});
const CONTENT_FEEDBACK_LABEL: Record<ContentFeedbackEvent['signal'], string> = {
  useful: '有用',
  'needs-more': '需补充',
  outdated: '已过时',
};
// 有反馈的数据排前（service 已排序），取有任意信号的
const summariesWithSignal = outcomeSummaries.filter(
  s => s.matchOutcome.responded > 0 || s.contentOutcome.totalFeedback > 0,
);

// 点赞排行 path → 内容标题映射
const contentByHref = new Map(contents.map(c => [c.href, c]));
---

<AdminLayout active="/admin/hit-rate" domain="creation" title="内容命中" subtitle="区分已解决、部分解决、卡住与尚无信号">
<style>
    .hit-list { display: grid; gap: 0.75rem; }
    .hit-row { border: 1px solid rgba(0,0,0,0.06); border-radius: 12px; background: #fff; padding: 1rem; }
    .hit-head { display: flex; justify-content: space-between; gap: 1rem; align-items: flex-start; margin-bottom: 0.7rem; }
    .hit-title { color: var(--adm-text); text-decoration: none; font-size: 0.98rem; font-weight: 850; line-height: 1.45; }
    .hit-title:hover { color: var(--adm-brand-strong); }
    .hit-rate { color: #065f46; font-size: 0.9rem; font-weight: 850; white-space: nowrap; }
    .hit-rate.empty { color: var(--adm-text-faint); }
    .hit-bar { display: flex; height: 0.7rem; overflow: hidden; border-radius: 999px; background: #e7e5e4; margin-bottom: 0.65rem; }
    .hit-bar-resolved { background: #16a34a; }
    .hit-bar-stuck { background: #f59e0b; }
    .hit-meta { display: flex; gap: 0.5rem; flex-wrap: wrap; color: var(--adm-text-dim); font-size: 0.75rem; }
    .hit-chip { padding: 0.18rem 0.5rem; border-radius: 999px; background: #f5f5f4; color: #57534e; font-weight: 750; }
    .empty { text-align: center; padding: 3rem 1rem; color: var(--adm-text-faint); border: 1px dashed rgba(0,0,0,0.08); border-radius: 12px; background: #fff; }
    .view-switch { display: inline-flex; gap: 0.3rem; padding: 0.25rem; margin-bottom: 1.25rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 10px; background: #fff; flex-wrap: wrap; }
    .view-switch a { padding: 0.4rem 0.7rem; border-radius: 8px; color: var(--adm-text-dim); text-decoration: none; font-size: 0.78rem; font-weight: 750; }
    .view-switch a.active { background: rgba(53,191,171,0.1); color: var(--adm-brand-strong); }
    .hit-chip.dim { background: rgba(124,58,237,0.08); color: #7c3aed; }
    .lb-list { display: grid; gap: 0.5rem; }
    .lb-row { display: flex; align-items: center; gap: 0.8rem; padding: 0.65rem 0.9rem; border: 1px solid rgba(0,0,0,0.06); border-radius: 10px; background: #fff; }
    .lb-rank { width: 1.6rem; text-align: center; font-weight: 850; color: var(--adm-text-faint); font-family: 'JetBrains Mono', monospace; flex-shrink: 0; }
    .lb-rank.top { color: var(--adm-brand-strong); }
    .lb-title { flex: 1; color: var(--adm-text); text-decoration: none; font-size: 0.9rem; font-weight: 700; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .lb-title:hover { color: var(--adm-brand-strong); }
    .lb-count { font-weight: 850; color: var(--adm-brand-strong); font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; flex-shrink: 0; }
    .lb-path { font-size: 0.7rem; color: var(--adm-text-faint); font-family: 'JetBrains Mono', monospace; flex-shrink: 0; }
    /* P1-C02：双信号结果分组 —— 需求匹配与内容阅读分开解释 */
    .outcome-groups { display: grid; gap: 0.6rem; margin-bottom: 0.5rem; }
    .outcome-group { padding: 0.6rem 0.75rem; border-radius: 8px; background: transparent; border: 1px solid rgba(0,0,0,0.04); }
    .outcome-label { font-size: 0.7rem; font-weight: 750; color: #57534e; margin-bottom: 0.4rem; }
    .outcome-body { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
    .outcome-null { font-size: 0.78rem; color: var(--adm-text-faint); }
    .feedback-details { margin-top: 0.65rem; border: 1px solid rgba(0,0,0,0.06); border-radius: 10px; background: #fff; overflow: hidden; }
    .feedback-details summary { cursor: pointer; padding: 0.65rem 0.8rem; color: #57534e; font-size: 0.78rem; font-weight: 800; list-style-position: inside; }
    .feedback-details[open] summary { border-bottom: 1px solid rgba(0,0,0,0.05); }
    .feedback-privacy { padding: 0 0.8rem 0.65rem; color: var(--adm-text-faint); font-size: 0.72rem; line-height: 1.6; }
    .feedback-list { display: grid; gap: 0.5rem; padding: 0 0.8rem 0.8rem; }
    .feedback-item { padding: 0.65rem; border-radius: 8px; background: transparent; border: 1px solid rgba(0,0,0,0.04); }
    .feedback-item-head { display: flex; gap: 0.45rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.35rem; }
    .feedback-note { color: #44403c; font-size: 0.8rem; line-height: 1.6; white-space: pre-wrap; overflow-wrap: anywhere; }
    .feedback-note.empty-note { color: var(--adm-text-faint); }
    @media (max-width: 760px) {
      .hit-head { flex-direction: column; }
      .lb-row { flex-wrap: wrap; }
      .lb-path { order: 5; width: 100%; }
    }
  </style>
<div class="adm-page">
    <section class="adm-page-welcome">
      <h1>内容反馈台</h1>
      <p>已发布内容的服务反馈全景：哪些真解决了问题，哪些还让人卡着，哪些更受点赞。</p>
    </section>

    <nav class="view-switch" aria-label="反馈视图">
      <a href="/admin/hit-rate?view=matrix" class={view === 'matrix' ? 'active' : ''}>反馈矩阵（{hitRates.length}）</a>
      <a href="/admin/hit-rate?view=outcome" class={view === 'outcome' ? 'active' : ''}>双信号结果（{summariesWithSignal.length}）</a>
      <a href="/admin/hit-rate?view=popular" class={view === 'popular' ? 'active' : ''}>热门内容（{likeLeaderboard.length}）</a>
    </nav>

    {view === 'matrix' ? (
      hitRates.length === 0 ? (
        <div class="empty">还没有内容与需求簇形成可统计关联。先在选题池采纳选题、生成内容，再回看反馈。</div>
      ) : (
        <section class="hit-list">
          {hitRates.map(row => {
            const resolvedPct = row.feedbackGiven > 0 ? Math.round((row.resolved / row.feedbackGiven) * 100) : 0;
            const stuckPct = row.feedbackGiven > 0 ? Math.round((row.stuck / row.feedbackGiven) * 100) : 0;
            const dims = FEEDBACK_DIMENSIONS.filter(d => (row.feedbackBreakdown[d] ?? 0) > 0);
            return (
              <article class="hit-row">
                <div class="hit-head">
                  <a class="hit-title" href={row.href}>{row.title}</a>
                  <div class={`hit-rate ${row.rate === null ? 'empty' : ''}`}>{row.rate === null ? '暂无反馈' : `${row.rate}% resolved`}</div>
                </div>
                <div class="hit-bar" aria-label={`resolved ${row.resolved}, stuck ${row.stuck}`}>
                  <div class="hit-bar-resolved" style={`width:${resolvedPct}%`} />
                  <div class="hit-bar-stuck" style={`width:${stuckPct}%`} />
                </div>
                <div class="hit-meta">
                  <span class="hit-chip">resolved {row.resolved}</span>
                  <span class="hit-chip">stuck {row.stuck}</span>
                  <span class="hit-chip">反馈 {row.feedbackGiven}</span>
                  <span class="hit-chip">需求样本 {row.totalCases}</span>
                  {dims.map(d => <span class="hit-chip dim">{FEEDBACK_LABEL[d]} {row.feedbackBreakdown[d]}</span>)}
                  <span class="hit-chip">关联簇 {row.topicTitles.slice(0, 2).join(' / ')}</span>
                </div>
              </article>
            );
          })}
        </section>
      )
    ) : view === 'outcome' ? (
      // P1-C02：双信号结果分组 —— 需求匹配结果与内容阅读结果分开解释，缺失数据不显示为 0%
      summariesWithSignal.length === 0 ? (
        <div class="empty">还没有匹配反馈或内容反馈。访客在内容页提交"有用 / 需补充 / 已过时"后，这里会按内容分开显示两类结果。</div>
      ) : (
        <section class="hit-list">
          {summariesWithSignal.map(summary => (
            <article class="hit-row">
              {(() => {
                const feedbackList = contentFeedbackByContent.get(summary.contentId) ?? [];
                return (
                  <>
              <div class="hit-head">
                <a class="hit-title" href={summary.href}>{summary.title}</a>
                {summary.hasSourceTopic
                  ? <span class="hit-chip">关联选题 {summary.sourceTopicIds.length}</span>
                  : <span class="hit-chip dim">内容未关联来源选题</span>}
              </div>
              <div class="outcome-groups">
                <div class="outcome-group">
                  <div class="outcome-label">需求匹配结果（NeedCase 反馈）</div>
                  <div class="outcome-body">
                    {summary.matchOutcome.rate === null
                      ? <span class="outcome-null">暂无匹配反馈</span>
                      : <span class="hit-rate">{summary.matchOutcome.rate}% 解决</span>}
                    <span class="hit-chip">样本 {summary.matchOutcome.totalCases}</span>
                    <span class="hit-chip">已反馈 {summary.matchOutcome.responded}</span>
                    <span class="hit-chip">解决 {summary.matchOutcome.resolved}</span>
                    <span class="hit-chip">未解决 {summary.matchOutcome.unresolved}</span>
                  </div>
                </div>
                <div class="outcome-group">
                  <div class="outcome-label">内容阅读结果（访客明确反馈）</div>
                  <div class="outcome-body">
                    {summary.contentOutcome.usefulRate === null
                      ? <span class="outcome-null">暂无内容反馈</span>
                      : <span class="hit-rate">{summary.contentOutcome.usefulRate}% 有用</span>}
                    <span class="hit-chip">反馈 {summary.contentOutcome.totalFeedback}</span>
                    <span class="hit-chip">有用 {summary.contentOutcome.useful}</span>
                    <span class="hit-chip">需补充 {summary.contentOutcome.needsMore}</span>
                    <span class="hit-chip">已过时 {summary.contentOutcome.outdated}</span>
                  </div>
                </div>
                <div class="outcome-group">
                  <div class="outcome-label">阅读深度（匿名遥测，P3-A）</div>
                  <div class="outcome-body">
                    {summary.readingOutcome.completionRate === null
                      ? <span class="outcome-null">暂无阅读信号</span>
                      : <span class="hit-rate">{summary.readingOutcome.completionRate}% 读完</span>}
                    <span class="hit-chip">读者 {summary.readingOutcome.uniqueReaders}</span>
                    <span class="hit-chip">读完 {summary.readingOutcome.completed}</span>
                    <span class="hit-chip">有进度 {summary.readingOutcome.withProgressSignal}</span>
                  </div>
                </div>
              </div>
              {summary.timeRange && (
                <div class="hit-meta">
                  <span class="hit-chip">统计范围 {new Date(summary.timeRange.from).toLocaleDateString('zh-CN')} ~ {new Date(summary.timeRange.to).toLocaleDateString('zh-CN')}</span>
                </div>
              )}
              {feedbackList.length > 0 && (
                <details class="feedback-details" data-feedback-details={summary.contentId}>
                  <summary>打开原始反馈列表（{feedbackList.length}）</summary>
                  <p class="feedback-privacy">仅显示服务端已脱敏后的反馈说明；不展示访客身份、IP、联系方式原文或其他私密原始字段。</p>
                  <div class="feedback-list">
                    {feedbackList.map(feedback => (
                      <div class="feedback-item" data-feedback-id={feedback.feedbackId}>
                        <div class="feedback-item-head">
                          <span class="hit-chip">{CONTENT_FEEDBACK_LABEL[feedback.signal]}</span>
                          <span class="hit-chip">{new Date(feedback.createdAt).toLocaleString('zh-CN')}</span>
                          <span class="hit-chip">{feedback.environment}</span>
                          <span class="hit-chip">{feedback.consentForAnalysis ? '可用于分析' : '仅作单条反馈'}</span>
                        </div>
                        {feedback.note
                          ? <p class="feedback-note">{feedback.note}</p>
                          : <p class="feedback-note empty-note">没有补充说明。</p>}
                      </div>
                    ))}
                  </div>
                </details>
              )}
                  </>
                );
              })()}
            </article>
          ))}
        </section>
      )
    ) : (
      likeLeaderboard.length === 0 ? (
        <div class="empty">还没有点赞数据（Redis 未配置或无点赞记录）。点赞会在访问内容页时累加。</div>
      ) : (
        <section class="lb-list">
          {likeLeaderboard.map((item, index) => {
            const content = contentByHref.get(item.path);
            return (
              <div class="lb-row">
                <span class={`lb-rank ${index < 3 ? 'top' : ''}`}>{index + 1}</span>
                <a class="lb-title" href={item.path}>{content?.title ?? item.path}</a>
                <span class="lb-path">{item.path}</span>
                <span class="lb-count">♥ {item.count.toLocaleString()}</span>
              </div>
            );
          })}
        </section>
      )
    )}
  </div>
</AdminLayout>
