---
// /admin/hit-rate — 内容命中率仪表盘，需认证
import { isAdmin } from '@/lib/admin-auth';
import { getRecentNeedCases, getTopicCandidates } from '@/conversation/store';
import { getPublishedContentItems } from '@/knowledge/content';
import { calculateContentHitRates } from '@/services/hit-rate.service';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const [contents, topics, needCases] = await Promise.all([
  getPublishedContentItems(),
  getTopicCandidates({ limit: 500 }),
  getRecentNeedCases(2000),
]);

const hitRates = calculateContentHitRates({ contents, topics, needCases });
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>内容命中率 — Walker</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; background: #fafaf9; color: #1c1917; }
    .admin-bar { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.08); background: #fff; position: sticky; top: 0; z-index: 100; }
    .admin-bar-left { display: flex; align-items: center; gap: 0.75rem; }
    .admin-bar-logo { font-size: 1rem; font-weight: 800; color: #c4704a; }
    .admin-bar-badge { padding: 0.15rem 0.5rem; border-radius: 999px; background: rgba(196,112,74,0.1); color: #c4704a; font-size: 0.68rem; font-weight: 700; }
    .admin-bar-right { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .admin-bar-link { color: #78716c; text-decoration: none; font-size: 0.82rem; font-weight: 650; }
    .admin-bar-link:hover, .admin-bar-link.active { color: #1c1917; }
    .logout-btn { padding: 0.35rem 0.75rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: transparent; color: #78716c; font-size: 0.78rem; font-weight: 650; cursor: pointer; }
    .admin-main { max-width: 62rem; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
    .admin-welcome { margin-bottom: 1.25rem; }
    .admin-welcome h1 { font-size: 1.5rem; font-weight: 850; margin-bottom: 0.35rem; }
    .admin-welcome p { color: #78716c; font-size: 0.88rem; line-height: 1.6; }
    .hit-list { display: grid; gap: 0.75rem; }
    .hit-row { border: 1px solid rgba(0,0,0,0.06); border-radius: 12px; background: #fff; padding: 1rem; }
    .hit-head { display: flex; justify-content: space-between; gap: 1rem; align-items: flex-start; margin-bottom: 0.7rem; }
    .hit-title { color: #1c1917; text-decoration: none; font-size: 0.98rem; font-weight: 850; line-height: 1.45; }
    .hit-title:hover { color: #c4704a; }
    .hit-rate { color: #065f46; font-size: 0.9rem; font-weight: 850; white-space: nowrap; }
    .hit-rate.empty { color: #a8a29e; }
    .hit-bar { display: flex; height: 0.7rem; overflow: hidden; border-radius: 999px; background: #e7e5e4; margin-bottom: 0.65rem; }
    .hit-bar-resolved { background: #16a34a; }
    .hit-bar-stuck { background: #f59e0b; }
    .hit-meta { display: flex; gap: 0.5rem; flex-wrap: wrap; color: #78716c; font-size: 0.75rem; }
    .hit-chip { padding: 0.18rem 0.5rem; border-radius: 999px; background: #f5f5f4; color: #57534e; font-weight: 750; }
    .empty { text-align: center; padding: 3rem 1rem; color: #a8a29e; border: 1px dashed rgba(0,0,0,0.08); border-radius: 12px; background: #fff; }
    @media (max-width: 760px) {
      .admin-bar { flex-direction: column; align-items: flex-start; }
      .admin-main { padding: 1.25rem 1rem 3rem; }
      .hit-head { flex-direction: column; }
    }
  </style>
</head>
<body>
  <div class="admin-bar">
    <div class="admin-bar-left">
      <span class="admin-bar-logo">Walker</span>
      <span class="admin-bar-badge">Admin</span>
    </div>
    <div class="admin-bar-right">
      <a href="/admin" class="admin-bar-link">仪表盘</a>
      <a href="/admin/insights" class="admin-bar-link">洞察</a>
      <a href="/admin/hit-rate" class="admin-bar-link active">命中率</a>
      <a href="/admin/topics" class="admin-bar-link">选题池</a>
      <a href="/admin/review?view=clusters" class="admin-bar-link">需求复盘</a>
      <a href="/" class="admin-bar-link">查看站点</a>
      <button class="logout-btn" id="logout-btn">登出</button>
    </div>
  </div>

  <main class="admin-main">
    <section class="admin-welcome">
      <h1>内容命中率</h1>
      <p>按已发布内容聚合它服务的需求簇反馈。resolved 是真正解决，stuck 是仍然卡住。</p>
    </section>

    {hitRates.length === 0 ? (
      <div class="empty">还没有内容与需求簇形成可统计关联。先在选题池采纳选题、生成内容，再回看反馈。</div>
    ) : (
      <section class="hit-list">
        {hitRates.map(row => {
          const resolvedPct = row.feedbackGiven > 0 ? Math.round((row.resolved / row.feedbackGiven) * 100) : 0;
          const stuckPct = row.feedbackGiven > 0 ? Math.round((row.stuck / row.feedbackGiven) * 100) : 0;
          return (
            <article class="hit-row">
              <div class="hit-head">
                <a class="hit-title" href={row.href}>{row.title}</a>
                <div class={`hit-rate ${row.rate === null ? 'empty' : ''}`}>{row.rate === null ? '暂无反馈' : `${row.rate}% resolved`}</div>
              </div>
              <div class="hit-bar" aria-label={`resolved ${row.resolved}, stuck ${row.stuck}`}>
                <div class="hit-bar-resolved" style={`width:${resolvedPct}%`} />
                <div class="hit-bar-stuck" style={`width:${stuckPct}%`} />
              </div>
              <div class="hit-meta">
                <span class="hit-chip">resolved {row.resolved}</span>
                <span class="hit-chip">stuck {row.stuck}</span>
                <span class="hit-chip">反馈 {row.feedbackGiven}</span>
                <span class="hit-chip">需求样本 {row.totalCases}</span>
                <span class="hit-chip">关联簇 {row.topicTitles.slice(0, 2).join(' / ')}</span>
              </div>
            </article>
          );
        })}
      </section>
    )}
  </main>

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/admin/auth', { method: 'DELETE' });
      window.location.href = '/admin/login';
    });
  </script>
</body>
</html>
