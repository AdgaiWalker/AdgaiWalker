---
// /admin/content - 管理员内容管理页
import { isAdmin } from '@/lib/admin-auth';
import { getAllContentEntries, getContentVisibility } from '@/knowledge/content';
import { buildPostPath } from '@/shared/routes';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const entries = await getAllContentEntries();
const rows = entries.map((entry) => ({
  id: entry.id,
  title: entry.data.title,
  type: entry.data.type,
  visibility: getContentVisibility(entry.data),
  date: entry.data.date,
  updated: entry.data.updated,
  tags: entry.data.tags ?? [],
  href: getContentVisibility(entry.data) === 'public' ? buildPostPath(entry.id) : null,
}));
const rowsJson = JSON.stringify(rows).replace(/</g, '\\u003c');
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>内容管理 - Walker</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; background: #fafaf9; color: #1c1917; }
    .admin-bar { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.08); background: #fff; position: sticky; top: 0; z-index: 100; }
    .admin-bar-left, .admin-bar-right { display: flex; align-items: center; gap: 0.75rem; }
    .admin-bar-logo { font-size: 1rem; font-weight: 800; color: #c4704a; text-decoration: none; }
    .admin-bar-badge { padding: 0.15rem 0.5rem; border-radius: 999px; background: rgba(196,112,74,0.1); color: #c4704a; font-size: 0.68rem; font-weight: 700; }
    .admin-bar-link { font-size: 0.82rem; color: #78716c; text-decoration: none; font-weight: 600; }
    .admin-bar-link:hover, .admin-bar-link.active { color: #1c1917; }
    .admin-main { max-width: 68rem; margin: 0 auto; padding: 1.5rem; }
    .page-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 1.25rem; }
    h1 { font-size: 1.35rem; font-weight: 800; margin-bottom: 0.25rem; }
    .sub { font-size: 0.82rem; color: #78716c; }
    .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.45rem 0.8rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: #fff; color: #57534e; font-size: 0.78rem; font-weight: 700; text-decoration: none; cursor: pointer; }
    .btn-primary { background: #c4704a; border-color: #c4704a; color: #fff; }
    .filters { display: grid; grid-template-columns: 1fr 10rem 10rem; gap: 0.75rem; margin-bottom: 1rem; }
    input, select { width: 100%; padding: 0.55rem 0.7rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: #fff; color: #1c1917; font-size: 0.84rem; }
    .table { border: 1px solid rgba(0,0,0,0.06); border-radius: 10px; background: #fff; overflow: hidden; }
    .row { display: grid; grid-template-columns: 7rem 7rem 1fr 6rem 8rem 20rem; gap: 0.75rem; align-items: center; padding: 0.7rem 0.85rem; border-bottom: 1px solid rgba(0,0,0,0.04); }
    .row:last-child { border-bottom: none; }
    .row-head { background: #f5f5f4; color: #78716c; font-size: 0.72rem; font-weight: 800; text-transform: uppercase; }
    .cell-title { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.88rem; font-weight: 700; }
    .muted { color: #a8a29e; font-size: 0.75rem; }
    .pill { display: inline-flex; width: fit-content; padding: 0.16rem 0.48rem; border-radius: 999px; font-size: 0.68rem; font-weight: 800; background: #f5f5f4; color: #57534e; }
    .pill-public { background: #ecfdf5; color: #047857; }
    .pill-draft { background: #fef9c3; color: #854d0e; }
    .pill-private { background: #fef2f2; color: #991b1b; }
    .actions { display: flex; gap: 0.4rem; justify-content: flex-end; }
    .btn-danger { color: #991b1b; border-color: rgba(153,27,27,0.16); }
    .btn-danger:hover { background: #fef2f2; }
    .empty { padding: 2rem; text-align: center; color: #a8a29e; font-size: 0.9rem; }
    @media (max-width: 820px) {
      .filters { grid-template-columns: 1fr; }
      .row { grid-template-columns: 1fr; gap: 0.35rem; }
      .row-head { display: none; }
      .actions { justify-content: flex-start; }
    }
  </style>
</head>
<body>
  <div class="admin-bar">
    <div class="admin-bar-left">
      <a href="/admin" class="admin-bar-logo">Walker</a>
      <span class="admin-bar-badge">Admin</span>
    </div>
    <div class="admin-bar-right">
      <a href="/admin" class="admin-bar-link">仪表盘</a>
      <a href="/admin/content" class="admin-bar-link active">内容</a>
      <a href="/admin/insights" class="admin-bar-link">洞察</a>
      <a href="/admin/topics" class="admin-bar-link">选题</a>
      <a href="/" class="admin-bar-link">站点</a>
    </div>
  </div>

  <main class="admin-main">
    <div class="page-head">
      <div>
        <h1>内容管理</h1>
        <p class="sub">全部内容 · {rows.length} 条</p>
      </div>
      <a class="btn btn-primary" href="/admin/content/edit">新建内容</a>
    </div>

    <div class="filters">
      <input id="q" type="search" placeholder="搜索标题、slug、标签" />
      <select id="type">
        <option value="">全部类型</option>
        <option value="knowledge">knowledge</option>
        <option value="tool">tool</option>
        <option value="idea">idea</option>
        <option value="project">project</option>
        <option value="community">community</option>
        <option value="learn">learn</option>
        <option value="learning">learning</option>
      </select>
      <select id="visibility">
        <option value="">全部可见性</option>
        <option value="public">public</option>
        <option value="draft">draft</option>
        <option value="private">private</option>
      </select>
    </div>

    <div class="table">
      <div class="row row-head">
        <div>可见性</div>
        <div>类型</div>
        <div>标题</div>
        <div>slug</div>
        <div>日期</div>
        <div></div>
      </div>
      <div id="rows"></div>
    </div>
  </main>

  <script is:inline type="application/json" id="content-rows" set:html={rowsJson}></script>
  <script>
    type ContentRow = {
      id: string;
      title: string;
      type: string;
      visibility: 'public' | 'draft' | 'private';
      date?: string;
      tags?: string[];
      href: string | null;
    };

    type ContentAction =
      | { kind: 'link'; label: string; href: (row: ContentRow) => string | null; external?: boolean }
      | { kind: 'visibility'; label: string; visibility: ContentRow['visibility'] }
      | { kind: 'delete'; label: string };

    const rowActions: ContentAction[] = [
      { kind: 'link', label: '查看', href: row => row.href, external: true },
      { kind: 'link', label: '编辑', href: row => `/admin/content/edit?slug=${encodeURIComponent(row.id)}` },
      { kind: 'visibility', label: '发布', visibility: 'public' },
      { kind: 'visibility', label: '草稿', visibility: 'draft' },
      { kind: 'visibility', label: '私密', visibility: 'private' },
      { kind: 'delete', label: '删除' },
    ];

    const rows = JSON.parse(document.getElementById('content-rows')?.textContent || '[]') as ContentRow[];
    const searchInput = document.getElementById('q') as HTMLInputElement;
    const typeFilter = document.getElementById('type') as HTMLSelectElement;
    const visibilityFilter = document.getElementById('visibility') as HTMLSelectElement;
    const rowsTarget = document.getElementById('rows') as HTMLDivElement;

    function fmtDate(value: string | number | Date | null | undefined) {
      if (!value) return '-';
      const d = new Date(value);
      return Number.isNaN(d.getTime()) ? String(value).slice(0, 10) : d.toISOString().slice(0, 10);
    }

    function esc(value: unknown) {
      const span = document.createElement('span');
      span.textContent = String(value ?? '');
      return span.innerHTML;
    }

    function filterRows() {
      const term = searchInput.value.trim().toLowerCase();
      const pickedType = typeFilter.value;
      const pickedVisibility = visibilityFilter.value;
      return rows.filter((row) => {
        const haystack = `${row.title} ${row.id} ${(row.tags || []).join(' ')}`.toLowerCase();
        return (!term || haystack.includes(term))
          && (!pickedType || row.type === pickedType)
          && (!pickedVisibility || row.visibility === pickedVisibility);
      });
    }

    function renderAction(action: ContentAction, row: ContentRow) {
      if (action.kind === 'link') {
        if (action.external && !row.href) return '<span class="muted">未公开</span>';
        const rel = action.external ? ' target="_blank" rel="noreferrer"' : '';
        return `<a class="btn" href="${esc(action.href(row))}"${rel}>${esc(action.label)}</a>`;
      }
      if (action.kind === 'visibility') {
        const disabled = row.visibility === action.visibility ? ' disabled' : '';
        return `<button class="btn" type="button" data-action="visibility" data-visibility="${action.visibility}" data-slug="${esc(row.id)}"${disabled}>${esc(action.label)}</button>`;
      }
      return `<button class="btn btn-danger" type="button" data-action="delete" data-slug="${esc(row.id)}">${esc(action.label)}</button>`;
    }

    function renderRow(row: ContentRow) {
      return `
        <div class="row">
          <div><span class="pill pill-${esc(row.visibility)}">${esc(row.visibility)}</span></div>
          <div><span class="pill">${esc(row.type)}</span></div>
          <div class="cell-title" title="${esc(row.title)}">${esc(row.title)}</div>
          <div class="muted" title="${esc(row.id)}">${esc(row.id)}</div>
          <div class="muted">${esc(fmtDate(row.date))}</div>
          <div class="actions">${rowActions.map(action => renderAction(action, row)).join('')}</div>
        </div>
      `;
    }

    function renderRows() {
      const filtered = filterRows();
      rowsTarget.innerHTML = filtered.length
        ? filtered.map(renderRow).join('')
        : '<div class="empty">没有匹配内容</div>';
    }

    async function updateVisibility(slug: string, nextVisibility: ContentRow['visibility']) {
      const res = await fetch(`/api/admin/content/${encodeURIComponent(slug)}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ visibility: nextVisibility }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || '更新失败');

      const row = rows.find(item => item.id === slug);
      if (row) {
        row.visibility = nextVisibility;
        row.href = nextVisibility === 'public' ? `/posts/${encodeURIComponent(row.id)}` : null;
      }
      renderRows();
    }

    async function deleteContent(slug: string) {
      const res = await fetch(`/api/admin/content/${encodeURIComponent(slug)}`, { method: 'DELETE' });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || '删除失败');

      const index = rows.findIndex(row => row.id === slug);
      if (index >= 0) rows.splice(index, 1);
      renderRows();
    }

    async function handleRowAction(button: HTMLButtonElement) {
      const slug = button.dataset.slug;
      const action = button.dataset.action;
      if (!slug || !action) return;
      if (action === 'delete' && !confirm(`确定删除 ${slug}？建议优先转为草稿或私密。`)) return;
      if (action === 'visibility') {
        const label = button.dataset.visibility === 'public' ? '发布' : button.dataset.visibility === 'draft' ? '转为草稿' : '设为私密';
        if (!confirm(`确定将 ${slug} ${label}？`)) return;
      }

      button.disabled = true;
      try {
        if (action === 'visibility') {
          const nextVisibility = button.dataset.visibility as ContentRow['visibility'];
          await updateVisibility(slug, nextVisibility);
        } else if (action === 'delete') {
          await deleteContent(slug);
        }
      } catch (err) {
        alert((err as Error).message);
        button.disabled = false;
      }
    }

    rowsTarget.addEventListener('click', (event) => {
      const button = (event.target as HTMLElement).closest('button[data-action]') as HTMLButtonElement | null;
      if (!button) return;
      handleRowAction(button);
    });

    searchInput.addEventListener('input', renderRows);
    typeFilter.addEventListener('change', renderRows);
    visibilityFilter.addEventListener('change', renderRows);
    renderRows();
  </script>
</body>
</html>
