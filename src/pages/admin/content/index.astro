---
// /admin/content — 内容管理（spec §4.4）
// 列表页模板：表格 + 筛选。
import { isAdmin } from '@/lib/admin-auth';
import { getAllContentEntries, getContentVisibility } from '@/knowledge/content';
import AdminLayout from '@/components/admin/AdminLayout.astro';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const entries = await getAllContentEntries();

// 类型 → spec §4.4 标签映射（方法/工具/随笔/生活/经验）
type TypeKind = 'method' | 'tool' | 'essay' | 'life' | 'exp';
function mapType(raw: string): { label: string; kind: TypeKind } {
  const map: Record<string, { label: string; kind: TypeKind }> = {
    knowledge: { label: '方法', kind: 'method' },
    tool: { label: '工具', kind: 'tool' },
    idea: { label: '随笔', kind: 'essay' },
    project: { label: '生活', kind: 'life' },
    community: { label: '经验', kind: 'exp' },
    learn: { label: '方法', kind: 'method' },
  };
  return map[raw] ?? { label: raw, kind: 'method' };
}
function mapStatus(v: string): { label: string; kind: 'public' | 'draft' | 'private' } {
  if (v === 'draft') return { label: '草稿', kind: 'draft' };
  if (v === 'private') return { label: '私密', kind: 'private' };
  return { label: '公开', kind: 'public' };
}

function relTime(d: Date): string {
  const diff = Date.now() - d.getTime();
  const day = Math.floor(diff / 86400000);
  if (day <= 0) return '今天';
  if (day === 1) return '昨天';
  if (day < 7) return `${day}天前`;
  if (day < 14) return '1周前';
  return `${Math.floor(day / 7)}周前`;
}

const rows = entries.slice(0, 6).map((e) => {
  const v = getContentVisibility(e.data);
  const t = mapType(e.data.type);
  const s = mapStatus(v);
  const updated = e.data.updated ?? e.data.date;
  return {
    title: e.data.title,
    slug: `/${e.id}`,
    typeLabel: t.label,
    typeKind: t.kind,
    statusLabel: s.label,
    statusKind: s.kind,
    views: '—',                       // 后端无浏览量，spec 列保留
    dateLabel: `${updated.getMonth() + 1}月${updated.getDate()}日`,
    dateRel: relTime(updated),
    editHref: `/admin/content/edit?slug=${encodeURIComponent(e.id)}`,
  };
});

const total = entries.length;
const pubCount = entries.filter(e => getContentVisibility(e.data) === 'public').length;
const draftCount = entries.filter(e => getContentVisibility(e.data) === 'draft').length;
const privCount = entries.filter(e => getContentVisibility(e.data) === 'private').length;

const subtitle = `${total} 篇 · ${pubCount} 公开 / ${draftCount} 草稿 / ${privCount} 私密`;
---
<AdminLayout
    active="/admin/content"
    title="内容管理"
    subtitle={subtitle}
  >
    <Fragment slot="actions">
      <button class="adm-btn" type="button">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>同步
      </button>
      <a class="adm-btn adm-btn-primary" href="/admin/content/edit">新建内容</a>
    </Fragment>
    {/* §4.4 筛选行 */}
    <div class="adm-content-filters">
      <div class="adm-filter-search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="search" placeholder="搜索标题、标签、slug…" aria-label="搜索内容" />
      </div>
      <button class="adm-filter-dropdown" type="button">
        类型：全部
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <button class="adm-filter-dropdown" type="button">
        状态：全部
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <button class="adm-filter-dropdown" type="button">
        排序：最新
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div class="adm-filter-spacer"></div>
      <button class="adm-filter-dropdown" type="button">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-2Z"/><path d="M5 12V7a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v5"/><path d="M12 22v-4"/></svg>
        批量操作
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
    </div>

    {/* §4.4 表格（严格 Table→Row→Cell） */}
    <div class="adm-content-table">
      {/* 表头（11px/700/text-faint/letterSpacing 0.5） */}
      <div class="adm-crow adm-crow-head">
        <div class="adm-crow-cell adm-crow-check"></div>
        <div class="adm-crow-cell adm-crow-title"><div class="adm-crow-t">标题</div></div>
        <div class="adm-crow-cell adm-crow-type">类型</div>
        <div class="adm-crow-cell adm-crow-status">状态</div>
        <div class="adm-crow-cell adm-crow-views">访问</div>
        <div class="adm-crow-cell adm-crow-date"><div class="adm-crow-t">更新</div></div>
        <div class="adm-crow-cell adm-crow-act">操作</div>
      </div>
      <div class="adm-content-tbody">
        {rows.map((r) => (
          <div class="adm-crow">
            <div class="adm-crow-cell adm-crow-check">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="adm-crow-checkbox"><rect width="18" height="18" x="3" y="3" rx="2"/></svg>
            </div>
            <div class="adm-crow-cell adm-crow-title">
              <div class="adm-crow-t">{r.title}</div>
              <div class="adm-crow-slug">{r.slug}</div>
            </div>
            <div class="adm-crow-cell adm-crow-type">
              <span class:list={["adm-tag", `adm-tag-${r.typeKind}`]}>{r.typeLabel}</span>
            </div>
            <div class="adm-crow-cell adm-crow-status">
              <span class:list={["adm-tag", "adm-tag-pill", `adm-tag-${r.statusKind === 'public' ? 'good' : r.statusKind === 'draft' ? 'warn' : 'neutral'}`]}>
                <span class="adm-tag-dot"></span>{r.statusLabel}
              </span>
            </div>
            <div class="adm-crow-cell adm-crow-views">{r.views}</div>
            <div class="adm-crow-cell adm-crow-date">
              <div class="adm-crow-date-main">{r.dateLabel}</div>
              <div class="adm-crow-date-rel">{r.dateRel}</div>
            </div>
            <div class="adm-crow-cell adm-crow-act">
              <a href={r.editHref} class="adm-btn adm-btn-sm">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/></svg>
                编辑
              </a>
              <button class="adm-crow-more" type="button" aria-label="更多操作">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
              </button>
            </div>
          </div>
        ))}
      </div>

      {/* §4.4 底栏：分页器 */}
      <div class="adm-content-foot">
        <span class="adm-content-count">显示 1–{rows.length} / 共 {total} 篇</span>
        <div class="adm-pager">
          <button class="adm-pager-btn" type="button" aria-label="上一页" disabled>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button class="adm-pager-btn is-active" type="button">1</button>
          <button class="adm-pager-btn" type="button">2</button>
          <span class="adm-pager-dots">…</span>
          <button class="adm-pager-btn" type="button">{Math.max(1, Math.ceil(total / 6))}</button>
          <button class="adm-pager-btn" type="button" aria-label="下一页">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>
  </AdminLayout>
<style is:global>
  /* §4.4 筛选行 */
  .adm-content-filters {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    background: var(--adm-surface);
    border-bottom: 1px solid var(--adm-border);
    margin: -24px -32px 0;
  }
  .adm-filter-search {
    display: flex; align-items: center; gap: 8px;
    width: 280px; flex-shrink: 0;
    padding: 8px 12px;
    background: var(--adm-bg);
    border: 1px solid var(--adm-border);
    border-radius: 8px;
    color: var(--adm-text-faint);
  }
  .adm-filter-search:focus-within { border-color: var(--adm-brand); }
  .adm-filter-search input {
    border: none; background: none; outline: none;
    font-family: inherit; font-size: 13px; color: var(--adm-text);
    width: 100%;
  }
  .adm-filter-search input::placeholder { color: var(--adm-text-faint); }
  .adm-filter-dropdown {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 12px;
    background: var(--adm-bg);
    border: 1px solid var(--adm-border);
    border-radius: 8px;
    color: var(--adm-text-dim);
    font-family: inherit; font-size: 13px; font-weight: 500;
    cursor: pointer;
  }
  .adm-filter-dropdown:hover { border-color: var(--adm-text-faint); color: var(--adm-text); }
  .adm-filter-spacer { flex: 1; }

  /* 表格容器 */
  .adm-content-table { display: flex; flex-direction: column; }
  .adm-content-tbody { display: flex; flex-direction: column; gap: 6px; }

  /* 行（与 ContentRow 一致，内联以承载表头态） */
  .adm-crow {
    display: flex; align-items: center; gap: 14px;
    padding: 12px 14px;
    background: var(--adm-surface);
    border: 1px solid var(--adm-border-soft);
    border-radius: 8px;
  }
  .adm-crow-cell { flex-shrink: 0; }
  .adm-crow-check { width: 28px; display: flex; align-items: center; color: #c8d4d6; cursor: pointer; }
  .adm-crow-title { width: 460px; max-width: 460px; display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .adm-crow-t { font-size: 13px; font-weight: 600; color: var(--adm-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .adm-crow-slug { font-size: 11px; color: var(--adm-text-faint); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: var(--adm-font-mono); }
  .adm-crow-type { width: 90px; }
  .adm-crow-status { width: 110px; }
  .adm-crow-views { width: 80px; text-align: right; font-size: 12px; font-weight: 600; color: var(--adm-text); font-variant-numeric: tabular-nums; }
  .adm-crow-date { width: 120px; display: flex; flex-direction: column; gap: 1px; }
  .adm-crow-date-main { font-size: 12px; color: var(--adm-text); }
  .adm-crow-date-rel { font-size: 10px; color: var(--adm-text-faint); }
  .adm-crow-act { flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 6px; }
  .adm-crow-more { background: none; border: none; cursor: pointer; color: var(--adm-text-faint); padding: 4px; display: inline-flex; }
  .adm-crow-more:hover { color: var(--adm-text-dim); }

  /* 表头行 */
  .adm-crow-head {
    background: var(--adm-bg) !important;
    border: none !important;
    border-radius: 0 !important;
    border-bottom: 1px solid var(--adm-border) !important;
  }
  .adm-crow-head .adm-crow-t,
  .adm-crow-head .adm-crow-cell {
    font-size: 11px;
    font-weight: 700;
    color: var(--adm-text-faint);
    letter-spacing: 0.5px;
    text-transform: none;
  }
  .adm-crow-head .adm-crow-views { font-weight: 700; }

  /* 底栏分页 */
  .adm-content-foot {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 14px 0;
  }
  .adm-content-count { font-size: 12px; color: var(--adm-text-faint); }
  .adm-pager { display: flex; align-items: center; gap: 4px; }
  .adm-pager-btn {
    min-width: 30px; height: 30px;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--adm-bg);
    border: 1px solid var(--adm-border);
    border-radius: 6px;
    color: var(--adm-text-dim);
    font-family: inherit; font-size: 12px; font-weight: 600;
    cursor: pointer;
    padding: 0 8px;
  }
  .adm-pager-btn:hover:not(:disabled):not(.is-active) { border-color: var(--adm-text-faint); color: var(--adm-text); }
  .adm-pager-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .adm-pager-btn.is-active { background: var(--adm-text); border-color: var(--adm-text); color: #fff; }
  .adm-pager-dots { color: var(--adm-text-faint); font-size: 12px; padding: 0 4px; }

  @media (max-width: 1100px) {
    .adm-crow-title { width: 280px; max-width: 280px; }
    .adm-content-filters { flex-wrap: wrap; }
    .adm-filter-search { width: 100%; }
  }
</style>
