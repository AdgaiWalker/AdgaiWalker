---
import AdminLayout from '@/components/admin/AdminLayout.astro';
// /admin/content/edit - 管理员 Markdown 编辑器
import { isAdmin } from '@/lib/admin-auth';
import { getTopicCandidateById } from '@/conversation/store';
import { generateBrief } from '@/services/brief.service';
import InlineEditor from '../../../components/admin/InlineEditor.astro';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const slug = Astro.url.searchParams.get('slug') || '';
const topicId = Astro.url.searchParams.get('topicId');
const prefill = Astro.url.searchParams.get('prefill');
const today = new Date().toISOString().slice(0, 10);
const topic = !slug && prefill === 'brief' && topicId ? await getTopicCandidateById(topicId) : null;
const brief = topic ? generateBrief(topic) : null;

function yamlString(value: string): string {
  return `"${value.replace(/\\/g, '\\\\').replace(/"/g, '\\"')}"`;
}

const draftTemplate = brief ? `---
title: ${yamlString(brief.title)}
date: ${today}
tags:
  - 需求簇
  - AI实践
type: knowledge
form: article
domain: ai
intent: teach
valueMode: utility
visibility: draft
published: false
sourceTopicId: ${yamlString(topicId ?? '')}
aiUsePolicy:
  level: AI-2
  readable: true
  citable: true
  actionable: false
summary: ${yamlString(brief.coreStuckPoint)}
related: []
---

> 写作简报参考，不是正文。请基于你的判断重新组织表达。

## 目标角色

${brief.targetRoles}

## 核心卡点

${brief.coreStuckPoint}

## 建议角度

${brief.suggestedAngles.map(angle => `- ${angle}`).join('\n')}

## 建议结构

${brief.suggestedStructure.map((item, index) => `${index + 1}. ${item}`).join('\n')}

## 站内可引用

${brief.referenceContent.length > 0 ? brief.referenceContent.map(title => `- ${title}`).join('\n') : '- 暂无可引用内容，先补最小路径。'}

## 正文

从这里开始写。
` : `---
title: 新文章
date: ${today}
tags: []
type: knowledge
visibility: draft
published: false
aiUsePolicy:
  level: AI-2
  readable: true
  citable: true
  actionable: false
---

正文内容...
`;
---

<AdminLayout active="/admin/content/edit" domain="creation" title="内容编辑" subtitle="编辑、预览、验证与发布">
<style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; background: transparent; color: var(--adm-text); }
    .bar-btn { padding: 0.4rem 0.85rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: transparent; color: var(--adm-text-dim); font-size: 0.78rem; font-weight: 600; cursor: pointer; text-decoration: none; transition: all 0.15s ease; }
    .bar-btn:hover { background: #f5f5f4; }
    .bar-btn-primary { background: var(--adm-brand-strong); color: #fff; border-color: var(--adm-brand-strong); }
    .bar-btn-primary:hover { background: #b5633f; }
    .bar-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .editor-main { max-width: 1180px; margin: 0 auto; }
    .create-panel { display: grid; grid-template-columns: 1fr 8rem; gap: 0.75rem; margin-bottom: 1rem; padding: 0.85rem; border: 1px solid rgba(0,0,0,0.06); border-radius: 10px; background: #fff; }
    .create-panel[hidden] { display: none; }
    input, select { width: 100%; padding: 0.5rem 0.7rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: #fff; color: var(--adm-text); font-size: 0.84rem; }
    .editor-split { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; height: calc(100vh - 7.5rem); }
    .editor-pane { display: flex; flex-direction: column; border: 1px solid rgba(0,0,0,0.06); border-radius: 12px; background: #fff; overflow: hidden; }
    .pane-header { padding: 0.6rem 0.85rem; border-bottom: 1px solid rgba(0,0,0,0.06); font-size: 0.78rem; font-weight: 700; color: var(--adm-text-dim); }
    .editor-textarea { flex: 1; width: 100%; padding: 1rem; border: 0; background: transparent; font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 0.85rem; line-height: 1.65; color: var(--adm-text); resize: none; outline: none; tab-size: 2; }
    .preview-pane { flex: 1; overflow-y: auto; padding: 1rem; }
    .preview-pane h1 { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.75rem; }
    .preview-pane h2 { font-size: 1.15rem; font-weight: 800; margin: 1.25rem 0 0.5rem; }
    .preview-pane h3 { font-size: 1rem; font-weight: 700; margin: 1rem 0 0.4rem; }
    .preview-pane p { font-size: 0.88rem; line-height: 1.7; margin-bottom: 0.65rem; }
    .preview-pane code { font-family: monospace; font-size: 0.82rem; padding: 0.15rem 0.35rem; background: rgba(0,0,0,0.05); border-radius: 4px; }
    .preview-pane pre { background: var(--adm-text); color: #e7e5e4; padding: 1rem; border-radius: 8px; overflow-x: auto; margin-bottom: 0.75rem; font-size: 0.82rem; line-height: 1.6; }
    .preview-pane blockquote { border-left: 3px solid var(--adm-brand-strong); padding-left: 0.85rem; color: var(--adm-text-dim); margin-bottom: 0.65rem; }
    .status-bar { padding: 0.45rem 1rem; font-size: 0.75rem; color: var(--adm-text-dim); text-align: center; }
    .loading { display: flex; align-items: center; justify-content: center; height: 100%; color: var(--adm-text-faint); font-size: 0.9rem; }
    @media (max-width: 820px) {
      .create-panel { grid-template-columns: 1fr; }
      .editor-split { grid-template-columns: 1fr; height: auto; }
      .editor-pane { min-height: 50vh; }
    }
  </style>
<div class="editor-main">
    <div class="create-panel" id="create-panel" hidden={Boolean(slug)}>
      <input id="slug-input" placeholder="slug，例如 my-new-post 或 新文章" />
      <select id="ext-input">
        <option value=".md">.md</option>
        <option value=".mdx">.mdx</option>
      </select>
    </div>

    <InlineEditor mode="standalone" initialBody={!slug ? draftTemplate : ''} />
  </div>

  <script is:inline define:vars={{ originalSlug: slug, topicIdParam: topicId ?? '' }}>
    window.__ieStandalone = { originalSlug, topicIdParam };
  </script>
  <script>
    import { initStandaloneEditor } from '@/scripts/inline-editor';
    const cfg = window.__ieStandalone;
    if (cfg) initStandaloneEditor(cfg.originalSlug || '', cfg.topicIdParam || undefined);
  </script>
</AdminLayout>
