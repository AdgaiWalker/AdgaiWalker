---
import AdminLayout from '@/components/admin/AdminLayout.astro';
import { getNeedCaseStats, getTopicCandidates } from '@/conversation/store';
import { isAdmin } from '@/lib/admin-auth';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const days = 30;
const [stats, topics] = await Promise.all([
  getNeedCaseStats({ days }),
  getTopicCandidates({ limit: 200 }),
]);

const pendingReviewCount = stats.byReviewStatus.pending ?? 0;
const unresolvedFeedbackCount = (stats.byFeedbackType.stuck ?? 0) + (stats.byFeedbackType['needs-more'] ?? 0);
const openTopicCount = topics.filter(topic => topic.status === 'observed' || topic.status === 'accepted').length;

const actions = [
  pendingReviewCount > 0 ? {
    label: '复盘需求',
    reason: `${pendingReviewCount} 条需求仍待人工判断`,
    href: '/admin/review',
  } : null,
  unresolvedFeedbackCount > 0 ? {
    label: '检查未解决反馈',
    reason: `${unresolvedFeedbackCount} 条真实反馈指向卡住或需要补充`,
    href: '/admin/hit-rate?view=outcome',
  } : null,
  openTopicCount > 0 ? {
    label: '处理选题',
    reason: `${openTopicCount} 个选题仍处于观察或已采纳状态`,
    href: '/admin/topics',
  } : null,
].filter((item): item is NonNullable<typeof item> => Boolean(item));

const reviewLabels: Record<string, string> = {
  pending: '待复盘',
  accepted: '已采纳',
  deferred: '已暂缓',
  ignored: '已忽略',
  produced: '已产出',
};

const feedbackLabels: Record<string, string> = {
  resolved: '已解决',
  stuck: '仍卡住',
  useful: '有用',
  'needs-more': '需要补充',
  outdated: '已过时',
  positive: '正向',
  negative: '负向',
};

const reviewEntries = Object.entries(stats.byReviewStatus).sort((a, b) => b[1] - a[1]);
const feedbackEntries = Object.entries(stats.byFeedbackType).sort((a, b) => b[1] - a[1]);
const dataGaps = [
  { title: '功能使用', detail: '尚未建立可用于功能取舍的完整事件口径。' },
  { title: '访问来源', detail: '尚未采集可靠的来源归因。' },
  { title: '流失环节', detail: '尚未建立完整漏斗，不能计算流失率。' },
  { title: '全站文章热度', detail: '当前只有阅读深度与明确反馈，不能冒充浏览热度榜。' },
];
---

<AdminLayout
  active="/admin/insights"
  domain="needs"
  title="需求分析"
  subtitle={`近 ${days} 天 · 只展示可追溯事实，缺失数据明确标记`}
>
  <section class="insight-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">现在可处理</p>
        <h2>由真实证据产生的动作</h2>
      </div>
      <span class="scope">统计范围：近 {days} 天</span>
    </div>

    {actions.length > 0 ? (
      <div class="action-grid">
        {actions.slice(0, 3).map((action, index) => (
          <a class="action-card" href={action.href}>
            <span class="action-index">{index + 1}</span>
            <span class="action-copy">
              <strong>{action.label}</strong>
              <small>{action.reason}</small>
            </span>
            <span aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <strong>当前没有可由现有证据生成的重点动作</strong>
        <span>新增需求、明确反馈或选题状态变化后，这里才会出现事项。</span>
      </div>
    )}
  </section>

  <section class="fact-grid" aria-label="真实聚合数据">
    <article class="fact-card">
      <span>需求记录</span>
      <strong>{stats.totalCases}</strong>
      <small>近 {days} 天真实 NeedCase</small>
    </article>
    <article class="fact-card">
      <span>匹配会话</span>
      <strong>{stats.totalSessions}</strong>
      <small>当前存储中的真实会话总数</small>
    </article>
    <article class="fact-card">
      <span>开放选题</span>
      <strong>{openTopicCount}</strong>
      <small>观察中或已采纳，尚未关闭</small>
    </article>
  </section>

  <section class="insight-columns">
    <article class="insight-section">
      <div class="section-head compact">
        <div>
          <p class="eyebrow">需求</p>
          <h2>重复出现的问题</h2>
        </div>
        <a href="/admin/review">查看原始需求</a>
      </div>
      {stats.topNeeds.length > 0 ? (
        <ol class="rank-list">
          {stats.topNeeds.slice(0, 8).map(item => (
            <li><span>{item.summary}</span><strong>{item.count}</strong></li>
          ))}
        </ol>
      ) : (
        <div class="empty-state small">近 {days} 天没有需求记录。</div>
      )}
    </article>

    <article class="insight-section">
      <div class="section-head compact">
        <div>
          <p class="eyebrow">状态</p>
          <h2>复盘与反馈</h2>
        </div>
      </div>
      <div class="signal-groups">
        <div>
          <h3>需求复盘</h3>
          {reviewEntries.length > 0 ? reviewEntries.map(([key, value]) => (
            <div class="signal-row"><span>{reviewLabels[key] ?? key}</span><strong>{value}</strong></div>
          )) : <p class="muted">暂无复盘状态。</p>}
        </div>
        <div>
          <h3>反馈信号</h3>
          {feedbackEntries.length > 0 ? feedbackEntries.map(([key, value]) => (
            <div class="signal-row"><span>{feedbackLabels[key] ?? key}</span><strong>{value}</strong></div>
          )) : <p class="muted">暂无反馈信号。</p>}
        </div>
      </div>
    </article>
  </section>

  <section class="insight-section">
    <div class="section-head compact">
      <div>
        <p class="eyebrow">数据边界</p>
        <h2>现在不能判断的事情</h2>
      </div>
    </div>
    <div class="gap-grid">
      {dataGaps.map(gap => (
        <article class="gap-card">
          <div><strong>{gap.title}</strong><span class="unknown">未采集</span></div>
          <p>{gap.detail}</p>
        </article>
      ))}
    </div>
  </section>
</AdminLayout>

<style>
  .insight-section {
    padding: clamp(1.1rem, 2vw, 1.6rem);
    border: 1px solid var(--adm-border);
    border-radius: var(--adm-radius-card);
    background: var(--adm-surface);
    box-shadow: 0 18px 55px rgba(27, 65, 59, 0.06);
  }
  .section-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
  .section-head.compact { margin-bottom: .85rem; }
  .section-head h2 { margin: .15rem 0 0; font-size: 1rem; color: var(--adm-text); }
  .section-head a { color: var(--adm-brand-strong); font-size: .8rem; text-decoration: none; }
  .eyebrow { margin: 0; color: var(--adm-brand-strong); font-size: .68rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
  .scope { color: var(--adm-text-faint); font-size: .72rem; }
  .action-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .7rem; }
  .action-card { display: flex; align-items: center; gap: .7rem; padding: .9rem; border: 1px solid rgba(53,191,171,.22); border-radius: 14px; background: rgba(53,191,171,.06); color: var(--adm-text); text-decoration: none; }
  .action-card:hover { border-color: rgba(53,191,171,.48); transform: translateY(-1px); }
  .action-index { display: grid; place-items: center; width: 1.65rem; height: 1.65rem; border-radius: 999px; background: var(--adm-brand-strong); color: white; font-size: .72rem; font-weight: 800; flex: 0 0 auto; }
  .action-copy { display: grid; gap: .2rem; min-width: 0; flex: 1; }
  .action-copy strong { font-size: .86rem; }
  .action-copy small { color: var(--adm-text-dim); line-height: 1.45; }
  .fact-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .75rem; }
  .fact-card { display: grid; gap: .25rem; padding: 1rem 1.1rem; border: 1px solid var(--adm-border); border-radius: 16px; background: rgba(255,255,255,.55); }
  .fact-card span, .fact-card small { color: var(--adm-text-dim); font-size: .74rem; }
  .fact-card strong { color: var(--adm-text); font-size: 1.7rem; font-variant-numeric: tabular-nums; }
  .insight-columns { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(300px, .75fr); gap: .85rem; }
  .rank-list { list-style: none; display: grid; gap: .3rem; margin: 0; padding: 0; }
  .rank-list li, .signal-row { display: flex; justify-content: space-between; gap: 1rem; padding: .65rem .75rem; border-radius: 10px; background: rgba(41,84,77,.035); }
  .rank-list span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: .82rem; }
  .rank-list strong, .signal-row strong { color: var(--adm-brand-strong); font-variant-numeric: tabular-nums; }
  .signal-groups { display: grid; grid-template-columns: 1fr 1fr; gap: .8rem; }
  .signal-groups h3 { margin: 0 0 .5rem; font-size: .76rem; color: var(--adm-text-dim); }
  .signal-row { padding: .5rem .65rem; margin-bottom: .3rem; font-size: .78rem; }
  .gap-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .65rem; }
  .gap-card { padding: .85rem; border: 1px dashed var(--adm-border); border-radius: 13px; background: rgba(255,255,255,.35); }
  .gap-card > div { display: flex; justify-content: space-between; align-items: center; gap: .5rem; }
  .gap-card strong { font-size: .8rem; }
  .gap-card p { margin: .55rem 0 0; color: var(--adm-text-dim); font-size: .72rem; line-height: 1.55; }
  .unknown { padding: .16rem .45rem; border-radius: 999px; background: rgba(100,116,139,.1); color: var(--adm-text-dim); font-size: .65rem; font-weight: 750; }
  .empty-state { display: grid; gap: .3rem; padding: 1rem; border: 1px dashed var(--adm-border); border-radius: 12px; color: var(--adm-text-dim); font-size: .78rem; }
  .empty-state strong { color: var(--adm-text); }
  .empty-state.small { padding: .8rem; }
  .muted { color: var(--adm-text-faint); font-size: .75rem; }
  @media (max-width: 1050px) { .action-grid, .gap-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .insight-columns { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { .action-grid, .fact-grid, .gap-grid, .signal-groups { grid-template-columns: 1fr; } .section-head { flex-direction: column; } }
</style>