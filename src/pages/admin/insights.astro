---
// /admin/insights — 洞察（spec §4.3）
// 三 tab（行为/内容/反馈）+ 顶部「本周该做的 3 件事」AI 优先级行动条。
import { isAdmin } from '@/lib/admin-auth';
import AdminLayout from '@/components/admin/AdminLayout.astro';
import FeatureRow from '@/components/admin/FeatureRow.astro';
import ArticleRow from '@/components/admin/ArticleRow.astro';
import ThemeCard from '@/components/admin/ThemeCard.astro';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

// §4.3 Tab1 功能使用热度（spec 写死 · 后端无 feature-usage 遥测）
const featureUsage = [
  { name: '提问匹配', count: 482, statusKind: 'good' as const, statusLabel: '活跃', delta: '↑18%', deltaKind: 'good' as const, action: '加固' },
  { name: '文章阅读', count: 391, statusKind: 'good' as const, statusLabel: '活跃', delta: '↑9%', deltaKind: 'good' as const, action: '加固' },
  { name: '学习轨道', count: 74, statusKind: 'warn' as const, statusLabel: '观察', delta: '↓4%', deltaKind: 'warn' as const, action: '观察' },
  { name: '内容关系图谱', count: 38, statusKind: 'warn' as const, statusLabel: '偏低', delta: '↓12%', deltaKind: 'warn' as const, action: '观察' },
  { name: '点赞', count: 9, statusKind: 'bad' as const, statusLabel: '冷门', delta: '↓41%', deltaKind: 'bad' as const, action: '考虑删除', actionKind: 'bad' as const },
  { name: '项目展示', count: 3, statusKind: 'bad' as const, statusLabel: '冷门', delta: '↓63%', deltaKind: 'bad' as const, action: '考虑删除', actionKind: 'bad' as const },
];
const featureMax = Math.max(...featureUsage.map(f => f.count));

// §4.3 流失环节（spec 写死 · 后端无 funnel 数据）
const dropoffs = [
  { label: '提问后无匹配走了', value: '61%', delta: '↑', note: '均值 48% · 本周异常', kind: 'bad' as const, action: '改匹配' },
  { label: '进首页直接走', value: '44%', delta: '↑', note: '均值 39% · 略升', kind: 'warn' as const, action: '改首屏' },
  { label: '文章读到一半走', value: '23%', delta: '→', note: '均值 24% · 持平', kind: 'neutral' as const, action: '改内容' },
];
const dropoffColor = { bad: 'var(--adm-bad)', warn: 'var(--adm-warn)', neutral: 'var(--adm-neutral)' };

// §4.3 Tab2 文章热度榜（spec 写死 · 后端无 article-heat）
const articleHeat = [
  { rank: 1, title: 'Ferry 隐喻：渡船到底渡的是什么', views: 842, asks: undefined, stay: '', delta: '↑22%', deltaKind: 'good' as const, action: '写更多', actionKind: 'good' as const },
  { rank: 2, title: 'P0-P4 方法：从原点到扩散', views: 531, asks: undefined, stay: '', delta: '↑11%', deltaKind: 'good' as const, action: '写更多', actionKind: 'good' as const },
  { rank: 3, title: '如何用 AI Gateway 做需求匹配', views: 318, asks: 88, stay: '2.4m', delta: '↓8%', deltaKind: 'warn' as const, action: '补问答', actionKind: 'warn' as const },
  { rank: 4, title: '双 Git 仓库协同工作流', views: 96, asks: undefined, stay: '', delta: '→持平', deltaKind: 'neutral' as const, action: '改写', actionKind: 'warn' as const },
  { rank: 5, title: '学习轨道：六月计划', views: 14, asks: undefined, stay: '', delta: '↓35%', deltaKind: 'bad' as const, action: '藏起来', actionKind: 'bad' as const },
];

// §4.3 Tab3 反馈聚类（spec 写死 4 主题 · 后端是 rule-based 聚类，非 AI 主题）
const themes = [
  { tagLabel: '该写教程', tagKind: 'good' as const, theme: 'P0→P2 完整案例怎么做', count: 18, quote: '看了 Ferry 那篇，但还是不懂具体怎么把一个想法从 P0 推到 P2，能不能给个完整例子一步步走一遍？', quoteMeta: '另有 17 条相似反馈 · 置信 92%', suggestion: '写一篇「P0→P2 完整案例」承接 Ferry 流量，可拆成连载', action: '加入选题', actionKind: 'good' as const },
  { tagLabel: '该改 bug', tagKind: 'warn' as const, theme: '提问匹配不上就白屏', count: 9, quote: '提问之后转了半天没匹配到东西，最后白屏了，体验很差。', quoteMeta: '另有 8 条相似反馈 · 置信 88% · 与流失率 61% 交叉印证', suggestion: '命中流失榜首，优先改匹配降级兜底（无结果时给推荐而非白屏）', action: '去改', actionKind: 'warn' as const },
  { tagLabel: '该补素材', tagKind: 'good' as const, theme: '双 Git 协同看不懂', count: 5, quote: '双 Git 仓库那段看晕了，有没有图？', quoteMeta: '另有 4 条相似反馈 · 置信 79%', suggestion: '给「双 Git 协同」补一张流程图，降低阅读门槛', action: '去补', actionKind: 'good' as const },
  { tagLabel: '无效吐槽', tagKind: 'neutral' as const, theme: '泛泛抱怨（无具体指向）', count: 5, quote: '字太多了懒得看', quoteMeta: '另有 4 条相似反馈 · 置信 64% · 未指向具体内容', suggestion: '标记无效 · 可一键隐藏，不占用决策精力', action: '全部忽略', actionKind: 'neutral' as const },
];
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>洞察 — Walker Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
  <AdminLayout
    active="/admin/insights"
    title="洞察"
    subtitle="看数据 → 改内容 / 改功能 · 近 30 天"
  >
    <Fragment slot="actions">
      <button class="adm-btn" type="button">近 30 天 <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
    </Fragment>
    {/* §4.3 「本周该做的 3 件事」AI 优先级行动条 */}
    <section class="adm-ins-priority">
      <div class="adm-ins-priority-lead">
        <span class="adm-ins-priority-badge">AI · 本周建议</span>
        <span class="adm-ins-priority-title">本周该做的 3 件事</span>
      </div>
      <div class="adm-ins-priority-cards">
        <div class="adm-ins-pcard adm-ins-pcard-bad">
          <span class="adm-ins-pcard-num" style="background:var(--adm-bad)">1</span>
          <div class="adm-ins-pcard-body">
            <div class="adm-ins-pcard-title">改提问匹配降级</div>
            <div class="adm-ins-pcard-sub">流失 61%↑ · 本周最该修</div>
          </div>
        </div>
        <div class="adm-ins-pcard adm-ins-pcard-good">
          <span class="adm-ins-pcard-num" style="background:var(--adm-good)">2</span>
          <div class="adm-ins-pcard-body">
            <div class="adm-ins-pcard-title">写 P0→P2 完整案例</div>
            <div class="adm-ins-pcard-sub">18 条反馈在等 · 接 Ferry 流量</div>
          </div>
        </div>
        <div class="adm-ins-pcard adm-ins-pcard-warn">
          <span class="adm-ins-pcard-num" style="background:var(--adm-warn)">3</span>
          <div class="adm-ins-pcard-body">
            <div class="adm-ins-pcard-title">换学习轨道标题再试</div>
            <div class="adm-ins-pcard-sub">14 看或因引流弱 · 先挽救再删</div>
          </div>
        </div>
      </div>
    </section>

    {/* §4.3 Tab 栏 */}
    <div class="adm-ins-tabs" role="tablist">
      <button class="adm-ins-tab is-active" role="tab" aria-selected="true" data-tab="behavior">行为 · 改功能</button>
      <button class="adm-ins-tab" role="tab" aria-selected="false" data-tab="content">内容 · 改文章</button>
      <button class="adm-ins-tab" role="tab" aria-selected="false" data-tab="feedback">反馈 · AI 归类</button>
    </div>

    {/* ===== Tab 1 · 行为（改功能） ===== */}
    <section class="adm-ins-panel is-active" data-panel="behavior" role="tabpanel">
      <div class="adm-ins-two-col">
        {/* 左列：功能使用热度 */}
        <div class="adm-ins-col">
          <div class="adm-ins-col-head">
            <span class="adm-ins-col-title">功能使用热度</span>
            <span class="adm-ins-col-sub">次数低 = 考虑删功能 · 次数高 = 加固它</span>
          </div>
          <div class="adm-ins-feature-list">
            {featureUsage.map(f => <FeatureRow {...f} max={featureMax} />)}
          </div>
        </div>

        {/* 右列：访客从哪来 · 在哪走 */}
        <div class="adm-ins-col adm-ins-col-flow">
          <div class="adm-ins-col-head">
            <span class="adm-ins-col-title">访客从哪来 · 在哪走</span>
          </div>

          {/* 来源卡 */}
          <div class="adm-ins-card adm-card">
            <div class="adm-ins-card-head">
              <span class="adm-ins-card-title">来源</span>
            </div>
            <div class="adm-ins-src">
              <div class="adm-ins-src-row">
                <div class="adm-ins-src-top"><span>自媒体公众号</span><span class="adm-mono">1240</span></div>
                <div class="adm-ins-src-bar"><div style="width:100%;background:var(--adm-brand)"></div></div>
              </div>
              <div class="adm-ins-src-row">
                <div class="adm-ins-src-top"><span>直接访问</span><span class="adm-mono">312</span></div>
                <div class="adm-ins-src-bar"><div style="width:25%;background:var(--adm-brand)"></div></div>
              </div>
              <div class="adm-ins-src-row">
                <div class="adm-ins-src-top"><span>搜索引擎</span><span class="adm-mono">88</span></div>
                <div class="adm-ins-src-bar"><div style="width:7%;background:var(--adm-brand)"></div></div>
              </div>
            </div>
          </div>

          {/* 流失环节卡（带「需改善」rose 标） */}
          <div class="adm-ins-card adm-card">
            <div class="adm-ins-card-head">
              <span class="adm-ins-card-title">流失环节</span>
              <span class="adm-tag adm-tag-bad">需改善</span>
            </div>
            {dropoffs.map(d => (
              <div class="adm-ins-drop-row">
                <div class="adm-ins-drop-top">
                  <span class="adm-ins-drop-label">{d.label}</span>
                  <span class="adm-ins-drop-val" style={`color:${dropoffColor[d.kind]}`}>{d.value} <span class="adm-ins-drop-delta">{d.delta}</span></span>
                </div>
                <div class="adm-ins-drop-note">
                  {d.note}
                  <button class="adm-btn adm-btn-sm" type="button">{d.action}</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ===== Tab 2 · 内容（改文章） ===== */}
    <section class="adm-ins-panel" data-panel="content" role="tabpanel" hidden>
      <div class="adm-ins-col-head">
        <span class="adm-ins-col-title">文章热度榜</span>
        <span class="adm-ins-col-sub">按热度降序 · 每条通向「写更多 / 补问答 / 改写 / 藏起来」</span>
      </div>
      <div class="adm-ins-article-list">
        {articleHeat.map(a => <ArticleRow {...a} />)}
      </div>
    </section>

    {/* ===== Tab 3 · 反馈（AI 归类） ===== */}
    <section class="adm-ins-panel" data-panel="feedback" role="tabpanel" hidden>
      <div class="adm-ins-col-head">
        <span class="adm-ins-col-title">访客反馈 · AI 已聚类</span>
        <span class="adm-ins-col-sub">37 条反馈 · AI 聚成 4 个主题 · 每主题取代表原话 + 建议</span>
      </div>
      <div class="adm-ins-theme-list">
        {themes.map(t => <ThemeCard {...t} />)}
      </div>
    </section>
  </AdminLayout>

  <script>
    // §5 交互：Tab 切换（激活态下划线 + 加粗，内容区切换）
    function initInsightsTabs() {
      const tabs = document.querySelectorAll('[data-tab]');
      const panels = document.querySelectorAll('[data-panel]');
      if (tabs.length === 0) return;
      tabs.forEach((tab) => {
        if ((tab as HTMLElement).dataset.bound === '1') return;
        (tab as HTMLElement).dataset.bound = '1';
        tab.addEventListener('click', () => {
          const key = (tab as HTMLElement).dataset.tab;
          tabs.forEach(t => {
            t.classList.toggle('is-active', t === tab);
            t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
          });
          panels.forEach(p => {
            const show = (p as HTMLElement).dataset.panel === key;
            p.classList.toggle('is-active', show);
            if (show) p.removeAttribute('hidden'); else p.setAttribute('hidden', '');
          });
        });
      });
    }

    function cleanupInsightsTabs() {
      document.removeEventListener('astro:page-load', initInsightsTabs);
      document.querySelectorAll('[data-bound="1"]').forEach((el) => {
        delete (el as HTMLElement).dataset.bound;
      });
    }

    initInsightsTabs();
    document.addEventListener('astro:page-load', initInsightsTabs);
    document.addEventListener('astro:before-swap', cleanupInsightsTabs);
  </script>
</body>
</html>

<style is:global>
  /* §4.3 AI 优先级行动条 */
  .adm-ins-priority {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 32px;
    background: var(--adm-bg);
    border-bottom: 1px solid var(--adm-border);
    /* 紧贴 tab 栏上方：用负 margin 抵消 content 的 gap */
    margin: -24px -32px 0;
  }
  .adm-ins-priority-lead { display: flex; flex-direction: column; gap: 2px; width: 172px; flex-shrink: 0; }
  .adm-ins-priority-badge {
    font-size: 10px; font-weight: 700; color: var(--adm-brand); letter-spacing: 1.2px;
  }
  .adm-ins-priority-title { font-size: 14px; font-weight: 700; color: var(--adm-text); }
  .adm-ins-priority-cards { display: flex; gap: 10px; flex: 1; min-width: 0; }
  .adm-ins-pcard {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px;
    background: var(--adm-surface);
    border-radius: 9px;
    border: 1px solid;
    flex: 1; min-width: 0;
  }
  .adm-ins-pcard-bad { border-color: #e11d4840; }
  .adm-ins-pcard-good { border-color: #35bfab40; }
  .adm-ins-pcard-warn { border-color: #f59e0b40; }
  .adm-ins-pcard-num {
    width: 22px; height: 22px; border-radius: 999px;
    display: inline-flex; align-items: center; justify-content: center;
    color: #fff; font-size: 11px; font-weight: 700; flex-shrink: 0;
  }
  .adm-ins-pcard-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .adm-ins-pcard-title { font-size: 13px; font-weight: 600; color: var(--adm-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .adm-ins-pcard-sub { font-size: 11px; color: var(--adm-text-faint); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* Tab 栏 */
  .adm-ins-tabs {
    display: flex; gap: 4px;
    padding: 0 32px;
    background: var(--adm-surface);
    border-bottom: 1px solid var(--adm-border);
    margin: 0 -32px;
  }
  .adm-ins-tab {
    padding: 12px 0;
    margin-right: 24px;
    background: none; border: none; cursor: pointer;
    font-family: inherit; font-size: 14px; font-weight: 500;
    color: var(--adm-text-dim);
    border-bottom: 2px solid transparent;
    transition: color 0.12s ease, border-color 0.12s ease;
  }
  .adm-ins-tab:hover { color: var(--adm-text); }
  .adm-ins-tab:focus-visible { outline: 2px solid var(--adm-brand); outline-offset: -2px; }
  .adm-ins-tab.is-active { color: var(--adm-text); font-weight: 700; border-bottom-color: var(--adm-brand); }

  .adm-ins-panel { display: none; }
  .adm-ins-panel.is-active { display: block; }

  /* 两列 */
  .adm-ins-two-col { display: grid; grid-template-columns: 1fr 360px; gap: 24px; }
  .adm-ins-col { display: flex; flex-direction: column; gap: 14px; min-width: 0; }
  .adm-ins-col-head { display: flex; flex-direction: column; gap: 2px; }
  .adm-ins-col-title { font-size: 14px; font-weight: 700; color: var(--adm-text); }
  .adm-ins-col-sub { font-size: 12px; color: var(--adm-text-faint); }
  .adm-ins-feature-list, .adm-ins-article-list, .adm-ins-theme-list { display: flex; flex-direction: column; gap: 8px; }

  /* 来源/流失卡 */
  .adm-ins-card { padding: 16px; display: flex; flex-direction: column; gap: 12px; }
  .adm-ins-card-head { display: flex; align-items: center; justify-content: space-between; }
  .adm-ins-card-title { font-size: 13px; font-weight: 700; color: var(--adm-text); }
  .adm-ins-src { display: flex; flex-direction: column; gap: 12px; }
  .adm-ins-src-row { display: flex; flex-direction: column; gap: 5px; }
  .adm-ins-src-top { display: flex; justify-content: space-between; font-size: 12px; color: var(--adm-text); }
  .adm-ins-src-bar { height: 6px; background: var(--adm-border-soft); border-radius: 3px; overflow: hidden; }
  .adm-ins-src-bar > div { height: 100%; border-radius: 3px; }

  .adm-ins-drop-row { display: flex; flex-direction: column; gap: 5px; padding-bottom: 10px; border-bottom: 1px solid var(--adm-border-soft); }
  .adm-ins-drop-row:last-child { border-bottom: none; padding-bottom: 0; }
  .adm-ins-drop-top { display: flex; justify-content: space-between; align-items: center; }
  .adm-ins-drop-label { font-size: 12px; color: var(--adm-text); }
  .adm-ins-drop-val { font-size: 14px; font-weight: 700; font-variant-numeric: tabular-nums; }
  .adm-ins-drop-delta { font-size: 11px; }
  .adm-ins-drop-note { display: flex; align-items: center; justify-content: space-between; gap: 8px; font-size: 11px; color: var(--adm-text-faint); }

  @media (max-width: 1100px) {
    .adm-ins-two-col { grid-template-columns: 1fr; }
    .adm-ins-priority { flex-direction: column; align-items: flex-start; }
    .adm-ins-priority-cards { width: 100%; flex-direction: column; }
  }
</style>
