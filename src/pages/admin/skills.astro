---
// /admin/skills — Skill 准入与 Agent 路由（U11）：候选 → 准入判断 → 注册 / 降级为方法卡
// 服务端渲染，需认证。Skill 准入标准：反复有效、输入有边界、输出可验证。
import { isAdmin } from '@/lib/admin-auth';
import { findRecentSkillCandidates, findExperienceEventById } from '@/conversation/store';
import type { SkillAdmissionStatus } from '@/stores/ports';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const skills = await findRecentSkillCandidates(500);

const ADMISSION_FLOW: SkillAdmissionStatus[] = ['candidate', 'admitted', 'demoted-to-method'];
const ADMISSION_LABEL: Record<SkillAdmissionStatus, string> = {
  candidate: '候选',
  admitted: '已准入',
  'demoted-to-method': '方法卡',
};
const ADMISSION_COLOR: Record<SkillAdmissionStatus, { color: string; bg: string }> = {
  candidate: { color: '#1d4ed8', bg: 'rgba(29,78,216,0.1)' },
  admitted: { color: '#065f46', bg: 'rgba(6,95,70,0.12)' },
  'demoted-to-method': { color: '#9a3412', bg: 'rgba(154,52,18,0.1)' },
};

const byAdmission = (s: SkillAdmissionStatus) => skills.filter(k => k.admissionStatus === s);
const counts = ADMISSION_FLOW.map(s => ({ status: s, count: byAdmission(s).length }));

const viewParam = Astro.url.searchParams.get('view');
const view: SkillAdmissionStatus | 'all' = viewParam && ADMISSION_FLOW.includes(viewParam as SkillAdmissionStatus) ? (viewParam as SkillAdmissionStatus) : 'all';
const visibleSkills = view === 'all' ? skills : byAdmission(view);

// 从经验转入：预填来源经验
const fromExperience = Astro.url.searchParams.get('fromExperience');
let seedExperience: { experienceId: string; rawQuote: string } | null = null;
if (fromExperience) {
  const ev = await findExperienceEventById(fromExperience);
  if (ev) seedExperience = { experienceId: ev.experienceId, rawQuote: ev.rawQuote };
}

function formatTime(iso: string): string {
  try {
    return new Date(iso).toLocaleString('zh-CN', { month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' });
  } catch {
    return iso;
  }
}

const NAV = [
  { href: '/admin', label: '仪表盘' },
  { href: '/admin/insights', label: '洞察' },
  { href: '/admin/hit-rate', label: '命中率' },
  { href: '/admin/topics', label: '选题池' },
  { href: '/admin/review', label: '需求复盘' },
  { href: '/admin/rules', label: '规则池' },
  { href: '/admin/experiences', label: '经验复盘' },
  { href: '/admin/skills', label: 'Skill' },
  { href: '/', label: '站点' },
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Skill 候选 — Walker</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; background: #fafaf9; color: #1c1917; }
    .admin-bar { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.08); background: #fff; position: sticky; top: 0; z-index: 100; }
    .admin-bar-left { display: flex; align-items: center; gap: 0.75rem; }
    .admin-bar-logo { font-size: 1rem; font-weight: 800; color: #c4704a; }
    .admin-bar-badge { padding: 0.15rem 0.5rem; border-radius: 999px; background: rgba(196,112,74,0.1); color: #c4704a; font-size: 0.68rem; font-weight: 700; }
    .admin-bar-right { display: flex; align-items: center; gap: 0.9rem; flex-wrap: wrap; }
    .admin-bar-link { color: #78716c; text-decoration: none; font-size: 0.82rem; font-weight: 650; }
    .admin-bar-link:hover, .admin-bar-link.active { color: #1c1917; }
    .logout-btn { padding: 0.35rem 0.75rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: transparent; color: #78716c; font-size: 0.78rem; font-weight: 650; cursor: pointer; }
    .admin-main { max-width: 62rem; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
    .admin-welcome { margin-bottom: 1.25rem; }
    .admin-welcome h1 { font-size: 1.5rem; font-weight: 850; margin-bottom: 0.35rem; }
    .admin-welcome p { color: #78716c; font-size: 0.88rem; line-height: 1.6; }

    .stat-row { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .stat-chip { padding: 0.55rem 0.85rem; border: 1px solid rgba(0,0,0,0.06); border-radius: 10px; background: #fff; min-width: 5.5rem; }
    .stat-chip-label { font-size: 0.7rem; color: #78716c; font-weight: 700; margin-bottom: 0.15rem; }
    .stat-chip-value { font-size: 1.25rem; font-weight: 850; }

    .panel { border: 1px solid rgba(0,0,0,0.06); border-radius: 12px; background: #fff; padding: 1rem 1.1rem; margin-bottom: 1.25rem; }
    .panel h2 { font-size: 0.92rem; font-weight: 850; margin-bottom: 0.75rem; color: #44403c; }
    .seed-hint { padding: 0.5rem 0.7rem; background: rgba(196,112,74,0.06); border-radius: 8px; font-size: 0.8rem; color: #9a3412; margin-bottom: 0.6rem; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
    .form-grid .full { grid-column: 1 / -1; }
    textarea, input[type=text] { width: 100%; padding: 0.5rem 0.7rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; font-size: 0.85rem; font-family: inherit; background: #fff; color: #1c1917; resize: vertical; }
    textarea:focus, input:focus { outline: 2px solid rgba(196,112,74,0.25); border-color: rgba(196,112,74,0.4); }
    .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.4rem 0.8rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; background: transparent; color: #57534e; text-decoration: none; font-size: 0.78rem; font-weight: 750; cursor: pointer; }
    .btn:hover { background: #fafaf9; }
    .btn-primary { background: rgba(196,112,74,0.1); border-color: rgba(196,112,74,0.22); color: #c4704a; }
    .btn-primary:hover { background: rgba(196,112,74,0.16); }

    .view-switch { display: inline-flex; gap: 0.3rem; padding: 0.25rem; margin-bottom: 1.25rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 10px; background: #fff; flex-wrap: wrap; }
    .view-switch a { padding: 0.4rem 0.7rem; border-radius: 8px; color: #78716c; text-decoration: none; font-size: 0.78rem; font-weight: 750; }
    .view-switch a.active { background: rgba(196,112,74,0.1); color: #c4704a; }

    .skill-list { display: grid; gap: 0.85rem; }
    .skill-card { border: 1px solid rgba(0,0,0,0.06); border-radius: 12px; background: #fff; padding: 1rem 1.1rem; }
    .skill-card.method { border-left: 3px solid #9a3412; }
    .skill-card.admitted { border-left: 3px solid #065f46; }
    .skill-head { display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; margin-bottom: 0.55rem; }
    .badge { padding: 0.15rem 0.5rem; border-radius: 999px; font-size: 0.68rem; font-weight: 800; }
    .skill-name { color: #1c1917; font-size: 1rem; font-weight: 850; }
    .skill-desc { color: #57534e; font-size: 0.85rem; line-height: 1.55; margin-bottom: 0.65rem; }
    .skill-meta { display: grid; gap: 0.4rem; color: #57534e; font-size: 0.78rem; line-height: 1.55; }
    .meta-label { color: #a8a29e; font-weight: 800; }
    .skill-time { margin-left: auto; color: #a8a29e; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; }
    .skill-foot { display: flex; gap: 0.45rem; flex-wrap: wrap; align-items: center; margin-top: 0.85rem; }
    .empty { text-align: center; padding: 3rem 1rem; color: #a8a29e; border: 1px dashed rgba(0,0,0,0.08); border-radius: 12px; background: #fff; }
    @media (max-width: 760px) {
      .admin-bar { flex-direction: column; align-items: flex-start; }
      .admin-main { padding: 1.25rem 1rem 3rem; }
      .form-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="admin-bar">
    <div class="admin-bar-left">
      <span class="admin-bar-logo">Walker</span>
      <span class="admin-bar-badge">Admin</span>
    </div>
    <div class="admin-bar-right">
      {NAV.map(item => (
        <a href={item.href} class={`admin-bar-link ${item.href === '/admin/skills' ? 'active' : ''}`}>{item.label}</a>
      ))}
      <button class="logout-btn" id="logout-btn">登出</button>
    </div>
  </div>

  <main class="admin-main">
    <section class="admin-welcome">
      <h1>Skill 候选</h1>
      <p>Skill 准入三标准：反复有效、输入有边界、输出可验证。满足则准入注册，输入太宽或输出不稳则降级为方法卡。</p>
    </section>

    <div class="stat-row">
      <div class="stat-chip"><div class="stat-chip-label">总数</div><div class="stat-chip-value">{skills.length}</div></div>
      {counts.map(c => (
        <div class="stat-chip"><div class="stat-chip-label">{ADMISSION_LABEL[c.status]}</div><div class="stat-chip-value">{c.count}</div></div>
      ))}
    </div>

    <div class="panel">
      <h2>新建 Skill 候选</h2>
      {seedExperience && (
        <div class="seed-hint">来自经验事件 {seedExperience.experienceId.slice(0, 8)}…，原话已带入描述，请补全边界与验证标准。</div>
      )}
      <form id="new-skill-form">
        <div class="form-grid">
          <input type="text" name="name" class="full" placeholder="Skill 名称（如「结构化拆解需求」）" required />
          <textarea name="description" rows="2" class="full" placeholder="这个 Skill 做什么">{seedExperience?.rawQuote ?? ''}</textarea>
          <input type="text" name="domain" placeholder="定义域：输入范围（如「用户问怎么做 X」）" />
          <input type="text" name="inputConditions" placeholder="输入条件（触发前提）" />
          <input type="text" name="outputForm" placeholder="输出形态（如「分类 + 步骤清单」）" />
          <input type="text" name="validationCriteria" placeholder="验证标准（怎么算对）" />
        </div>
        {seedExperience && <input type="hidden" name="sourceExperienceIds" value={seedExperience.experienceId} />}
        <div style="margin-top:0.6rem;"><button type="submit" class="btn btn-primary">加入候选</button></div>
      </form>
    </div>

    <nav class="view-switch" aria-label="准入状态筛选">
      <a href="/admin/skills?view=all" class={view === 'all' ? 'active' : ''}>全部（{skills.length}）</a>
      {ADMISSION_FLOW.map(s => (
        <a href={`/admin/skills?view=${s}`} class={view === s ? 'active' : ''}>{ADMISSION_LABEL[s]}（{byAdmission(s).length}）</a>
      ))}
    </nav>

    {visibleSkills.length === 0 ? (
      <div class="empty">还没有 Skill 候选。从经验复盘里成熟度推进到「Skill 候选」，或在这里手动新建。</div>
    ) : (
      <section class="skill-list">
        {visibleSkills.map(skill => {
          const cfg = ADMISSION_COLOR[skill.admissionStatus];
          const cls = skill.admissionStatus === 'admitted' ? 'admitted' : skill.admissionStatus === 'demoted-to-method' ? 'method' : '';
          return (
            <article class={`skill-card ${cls}`} data-skill-id={skill.skillId} data-status={skill.admissionStatus} data-version={skill.version}>
              <div class="skill-head">
                <span class="badge" style={`background:${cfg.bg};color:${cfg.color}`}>{ADMISSION_LABEL[skill.admissionStatus]}</span>
                <span class="badge" style="background:#f5f5f4;color:#57534e">v{skill.version}</span>
                <span class="skill-time">{formatTime(skill.updatedAt)}</span>
              </div>
              <div class="skill-name">{skill.name}</div>
              {skill.description && <div class="skill-desc">{skill.description}</div>}
              <div class="skill-meta">
                {skill.domain && <div><span class="meta-label">定义域：</span>{skill.domain}</div>}
                {skill.inputConditions && <div><span class="meta-label">输入条件：</span>{skill.inputConditions}</div>}
                {skill.outputForm && <div><span class="meta-label">输出形态：</span>{skill.outputForm}</div>}
                {skill.validationCriteria && <div><span class="meta-label">验证标准：</span>{skill.validationCriteria}</div>}
                {skill.sourceExperienceIds.length > 0 && <div><span class="meta-label">来源经验：</span>{skill.sourceExperienceIds.map(id => id.slice(0, 8)).join('、')}</div>}
              </div>
              <div class="skill-foot">
                {skill.admissionStatus === 'candidate' && (
                  <>
                    <button class="btn btn-primary" data-action="admit">准入注册</button>
                    <button class="btn" data-action="demote">降级为方法卡</button>
                  </>
                )}
                {skill.admissionStatus !== 'candidate' && (
                  <button class="btn" data-action="reset">回到候选</button>
                )}
                <button class="btn" data-action="bump">升版本（迭代）</button>
              </div>
            </article>
          );
        })}
      </section>
    )}
  </main>

  <script is:inline>
    const post = (url, body) => fetch(url, {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    }).then(r => r.json().then(d => ({ ok: r.ok, data: d })));
    const tell = (message) => window.WalkerAdminUI?.notify({ title: '操作结果', message }) ?? Promise.resolve();

    document.getElementById('new-skill-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const payload = Object.fromEntries(fd.entries());
      payload.name = (payload.name || '').toString().trim();
      if (!payload.name) return;
      if (payload.sourceExperienceIds) payload.sourceExperienceIds = [payload.sourceExperienceIds];
      else delete payload.sourceExperienceIds;
      const { ok, data } = await post('/api/admin/skills', payload);
      if (ok && data.ok) window.location.href = '/admin/skills'; else await tell(data.error || '保存失败');
    });

    document.querySelectorAll('.btn[data-action]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const card = btn.closest('.skill-card');
        const skillId = card?.dataset.skillId;
        const action = btn.dataset.action;
        if (!skillId || !action) return;
        if (action === 'admit') {
          const { ok, data } = await post('/api/admin/skills?action=admission', { skillId, admissionStatus: 'admitted' });
          if (ok && data.ok) window.location.reload(); else await tell(data.error || '操作失败');
        } else if (action === 'demote') {
          const { ok, data } = await post('/api/admin/skills?action=admission', { skillId, admissionStatus: 'demoted-to-method' });
          if (ok && data.ok) window.location.reload(); else await tell(data.error || '操作失败');
        } else if (action === 'reset') {
          const { ok, data } = await post('/api/admin/skills?action=admission', { skillId, admissionStatus: 'candidate' });
          if (ok && data.ok) window.location.reload(); else await tell(data.error || '操作失败');
        } else if (action === 'bump') {
          const name = card.querySelector('.skill-name')?.textContent ?? '';
          const desc = card.querySelector('.skill-desc')?.textContent ?? '';
          const v = Number(card.dataset.version ?? '1') + 1;
          const { ok, data } = await post('/api/admin/skills', { skillId, name, description: desc, version: v });
          if (ok && data.ok) window.location.reload(); else await tell(data.error || '操作失败');
        }
      });
    });

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/admin/auth', { method: 'DELETE' });
      window.location.href = '/admin/login';
    });
  </script>
</body>
</html>
