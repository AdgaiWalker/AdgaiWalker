---
// /admin/incidents — 安全事件/失败降级待复盘（Incident），SSR，需认证
import { isAdmin } from '@/lib/admin-auth';
import { createIncidentStore } from '@/stores/incident.store';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const incidents = await createIncidentStore().findUnresolved(100);

const severityConfig: Record<string, { label: string; color: string; bg: string }> = {
  high: { label: '高', color: '#dc2626', bg: 'rgba(220,38,38,0.08)' },
  medium: { label: '中', color: '#b45309', bg: 'rgba(180,83,9,0.08)' },
  low: { label: '低', color: '#78716c', bg: 'rgba(120,113,108,0.08)' },
};

function formatTime(iso: string): string {
  try {
    return new Date(iso).toLocaleString('zh-CN', { month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' });
  } catch {
    return iso;
  }
}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>安全事件 — Walker</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; background: #fafaf9; color: #1c1917; }
    .admin-bar { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.08); background: #fff; position: sticky; top: 0; z-index: 100; }
    .admin-bar-left { display: flex; align-items: center; gap: 0.75rem; }
    .admin-bar-logo { font-size: 1rem; font-weight: 800; color: #c4704a; }
    .admin-bar-badge { padding: 0.15rem 0.5rem; border-radius: 999px; background: rgba(196,112,74,0.1); color: #c4704a; font-size: 0.68rem; font-weight: 700; }
    .admin-bar-right { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .admin-bar-link { color: #78716c; text-decoration: none; font-size: 0.82rem; font-weight: 650; }
    .admin-bar-link:hover, .admin-bar-link.active { color: #1c1917; }
    .logout-btn { padding: 0.35rem 0.75rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: transparent; color: #78716c; font-size: 0.78rem; font-weight: 650; cursor: pointer; }
    .admin-main { max-width: 56rem; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
    .admin-welcome { margin-bottom: 1.25rem; }
    .admin-welcome h1 { font-size: 1.5rem; font-weight: 850; margin-bottom: 0.35rem; }
    .admin-welcome p { color: #78716c; font-size: 0.88rem; line-height: 1.6; }
    .incident-card { border: 1px solid rgba(0,0,0,0.06); border-radius: 12px; background: #fff; padding: 1rem; margin-bottom: 0.75rem; }
    .incident-head { display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; margin-bottom: 0.55rem; }
    .badge { padding: 0.15rem 0.5rem; border-radius: 999px; background: #f5f5f4; color: #57534e; font-size: 0.68rem; font-weight: 800; }
    .incident-time { margin-left: auto; color: #a8a29e; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; }
    .incident-message { color: #1c1917; font-size: 0.9rem; line-height: 1.55; }
    .incident-meta { margin-top: 0.45rem; color: #78716c; font-size: 0.76rem; }
    .empty { text-align: center; padding: 3rem 1rem; color: #a8a29e; border: 1px dashed rgba(0,0,0,0.08); border-radius: 12px; background: #fff; }
    @media (max-width: 760px) { .admin-bar { flex-direction: column; align-items: flex-start; } .admin-main { padding: 1.25rem 1rem 3rem; } }
  </style>
</head>
<body>
  <div class="admin-bar">
    <div class="admin-bar-left">
      <span class="admin-bar-logo">Walker</span>
      <span class="admin-bar-badge">Admin</span>
    </div>
    <div class="admin-bar-right">
      <a href="/admin" class="admin-bar-link">仪表盘</a>
      <a href="/admin/insights" class="admin-bar-link">洞察</a>
      <a href="/admin/review?view=clusters" class="admin-bar-link">需求复盘</a>
      <a href="/admin/incidents" class="admin-bar-link active">安全事件</a>
      <a href="/admin/topics" class="admin-bar-link">选题池</a>
      <a href="/" class="admin-bar-link">查看站点</a>
      <button class="logout-btn" id="logout-btn">登出</button>
    </div>
  </div>

  <main class="admin-main">
    <section class="admin-welcome">
      <h1>安全事件 / 待复盘</h1>
      <p>系统在关键失败时记录的 Incident（如 NeedCase 保存失败、画像保存失败等）。U8 Safety 失败矩阵的可观测入口。</p>
    </section>

    {incidents.length === 0 ? (
      <div class="empty">暂未解决的安全事件。系统降级正常运作中。</div>
    ) : (
      incidents.map(incident => {
        const cfg = severityConfig[incident.severity] ?? severityConfig.low;
        return (
          <article class="incident-card">
            <div class="incident-head">
              <span class="badge" style={`background:${cfg.bg};color:${cfg.color}`}>{cfg.label}</span>
              <span class="badge">{incident.scope}</span>
              <span class="incident-time">{formatTime(incident.createdAt)}</span>
            </div>
            <div class="incident-message">{incident.message}</div>
            {(incident.relatedNeedCaseId || incident.relatedSessionId) && (
              <div class="incident-meta">
                {incident.relatedNeedCaseId && <span>NeedCase: {incident.relatedNeedCaseId.slice(0, 8)}… </span>}
                {incident.relatedSessionId && <span>Session: {incident.relatedSessionId.slice(0, 8)}…</span>}
              </div>
            )}
          </article>
        );
      })
    )}
  </main>

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/admin/auth', { method: 'DELETE' });
      window.location.href = '/admin/login';
    });
  </script>
</body>
</html>
