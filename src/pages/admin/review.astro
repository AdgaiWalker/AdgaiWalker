---
// /admin/review — 需求复盘 + 需求簇工作台，服务端渲染，需认证
import { isAdmin } from '@/lib/admin-auth';
import { getTopicCandidates } from '@/conversation/store';
import { matchResources } from '@/profiles/resource-index';
import { createAdminReviewService } from '@/services/admin-review.service';
import { createFeedbackStore } from '@/stores/feedback.store';
import { createNeedCaseStore } from '@/stores/need-case.store';
import type { NeedCaseReviewItem } from '@/services/interfaces';
import type { TopicCandidate } from '@/stores/ports';

export const prerender = false;

if (!isAdmin(Astro.request)) {
  return Astro.redirect('/admin/login');
}

const view = Astro.url.searchParams.get('view') === 'list' ? 'list' : 'clusters';
const adminReviewService = createAdminReviewService({
  needCaseStore: createNeedCaseStore(),
  feedbackStore: createFeedbackStore(),
});

const clusterTopics = await getTopicCandidates({ limit: 100 });
const allItems = await adminReviewService.listAll({ limit: 120 });
const reviewStatuses = ['pending', 'accepted', 'deferred', 'ignored'] as const;
const reviewItems = Object.fromEntries(
  reviewStatuses.map(status => [status, allItems.filter(item => item.needCase.adminReviewStatus === status)]),
) as Record<(typeof reviewStatuses)[number], NeedCaseReviewItem[]>;

const reviewStatusConfig: Record<string, { label: string; color: string; bg: string }> = {
  pending: { label: '待复盘', color: '#b45309', bg: 'rgba(180,83,9,0.08)' },
  accepted: { label: '已采纳', color: '#065f46', bg: 'rgba(6,95,70,0.08)' },
  deferred: { label: '已暂缓', color: '#854d0e', bg: 'rgba(133,77,14,0.08)' },
  ignored: { label: '已忽略', color: '#78716c', bg: 'rgba(120,113,108,0.08)' },
};

const feedbackLabels: Record<string, string> = {
  none: '未反馈',
  resolved: '解决了',
  stuck: '还卡着',
  'not-fit': '不适合',
  'want-tutorial': '想看教程',
  'first-draft': '做出第一版',
  'next-step-clear': '知道下一步',
  'wrong-direction': '方向不对',
  'need-tutorial': '还缺教程',
};

function formatTime(iso: string): string {
  try {
    return new Date(iso).toLocaleString('zh-CN', { month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' });
  } catch {
    return iso;
  }
}

function profileSummary(item: NeedCaseReviewItem): string {
  const p = item.needCase.profileSnapshot;
  if (!p) return '已脱敏或未推断';
  const parts = [p.roleInContext, p.goal, p.stuckPoint].filter(Boolean);
  return parts.length > 0 ? parts.join(' · ') : '未推断';
}

function roleText(topic: TopicCandidate): string {
  if (topic.roleDistribution.length === 0) return '未主动说明的人群';
  return topic.roleDistribution.map(item => `${item.role}×${item.count}`).join(' ');
}

function relatedText(topic: TopicCandidate): string {
  if (topic.relatedContentIds.length === 0) return '暂无相关内容';
  return topic.relatedContentIds
    .map(id => matchResources.find(resource => resource.id === id)?.title ?? id)
    .slice(0, 5)
    .join(' / ');
}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>需求复盘 — Walker</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; background: #fafaf9; color: #1c1917; }
    .admin-bar { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.08); background: #fff; position: sticky; top: 0; z-index: 100; }
    .admin-bar-left { display: flex; align-items: center; gap: 0.75rem; }
    .admin-bar-logo { font-size: 1rem; font-weight: 800; color: #c4704a; }
    .admin-bar-badge { padding: 0.15rem 0.5rem; border-radius: 999px; background: rgba(196,112,74,0.1); color: #c4704a; font-size: 0.68rem; font-weight: 700; }
    .admin-bar-right { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .admin-bar-link { color: #78716c; text-decoration: none; font-size: 0.82rem; font-weight: 650; }
    .admin-bar-link:hover, .admin-bar-link.active { color: #1c1917; }
    .logout-btn { padding: 0.35rem 0.75rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: transparent; color: #78716c; font-size: 0.78rem; font-weight: 650; cursor: pointer; }
    .admin-main { max-width: 64rem; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
    .admin-welcome { margin-bottom: 1.25rem; }
    .admin-welcome h1 { font-size: 1.5rem; font-weight: 850; margin-bottom: 0.35rem; }
    .admin-welcome p { color: #78716c; font-size: 0.88rem; line-height: 1.6; }
    .view-switch { display: inline-flex; gap: 0.35rem; padding: 0.25rem; margin-bottom: 1.25rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 10px; background: #fff; }
    .view-switch a { padding: 0.45rem 0.75rem; border-radius: 8px; color: #78716c; text-decoration: none; font-size: 0.8rem; font-weight: 750; }
    .view-switch a.active { background: rgba(196,112,74,0.1); color: #c4704a; }
    .cluster-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.85rem; }
    .cluster-card, .case-card { border: 1px solid rgba(0,0,0,0.06); border-radius: 12px; background: #fff; padding: 1rem; }
    .cluster-head, .case-head { display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; margin-bottom: 0.65rem; }
    .badge { padding: 0.15rem 0.5rem; border-radius: 999px; background: #f5f5f4; color: #57534e; font-size: 0.68rem; font-weight: 800; }
    .cluster-title, .case-summary { color: #1c1917; font-size: 0.96rem; font-weight: 850; line-height: 1.45; margin-bottom: 0.55rem; }
    .cluster-meta, .case-meta { display: grid; gap: 0.42rem; color: #57534e; font-size: 0.78rem; line-height: 1.55; }
    .meta-label { color: #78716c; font-weight: 850; }
    .cluster-actions, .case-actions { display: flex; gap: 0.45rem; flex-wrap: wrap; margin-top: 0.85rem; }
    .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.35rem 0.72rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; background: transparent; color: #57534e; text-decoration: none; font-size: 0.75rem; font-weight: 750; cursor: pointer; }
    .btn-primary { background: rgba(196,112,74,0.08); border-color: rgba(196,112,74,0.18); color: #c4704a; }
    .case-card { margin-bottom: 0.75rem; }
    .case-time { margin-left: auto; color: #a8a29e; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; }
    .case-bridge { margin-top: 0.65rem; padding: 0.65rem 0.75rem; border-left: 2px solid #c4704a; border-radius: 8px; background: #fafaf9; color: #44403c; font-size: 0.82rem; line-height: 1.6; }
    .review-tabs { display: flex; gap: 0.35rem; margin-bottom: 1.25rem; border-bottom: 1px solid rgba(0,0,0,0.08); overflow-x: auto; }
    .review-tab { padding: 0.55rem 0.85rem; border: 0; border-bottom: 2px solid transparent; background: transparent; color: #78716c; font-size: 0.82rem; font-weight: 750; cursor: pointer; white-space: nowrap; }
    .review-tab.active { color: #1c1917; border-bottom-color: #c4704a; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .empty { text-align: center; padding: 3rem 1rem; color: #a8a29e; border: 1px dashed rgba(0,0,0,0.08); border-radius: 12px; background: #fff; }
    .note-input { display: none; width: 100%; margin-top: 0.5rem; padding: 0.45rem 0.65rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 7px; font-size: 0.78rem; }
    .note-input.visible { display: block; }
    @media (max-width: 760px) {
      .admin-bar { flex-direction: column; align-items: flex-start; }
      .admin-main { padding: 1.25rem 1rem 3rem; }
      .cluster-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="admin-bar">
    <div class="admin-bar-left">
      <span class="admin-bar-logo">Walker</span>
      <span class="admin-bar-badge">Admin</span>
    </div>
    <div class="admin-bar-right">
      <a href="/admin" class="admin-bar-link">仪表盘</a>
      <a href="/admin/insights" class="admin-bar-link">洞察</a>
      <a href="/admin/hit-rate" class="admin-bar-link">命中率</a>
      <a href="/admin/topics" class="admin-bar-link">选题池</a>
      <a href="/admin/review?view=clusters" class="admin-bar-link active">需求复盘</a>
      <a href="/" class="admin-bar-link">查看站点</a>
      <button class="logout-btn" id="logout-btn">登出</button>
    </div>
  </div>

  <main class="admin-main">
    <section class="admin-welcome">
      <h1>需求复盘</h1>
      <p>先从需求簇俯瞰选题，再回到逐条 NeedCase 判断证据。簇是雷达，逐条是样本。</p>
    </section>

    <nav class="view-switch" aria-label="复盘视图">
      <a href="/admin/review?view=clusters" class={view === 'clusters' ? 'active' : ''}>需求簇</a>
      <a href="/admin/review?view=list" class={view === 'list' ? 'active' : ''}>逐条复盘</a>
    </nav>

    {view === 'clusters' ? (
      clusterTopics.length === 0 ? (
        <div class="empty">还没有需求簇。先积累 NeedCase，或手动触发 `/api/match-process`。</div>
      ) : (
        <section class="cluster-grid">
          {clusterTopics.map(topic => (
            <article class="cluster-card">
              <div class="cluster-head">
                <span class="badge">{topic.status === 'observed' ? '观察中' : topic.status}</span>
                <span class="badge">{topic.source === 'inspiration' ? '站主灵感' : `${topic.density} 条需求`}</span>
                <span class="badge">{topic.priority}</span>
              </div>
              <h2 class="cluster-title">{topic.title}</h2>
              <div class="cluster-meta">
                <div><span class="meta-label">角色分布：</span>{roleText(topic)}</div>
                <div><span class="meta-label">代表需求：</span>{topic.representativeNeed}</div>
                <div><span class="meta-label">已有相关：</span>{relatedText(topic)}</div>
              </div>
              <div class="cluster-actions">
                <a class="btn btn-primary" href={`/admin/brief?topicId=${topic.topicId}`}>生成简报</a>
                <a class="btn" href="/admin/topics">去选题池</a>
              </div>
            </article>
          ))}
        </section>
      )
    ) : (
      <>
        <nav class="review-tabs">
          {reviewStatuses.map((status, index) => (
            <button class={`review-tab ${index === 0 ? 'active' : ''}`} data-tab={status}>
              {reviewStatusConfig[status].label}<span class="badge">{reviewItems[status].length}</span>
            </button>
          ))}
        </nav>

        {reviewStatuses.map((status, index) => (
          <section class={`tab-panel ${index === 0 ? 'active' : ''}`} data-panel={status}>
            {reviewItems[status].length === 0 ? (
              <div class="empty">{status === 'pending' ? '暂无待复盘需求' : '暂无记录'}</div>
            ) : reviewItems[status].map(item => {
              const nc = item.needCase;
              const cfg = reviewStatusConfig[nc.adminReviewStatus] ?? reviewStatusConfig.pending;
              return (
                <article class="case-card" data-need-case-id={nc.needCaseId}>
                  <div class="case-head">
                    <span class="badge" style={`background:${cfg.bg};color:${cfg.color}`}>{cfg.label}</span>
                    <span class="badge">{feedbackLabels[nc.feedbackStatus] ?? nc.feedbackStatus}</span>
                    {nc.sliceInferred === false && <span class="badge">低置信切片</span>}
                    <span class="case-time">{formatTime(nc.createdAt)}</span>
                  </div>
                  <h2 class="case-summary">{nc.needSummary}</h2>
                  <div class="case-meta">
                    <div><span class="meta-label">画像：</span>{profileSummary(item)}</div>
                    {nc.frictionLayer && <div><span class="meta-label">卡点：</span>{nc.frictionLayer}</div>}
                    {nc.recommendedAbilityType && <div><span class="meta-label">能力方向：</span>{nc.recommendedAbilityType}</div>}
                  </div>
                  {nc.agentRecommendation?.bridge && <div class="case-bridge">{nc.agentRecommendation.bridge}</div>}
                  {status === 'pending' && (
                    <div class="case-actions">
                      <button class="btn" data-action="accepted" data-id={nc.needCaseId}>采纳</button>
                      <button class="btn" data-action="deferred" data-id={nc.needCaseId}>暂缓</button>
                      <button class="btn" data-action="ignored" data-id={nc.needCaseId}>忽略</button>
                      <button class="btn" data-note-toggle={nc.needCaseId}>备注</button>
                      <input class="note-input" data-note-input={nc.needCaseId} placeholder="可选：记录复盘判断依据" />
                    </div>
                  )}
                </article>
              );
            })}
          </section>
        ))}
      </>
    )}
  </main>

  <script>
    document.querySelectorAll('.review-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.tab;
        document.querySelectorAll('.review-tab').forEach(item => item.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(item => item.classList.remove('active'));
        btn.classList.add('active');
        document.querySelector(`[data-panel="${tab}"]`)?.classList.add('active');
      });
    });

    document.querySelectorAll('[data-note-toggle]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.noteToggle;
        const input = document.querySelector(`[data-note-input="${id}"]`);
        input?.classList.toggle('visible');
      });
    });

    document.querySelectorAll('.btn[data-action]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLElement;
        const needCaseId = el.dataset.id;
        const status = el.dataset.action;
        if (!needCaseId || !status) return;
        const card = el.closest('.case-card') as HTMLElement | null;
        const note = card?.querySelector<HTMLInputElement>('.note-input.visible')?.value.trim();
        try {
          const res = await fetch('/api/admin/review', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ needCaseId, status, note }),
          });
          const data = await res.json();
          if (res.ok && data.ok) {
            if (card) card.style.opacity = '0.35';
          } else {
            alert(data.error || '操作失败');
          }
        } catch {
          alert('网络异常，请重试。');
        }
      });
    });

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/admin/auth', { method: 'DELETE' });
      window.location.href = '/admin/login';
    });
  </script>
</body>
</html>
