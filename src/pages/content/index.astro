---
import ContentFilterTabs from '@/components/content-universe/ContentFilterTabs.astro';
import ContentUniverseCard from '@/components/content-universe/ContentUniverseCard.astro';
import Base from '@/layouts/Base.astro';
import { getPublishedContentItems } from '@/knowledge/content';
import {
  contentSpaces,
  itemBelongsToSpace,
  type ContentSpace,
} from '@/knowledge/content-model';

export const prerender = true;

const contentItems = await getPublishedContentItems();
const activeSpace: ContentSpace = 'all';

const counts = Object.fromEntries(
  contentSpaces.map((space) => [
    space.id,
    contentItems.filter((item) => itemBelongsToSpace(item, space.id)).length,
  ])
) as Record<ContentSpace, number>;

function getItemSpaces(item: (typeof contentItems)[number]): ContentSpace[] {
  return contentSpaces
    .filter((space) => itemBelongsToSpace(item, space.id))
    .map((space) => space.id);
}
---

<Base
  title="内容宇宙 · Walker"
  description="Walker 的内容宇宙：点子是驱动力，生活是土壤，所有公开内容在这里按空间重新组织。"
  ogDescription="Walker 的内容宇宙：点子是驱动力，生活是土壤，所有公开内容在这里按空间重新组织。"
>

  <section class="content-universe-shell" aria-labelledby="content-universe-title" style="max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 4rem;">
    <div class="content-hero panel-glass">
      <div class="hero-kicker">CONTENT UNIVERSE</div>
      <h2 id="content-universe-title">点子是驱动力，生活是土壤。</h2>
      <p>
        这里把文章、工具、项目、点子与生活记录放回同一个系统里：点子负责推动下一步行动，生活负责提供真实的感受、材料与边界。内容不是孤立条目，而是一张持续生长的个人前进地图。
      </p>
      <div class="hero-stats" aria-label="内容宇宙概览">
        <span><strong>{counts.all}</strong> 条公开内容</span>
        <span><strong>{counts.ideas}</strong> 个点子火花</span>
        <span><strong>{counts.life}</strong> 条生活现场</span>
      </div>
    </div>

    <ContentFilterTabs activeSpace={activeSpace} counts={counts} />

    <p class="active-space-note" data-active-space-note aria-live="polite">
      当前显示：全部内容。
    </p>

    <div class="content-grid" aria-label="内容列表">
      {contentItems.map((item) => (
        <ContentUniverseCard item={item} spaces={getItemSpaces(item)} />
      ))}
    </div>

    <div class="empty-state panel-glass" data-empty-state hidden>
      <p class="empty-title">这个内容空间暂时还没有公开内容。</p>
      <p class="empty-copy">等下一条记录长出来，它会出现在这里。</p>
    </div>
  </section>
</Base>

<style>
  .content-universe-shell {
    display: grid;
    gap: 1.5rem;
  }

  .content-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(1.35rem, 3vw, 2.2rem);
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.12);
    border-radius: 1.75rem;
    background:
      radial-gradient(circle at 12% 18%, rgba(var(--color-brand-rgb, 196, 112, 74), 0.18), transparent 32%),
      radial-gradient(circle at 86% 8%, rgba(var(--color-accent-rgb, 91, 141, 115), 0.12), transparent 30%),
      rgba(var(--color-surface-rgb, 255, 255, 255), 0.58);
  }

  .content-hero::after {
    content: '';
    position: absolute;
    right: -4rem;
    bottom: -5rem;
    width: 15rem;
    height: 15rem;
    border-radius: 999px;
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
    filter: blur(2px);
    pointer-events: none;
  }

  .hero-kicker {
    position: relative;
    z-index: 1;
    color: var(--color-brand, #c4704a);
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
  }

  .content-hero h2 {
    position: relative;
    z-index: 1;
    max-width: 13em;
    margin: 0.7rem 0 0;
    color: var(--color-heading, var(--color-text, #3f3027));
    font-family: var(--font-heading, inherit);
    font-size: clamp(1.7rem, 4vw, 3rem);
    font-weight: 850;
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .content-hero p {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    margin: 1rem 0 0;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.66));
    font-size: 0.98rem;
    line-height: 1.9;
  }

  .hero-stats {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.35rem;
  }

  .hero-stats span {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.5rem 0.7rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
    border-radius: 999px;
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.55);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.62));
    font-size: 0.78rem;
    font-weight: 700;
  }

  .hero-stats strong {
    color: var(--color-brand, #c4704a);
    font-family: var(--font-mono, monospace);
    font-size: 0.9rem;
  }

  .active-space-note {
    margin: -0.35rem 0 0;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.6));
    font-size: 0.85rem;
    font-weight: 650;
  }
  .content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .content-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .empty-state {
    padding: 3rem 1.5rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.12);
    border-radius: 1.5rem;
    text-align: center;
  }

  .empty-title {
    margin: 0;
    color: var(--color-heading, var(--color-text, #3f3027));
    font-family: var(--font-heading, inherit);
    font-size: 1.1rem;
    font-weight: 800;
  }

  .empty-copy {
    margin: 0.45rem 0 0;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.58));
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .content-universe-shell {
      gap: 1rem;
    }

    .hero-stats {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-stats span {
      justify-content: space-between;
    }
  }
</style>

<script>
  let contentAbort: AbortController | null = null;

  const validSpaces = new Set(['all', 'progress', 'life', 'learning', 'tools', 'works', 'ideas']);
  const spaceLabels = new Map([
    ['all', '全部内容'],
    ['progress', '前进系统'],
    ['life', '生活现场'],
    ['learning', '学习笔记'],
    ['tools', '工具资源'],
    ['works', '作品项目'],
    ['ideas', '点子火花'],
  ]);

  function getRequestedSpace() {
    const requestedSpace = new URLSearchParams(location.search).get('space');
    return requestedSpace && validSpaces.has(requestedSpace) ? requestedSpace : 'all';
  }

  function updateContentFilter() {
    const activeSpace = getRequestedSpace();
    const cards = [...document.querySelectorAll('[data-spaces]')];
    const tabs = [...document.querySelectorAll('[data-space]')];
    const activeLabel = spaceLabels.get(activeSpace) ?? spaceLabels.get('all') ?? '全部内容';
    let visibleCount = 0;

    for (const card of cards) {
      const spaces = new Set((card.getAttribute('data-spaces') ?? '').split(' ').filter(Boolean));
      const isVisible = spaces.has(activeSpace);
      card.toggleAttribute('hidden', !isVisible);
      if (isVisible) visibleCount += 1;
    }

    for (const tab of tabs) {
      const isActive = tab.getAttribute('data-space') === activeSpace;
      tab.classList.toggle('is-active', isActive);
      if (isActive) {
        tab.setAttribute('aria-current', 'page');
      } else {
        tab.removeAttribute('aria-current');
      }
    }

    const note = document.querySelector('[data-active-space-note]');
    if (note) {
      note.textContent = `当前显示：${activeLabel}，共 ${visibleCount} 条。`;
    }

    const count = document.querySelector('#log-count');
    if (count) {
      count.textContent = `${visibleCount} 条`;
    }

    const emptyState = document.querySelector('[data-empty-state]');
    if (emptyState) {
      emptyState.toggleAttribute('hidden', visibleCount > 0);
    }
  }

  function initContentFilter() {
    contentAbort?.abort();
    contentAbort = new AbortController();
    const { signal } = contentAbort;

    updateContentFilter();
    window.addEventListener('popstate', updateContentFilter, { signal });
  }

  initContentFilter();
  document.addEventListener('astro:page-load', initContentFilter);
  document.addEventListener('astro:before-swap', () => {
    contentAbort?.abort();
    contentAbort = null;
  });
</script>