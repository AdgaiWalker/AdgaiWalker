---
import ContentFilterTabs from '@/components/content-universe/ContentFilterTabs.astro';
import ContentStreamItem from '@/components/content-universe/ContentStreamItem.astro';
import Base from '@/layouts/Base.astro';
import { getPublishedContentItems } from '@/knowledge/content';
import {
  contentSpaces,
  itemBelongsToSpace,
  SPACE_COLOR,
  type ContentSpace,
  type ContentSpaceMeta,
} from '@/knowledge/content-model';

export const prerender = true;

const allItems = await getPublishedContentItems();

const activeSpace: ContentSpace = 'all';

/** 排除 'all' 的具体空间（图例 + 归属计算共用） */
const concreteSpaces = contentSpaces.filter(
  (s): s is ContentSpaceMeta & { id: Exclude<ContentSpace, 'all'> } => s.id !== 'all',
);

/** 每项内容所属的具体空间（按 contentSpaces 顺序）——一次遍历算出，供筛选 data-spaces + 色点共用 */
const itemSpaces = new Map<string, Exclude<ContentSpace, 'all'>[]>(
  allItems.map((item) => [
    item.id,
    concreteSpaces.filter((s) => itemBelongsToSpace(item, s.id)).map((s) => s.id),
  ]),
);

const counts = Object.fromEntries(contentSpaces.map((s) => [s.id, 0])) as Record<ContentSpace, number>;
counts.all = allItems.length;
for (const spaces of itemSpaces.values()) {
  for (const s of spaces) counts[s] += 1;
}
---

<Base
  title="内容宇宙 · Walker"
  description="Walker 的内容宇宙：所有公开内容按时间倒序汇集，最新在上，持续生长。"
  ogDescription="Walker 的内容宇宙：所有公开内容按时间倒序汇集，最新在上，持续生长。"
  pureMode={true}
>
  <section class="stream-shell">
    <header class="stream-hero">
      <p class="stream-kicker">内容宇宙</p>
      <h1 class="stream-tagline">点子是<em>驱动力</em>，生活是<em>土壤</em>。</h1>
      <p class="stream-count">持续更新 · <strong>{counts.all}</strong> 篇</p>
    </header>

    <ContentFilterTabs activeSpace={activeSpace} counts={counts} />

    <p class="active-space-note" data-active-space-note aria-live="polite">
      当前显示：全部内容。
    </p>

    <div class="stream-list" aria-label="内容流">
      {allItems.map((item) => (
        <ContentStreamItem item={item} spaces={itemSpaces.get(item.id) ?? []} />
      ))}
    </div>

    <div class="empty-state" data-empty-state hidden>
      <p>这个内容空间暂时还没有公开内容。</p>
    </div>

    <footer class="stream-legend" aria-label="空间配色图例">
      {concreteSpaces.map((s) => (
        <span class="legend-item">
          <i class="legend-dot" style={`background:${SPACE_COLOR[s.id]}`}></i>
          {s.label}
        </span>
      ))}
    </footer>
  </section>
</Base>

<style>
  .stream-shell { max-width: 720px; margin: 0 auto; padding: 3rem 1.5rem 4rem; }

  .stream-hero { margin-bottom: 1.5rem; }
  .stream-kicker { margin: 0; color: var(--color-muted, #a8a29e); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; }
  .stream-tagline { margin: 0.6rem 0 0; font-size: clamp(1.4rem, 3vw, 1.9rem); line-height: 1.4; color: var(--color-heading, #2a2522); font-weight: 600; }
  .stream-tagline em { font-style: normal; color: var(--color-brand, #c4704a); }
  .stream-count { margin: 0.7rem 0 0; font-size: 0.78rem; color: var(--color-muted, #a8a29e); }
  .stream-count strong { color: var(--color-text-muted, #78716c); font-weight: 700; }

  .active-space-note { margin: 0.5rem 0 1rem; color: var(--color-muted, #a8a29e); font-size: 0.78rem; }

  .stream-list { margin-top: 0.5rem; }

  .empty-state { padding: 3rem 1rem; text-align: center; color: var(--color-muted, #a8a29e); font-size: 0.9rem; }

  .stream-legend { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2.5rem; padding-top: 1.2rem; border-top: 1px solid rgba(0,0,0,0.06); }
  .legend-item { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.72rem; color: var(--color-muted, #a8a29e); }
  .legend-dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }

  body.theme-aurora .stream-tagline,
  body.theme-sunset .stream-tagline,
  body.theme-mint .stream-tagline { color: var(--color-heading, #f5f5f4); }

  @media (max-width: 640px) {
    .stream-shell { padding: 2rem 1.25rem 3rem; }
  }
</style>

<script>
  import { contentSpaces } from '@/knowledge/content-model';

  let contentAbort: AbortController | null = null;

  const validSpaces = new Set<string>(contentSpaces.map((space) => space.id));
  const spaceLabels = new Map<string, string>(contentSpaces.map((space) => [space.id, space.label]));

  function getRequestedSpace() {
    const requestedSpace = new URLSearchParams(location.search).get('space');
    return requestedSpace && validSpaces.has(requestedSpace) ? requestedSpace : 'all';
  }

  function updateContentFilter() {
    const activeSpace = getRequestedSpace();
    const cards = [...document.querySelectorAll('[data-spaces]')];
    const tabs = [...document.querySelectorAll('[data-space]')];
    const activeLabel = spaceLabels.get(activeSpace) ?? spaceLabels.get('all') ?? '全部内容';
    let visibleCount = 0;

    for (const card of cards) {
      const spaces = new Set((card.getAttribute('data-spaces') ?? '').split(' ').filter(Boolean));
      const isVisible = activeSpace === 'all' || spaces.has(activeSpace);
      card.toggleAttribute('hidden', !isVisible);
      if (isVisible) visibleCount += 1;
    }

    for (const tab of tabs) {
      const isActive = tab.getAttribute('data-space') === activeSpace;
      tab.classList.toggle('is-active', isActive);
      if (isActive) tab.setAttribute('aria-current', 'page');
      else tab.removeAttribute('aria-current');
    }

    const note = document.querySelector('[data-active-space-note]');
    if (note) note.textContent = `当前显示：${activeLabel}，共 ${visibleCount} 条。`;

    const emptyState = document.querySelector('[data-empty-state]');
    if (emptyState) emptyState.toggleAttribute('hidden', visibleCount > 0);
  }

  function initContentFilter() {
    contentAbort?.abort();
    contentAbort = new AbortController();
    const { signal } = contentAbort;

    updateContentFilter();
    window.addEventListener('popstate', () => { updateContentFilter(); }, { signal });
  }

  initContentFilter();
  document.addEventListener('astro:page-load', initContentFilter);
  document.addEventListener('astro:before-swap', () => {
    contentAbort?.abort();
    contentAbort = null;
  });
</script>
