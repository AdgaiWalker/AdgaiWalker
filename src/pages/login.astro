---
/**
 * /login — 统一登录 / 注册页（专注版）
 *
 * 用 FullscreenLayout 剥离侧栏/页脚/背景特效，只剩居中卡片。
 * 服务端渲染：readSessionPayload 探测会话，已登录显示状态 + 登出。
 * 注册需邀请码；零 PII（不收邮箱/手机）。
 */
import FullscreenLayout from '@/layouts/FullscreenLayout.astro';
import { Icon } from 'astro-icon/components';
import { readSessionPayload } from '@/lib/account-auth';
import { createAccountStore } from '@/stores/account.store';

const session = readSessionPayload(Astro.request);
// 首次部署无账号时，显示站主初始化面板（凭 ADMIN_PASSWORD 一次性建 owner）
const needsBootstrap = !(await createAccountStore().exists());
---

<FullscreenLayout title="登录 / 注册 — iwalk.pro">
  <main class="auth-page">
    <div class="auth-shell">
      <a href="/" class="auth-brand" aria-label="返回首页">
        <Icon name="lucide:compass" width={22} height={22} />
        <span>Walker</span>
      </a>

      {needsBootstrap && (
        <section class="auth-card bootstrap-card">
          <span class="bootstrap-tag">首次部署 · 站主初始化</span>
          <h1>创建站主账号</h1>
          <p class="auth-sub">系统还没有账号。用 <code>ADMIN_PASSWORD</code> 一次性建 owner 账号；之后此面板自动隐藏。</p>
          <form class="auth-form" data-form="setup" autocomplete="off">
            <label class="field">
              <span>bootstrap 密钥（ADMIN_PASSWORD）</span>
              <input type="password" name="adminPassword" required placeholder="部署时配置的 ADMIN_PASSWORD" />
            </label>
            <label class="field">
              <span>站主用户名</span>
              <input type="text" name="ownerUsername" required placeholder="如 owner" />
            </label>
            <label class="field">
              <span>站主密码（≥8 位）</span>
              <input type="password" name="ownerPassword" required minlength="8" placeholder="至少 8 位" />
            </label>
            <p class="auth-error" data-error="setup" hidden></p>
            <button class="btn primary" type="submit">创建并登录</button>
          </form>
        </section>
      )}

      {session ? (
        <section class="auth-card">
          <h1>已登录</h1>
          <p class="auth-sub">身份：{session.role === 'admin' ? '站主' : '用户'}</p>
          <div class="auth-actions">
            <a class="btn primary" href={session.role === 'admin' ? '/admin' : '/tools'}>进入</a>
            <button class="btn ghost" id="logout-btn">登出</button>
          </div>
        </section>
      ) : (
        <section class="auth-card">
          <div class="auth-seg" role="tablist" aria-label="登录或注册">
            <button class="seg-btn active" data-tab="login" role="tab" aria-selected="true">登录</button>
            <button class="seg-btn" data-tab="register" role="tab" aria-selected="false">注册</button>
          </div>

          <form class="auth-form" data-form="login" autocomplete="on">
            <label class="field">
              <span>用户名</span>
              <input type="text" name="username" required autocomplete="username" placeholder="用户名" />
            </label>
            <label class="field">
              <span>密码</span>
              <input type="password" name="password" required autocomplete="current-password" placeholder="密码" />
            </label>
            <p class="auth-error" data-error="login" hidden></p>
            <button class="btn primary" type="submit">登录</button>
          </form>

          <form class="auth-form" data-form="register" hidden autocomplete="on">
            <label class="field">
              <span>邀请码</span>
              <input type="text" name="inviteCode" required placeholder="输入邀请码" />
            </label>
            <label class="field">
              <span>用户名</span>
              <input type="text" name="username" required placeholder="2-20 位中英文/数字/下划线" />
            </label>
            <label class="field">
              <span>密码</span>
              <input type="password" name="password" required minlength="8" autocomplete="new-password" placeholder="至少 8 位" />
            </label>
            <label class="field">
              <span>一句话说说你是谁（可选）</span>
              <input type="text" name="personaAnchor" maxlength="10" placeholder="≤10 字" />
              <div class="chips">
                <button type="button" class="chip" data-anchor="学生">学生</button>
                <button type="button" class="chip" data-anchor="上班族">上班族</button>
                <button type="button" class="chip" data-anchor="自由职业">自由职业</button>
                <button type="button" class="chip" data-anchor="想搞副业">想搞副业</button>
              </div>
            </label>
            <label class="consent">
              <input type="checkbox" name="consent" required />
              <span>同意被 Walker 记住需求，用于改进选题</span>
            </label>
            <p class="auth-error" data-error="register" hidden></p>
            <button class="btn primary" type="submit">注册并进入</button>
          </form>

          <p class="auth-foot">站主与用户同一入口 · 忘密联系站主</p>
        </section>
      )}
    </div>
  </main>
</FullscreenLayout>

<style>
  .auth-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; }
  .auth-shell { width: 100%; max-width: 380px; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
  .auth-brand {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: var(--color-parchment, #1a2325);
    font-family: var(--font-heading); font-size: 1.15rem; font-weight: 700;
    text-decoration: none; opacity: 0.85; transition: opacity 0.2s;
  }
  .auth-brand:hover { opacity: 1; }

  .auth-card {
    width: 100%; padding: 2rem; border-radius: 18px;
    background: var(--color-card, rgba(255, 255, 255, 0.94));
    border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 14%, transparent);
    backdrop-filter: blur(20px);
    box-shadow: 0 18px 54px color-mix(in srgb, var(--color-parchment, #1a2325) 20%, transparent);
  }
  .auth-card h1 { margin: 0 0 0.25rem; font-size: 1.3rem; color: var(--color-parchment, #1a2325); }
  .auth-sub { margin: 0 0 1.25rem; font-size: 0.85rem; color: var(--color-parchment-dim, #64748b); line-height: 1.6; }

  .auth-seg {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.25rem; padding: 0.25rem;
    margin-bottom: 1.5rem;
    background: color-mix(in srgb, var(--color-parchment, #1a2325) 8%, transparent);
    border-radius: 999px;
  }
  .seg-btn {
    padding: 0.6rem; border: none; border-radius: 999px; background: transparent;
    color: var(--color-parchment-dim, #64748b); font-size: 0.9rem; font-weight: 600;
    cursor: pointer; transition: all 0.2s ease;
  }
  .seg-btn.active { background: var(--color-brand, #35bfab); color: #fff; }

  .auth-form { display: flex; flex-direction: column; gap: 0.9rem; }
  .field { display: flex; flex-direction: column; gap: 0.3rem; }
  .field > span { font-size: 0.78rem; color: var(--color-parchment-dim, #64748b); font-weight: 600; }
  .field input {
    padding: 0.7rem 0.85rem; border-radius: 10px;
    border: 1.5px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent);
    background: color-mix(in srgb, var(--color-parchment, #1a2325) 4%, transparent);
    color: var(--color-parchment, #1a2325);
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .field input::placeholder { color: var(--color-parchment-dim, #9ca3af); opacity: 0.7; }
  .field input:focus {
    outline: none;
    border-color: var(--color-brand, #35bfab);
    box-shadow: 0 0 0 3px var(--color-brand-glow, rgba(53, 191, 171, 0.2));
  }

  .chips { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.35rem; }
  .chip {
    padding: 0.2rem 0.6rem; border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent);
    background: transparent; color: var(--color-parchment-dim, #64748b);
    font-size: 0.78rem; cursor: pointer; transition: all 0.18s;
  }
  .chip:hover { color: var(--color-brand, #35bfab); border-color: var(--color-brand, #35bfab); }

  .consent { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: var(--color-parchment-dim, #64748b); }

  .auth-error { color: #ef4444; font-size: 0.82rem; margin: 0; font-weight: 500; }

  .btn {
    padding: 0.78rem 1rem; border-radius: 10px; border: none; cursor: pointer;
    font-size: 0.95rem; font-weight: 700; transition: opacity 0.2s, transform 0.05s;
  }
  .btn.primary { background: var(--color-brand, #35bfab); color: #fff; }
  .btn.ghost { background: transparent; color: var(--color-parchment, #1a2325); border: 1px solid color-mix(in srgb, var(--color-parchment, #1a2325) 16%, transparent); }
  .btn:active { transform: translateY(1px); }
  .btn:disabled { opacity: 0.55; cursor: not-allowed; }

  .auth-actions { display: flex; gap: 0.6rem; }
  .auth-actions .btn { flex: 1; }

  .auth-foot { margin: 1.25rem 0 0; text-align: center; font-size: 0.76rem; color: var(--color-parchment-dim, #9ca3af); }
  .bootstrap-card { border-color: var(--color-brand, #35bfab); box-shadow: 0 18px 54px var(--color-brand-glow, rgba(53, 191, 171, 0.24)); }
  .bootstrap-tag { display: inline-block; margin-bottom: 0.6rem; padding: 0.15rem 0.6rem; border-radius: 999px; background: var(--color-brand-glow, rgba(53, 191, 171, 0.16)); color: var(--color-brand, #35bfab); font-size: 0.72rem; font-weight: 700; }
  .bootstrap-card code { font-family: var(--font-mono, monospace); font-size: 0.82em; color: var(--color-parchment, #1a2325); }
</style>

<script>
  import { registerLifecycle } from '@/scripts/with-lifecycle';

  registerLifecycle(() => {
  const tabs = document.querySelectorAll<HTMLButtonElement>('.seg-btn');
  const forms = document.querySelectorAll<HTMLFormElement>('.auth-form');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.toggle('active', t === tab); t.setAttribute('aria-selected', t === tab ? 'true' : 'false'); });
      forms.forEach(f => { f.hidden = f.dataset.form !== tab.dataset.tab; });
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const input = chip.closest('.field')?.querySelector('input') as HTMLInputElement | null;
      if (input) { input.value = chip.dataset.anchor ?? ''; input.focus(); }
    });
  });

  async function submitForm(form: HTMLFormElement, url: string, errorEl: HTMLElement) {
    const data = Object.fromEntries(new FormData(form).entries());
    delete (data as Record<string, unknown>).consent;
    errorEl.hidden = true;
    const btn = form.querySelector<HTMLButtonElement>('button[type=submit]');
    if (btn) btn.disabled = true;
    try {
      const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const json = await res.json();
      if (res.ok && json.ok) {
        window.location.href = '/';
      } else {
        errorEl.textContent = json.reason || '操作失败，请重试。';
        errorEl.hidden = false;
      }
    } catch {
      errorEl.textContent = '网络错误，请重试。';
      errorEl.hidden = false;
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  const loginForm = document.querySelector<HTMLFormElement>('[data-form=login]');
  const loginErr = document.querySelector<HTMLElement>('[data-error=login]');
  loginForm?.addEventListener('submit', (e) => { e.preventDefault(); if (loginErr) submitForm(loginForm, '/api/auth/login', loginErr); });

  const regForm = document.querySelector<HTMLFormElement>('[data-form=register]');
  const regErr = document.querySelector<HTMLElement>('[data-error=register]');
  regForm?.addEventListener('submit', (e) => { e.preventDefault(); if (regErr) submitForm(regForm, '/api/auth/register', regErr); });

  const setupForm = document.querySelector<HTMLFormElement>('[data-form=setup]');
  const setupErr = document.querySelector<HTMLElement>('[data-error=setup]');
  setupForm?.addEventListener('submit', (e) => { e.preventDefault(); if (setupErr) submitForm(setupForm, '/api/auth/setup', setupErr); });

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.reload();
  });
  });
</script>
