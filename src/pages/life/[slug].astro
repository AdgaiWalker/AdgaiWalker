---
/**
 * /life/[slug] — 重定向到 /posts/[slug]
 * 保留 getStaticPaths 以生成旧 URL 的 HTML 文件。
 */
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('log', ({ data }) => data.published && data.category === 'life');
  return entries.map(entry => ({
    params: { slug: entry.id },
  }));
}

const { slug } = Astro.params;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={`/posts/${slug}`} />
    <meta http-equiv="refresh" content={`0;url=/posts/${slug}`} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting to <a href={`/posts/${slug}`}>{`/posts/${slug}`}</a>...</p>
  </body>
</html>
