---
import Base from '../layouts/Base.astro';
import WalkerProfile from '../components/WalkerProfile.astro';
import GreetingCard from '../components/GreetingCard.astro';
import NavigationConsole from '../components/NavigationConsole.astro';
import CalendarWidget from '../components/CalendarWidget.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import RandomRecommend from '../components/RandomRecommend.astro';
import RecentTraces from '../components/RecentTraces.astro';
import SearchModal from '../components/SearchModal.astro';
import LikeCounter from '../components/LikeCounter.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const logs = (await getCollection('log', ({ data }) => data.published))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latestPhoto = logs.find(l => l.data.type === 'photo');
const coverUrl = latestPhoto?.data.cover ?? "https://images.unsplash.com/photo-1551244072-5d12893278ab?q=80&w=800&auto=format&fit=crop";
---

<Base title="秋知 — 行过万里水路" theme="nature">

  <!-- 画板模式：绝对居中并根据窗口大小按比例缩放 -->
  <div class="fixed inset-0 flex items-center justify-center overflow-hidden pointer-events-none">
    <!-- 内容容器恢复指针事件 -->
    <div id="desktop-canvas" class="w-[1024px] pointer-events-auto transition-transform duration-300 origin-center flex justify-center">

      <!-- === 三栏 Bento Box 布局（错落感，但不交叉重叠） === -->
      <div class="grid grid-cols-[240px_380px_320px] justify-center gap-8 items-start w-full relative pb-10">

        <!-- ========================================= -->
        <!-- 左栏：资料与导航 -->
        <!-- ========================================= -->
        <div class="flex flex-col gap-8 mt-24">
          <!-- 个人资料卡 + 导航菜单 -->
          <div class="pop-in delay-1 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <WalkerProfile />
          </div>
          
          <!-- 最新文章 (轻微错开，不重叠) -->
          <div class="pop-in delay-2 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[32px] ml-4">
            <RecentTraces logs={logs.slice(0, 4)} />
          </div>
        </div>

        <!-- ========================================= -->
        <!-- 中栏：墙纸 + 问候 + 社交 + 推荐 -->
        <!-- ========================================= -->
        <!-- 中栏：整体往上提，错开左右两栏 -->
        <div class="flex flex-col items-center -mt-6">
          <!-- 顶部照片墙/壁纸展示 (Polaroid Collage Style) -->
          <div class="aspect-[4/3] w-full flex items-center justify-center overflow-visible pop-in delay-2 draggable-card cursor-grab mb-2">
             <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
               <div class="relative w-[90%] h-[90%]">
                 <div class="absolute inset-0 rotate-[-8deg] scale-[0.8] bg-white p-2 pb-10 shadow-lg rounded-sm translate-x-[-20%] translate-y-[5%] border border-black/[0.03]">
                   <img src="https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=400&auto=format&fit=crop" class="w-full h-full object-cover rounded-sm grayscale-[0.2]" />
                 </div>
                 <div class="absolute inset-0 rotate-[12deg] scale-[0.85] bg-white p-2 pb-10 shadow-lg rounded-sm translate-x-[20%] translate-y-[-10%] border border-black/[0.03]">
                   <img src="https://images.unsplash.com/photo-1493246507139-91e8bef99c02?q=80&w=400&auto=format&fit=crop" class="w-full h-full object-cover rounded-sm" />
                 </div>
                 <div class="absolute inset-0 rotate-[-1deg] scale-[0.95] bg-white p-2.5 pt-2.5 pb-12 shadow-2xl rounded-sm z-10 border border-black/[0.05]">
                   <img src={coverUrl} alt="Cover" onerror="this.src='https://images.unsplash.com/photo-1551244072-5d12893278ab?q=80&w=800&auto=format&fit=crop'" class="w-full h-full object-cover rounded-sm pointer-events-auto" loading="eager" />
                   <div class="absolute bottom-3 left-1/2 -translate-x-1/2 text-[11px] font-mono text-[#8a9ca0] italic font-medium tracking-wide">Moments</div>
                 </div>
               </div>
             </div>
          </div>

          <!-- 问候卡 (正常间距，不再负边距重叠) -->
          <div class="pop-in delay-3 w-full draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px] mt-4">
            <GreetingCard />
          </div>

          <!-- 社交按钮 -->
          <div class="flex flex-wrap items-center justify-center gap-3 pop-in delay-4 mt-6 draggable-card cursor-grab">
            <a href="https://github.com/AdgaiWalker" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-3 rounded-2xl bg-[#111] text-white hover:scale-105 transition-transform no-underline text-[14px] font-body font-medium shadow-sm">
              <iconify-icon icon="mdi:github" width="18" height="18"></iconify-icon>
              Github
            </a>
            <a href="https://space.bilibili.com/1029612512" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 px-5 py-3 rounded-2xl bg-white/70 text-[#fb7299] hover:scale-105 transition-transform no-underline text-[14px] font-body shadow-sm">
               <iconify-icon icon="ri:bilibili-fill" width="18" height="18"></iconify-icon>
               Bilibili
            </a>
            <a href="https://www.xiaohongshu.com/user/profile/689dd905000000001802921e" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 px-5 py-3 rounded-2xl bg-white/70 text-[#ff2442] hover:scale-105 transition-transform no-underline text-[14px] font-body shadow-sm">
               <iconify-icon icon="ri:xiaohongshu-fill" width="18" height="18"></iconify-icon>
               小红书
            </a>
            <a href="mailto:praxiswalker@gmail.com" class="w-[44px] h-[44px] rounded-2xl bg-white/70 text-brand flex items-center justify-center hover:scale-105 transition-transform no-underline shadow-sm">
              <iconify-icon icon="mingcute:mail-fill" width="18" height="18"></iconify-icon>
            </a>
          </div>

          <!-- 随机推荐 -->
          <div class="pop-in delay-5 mt-8 w-[95%] draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <RandomRecommend />
          </div>
        </div>

        <!-- ========================================= -->
        <!-- 右栏：小组件 -->
        <!-- ========================================= -->
        <div class="flex flex-col gap-6 mt-12 relative">
          <!-- 顶部写文章按钮 + 搜索 -->
          <div class="flex items-center justify-end gap-3 pop-in delay-2 draggable-card cursor-grab">
            <a href="/log" class="px-6 h-11 flex items-center justify-center gap-2 text-white bg-[#35bfab] hover:opacity-90 transition-opacity shadow-md no-underline font-body text-[14px] font-medium tracking-wide rounded-full border-none">
              <iconify-icon icon="lucide:pen-line" width="16" height="16"></iconify-icon>
              写文章
            </a>
            <button class="w-11 h-11 flex items-center justify-center text-parchment/40 hover:text-parchment transition-colors rounded-xl bg-white/30 border-none cursor-pointer">
              <iconify-icon icon="lucide:grip" width="20" height="20"></iconify-icon>
            </button>
          </div>

          <!-- 数字时钟 -->
          <div class="pop-in delay-3 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <NavigationConsole />
          </div>

          <!-- 日历 -->
          <div class="pop-in delay-4 ml-4 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <CalendarWidget />
          </div>

          <!-- 音乐播放器 (不再交叉，只给个左边距) -->
          <div class="pop-in delay-5 -ml-4 mt-2 w-[280px] draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <MusicPlayer />
          </div>
          
          <!-- 点赞按钮 (放在正常文档流并居中，约束宽度防止产生巨型阴影) -->
          <div class="flex justify-center pop-in delay-6 pt-4">
            <div class="w-max draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-full">
              <LikeCounter pagePath="/" />
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <style>
    /* 弹跳式进入动画 */
    .pop-in {
      animation: popInBounce 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      opacity: 0;
      transform: translateY(40px) scale(0.85);
      will-change: transform, opacity;
    }
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    .delay-4 { animation-delay: 0.4s; }
    .delay-5 { animation-delay: 0.5s; }
    .delay-6 { animation-delay: 0.6s; }

    @keyframes popInBounce {
      0% {
        opacity: 0;
        transform: translateY(40px) scale(0.85);
      }
      100% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
    
    .cursor-grab {
      cursor: grab !important;
    }
    .cursor-grabbing {
      cursor: grabbing !important;
    }
  </style>

  <script>
    // 画板缩放逻辑：始终保证 1024x800 的画板完整显示在屏幕中心
    function resizeCanvas() {
      const canvas = document.getElementById('desktop-canvas');
      if (!canvas) return;
      const CANVAS_WIDTH = 1024;
      const CANVAS_HEIGHT = 860;
      const scaleX = window.innerWidth / CANVAS_WIDTH;
      const scaleY = window.innerHeight / CANVAS_HEIGHT;
      let scale = Math.min(scaleX, scaleY);
      scale = Math.min(scale, 1.2);
      canvas.style.transform = `scale(${scale})`;
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();
    
    // === 自由拖拽逻辑 ===
    function initDraggables() {
      const draggables = document.querySelectorAll('.draggable-card');
      let activeItem: HTMLElement | null = null;
      let initialX = 0, initialY = 0;

      draggables.forEach((item: any) => {
        // 初始化存储坐标数据
        if (!item.dataset.x) item.dataset.x = '0';
        if (!item.dataset.y) item.dataset.y = '0';

        const onDragStart = (e: MouseEvent | TouchEvent) => {
          // 如果点击的是链接或按钮，不触发拖拽
          const target = e.target as HTMLElement;
          if (target.closest('a') || target.closest('button')) return;

          activeItem = item;
          activeItem.classList.remove('cursor-grab');
          activeItem.classList.add('cursor-grabbing');
          
          // 提升层级，防止被遮挡
          activeItem.style.zIndex = '1000';

          const clientX = e.type.includes('mouse') ? (e as MouseEvent).clientX : (e as TouchEvent).touches[0].clientX;
          const clientY = e.type.includes('mouse') ? (e as MouseEvent).clientY : (e as TouchEvent).touches[0].clientY;

          initialX = clientX - parseFloat(activeItem.dataset.x);
          initialY = clientY - parseFloat(activeItem.dataset.y);
        };

        item.addEventListener('mousedown', onDragStart);
        item.addEventListener('touchstart', onDragStart, { passive: true });
      });

      const onDragMove = (e: MouseEvent | TouchEvent) => {
        if (!activeItem) return;
        
        const clientX = e.type.includes('mouse') ? (e as MouseEvent).clientX : (e as TouchEvent).touches[0].clientX;
        const clientY = e.type.includes('mouse') ? (e as MouseEvent).clientY : (e as TouchEvent).touches[0].clientY;

        const currentX = clientX - initialX;
        const currentY = clientY - initialY;

        activeItem.dataset.x = currentX.toString();
        activeItem.dataset.y = currentY.toString();

        // 应用拖拽时的 transform，并加上悬浮感 (scale) 和倾斜
        activeItem.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) scale(1.03) rotate(1deg)`;
      };

      const onDragEnd = () => {
        if (!activeItem) return;
        activeItem.classList.remove('cursor-grabbing');
        activeItem.classList.add('cursor-grab');
        activeItem.style.zIndex = '10'; // 恢复默认的高层级
        
        // 恢复 transform，只保留位移
        activeItem.style.transform = `translate3d(${activeItem.dataset.x}px, ${activeItem.dataset.y}px, 0)`;
        activeItem = null;
      };

      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('touchmove', onDragMove, { passive: true });
      document.addEventListener('mouseup', onDragEnd);
      document.addEventListener('touchend', onDragEnd);
    }

    initDraggables();
    document.addEventListener('astro:after-swap', () => {
      resizeCanvas();
      initDraggables();
    });
  </script>
</Base>
