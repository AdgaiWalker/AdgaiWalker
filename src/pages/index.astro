---
import Base from '../layouts/Base.astro';
import WalkerProfile from '../components/WalkerProfile.astro';
import GreetingCard from '../components/GreetingCard.astro';
import NavigationConsole from '../components/NavigationConsole.astro';
import CalendarWidget from '../components/CalendarWidget.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import RandomRecommend from '../components/RandomRecommend.astro';
import RecentTraces from '../components/RecentTraces.astro';
import DockShowcase from '../components/DockShowcase.astro';

import LikeCounter from '../components/LikeCounter.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const allLogs = await getCollection('log', ({ data }) => data.published);
const aiLogs = allLogs
  .filter(log => log.data.category === 'ai')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Walker — 行过万里水路" theme="nature">

  <div class="fixed inset-0 flex items-center justify-center overflow-hidden pointer-events-none">
    <div id="desktop-canvas" class="w-[1060px] pointer-events-auto transition-transform duration-300 origin-center flex justify-center">

      {/* === 三栏 Bento Box 布局 === */}
      <div class="grid grid-cols-[240px_400px_320px] justify-center gap-6 items-start w-full relative pb-10">

        {/* ========================================= */}
        {/* 左栏：身份 + 最近文章 */}
        {/* ========================================= */}
        <div class="flex flex-col gap-5 mt-20">
          <div class="pop-in delay-1 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <WalkerProfile />
          </div>

          <div class="pop-in delay-2 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[32px] ml-3">
            <RecentTraces logs={aiLogs.slice(0, 4)} />
          </div>

          {/* 搜索入口 */}
          <div class="pop-in delay-3 ml-1">
            <button
              class="w-full flex items-center gap-3 px-5 py-3.5 rounded-2xl bg-white/40 border border-white/60 text-parchment-dim/60 hover:bg-white/60 hover:text-parchment-dim transition-all text-[13px] font-body tracking-wide cursor-pointer backdrop-blur-sm"
              id="search-trigger"
              aria-label="搜索"
            >
              <iconify-icon icon="lucide:search" width="15" height="15"></iconify-icon>
              <span class="flex-1 text-left">搜索文章...</span>
              <span class="flex items-center gap-1">
                <span class="kbd">⌘</span>
                <span class="kbd">K</span>
              </span>
            </button>
          </div>
        </div>

        {/* ========================================= */}
        {/* 中栏：装备库 + 问候 + 社交 */}
        {/* ========================================= */}
        <div class="flex flex-col items-center -mt-4">
          {/* 装备库展示卡（核心钩子） */}
          <div class="pop-in delay-1 w-full draggable-card cursor-grab rounded-[40px]">
            <DockShowcase />
          </div>

          {/* 问候卡 → 关于我 */}
          <a href="/about" class="block pop-in delay-3 w-full draggable-card cursor-grab rounded-[40px] mt-5 no-underline group/greeting transition-all hover:shadow-xl hover:-translate-y-1">
            <div class="relative">
              <GreetingCard />
              <div class="absolute bottom-4 right-5 opacity-0 group-hover/greeting:opacity-60 transition-opacity text-parchment-dim">
                <iconify-icon icon="lucide:arrow-right" width="16" height="16"></iconify-icon>
              </div>
            </div>
          </a>

          {/* 社交按钮 */}
          <div class="flex flex-wrap items-center justify-center gap-2.5 pop-in delay-4 mt-5 draggable-card cursor-grab">
            <a href="https://github.com/AdgaiWalker" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-2.5 rounded-full bg-[#111]/90 text-white/90 hover:bg-[#111] hover:text-white hover:scale-105 transition-all no-underline text-[13px] font-body font-medium shadow-sm backdrop-blur-sm">
              <iconify-icon icon="mdi:github" width="17" height="17"></iconify-icon>
              Github
            </a>
            <a href="https://space.bilibili.com/1029612512" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-white/60 text-[#fb7299] hover:bg-white/80 hover:scale-105 transition-all no-underline text-[13px] font-body font-medium shadow-sm backdrop-blur-sm border border-white/60">
               <iconify-icon icon="ri:bilibili-fill" width="17" height="17"></iconify-icon>
               Bilibili
            </a>
            <a href="mailto:praxiswalker@gmail.com" class="w-[40px] h-[40px] rounded-full bg-white/60 text-brand flex items-center justify-center hover:bg-white/80 hover:scale-105 transition-all no-underline shadow-sm backdrop-blur-sm border border-white/60">
              <iconify-icon icon="lucide:mail" width="17" height="17"></iconify-icon>
            </a>
          </div>

          {/* 随机推荐 */}
          <div class="pop-in delay-5 mt-6 w-[95%] draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <RandomRecommend />
          </div>
        </div>

        {/* ========================================= */}
        {/* 右栏：小组件 */}
        {/* ========================================= */}
        <div class="flex flex-col gap-5 mt-10 relative">
          <div class="pop-in delay-3 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <NavigationConsole />
          </div>

          <div class="pop-in delay-4 ml-3 draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <CalendarWidget />
          </div>

          <div class="pop-in delay-5 -ml-3 mt-1 w-[280px] draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[40px]">
            <MusicPlayer />
          </div>

          <div class="flex justify-center pop-in delay-6 pt-3">
            <div class="w-max draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-full">
              <LikeCounter pagePath="/" />
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  {/* 底部签名线 */}
  <div class="fixed bottom-4 left-1/2 -translate-x-1/2 z-50 flex items-center gap-2 text-[11px] font-mono text-parchment/25 tracking-wider pop-in delay-6" style="animation-delay: 1s;">
    <span class="status-dot"></span>
    <span>Walker · 行过万里水路</span>
  </div>

  <style>
    .pop-in {
      animation: popInSpring 0.9s cubic-bezier(0.22, 1.2, 0.36, 1) forwards;
      opacity: 0;
      transform: translateY(30px) scale(0.92);
      will-change: transform, opacity;
    }
    .delay-1 { animation-delay: 0.08s; }
    .delay-2 { animation-delay: 0.16s; }
    .delay-3 { animation-delay: 0.24s; }
    .delay-4 { animation-delay: 0.32s; }
    .delay-5 { animation-delay: 0.42s; }
    .delay-6 { animation-delay: 0.52s; }

    @keyframes popInSpring {
      0% {
        opacity: 0;
        transform: translateY(30px) scale(0.92);
      }
      60% {
        opacity: 1;
        transform: translateY(-4px) scale(1.01);
      }
      100% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .cursor-grab {
      cursor: grab !important;
    }
    .cursor-grabbing {
      cursor: grabbing !important;
    }
  </style>

  <script>
    function resizeCanvas() {
      const canvas = document.getElementById('desktop-canvas');
      if (!canvas) return;
      const CANVAS_WIDTH = 1060;
      const CANVAS_HEIGHT = 860;
      const scaleX = window.innerWidth / CANVAS_WIDTH;
      const scaleY = window.innerHeight / CANVAS_HEIGHT;
      let scale = Math.min(scaleX, scaleY);
      scale = Math.min(scale, 1.15);
      canvas.style.transform = `scale(${scale})`;
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    function initDraggables() {
      const draggables = document.querySelectorAll('.draggable-card');
      let activeItem: HTMLElement | null = null;
      let initialX = 0, initialY = 0;

      draggables.forEach((item: any) => {
        if (!item.dataset.x) item.dataset.x = '0';
        if (!item.dataset.y) item.dataset.y = '0';

        const onDragStart = (e: MouseEvent | TouchEvent) => {
          const target = e.target as HTMLElement;
          if (target.closest('a') || target.closest('button')) return;

          activeItem = item;
          if (!activeItem) return;
          activeItem.classList.remove('cursor-grab');
          activeItem.classList.add('cursor-grabbing');
          activeItem.style.zIndex = '1000';

          const clientX = e.type.includes('mouse') ? (e as MouseEvent).clientX : (e as TouchEvent).touches[0].clientX;
          const clientY = e.type.includes('mouse') ? (e as MouseEvent).clientY : (e as TouchEvent).touches[0].clientY;

          initialX = clientX - parseFloat(activeItem.dataset.x || '0');
          initialY = clientY - parseFloat(activeItem.dataset.y || '0');
        };

        item.addEventListener('mousedown', onDragStart);
        item.addEventListener('touchstart', onDragStart, { passive: true });
      });

      const onDragMove = (e: MouseEvent | TouchEvent) => {
        if (!activeItem) return;

        const clientX = e.type.includes('mouse') ? (e as MouseEvent).clientX : (e as TouchEvent).touches[0].clientX;
        const clientY = e.type.includes('mouse') ? (e as MouseEvent).clientY : (e as TouchEvent).touches[0].clientY;

        const currentX = clientX - initialX;
        const currentY = clientY - initialY;

        activeItem.dataset.x = currentX.toString();
        activeItem.dataset.y = currentY.toString();

        activeItem.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) scale(1.02) rotate(0.5deg)`;
      };

      const onDragEnd = () => {
        if (!activeItem) return;
        activeItem.classList.remove('cursor-grabbing');
        activeItem.classList.add('cursor-grab');
        activeItem.style.zIndex = '10';
        activeItem.style.transform = `translate3d(${activeItem.dataset.x}px, ${activeItem.dataset.y}px, 0)`;
        activeItem = null;
      };

      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('touchmove', onDragMove, { passive: true });
      document.addEventListener('mouseup', onDragEnd);
      document.addEventListener('touchend', onDragEnd);
    }

    document.addEventListener('astro:page-load', () => {
      resizeCanvas();
      initDraggables();
    });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        const modal = document.getElementById('search-modal');
        if (modal) {
          modal.classList.toggle('hidden');
        }
      }
    });
  </script>
</Base>
