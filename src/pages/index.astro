---
import Base from '../layouts/Base.astro';
import HomeCanvas from '../components/home/HomeCanvas.astro';
import SparkBoxModal from '../components/home/SparkBoxModal.astro';
import CustomPalette from '../components/home/CustomPalette.astro';
import CanvasZoomControls from '../components/home/CanvasZoomControls.astro';
import { getPublishedPosts, getPublishedResources, getPublishedProjects, getPublishedIdeas } from '@/lib/content';

export const prerender = true;

const recentLogs = await getPublishedPosts();
const toolEntries = await getPublishedResources();
const projectEntries = await getPublishedProjects();
const ideaEntries = await getPublishedIdeas();
---

<Base title="Walker — 行过万里水路" theme="nature">
  <HomeCanvas recentLogs={recentLogs} toolEntries={toolEntries} projectEntries={projectEntries} ideaEntries={ideaEntries} />
  <SparkBoxModal />
  <CustomPalette />
  <CanvasZoomControls />

  <script>
    import '../scripts/home-canvas';
  </script>
</Base>
