---
/**
 * /about — 关于
 * 全屏 Hero 视频 + 时代背景 + 引路人定位 + 航行日志 + 邀请
 * 使用 FullscreenLayout
 * 时间轴数据来自 src/data/site-stats.json
 */
import FullscreenLayout from '../../layouts/FullscreenLayout.astro';
import LikeCounter from '../../components/LikeCounter.astro';
import AboutSiteTab from '../../components/about/AboutSiteTab.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import avatar from '/public/images/秋知（我的头像）.jpg';
import stats from '@/data/site-stats.json';
import { getPublishedContentItems } from '@/lib/content';
import { contentSpaces, itemBelongsToSpace } from '@/lib/content-model';

export const prerender = true;

const { personalTimeline } = stats;

const contentItems = await getPublishedContentItems();
const contentCounts = contentSpaces.map(space => ({
  ...space,
  count: contentItems.filter(item => itemBelongsToSpace(item, space.id)).length,
}));
const totalLikesPlaceholder = 'Supabase 统计中';
---

<FullscreenLayout
  title="关于 — Walker"
  description="秋知 (Walker) — 用点子连接人与 AI，将想法点石成金。"
>
  {/* ===== 全局 Orbs 流光自适应背景 ===== */}
  <div class="fixed inset-0 -z-30 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="ambient-orb ambient-orb-1" style="background-color: var(--orb-color-1, #fee196);"></div>
    <div class="ambient-orb ambient-orb-2" style="background-color: var(--orb-color-2, #ffafc8);"></div>
    <div class="ambient-orb ambient-orb-3" style="background-color: var(--orb-color-3, #a0f0ff);"></div>
    <div class="ambient-orb ambient-orb-4" style="background-color: var(--orb-color-4, #b4f5cd);"></div>
  </div>

  {/* ===== 1. Hero 区域 ===== */}
  <section class="hero-section" id="hero-section">
    <div class="hero-bg">
      <video
        class="hero-bg-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster="/video/A-storyboard-2.mp4"
      >
        <source src="/video/A-storyboard-2.mp4" type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content">
      <div class="hero-badge">
        <span class="hero-dot"></span>
        <span>探索中</span>
      </div>
      <h1 class="hero-title">Walker</h1>
      <p class="hero-tagline">用点子连接人与 AI</p>
      <p class="hero-sub-tagline">用点子驱动 AI，点石成金，最终去到一个没有重复工作的地方</p>
      <p class="hero-era-line">AI 改变了规则。从"好厉害"到"我能用它做什么"之间，缺一条路。我正在走。</p>

      {/* Tab 切换按钮 */}
      <div class="about-tabs" id="about-tabs">
        <button class="about-tab-btn is-active" data-tab="me" type="button">
          <Icon name="lucide:user" width={14} height={14} />
          关于我
        </button>
        <button class="about-tab-btn" data-tab="site" type="button">
          <Icon name="lucide:globe" width={14} height={14} />
          关于站
        </button>
      </div>
    </div>

    <div class="hero-scroll-hint" id="scroll-hint">
      <Icon name="lucide:chevron-down" width={24} height={24} />
    </div>
  </section>

  {/* ===== "关于我" Tab 内容 ===== */}
  <div class="about-tab-panel" id="about-me-content">

  {/* ===== 2. 我为什么站在这里 ===== */}
  <section class="guide-section py-20 px-4 sm:px-6 flex justify-center" id="guide-section">
    <div class="about-card panel-glass max-w-[620px] w-full p-8 sm:p-10 relative overflow-hidden">

      {/* 头像 + 名字 */}
      <div class="about-avatar-wrapper flex flex-col items-center mb-6">
        <div class="about-avatar border-2 border-[var(--color-brand)] p-0.5 rounded-full overflow-hidden shadow-lg transition-transform duration-500 hover:rotate-6">
          <Image src={avatar} alt="秋知" width={96} height={96} class="rounded-full object-cover" />
        </div>
        <h2 class="about-name text-2xl font-bold mt-4 flex items-center gap-2">
          秋知 <span class="about-name-en text-sm font-mono text-parchment-dim">Walker</span>
        </h2>
      </div>

      {/* 叙事文案 */}
      <div class="text-sm leading-relaxed text-parchment/80 space-y-4">
        <p>
          Walker 不是一个人名，而是一种状态：带着自己的目标，准备出发、正在出发、歇会再出发。
        </p>
        <p>
          空乘专业给了我时间，马哲给了我方法，AI 给了我路。
        </p>
        <p>
          我不是在学 AI，而是在用 AI 解决真实问题。
        </p>
      </div>

      {/* 马克思名言 */}
      <div class="bio-quote-callout p-5 rounded-2xl border border-[var(--color-nav-border)] bg-[var(--color-brand-glow)] my-6 relative overflow-hidden">
        <div class="absolute right-4 bottom-1 text-[var(--color-brand)] opacity-[0.06] select-none pointer-events-none" style="font-size: 5rem; font-family: Georgia, serif;">"</div>
        <p class="font-heading text-[14px] font-bold text-parchment leading-relaxed text-center italic m-0">
          "哲学家们只是用不同的方式解释世界，问题在于改变世界。"
        </p>
        <p class="text-[9px] font-mono tracking-widest text-parchment-dim opacity-50 uppercase mt-2 text-center">
          —— 马克思
        </p>
      </div>

      {/* 致谢 */}
      <div class="panel-glass p-5 rounded-2xl border-l-3 border-brand relative overflow-hidden my-6">
        <div class="absolute top-3 right-4 border-2 border-dashed border-brand/40 p-1 text-[9px] text-brand select-none opacity-40 font-mono tracking-widest">
          航行信戳
        </div>
        <h4 class="text-sm font-bold mb-3 flex items-center gap-2 text-brand">
          <Icon name="lucide:heart" width={16} height={16} />
          致我的引路人与恩师
        </h4>
        <p class="text-xs leading-relaxed text-parchment/70 italic">
          "一路走来，秋芝引我入门，海哥（海拉鲁编程客）带我成长，刘、于二老在迷茫时点醒方向。感谢虽不理解但给予经济支持的亲人。水路万里，停靠因你们而有据可循。"
        </p>
      </div>

      <div class="border-b border-[var(--color-nav-border)] mb-6 opacity-40"></div>

      {/* 社交链接 */}
      <div class="about-social flex flex-wrap justify-center gap-3">
        <a href="https://github.com/AdgaiWalker" target="_blank" rel="noopener noreferrer" class="social-btn flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.04)] text-sm font-medium hover:bg-black hover:text-white hover:border-black transition-all">
          <Icon name="lucide:github" width={16} height={16} />
          <span>GitHub</span>
        </a>
        <a href="https://space.bilibili.com/1029612512" target="_blank" rel="noopener noreferrer" class="social-btn flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.04)] text-sm font-medium hover:bg-[#fb7299] hover:text-white hover:border-[#fb7299] transition-all">
          <Icon name="lucide:circle-play" width={16} height={16} />
          <span>Bilibili</span>
        </a>
        <a href="https://www.xiaohongshu.com/user/profile/689dd905000000001802921e" target="_blank" rel="noopener noreferrer" class="social-btn flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.04)] text-sm font-medium hover:bg-[#ff2442] hover:text-white hover:border-[#ff2442] transition-all">
          <Icon name="lucide:book-open" width={16} height={16} />
          <span>小红书</span>
        </a>
        <button type="button" class="social-btn flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.04)] text-sm font-medium hover:bg-[var(--color-brand)] hover:text-white hover:border-[var(--color-brand)] transition-all cursor-pointer" id="copy-email">
          <Icon name="lucide:mail" width={16} height={16} />
          <span>Email</span>
        </button>
      </div>
    </div>
  </section>

  {/* ===== 4. 我正在铺的路 ===== */}
  <section class="path-section py-20 px-4 sm:px-6 flex flex-col items-center relative overflow-hidden" id="path-section">
    <div class="section-header max-w-[700px] w-full mb-16 flex items-center gap-4">
      <h2 class="section-title text-sm font-bold text-parchment-dim tracking-widest">正在铺的路</h2>
      <div class="section-line flex-1 h-px bg-gradient-to-r from-[var(--color-nav-border)] to-transparent"></div>
    </div>

    <div class="cruise-timeline-container max-w-[620px] w-full relative py-6">
      {/* 航行者宣言 */}
      <div class="panel-glass p-6 rounded-[28px] border border-[var(--color-nav-border)] mb-12 relative overflow-hidden group/philosophy shadow-lg">
        <div class="absolute -right-20 -top-20 w-44 h-44 rounded-full bg-amber-400/10 blur-3xl group-hover/philosophy:bg-amber-400/18 transition-all duration-700"></div>
        <div class="absolute -left-20 -bottom-20 w-44 h-44 rounded-full bg-[var(--color-brand-glow)] blur-3xl opacity-50"></div>

        <div class="relative z-10 flex flex-col gap-5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-brand/10 border border-brand/20 flex items-center justify-center text-brand shrink-0 shadow-sm mt-0.5 group-hover/philosophy:scale-105 transition-transform duration-300">
              <Icon name="lucide:compass" width={18} height={18} class="animate-spin-slow text-brand" />
            </div>
            <div>
              <p class="font-serif text-[15px] sm:text-[16px] text-parchment leading-relaxed tracking-wide font-medium italic">
                " 最好的生活状态是，带着自己的目标，准备出发、正在出发、歇会再出发。 "
              </p>
              <p class="text-[9px] font-mono tracking-widest text-parchment-dim opacity-50 uppercase mt-2">
                — VOYAGER'S SPIRITUAL MANIFESTO / 航行者宣言
              </p>
            </div>
          </div>

          {/* 三态指示器 */}
          <div class="flex items-center justify-around bg-[rgba(0,0,0,0.03)] dark:bg-[rgba(255,255,255,0.03)] border border-[var(--color-nav-border)] rounded-2xl p-2.5 mt-1">
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[11px] font-body text-parchment-dim/60 font-semibold cursor-default">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 opacity-60"></span>
              准备出发
            </div>
            <div class="flex items-center gap-1.5 px-3.5 py-1.5 rounded-xl text-[11.5px] font-body text-brand font-black bg-brand/10 border border-brand/20 shadow-sm cursor-default">
              <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse"></span>
              正在出发
            </div>
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[11px] font-body text-parchment-dim/60 font-semibold cursor-default">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 opacity-60"></span>
              歇会再出发
            </div>
          </div>
        </div>
      </div>

      {/* 纵向发光虚线航道 */}
      <div class="absolute left-4 sm:left-1/2 top-0 bottom-0 w-0.5 sm:-translate-x-1/2 bg-dashed border-l border-brand/40 -z-10"></div>

      {personalTimeline.slice(0, 2).map((item, i) => {
        const isEven = i % 2 === 0;
        const isLast = i === personalTimeline.length - 1;
        const hasChildren = item.children && item.children.length > 0;
        return (
          <div class:list={['timeline-anchor relative flex flex-col sm:flex-row items-start sm:justify-between gap-8 w-full', { 'mb-16': !isLast }]}>
            <div class="timeline-marker absolute left-4 sm:left-1/2 sm:-translate-x-1/2 w-6 h-6 rounded-full flex items-center justify-center bg-[var(--color-bg)] border-2 border-brand z-20 cursor-default">
              <span class="marker-dot w-2.5 h-2.5 rounded-full bg-brand"></span>
              <span class="marker-ripple absolute inset-0 rounded-full border border-brand opacity-0"></span>
            </div>

            {isEven ? (
              <>
                <div class="w-full sm:w-[45%] pl-10 sm:pl-0 sm:text-right">
                  <span class="timeline-date font-mono text-xs text-brand font-bold bg-brand/10 px-2 py-0.5 rounded-full">{item.date}</span>
                </div>
                <div class="w-full sm:w-[45%] pl-10 sm:pl-0">
                  <div class="panel-glass p-5 rounded-2xl hover:border-brand/30 transition-all duration-300">
                    <h4 class="text-sm font-bold mb-1.5 flex items-center gap-1.5 sm:justify-start">
                      <Icon name={item.icon} width={14} height={14} class="text-brand" />
                      {item.title}
                    </h4>
                    <p class="text-xs text-parchment/70 leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              </>
            ) : (
              <>
                <div class="w-full sm:w-[45%] pl-10 sm:pl-0 order-2 sm:order-1 sm:text-right">
                  <div class="panel-glass p-5 rounded-2xl hover:border-brand/30 transition-all duration-300 text-left sm:text-left">
                    <h4 class="text-sm font-bold mb-1.5 flex items-center gap-1.5 justify-start sm:justify-end">
                      {hasChildren ? (
                        <>
                          {item.title}
                          <Icon name={item.icon} width={14} height={14} class="text-brand" />
                        </>
                      ) : (
                        <>
                          {item.title}
                          <Icon name={item.icon} width={14} height={14} class="text-brand" />
                        </>
                      )}
                    </h4>
                    {hasChildren ? (
                      <div class="space-y-3 text-xs text-parchment/70 leading-relaxed">
                        {item.children.map((child: { label: string; text: string; href?: string }) => (
                          <div class="flex items-start gap-2">
                            {child.href ? (
                              <a href={child.href} target="_blank" rel="noopener noreferrer" class="text-brand font-bold shrink-0 no-underline hover:underline">{child.label}</a>
                            ) : (
                              <span class="text-brand font-bold shrink-0">{child.label}</span>
                            )}
                            <span>{child.text}</span>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p class="text-xs text-parchment/70 leading-relaxed">{item.desc}</p>
                    )}
                  </div>
                </div>
                <div class="w-full sm:w-[45%] pl-10 sm:pl-0 order-1 sm:order-2">
                  <span class="timeline-date font-mono text-xs text-brand font-bold bg-brand/10 px-2 py-0.5 rounded-full">{item.date}</span>
                </div>
              </>
            )}
          </div>
        );
      })}

      {/* 折叠更多时间线 */}
      {personalTimeline.length > 2 && (
        <details class="mt-8">
          <summary class="font-mono text-xs text-brand cursor-pointer hover:text-brand-secondary transition-colors text-center w-full py-3">
            查看完整时间线 ↓
          </summary>
          <div class="space-y-16 mt-8">
            {personalTimeline.slice(2).map((item, i) => {
              const isEven = (i + 2) % 2 === 0;
              const hasChildren = item.children && item.children.length > 0;
              return (
                <div class:list={['timeline-anchor relative flex flex-col sm:flex-row items-start sm:justify-between gap-8 w-full']}>
                  <div class="timeline-marker absolute left-4 sm:left-1/2 sm:-translate-x-1/2 w-6 h-6 rounded-full flex items-center justify-center bg-[var(--color-bg)] border-2 border-brand z-20 cursor-default">
                    <span class="marker-dot w-2.5 h-2.5 rounded-full bg-brand"></span>
                  </div>
                  {isEven ? (
                    <>
                      <div class="w-full sm:w-[45%] pl-10 sm:pl-0 sm:text-right">
                        <span class="timeline-date font-mono text-xs text-brand font-bold bg-brand/10 px-2 py-0.5 rounded-full">{item.date}</span>
                      </div>
                      <div class="w-full sm:w-[45%] pl-10 sm:pl-0">
                        <div class="panel-glass p-5 rounded-2xl hover:border-brand/30 transition-all duration-300">
                          <h4 class="text-sm font-bold mb-1.5 flex items-center gap-1.5">
                            <Icon name={item.icon} width={14} height={14} class="text-brand" />
                            {item.title}
                          </h4>
                          <p class="text-xs text-parchment/70 leading-relaxed">{item.desc}</p>
                        </div>
                      </div>
                    </>
                  ) : (
                    <>
                      <div class="w-full sm:w-[45%] pl-10 sm:pl-0 order-2 sm:order-1">
                        <div class="panel-glass p-5 rounded-2xl hover:border-brand/30 transition-all duration-300 text-left">
                          <h4 class="text-sm font-bold mb-1.5 flex items-center gap-1.5">
                            {item.title}
                            <Icon name={item.icon} width={14} height={14} class="text-brand" />
                          </h4>
                          {hasChildren ? (
                            <div class="space-y-3 text-xs text-parchment/70 leading-relaxed">
                              {item.children.map((child: { label: string; text: string; href?: string }) => (
                                <div class="flex items-start gap-2">
                                  {child.href ? (
                                    <a href={child.href} target="_blank" rel="noopener noreferrer" class="text-brand font-bold shrink-0 no-underline hover:underline">{child.label}</a>
                                  ) : (
                                    <span class="text-brand font-bold shrink-0">{child.label}</span>
                                  )}
                                  <span>{child.text}</span>
                                </div>
                              ))}
                            </div>
                          ) : (
                            <p class="text-xs text-parchment/70 leading-relaxed">{item.desc}</p>
                          )}
                        </div>
                      </div>
                      <div class="w-full sm:w-[45%] pl-10 sm:pl-0 order-1 sm:order-2 sm:text-right">
                        <span class="timeline-date font-mono text-xs text-brand font-bold bg-brand/10 px-2 py-0.5 rounded-full">{item.date}</span>
                      </div>
                    </>
                  )}
                </div>
              );
            })}
          </div>
        </details>
      )}

    </div>
  </section>

  {/* ===== 5. 底部出口 ===== */}
  <div class="about-exit-cta py-12 px-4 text-center">
    <p class="text-sm text-parchment/50">觉得有意思？</p>
    <a href="/tools#info-source" class="inline-flex items-center gap-2 mt-2 text-sm font-medium text-brand hover:underline">
      <Icon name="lucide:users" width={14} height={14} />
      点子共促，一起学 AI
    </a>
  </div>

  {/* ===== 底部 ===== */}
  <footer class="about-footer py-16 px-4 sm:px-6 flex justify-center border-t border-[var(--color-nav-border)] bg-[rgba(255,255,255,0.02)] relative z-20" id="about-footer">
    <div class="about-footer-inner flex flex-col items-center gap-6 max-w-[620px] w-full text-center">
      <LikeCounter pagePath="/about" />

      <div class="panel-glass px-5 py-3 rounded-full flex items-center gap-3 border border-brand/20 bg-brand/5 shadow-inner">
        <Icon name="lucide:hourglass" width={14} height={14} class="text-brand animate-spin" style="animation-duration: 4s;" />
        <div class="site-uptime font-mono text-xs tracking-wider text-parchment/80" id="site-uptime"></div>
      </div>

      <div class="about-signature flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-parchment-dim">
        <span class="about-sig-dot w-2 h-2 rounded-full bg-brand animate-ping"></span>
        Walker · 行过万里水路
      </div>
    </div>
  </footer>

  </div>{/* end about-me-content */}

  {/* "关于站" Tab */}
  <AboutSiteTab />

</FullscreenLayout>

<script>
  import { setupTilt } from '../../scripts/tilt-effect';

  let abort: AbortController | null = null;
  let postcardTiltCleanup: (() => void) | null = null;
  let uptimeTimer: ReturnType<typeof setInterval> | null = null;

  function cleanup() {
    abort?.abort();
    abort = null;
    postcardTiltCleanup?.();
    postcardTiltCleanup = null;
    if (uptimeTimer !== null) {
      clearInterval(uptimeTimer);
      uptimeTimer = null;
    }
  }

  function initAll() {
    cleanup();
    abort = new AbortController();
    const { signal } = abort;

    // 视差滚动
    const hero = document.getElementById('hero-section');
    const bgVideo = hero?.querySelector('.hero-bg-video') as HTMLElement | null;
    const heroContent = hero?.querySelector('.hero-content') as HTMLElement | null;
    const scrollHint = document.getElementById('scroll-hint');

    if (hero) {
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        const heroHeight = hero.offsetHeight;

        if (scrollY < heroHeight) {
          if (bgVideo) bgVideo.style.transform = `scale(${1 + scrollY / heroHeight * 0.1}) translateY(${scrollY * 0.3}px)`;
          if (heroContent) {
            heroContent.style.opacity = String(1 - scrollY / heroHeight * 1.5);
            heroContent.style.transform = `translateY(${scrollY * 0.15}px)`;
          }
          if (scrollHint) scrollHint.style.opacity = String(Math.max(0, 1 - scrollY / heroHeight * 3));
        }
      }, { passive: true, signal });

      scrollHint?.addEventListener('click', () => {
        document.getElementById('era-section')?.scrollIntoView({ behavior: 'smooth' });
      }, { signal });
    }

    // 3D 物理磁性倾斜
    postcardTiltCleanup = setupTilt('.postcard', {
      perspective: 1000,
      maxRotation: 8,
      scale: 1.02,
    });

    // 站点 LCD 运行时间
    const el = document.getElementById('site-uptime') as HTMLElement;
    if (el) {
      const launch = new Date('2026-05-02T00:00:00+08:00');
      const update = () => {
        const diff = Date.now() - launch.getTime();
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const minutes = Math.floor((diff % 3600000) / 60000);
        const seconds = Math.floor((diff % 60000) / 1000);
        el.textContent = `SYSTEM ONLINE: ${days}D ${hours}H ${minutes}M ${seconds}S`;
      };
      update();
      uptimeTimer = setInterval(update, 1000);
    }

    // 点击复制邮箱
    const emailBtn = document.getElementById('copy-email');
    emailBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('praxiswalker@gmail.com');
        const span = emailBtn.querySelector('span');
        const orig = span?.textContent;
        if (span) span.textContent = '已复制邮箱';
        setTimeout(() => { if (span && orig) span.textContent = orig; }, 1500);
      } catch { /* fallback */ }
    }, { signal });
  }

  initAll();
  document.addEventListener('astro:page-load', initAll);
  document.addEventListener('astro:before-swap', cleanup);
</script>

<script>
  function initAboutTabs() {
    const tabs = document.querySelectorAll('.about-tab-btn');
    const meContent = document.getElementById('about-me-content');
    const siteContent = document.getElementById('about-site-content');
    if (!tabs.length || !meContent || !siteContent) return;

    const showTab = (tab: string) => {
      tabs.forEach(btn => btn.classList.toggle('is-active', (btn as HTMLElement).dataset.tab === tab));
      meContent.hidden = tab !== 'me';
      siteContent.hidden = tab !== 'site';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    tabs.forEach(btn => {
      btn.addEventListener('click', () => showTab((btn as HTMLElement).dataset.tab!));
    });

    // URL ?tab=site support
    const params = new URLSearchParams(location.search);
    if (params.get('tab') === 'site') showTab('site');
  }
  initAboutTabs();
  document.addEventListener('astro:page-load', initAboutTabs);
</script>

