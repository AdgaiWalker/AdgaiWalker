---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { aiModelNotes, workflowNotes, savingNotes } from '../../data/toolkit-notes';

export const prerender = true;

const items = (await getCollection('dockItem', ({ data }) =>
  data.published && (data.category === 'tool' || data.category === 'skill')
)).sort((a, b) => a.data.name.localeCompare(b.data.name, 'zh-CN'));

const tools = items.filter(item => item.data.category === 'tool');
const skills = items.filter(item => item.data.category === 'skill');

const aiArticles = (await getCollection('log', ({ data }) =>
  data.published && data.category === 'ai'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatShortDate = (d: Date) =>
  `${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
---

<Base
  title="工具箱 — Walker"
  description="Walker 正在使用的 AI 工具、Skill、工作流和省钱方法。"
  ogTitle="工具箱 — Walker"
  ogDescription="个人精选的 AI 工具箱、模型分工和工作流清单。"
>
  <div class="toolkit-doc-layout">
    <div class="toolkit-resize-handle toolkit-resize-global" data-resize="global" aria-hidden="true"></div>

    <aside class="toolkit-article-nav" aria-label="AI 文章列表导航">
      <div class="article-nav-header">
        <h2>文章导航</h2>
        <span>{aiArticles.length} 篇</span>
      </div>
      <nav class="article-list-nav">
        {aiArticles.map(article => (
          <a href={`/posts/${article.id}`} class="article-list-link">
            <time>{formatShortDate(article.data.date)}</time>
            <span class="article-list-copy">
              <span class="article-list-title">{article.data.title}</span>
              {article.data.summary && <span class="article-list-summary">{article.data.summary}</span>}
            </span>
          </a>
        ))}
      </nav>
    </aside>

    <div class="toolkit-resize-handle toolkit-resize-middle" data-resize="article" aria-hidden="true"></div>

    <main class="toolkit-doc" data-pagefind-body>
      <header class="toolkit-hero">
        <h1 data-pagefind-meta="title">AI 工具箱清单</h1>
        <p>
          这里整理我日常使用的 AI 工具、自定义 Skill、模型分工和工作流。它不是“越多越好”的收藏夹，而是一个可复用的创作与开发装备表。
        </p>
      </header>

      <section class="toolkit-section" id="models">
        <h2><span aria-hidden="true">🧠</span> 模型分工</h2>
        <h3>主力模型</h3>
        <ul>
          {aiModelNotes.map(([name, desc]) => (
            <li><strong>{name}</strong> - {desc}</li>
          ))}
        </ul>
      </section>

      <section class="toolkit-section" id="tools">
        <h2><span aria-hidden="true">🛠️</span> 常用工具</h2>
        <h3>开发与效率</h3>
        {tools.length > 0 ? (
          <ul>
            {tools.map(item => (
              <li>
                <strong>{item.data.name}</strong> - {item.data.description}
                {item.data.url && (
                  <>
                    {' '}
                    <a href={item.data.url} target="_blank" rel="noopener noreferrer">访问</a>
                  </>
                )}
              </li>
            ))}
          </ul>
        ) : (
          <p class="toolkit-empty">暂时没有公开的工具条目。</p>
        )}
      </section>

      <section class="toolkit-section" id="skills">
        <h2><span aria-hidden="true">✨</span> 自定义 Skill</h2>
        <h3>可复用能力</h3>
        {skills.length > 0 ? (
          <ul>
            {skills.map(item => (
              <li>
                <strong>{item.data.name}</strong> - {item.data.description}
                {item.data.url && (
                  <>
                    {' '}
                    <a href={item.data.url} target="_blank" rel="noopener noreferrer">查看</a>
                  </>
                )}
              </li>
            ))}
          </ul>
        ) : (
          <p class="toolkit-empty">暂时没有公开的 Skill 条目。</p>
        )}
      </section>

      <section class="toolkit-section" id="workflow">
        <h2><span aria-hidden="true">🧭</span> 工作流装备</h2>
        <h3>从想法到发布</h3>
        <ul>
          {workflowNotes.map(([name, desc]) => (
            <li><strong>{name}</strong> - {desc}</li>
          ))}
        </ul>
      </section>

      <section class="toolkit-section" id="saving">
        <h2><span aria-hidden="true">💸</span> 省钱与降耗</h2>
        <h3>Token 使用习惯</h3>
        <ul>
          {savingNotes.map(([name, desc]) => (
            <li><strong>{name}</strong> - {desc}</li>
          ))}
        </ul>
      </section>

      <section class="toolkit-section" id="buying">
        <h2><span aria-hidden="true">📌</span> 选择建议</h2>
        <ol>
          <li><strong>新手入门</strong>：先固定一个主力模型和一个笔记/文档入口，不急着堆工具。</li>
          <li><strong>进阶开发</strong>：把常见流程沉淀成 Skill、模板或检查清单。</li>
          <li><strong>长期创作</strong>：工具只是加速器，稳定输出和复盘才是核心资产。</li>
        </ol>
      </section>
    </main>
  </div>

  <script>
    import { initColumnResize, bootColumnResize } from '../../scripts/column-resize';

    document.addEventListener('astro:page-load', () => {
      initColumnResize('global', {
        cssVar: '--walker-nav-width',
        storageKey: 'walker-nav-width',
        min: 220,
        max: 340,
      });
      initColumnResize('article', {
        cssVar: '--toolkit-article-nav-width',
        storageKey: 'walker-toolkit-article-nav-width',
        min: 220,
        max: 400,
      });
      bootColumnResize();
    });
  </script>
</Base>

<style>
  .toolkit-doc-layout {
    min-height: 100vh;
    display: grid;
    grid-template-columns: var(--toolkit-article-nav-width, 300px) 16px minmax(0, 1fr);
    background: rgba(255, 255, 255, 0.38);
    backdrop-filter: blur(18px);
  }

  .toolkit-article-nav {
    position: sticky;
    top: 0;
    align-self: start;
    height: 100vh;
    padding: 1.6rem 1.35rem;
    background: rgba(252, 251, 249, 0.72);
  }

  .article-nav-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1.15rem;
  }

  .article-nav-header h2 {
    margin: 0;
    color: #1a2325;
    font-family: 'Sora', 'PingFang SC', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .article-nav-header span {
    color: rgba(42, 59, 62, 0.36);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .article-list-nav {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .article-list-link {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    align-items: baseline;
    gap: 0.55rem;
    min-height: 36px;
    padding: 0.45rem 0.65rem;
    border: 1px solid transparent;
    border-radius: 9px;
    color: rgba(42, 59, 62, 0.62);
    text-decoration: none;
    transition: background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
  }

  .article-list-link time {
    color: rgba(42, 59, 62, 0.34);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
  }

  .article-list-link:hover {
    color: #218f80;
    background: rgba(53, 191, 171, 0.075);
    border-color: rgba(53, 191, 171, 0.12);
  }

  .article-list-copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.12rem;
  }

  .article-list-title {
    overflow: hidden;
    color: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.45;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .article-list-summary {
    display: -webkit-box;
    overflow: hidden;
    color: rgba(42, 59, 62, 0.38);
    font-size: 0.68rem;
    line-height: 1.45;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .toolkit-resize-handle {
    position: relative;
    width: 16px;
    cursor: col-resize;
    touch-action: none;
    user-select: none;
    z-index: 80;
  }

  .toolkit-resize-handle::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 1px;
    height: 100%;
    transform: translateX(-50%);
    background: rgba(42, 59, 62, 0.08);
    transition: background 0.16s ease, box-shadow 0.16s ease, width 0.16s ease;
  }

  .toolkit-resize-handle::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 7px;
    height: 42px;
    border-radius: 999px;
    opacity: 0;
    transform: translate(-50%, -50%);
    background:
      linear-gradient(to bottom, transparent 0 7px, rgba(53, 191, 171, 0.42) 7px 11px, transparent 11px 16px) center/3px 16px repeat-y;
    transition: opacity 0.16s ease, background-color 0.16s ease;
  }

  .toolkit-resize-handle:hover::after,
  .toolkit-resize-handle.is-active::after {
    width: 2px;
    background: rgba(53, 191, 171, 0.45);
    box-shadow: 0 0 0 4px rgba(53, 191, 171, 0.08);
  }

  .toolkit-resize-handle:hover::before,
  .toolkit-resize-handle.is-active::before {
    opacity: 1;
  }

  :global(.is-resizing-columns),
  :global(.is-resizing-columns *) {
    cursor: col-resize !important;
    user-select: none !important;
  }

  :global(.is-resizing-columns #main-nav) {
    transition: none !important;
  }

  .toolkit-resize-global {
    position: fixed;
    top: 0;
    bottom: 0;
    left: calc(var(--walker-nav-width, 260px) - 8px);
    width: 16px;
  }

  :global(body.sidebar-collapsed) .toolkit-resize-global {
    display: none;
  }

  .toolkit-resize-middle {
    position: sticky;
    top: 0;
    height: 100vh;
  }

  .toolkit-doc {
    width: min(920px, calc(100vw - var(--walker-nav-width, 260px) - var(--toolkit-article-nav-width, 300px) - 4rem));
    margin: 0 auto;
    padding: 2rem 0 6rem;
    color: #1a2325;
  }

  .toolkit-hero {
    margin-bottom: 3.5rem;
  }

  .toolkit-hero h1 {
    margin: 0 0 2rem;
    color: #1a2325;
    font-family: 'Sora', 'PingFang SC', system-ui, sans-serif;
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .toolkit-hero p {
    max-width: 860px;
    margin: 0;
    color: rgba(42, 59, 62, 0.66);
    font-size: 1.05rem;
    line-height: 1.9;
  }

  .toolkit-section {
    margin: 0 0 3.8rem;
    scroll-margin-top: 2rem;
  }

  .toolkit-section h2 {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0 0 1.75rem;
    color: #1a2325;
    font-family: 'Sora', 'PingFang SC', system-ui, sans-serif;
    font-size: 1.65rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .toolkit-section h3 {
    margin: 0 0 1.15rem;
    color: #1a2325;
    font-size: 1.12rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .toolkit-section ul,
  .toolkit-section ol {
    margin: 0;
    padding-left: 1.35rem;
    color: rgba(42, 59, 62, 0.66);
    font-size: 1rem;
    line-height: 2.05;
  }

  .toolkit-section li {
    padding-left: 0.35rem;
  }

  .toolkit-section li::marker {
    color: rgba(42, 59, 62, 0.18);
  }

  .toolkit-section strong {
    color: #1a2325;
    font-weight: 700;
  }

  .toolkit-section a {
    color: #218f80;
    font-weight: 600;
    text-decoration: none;
  }

  .toolkit-section a:hover {
    text-decoration: underline;
  }

  .toolkit-empty {
    margin: 0;
    color: rgba(75, 85, 99, 0.62);
    font-size: 0.95rem;
  }

  @media (max-width: 1279px) {
    .toolkit-doc-layout {
      grid-template-columns: 240px 16px minmax(0, 1fr);
    }

    .toolkit-article-nav {
      padding: 1.25rem 1rem;
    }

    .toolkit-doc {
      width: auto;
      margin: 0;
      padding: 2rem 2rem 5rem;
    }
  }

  @media (max-width: 1023px) {
    .toolkit-doc-layout {
      display: block;
      padding-top: 3.5rem;
    }

    .toolkit-article-nav {
      position: relative;
      height: auto;
      padding: 1.25rem 1rem;
      border-right: 0;
      border-bottom: 1px solid rgba(42, 59, 62, 0.08);
    }

    .article-list-nav {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .toolkit-resize-handle {
      display: none;
    }

    .toolkit-doc {
      padding: 2rem 1.2rem 4rem;
    }
  }

  @media (max-width: 640px) {
    .article-list-nav {
      grid-template-columns: 1fr;
    }

    .toolkit-hero h1 {
      font-size: 2.05rem;
    }

    .toolkit-section {
      margin-bottom: 3rem;
    }
  }
</style>
