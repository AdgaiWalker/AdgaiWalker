---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import { getPublishedIdeas } from '@/lib/content';
import { Icon } from 'astro-icon/components';
import { render } from 'astro:content';
import { formatDateCompact } from '@/lib/format';

export const prerender = true;

const ideas = await getPublishedIdeas();

// 自定义排序权重：活跃状态靠前，已完成/已归档靠后
const statusWeight = {
  building: 1,
  validating: 2,
  thinking: 3,
  verified: 4,
  archived: 5,
};

ideas.sort((a, b) => {
  const weightA = statusWeight[a.data.status || 'thinking'] ?? 3;
  const weightB = statusWeight[b.data.status || 'thinking'] ?? 3;
  
  if (weightA !== weightB) {
    return weightA - weightB;
  }
  return b.data.date.getTime() - a.data.date.getTime();
});

const statusLabel = {
  thinking: '构思中',
  validating: '验证中',
  building: '实现中',
  verified: '已完成',
  archived: '已归档',
};

// 预渲染所有 Markdown 内容，这样它们可以直接潜入卡牌背面
const renderedIdeas = await Promise.all(
  ideas.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);
---

<SidebarLayout
  title="点子 · Walker"
  description="冒出来的想法，记下来。现在没用的，未来可能刚好戳中一个需求。"
  pageTitle="点子"
  pageSubtitle="Ideas"
  pageIcon="lightbulb"
  itemCount={ideas.length}
  itemUnit="个"
>
  <div class="space-y-6">
    <!-- 简短说明与引导 -->
    <div class="intro-description panel-glass p-5 rounded-2xl border border-border">
      <p class="text-xs sm:text-sm text-parchment-dim leading-relaxed">
        💡 <strong>冒出来的想法，开放给所有人。</strong> 这里是我正在构思或推动的小项目与创意点子。如果你看中了哪张卡牌，欢迎加入讨论、一起动手让它落地。<strong>有点子，先动手，再开口。</strong>
      </p>
    </div>

    <!-- 状态筛选标签栏 -->
    <div class="filter-tabs-wrapper flex flex-wrap gap-2 py-1" aria-label="状态筛选">
      <button type="button" class="filter-tab is-active" data-status="all">
        <span class="tab-dot dot-all"></span>
        全部 ({ideas.length})
      </button>
      <button type="button" class="filter-tab" data-status="active">
        <span class="tab-dot dot-thinking"></span>
        进行中 ({ideas.filter(i => ['thinking', 'validating', 'building'].includes(i.data.status || 'thinking')).length})
      </button>
      <button type="button" class="filter-tab" data-status="verified">
        <span class="tab-dot dot-verified"></span>
        已完成 ({ideas.filter(i => i.data.status === 'verified').length})
      </button>
      <button type="button" class="filter-tab" data-status="archived">
        <span class="tab-dot dot-archived"></span>
        已归档 ({ideas.filter(i => i.data.status === 'archived').length})
      </button>
    </div>

    <!-- 卡牌桌区域 -->
    <div class="ideas-tabletop relative">
      <!-- 桌面微妙质感的光晕效果 -->
      <div class="tabletop-ambient-glow"></div>
      
      <div class="card-grid" id="ideas-grid">
        {renderedIdeas.map(({ entry, Content }) => {
          const status = entry.data.status || 'thinking';
          const isThinking = status === 'thinking';

          return (
            <div 
              class={`card-container ${isThinking ? 'is-blurred' : ''}`}
              id={entry.id}
              data-status={status}
              data-id={entry.id}
              tabindex="0"
              role="button"
              aria-expanded="false"
              aria-haspopup="dialog"
              aria-label={`点子：${entry.data.title}，状态：${statusLabel[status] ?? status}`}
            >
              <div class="card-inner">
                <!-- 正面 (牌面) -->
                <div class="card-face card-front">
                  <!-- Thinking 状态特有的模糊遮罩层 -->
                  {isThinking && (
                    <div class="thinking-overlay">
                      <div class="overlay-lock-glow">
                        <Icon name="lucide:lock" width={22} height={22} class="text-brand shrink-0" />
                      </div>
                      <span class="overlay-status-title">💡 构思中</span>
                      <p class="overlay-status-desc">构思中的点子，点击此卡牌解密解锁</p>
                      <button type="button" class="reveal-btn">点击翻开解密</button>
                    </div>
                  )}

                  <div class="card-body">
                    <!-- 顶部元信息 -->
                    <div class="card-header-meta">
                      <span class="card-date">{formatDateCompact(entry.data.date)}</span>
                      <span class={`status-badge badge-${status}`}>
                        <span class="status-indicator"></span>
                        {statusLabel[status] ?? status}
                      </span>
                    </div>

                    <!-- 标题 -->
                    <h3 class="card-title">
                      {entry.data.title}
                    </h3>

                    <!-- 摘要 -->
                    <p class="card-summary">
                      {entry.data.summary ?? '这只是一星闪现的火花，先点击解密翻开查看细节。'}
                    </p>

                    <!-- 标签 (最多4个) -->
                    {entry.data.tags && entry.data.tags.length > 0 && (
                      <div class="card-tags">
                        {entry.data.tags.slice(0, 4).map(tag => (
                          <span class="card-tag">#{tag}</span>
                        ))}
                      </div>
                    )}

                    <!-- 底部翻牌操作 -->
                    <div class="card-footer">
                      <button type="button" class="flip-btn-action">
                        <Icon name="lucide:rotate-3d" width={14} height={14} class="flip-icon" />
                        查看详细构想
                      </button>
                    </div>
                  </div>
                </div>

                <!-- 背面 (详情) -->
                <div class="card-face card-back">
                  <div class="card-back-container">
                    <!-- 背面头部 -->
                    <div class="card-back-header">
                      <div class="flex-1 min-w-0">
                        <span class="text-[9px] font-mono tracking-widest text-brand uppercase">IDEA DETAILS / 深度规划</span>
                        <h4 class="card-back-title">{entry.data.title}</h4>
                      </div>
                      <button type="button" class="close-back-btn" aria-label="返回正面">
                        <Icon name="lucide:x" width={16} height={16} />
                      </button>
                    </div>

                    <!-- 详情区域 - 带原生滚动条与视觉淡出指示器 -->
                    <div class="card-back-scroll-wrapper relative flex-grow overflow-hidden flex flex-col mb-3">
                      <div class="card-back-scroll scrollable-y flex-grow">
                        <div class="prose-mini">
                          <Content />
                        </div>
                      </div>
                      <div class="scroll-fade-overlay pointer-events-none"></div>
                    </div>

                    <!-- 底部返回与连结 -->
                    <div class="card-back-footer">
                      <button type="button" class="flip-back-btn">
                        <Icon name="lucide:arrow-left" width={12} height={12} />
                        返回牌面
                      </button>
                      <a href={`/posts/${entry.id}`} class="read-full-link">
                        阅读全文
                        <Icon name="lucide:arrow-up-right" width={12} height={12} />
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <!-- 空状态 -->
      <div class="empty-state text-center py-20 text-parchment-dim" id="ideas-empty" hidden>
        <Icon name="lucide:lightbulb-off" width={42} height={42} class="mx-auto mb-4 opacity-30 animate-pulse text-brand" />
        <p class="text-sm font-bold">该状态下暂无点子牌</p>
        <p class="text-xs mt-1 opacity-60">灵感火花正在孕育中，稍后再来瞧瞧吧。</p>
      </div>
    </div>

    <!-- 底部高价值组队 CTA -->
    <div class="cta-section panel-glass p-6 sm:p-8 rounded-[2rem] border border-border">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="space-y-2 text-center md:text-left">
          <div class="cta-kicker">TEAM UP / 共促社区</div>
          <h3 class="text-lg sm:text-xl font-bold text-parchment">🃏 看中了哪张牌？来组队。</h3>
          <p class="text-xs sm:text-sm text-parchment-dim leading-relaxed max-w-2xl">
            此处的每个点子都开放共享，期待同行者一起加入，不管是提出交互反馈、技术建议还是共同编码，都随时欢迎。
          </p>
          <a href="mailto:praxiswalker@gmail.com" class="cta-mail-link">
            <Icon name="lucide:mail" width={11} height={11} />
            praxiswalker@gmail.com
          </a>
        </div>
        <div class="flex flex-col items-center gap-2 shrink-0">
          <a href="/tools#info-source" class="cta-join-link">
            <Icon name="lucide:users" width={14} height={14} />
            加入点子共促
          </a>
          <span class="text-[10px] font-mono text-parchment-dim tracking-wide">二维码在工具页</span>
        </div>
      </div>
    </div>
  </div>
</SidebarLayout>

<style>
  /* ------------------- Tabletop 桌面风格 ------------------- */
  .ideas-tabletop {
    border-radius: 1.75rem;
    padding: clamp(1rem, 3.5vw, 2.5rem);
    min-height: 520px;
    background-color: var(--color-inner-bg);
    background-image:
      radial-gradient(circle at 50% 50%, var(--color-brand-glow) 0%, transparent 100%),
      linear-gradient(color-mix(in srgb, var(--color-brand) 6%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--color-brand) 6%, transparent) 1px, transparent 1px);
    background-size: 100% 100%, 30px 30px, 30px 30px;
    border: 1px solid var(--color-border);
    box-shadow: 
      inset 0 24px 48px rgba(0, 0, 0, 0.03),
      0 12px 36px var(--color-inner-shadow);
    transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }

  body.theme-aurora .ideas-tabletop,
  body.theme-sunset .ideas-tabletop,
  body.theme-mint .ideas-tabletop {
    box-shadow: 
      inset 0 24px 48px rgba(0, 0, 0, 0.55),
      0 12px 40px rgba(0, 0, 0, 0.45);
  }

  .tabletop-ambient-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 80%;
    background: radial-gradient(circle, var(--color-brand-glow) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ------------------- Grid 与卡牌卡槽 ------------------- */
  .card-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 2rem;
  }

  .card-container {
    perspective: 1200px;
    height: 380px;
    width: 100%;
    position: relative;
  }

  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.65s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* 3D 翻转动作 */
  .card-container.is-flipped .card-inner {
    transform: rotateY(180deg);
  }

  /* 当翻开牌面阅读时，强力清除所有外部投影、发光、脉冲与动画，安安静静看书 */
  .card-container.is-flipped .card-inner {
    box-shadow: none !important;
    animation: none !important;
  }
  .card-container.is-flipped .card-front,
  .card-container.is-flipped .card-back {
    animation: none !important;
    box-shadow: inset 0 0 20px var(--color-inner-shadow) !important; /* 仅保留极弱内凹陷，彻底移除外部发光 */
  }

  /* 卡牌面基础面貌 */
  .card-face {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 1.25rem;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ------------------- Card Front 正面 (全息毛玻璃) ------------------- */
  .card-front {
    background: var(--color-card);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border: 1px solid var(--color-border);
    cursor: pointer;
  }

  .card-container:hover .card-front {
    transform: translateY(-12px) rotate(0.8deg);
    border-color: rgba(var(--color-brand-rgb), 0.45);
    box-shadow: 
      inset 0 1px 3px rgba(255, 255, 255, 0.15),
      0 20px 40px -8px var(--color-brand-glow),
      0 8px 16px -4px rgba(0, 0, 0, 0.2);
  }

  body.theme-aurora .card-container:hover .card-front,
  body.theme-sunset .card-container:hover .card-front,
  body.theme-mint .card-container:hover .card-front {
    box-shadow: 
      inset 0 1.5px 3.5px rgba(255, 255, 255, 0.12),
      0 24px 48px -8px rgba(0, 0, 0, 0.6),
      0 0 20px var(--color-brand-glow);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.35rem;
  }

  .card-header-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }

  .card-date {
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    color: var(--color-brand);
    font-weight: 700;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.68rem;
    font-weight: 800;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .status-indicator {
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }

  /* 状态特异性配色 */
  .badge-thinking {
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.08);
    color: var(--color-brand);
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.18);
  }
  .badge-thinking .status-indicator { background: var(--color-brand); }

  .badge-validating {
    background: color-mix(in srgb, var(--color-brand-secondary) 12%, transparent);
    color: var(--color-brand-secondary);
    border-color: color-mix(in srgb, var(--color-brand-secondary) 25%, transparent);
  }
  .badge-validating .status-indicator { background: var(--color-brand-secondary); }

  .badge-building {
    background: var(--color-brand-glow);
    color: var(--color-brand);
    border-color: color-mix(in srgb, var(--color-brand) 30%, transparent);
  }
  .badge-building .status-indicator { background: var(--color-brand); }

  .badge-verified {
    background: color-mix(in srgb, var(--color-brand-secondary) 12%, transparent);
    color: var(--color-brand-secondary);
    border-color: color-mix(in srgb, var(--color-brand-secondary) 25%, transparent);
  }
  .badge-verified .status-indicator { background: var(--color-brand-secondary); }

  .badge-archived {
    background: color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
    color: var(--color-parchment-dim);
    border-color: color-mix(in srgb, var(--color-parchment-dim) 20%, transparent);
  }
  .badge-archived .status-indicator { background: var(--color-parchment-dim); opacity: 0.5; }

  .card-title {
    margin: 0 0 0.65rem;
    font-family: var(--font-heading, inherit);
    color: var(--color-parchment);
    font-size: 1.15rem;
    font-weight: 850;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-summary {
    font-size: 0.82rem;
    color: var(--color-parchment-dim);
    line-height: 1.7;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1rem;
    padding-top: 0.65rem;
    border-top: 1px dashed var(--color-border);
  }

  .card-tag {
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    color: var(--color-parchment-dim);
    opacity: 0.8;
  }

  .card-footer {
    margin-top: auto;
  }

  .flip-btn-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    width: 100%;
    padding: 0.55rem 0.8rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-inner-bg);
    color: var(--color-parchment);
    font-size: 0.75rem;
    font-weight: 750;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .flip-btn-action:hover {
    background: var(--color-brand);
    color: #ffffff;
    border-color: var(--color-brand);
    box-shadow: 0 4px 12px var(--color-brand-glow);
  }

  .flip-icon {
    transition: transform 0.4s ease;
  }

  .flip-btn-action:hover .flip-icon {
    transform: rotate(180deg);
  }

  /* ------------------- Card Back 背面 ------------------- */
  .card-back {
    transform: rotateY(180deg);
    background: var(--color-card);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border: 1px solid var(--color-border);
    box-shadow: inset 0 0 20px var(--color-inner-shadow);
  }

  .card-back-container {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.15rem;
  }

  .card-back-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.85rem;
  }

  .card-back-title {
    margin: 0.15rem 0 0;
    font-family: var(--font-heading, inherit);
    color: var(--color-parchment);
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .close-back-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-parchment-dim);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .close-back-btn:hover {
    background: var(--color-brand-glow);
    color: var(--color-brand);
    border-color: var(--color-brand);
  }

  .card-back-scroll {
    flex-grow: 1;
    overflow-y: auto;
    padding-right: 0.35rem;
    margin-bottom: 0.85rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-brand) transparent;
  }

  .card-back-scroll::-webkit-scrollbar {
    width: 4px;
  }

  .card-back-scroll::-webkit-scrollbar-thumb {
    background: var(--color-brand);
    border-radius: 99px;
  }

  /* 精简的 Markdown 正文排版 */
  .prose-mini {
    font-size: 0.78rem;
    line-height: 1.65;
    color: var(--color-parchment-dim);
  }

  .prose-mini :global(h2), .prose-mini :global(h3) {
    color: var(--color-parchment);
    font-size: 0.85rem;
    font-weight: 800;
    margin: 1rem 0 0.45rem;
  }

  .prose-mini :global(h2:first-child), .prose-mini :global(h3:first-child) {
    margin-top: 0;
  }

  .prose-mini :global(p) {
    margin: 0 0 0.65rem;
    text-indent: 2em !important; /* 同样支持首行缩进，空出两格 */
  }

  .prose-mini :global(ul), .prose-mini :global(ol) {
    margin: 0 0 0.65rem;
    padding-left: 1.1rem;
  }

  .prose-mini :global(li) {
    margin-bottom: 0.25rem;
  }

  .prose-mini :global(code) {
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    padding: 0.1rem 0.25rem;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    color: var(--color-brand);
  }

  .prose-mini :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.72rem;
    margin: 0.8rem 0;
  }

  .prose-mini :global(th), .prose-mini :global(td) {
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.3rem 0.45rem;
    text-align: left;
  }

  .prose-mini :global(th) {
    background: rgba(var(--color-brand-rgb), 0.12);
    color: #ffffff;
  }

  .card-back-footer {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .flip-back-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    flex: 1;
    padding: 0.45rem 0.7rem;
    border-radius: 0.65rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-parchment-dim);
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .flip-back-btn:hover {
    background: var(--color-brand-glow);
    color: var(--color-brand);
    border-color: var(--color-brand);
  }

  .read-full-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    flex: 1;
    padding: 0.45rem 0.7rem;
    border-radius: 0.65rem;
    background: var(--color-brand);
    color: #ffffff;
    font-size: 0.72rem;
    font-weight: 800;
    text-decoration: none;
    transition: all 0.2s ease;
    text-align: center;
  }

  .read-full-link:hover {
    background: var(--color-brand-secondary);
    box-shadow: 0 4px 12px var(--color-brand-glow);
  }

  /* ------------------- Accessibility Focus Rings (无障碍焦点环) ------------------- */
  .card-container:focus-visible {
    outline: none;
  }
  .card-container:focus-visible .card-inner {
