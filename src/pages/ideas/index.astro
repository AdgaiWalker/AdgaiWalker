      gap: 1.25rem;
    }
    .card-container {
      height: 390px;
    }
    .card-summary {
      -webkit-line-clamp: 3;
    }
    .cta-section {
      padding: 1.25rem;
      border-radius: 1.5rem;
    }
    .cta-qr {
      width: 100px;
      height: 100px;
    }
