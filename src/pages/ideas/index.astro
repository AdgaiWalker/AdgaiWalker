  }

  .dot-all { background: var(--color-brand); }
  .dot-thinking { background: var(--color-brand); opacity: 0.5; }
  .dot-validating { background: var(--color-brand-secondary); }
  .dot-building { background: var(--color-brand); }
  .dot-verified { background: var(--color-brand-secondary); }
  .dot-archived { background: var(--color-parchment-dim); opacity: 0.4; }

  /* ------------------- Bottom CTA Section ------------------- */
  .cta-section {
    background: 
      radial-gradient(circle at 10% 20%, rgba(var(--color-brand-rgb), 0.08), transparent 35%),
      var(--color-card);
  }

  .cta-kicker {
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    font-weight: 800;
    color: var(--color-brand);
    letter-spacing: 0.12em;
  }

  .cta-mail-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-parchment-dim);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .cta-mail-link:hover {
    opacity: 1;
    color: var(--color-brand);
  }

  .cta-join-link {
    display: inline-flex;
