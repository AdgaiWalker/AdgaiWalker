    100% { transform: scale(1.06); box-shadow: 0 0 20px var(--color-brand-glow); }
  }

  .overlay-status-title {
    font-size: 0.85rem;
    font-weight: 850;
    color: var(--color-brand);
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
  }

  .overlay-status-desc {
    font-size: 0.72rem;
    color: var(--color-parchment-dim);
    opacity: 0.85;
    line-height: 1.5;
    max-width: 180px;
    margin: 0 0 1rem;
  }

  .reveal-btn {
    padding: 0.45rem 0.9rem;
    border-radius: 0.65rem;
    border: 1px solid var(--color-brand);
    background: var(--color-brand-glow);
    color: var(--color-brand);
    font-size: 0.72rem;
    font-weight: 800;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .reveal-btn:hover {
    background: var(--color-brand);
    color: #ffffff;
    box-shadow: 0 0 12px rgba(var(--color-brand-rgb), 0.35);
  }

  /* ------------------- 特别状态效果 (Glow & Pulse) ------------------- */
  
  /* 验证中 - 全息边缘微光 */
  .card-container[data-status="validating"] .card-front {
    border-color: rgba(var(--color-brand-rgb), 0.35);
    box-shadow: 
      0 0 14px var(--color-brand-glow),
      0 10px 25px -5px rgba(0, 0, 0, 0.08);
  }
  .card-container[data-status="validating"]:hover .card-front {
    border-color: var(--color-brand);
    box-shadow: 
      0 0 22px var(--color-brand-glow),
      0 20px 40px -8px var(--color-brand-glow);
  }

  /* 实现中 - 脉冲发光 */
  .card-container[data-status="building"] .card-front {
    border-color: rgba(var(--color-brand-rgb), 0.45);
    animation: building-glow 3s infinite alternate;
  }
  @keyframes building-glow {
    0% {
      box-shadow: 
        0 0 12px var(--color-brand-glow),
        0 10px 25px -5px rgba(0, 0, 0, 0.08);
    }
    100% {
      box-shadow: 
        0 0 24px var(--color-brand-glow),
        0 10px 25px -5px rgba(0, 0, 0, 0.08);
    }
  }
  .card-container[data-status="building"]:hover .card-front {
    animation: none;
    border-color: var(--color-brand);
    box-shadow: 
      0 0 28px var(--color-brand-glow),
      0 20px 40px -8px var(--color-brand-glow);
  }

  /* 已归档 - 降饱和度 */
  .card-container[data-status="archived"] {
    opacity: 0.55;
    filter: saturate(0.35);
  }
  .card-container[data-status="archived"]:hover {
    opacity: 0.85;
    filter: saturate(0.7);
  }

  /* ------------------- Status tabs 筛选器 ------------------- */
  .filter-tabs-wrapper {
    position: relative;
    z-index: 5;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .filter-tabs-wrapper::-webkit-scrollbar {
    display: none;
  }

  .filter-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    backdrop-filter: blur(20px);
    color: var(--color-parchment-dim);
    font-size: 0.76rem;
    font-weight: 750;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .filter-tab:hover {
    background: var(--color-inner-bg);
    color: var(--color-parchment);
    border-color: var(--color-brand);
    transform: translateY(-1px);
  }

  .filter-tab.is-active {
    background: var(--color-brand);
    color: #ffffff;
    border-color: var(--color-brand);
    box-shadow: 0 4px 12px var(--color-brand-glow);
  }

  .tab-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: transparent;
  }

  .filter-tab.is-active .tab-dot {
