  }

  .cta-qr:hover {
    border-color: color-mix(in srgb, var(--color-brand) 40%, transparent);
  }

  /* ------------------- Responsive ------------------- */
  @media (max-width: 640px) {
    .ideas-tabletop {
      padding: 1rem;
      min-height: 480px;
    }
    .card-grid {
