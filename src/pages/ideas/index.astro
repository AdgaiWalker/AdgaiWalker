---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import { getPublishedIdeas } from '@/lib/content';
import { Icon } from 'astro-icon/components';

export const prerender = true;

const ideas = await getPublishedIdeas();

const statusLabel = {
  thinking: '构思中',
  practicing: '验证中',
  verified: '已验证',
  archived: '已归档',
};
---

<SidebarLayout
  title="点子 · Walker"
  description="冒出来的想法，记下来。现在没用的，未来可能刚好戳中一个需求。"
  pageTitle="点子"
  pageSubtitle="Ideas"
  pageIcon="lightbulb"
  itemCount={ideas.length}
  itemUnit="个"
>
  <div class="space-y-10">
    <div class="space-y-4" id="ideas-list">
      {ideas.map(entry => {
        const status = entry.data.status;

        return (
          <div class="idea-item panel-glass p-5 rounded-2xl transition-all duration-300 hover:border-brand/30 hover:-translate-y-0.5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1.5">
                  <Icon name="lucide:lightbulb" width={14} height={14} class="text-brand shrink-0" />
                  <h3 class="text-sm font-bold truncate">{entry.data.title}</h3>
                  {status && (
                    <span class="text-[9px] font-mono px-1.5 py-0.5 rounded bg-brand/10 text-brand border border-brand/20">
                      {statusLabel[status] ?? status}
                    </span>
                  )}
                </div>
                {entry.data.summary && (
                  <p class="text-xs text-parchment-dim leading-relaxed line-clamp-3">
                    {entry.data.summary}
                  </p>
                )}
                <div class="flex items-center gap-2 mt-2">
                  {entry.data.tags.slice(0, 4).map(tag => (
                    <span class="text-[10px] text-parchment-dim/60 font-mono">#{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    {ideas.length === 0 && (
      <div class="text-center py-20 text-parchment-dim">
        <Icon name="lucide:lightbulb" width={40} height={40} class="mx-auto mb-4 opacity-30" />
        <p class="text-sm">还没有点子</p>
        <p class="text-xs mt-1 opacity-50">点子在路上。</p>
      </div>
    )}
  </div>
</SidebarLayout>
