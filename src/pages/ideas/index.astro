---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import { STATUS_LABELS, SITE_EMAIL } from '@/shared/constants';
import { Icon } from 'astro-icon/components';
import { PUBLIC_DEMAND_SIGNAL_MIN } from '@/knowledge/ideas';
import { createIdeasService } from '@/services/ideas.service';
import { formatDateCompact } from '@/shared/format';
import { buildPostPath } from '@/shared/routes';

export const prerender = false;

const { ideas, renderedIdeas } = await createIdeasService().getIdeasPageData();
const statusLabel = STATUS_LABELS;
---

<SidebarLayout
  title="点子 · Walker"
  description="冒出来的想法，记下来。现在没用的，未来可能刚好戳中一个需求。"
  pageTitle="点子"
  pageSubtitle="Ideas"
  pageIcon="lightbulb"
  itemCount={ideas.length}
  itemUnit="个"
>
  <div class="space-y-6" data-ideas-page>
    <!-- 简短说明与引导 -->
    <div class="intro-description panel-glass p-5 rounded-2xl border border-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-xs sm:text-sm text-parchment-dim leading-relaxed max-w-2xl">
        💡 <strong>让你的点子被看见、被回应。</strong> 这里不仅有我的规划，也欢迎你发布灵感。AI 整理提效，遇见需要它的人。<strong>有点子，先动手，再开口。</strong>
      </p>
      <a href="/ideas/new" class="new-idea-btn shrink-0">
        <Icon name="lucide:plus" width={14} height={14} />
        我有新点子
      </a>
    </div>

    <!-- 状态筛选标签栏 -->
    <div class="filter-tabs-wrapper flex flex-wrap gap-2 py-1" aria-label="状态筛选">
      <button type="button" class="filter-tab is-active" data-status="all">
        <span class="tab-dot dot-all"></span>
        全部 ({ideas.length})
      </button>
      {(() => {
        const activeCount = ideas.filter(i => ['thinking', 'validating', 'building'].includes(i.data.status || 'thinking')).length;
        const verifiedCount = ideas.filter(i => i.data.status === 'verified').length;
        return (
          <>
            {activeCount > 0 && (
              <button type="button" class="filter-tab" data-status="active">
                <span class="tab-dot dot-thinking"></span>
                进行中 ({activeCount})
              </button>
            )}
            {verifiedCount > 0 && (
              <button type="button" class="filter-tab" data-status="verified">
                <span class="tab-dot dot-verified"></span>
                已完成 ({verifiedCount})
              </button>
            )}
          </>
        );
      })()}
    </div>

    <!-- 卡牌桌区域 -->
    <div class="ideas-tabletop relative">
      <!-- 桌面微妙质感的光晕效果 -->
      <div class="tabletop-ambient-glow"></div>
      
      <div class="card-grid" id="ideas-grid">
        {renderedIdeas.map(({ entry, Content, demandSignal, collaboratorCount = 0, isCommunity, reactions }) => {
          const status = entry.data.status || 'thinking';
          const isThinking = status === 'thinking';

          return (
            <div 
              class={`card-container ${isThinking ? 'is-blurred' : ''}`}
              id={entry.id}
              data-status={status}
              data-id={entry.id}
              tabindex="0"
              role="button"
              aria-expanded="false"
              aria-haspopup="dialog"
              aria-label={`点子：${entry.data.title}，状态：${statusLabel[status] ?? status}`}
            >
              <div class="card-inner">
                <!-- 正面 (牌面) -->
                <div class="card-face card-front">
                  <!-- Thinking 状态特有的模糊遮罩层 -->
                  {isThinking && (
                    <div class="thinking-overlay">
                      <div class="overlay-lock-glow">
                        <Icon name="lucide:lock" width={22} height={22} class="text-brand shrink-0" />
                      </div>
                      <span class="overlay-status-title">💡 构思中</span>
                      <p class="overlay-status-desc">构思中的点子，点击此卡牌解密解锁</p>
                      <button type="button" class="reveal-btn">点击翻开解密</button>
                    </div>
                  )}

                  <div class="card-body">
                    <!-- 顶部元信息 -->
                    <div class="card-header-meta">
                      <span class="card-date">{formatDateCompact(entry.data.date)}</span>
                      <div class="card-header-badges">
                        <span class={`status-badge badge-${status}`}>
                          <span class="status-indicator"></span>
                          {statusLabel[status] ?? status}
                        </span>
                        {collaboratorCount > 0 && (
                          <span class="collab-count-badge" title={`${collaboratorCount} 位同频者靠近`}>
                            <Icon name="lucide:users" width={10} height={10} />
                            {collaboratorCount}人靠近
                          </span>
                        )}
                        {reactions && (reactions.need > 0 || reactions.thought_before > 0) && (
                          <span class="reactions-count-badge" title={`${reactions.need}人需要，${reactions.thought_before}人想过`}>
                            <Icon name="lucide:flame" width={10} height={10} />
                            {reactions.need + reactions.thought_before} 引力
                          </span>
                        )}
                        {demandSignal >= PUBLIC_DEMAND_SIGNAL_MIN && (
                          <span class="demand-signal-badge">
                            <Icon name="lucide:activity" width={10} height={10} />
                            有需求信号
                          </span>
                        )}
                      </div>
                    </div>

                    <!-- 标题 -->
                    <h3 class="card-title">
                      {entry.data.title}
                    </h3>

                    <!-- 摘要 -->
                    <p class="card-summary">
                      {entry.data.summary ?? '这只是一星闪现的火花，先点击解密翻开查看细节。'}
                    </p>

                    <!-- 标签 (最多4个) -->
                    {entry.data.tags && entry.data.tags.length > 0 && (
                      <div class="card-tags">
                        {entry.data.tags.slice(0, 4).map(tag => (
                          <span class="card-tag">#{tag}</span>
                        ))}
                      </div>
                    )}

                    <!-- 底部翻牌操作 -->
                    <div class="card-footer">
                      <button type="button" class="flip-btn-action">
                        <Icon name="lucide:rotate-3d" width={14} height={14} class="flip-icon" />
                        查看详细构想
                      </button>
                    </div>
                  </div>
                </div>

                <!-- 背面 (详情) -->
                <div class="card-face card-back">
                  <div class="card-back-container relative">
                    <!-- 背面头部 -->
                    <div class="card-back-header">
                      <div class="flex-1 min-w-0">
                        <span class="text-[9px] font-mono tracking-widest text-brand uppercase">
                          {isCommunity ? "COMMUNITY IDEA / 社区提报" : "IDEA DETAILS / 深度规划"}
                        </span>
                        <h4 class="card-back-title">{entry.data.title}</h4>
                      </div>
                    </div>

                    <!-- 详情区域 - 带原生滚动条与视觉淡出指示器 -->
                    <div class="card-back-scroll-wrapper relative flex-grow overflow-hidden flex flex-col mb-2">
                      <div class="card-back-scroll scrollable-y flex-grow">
                        <div class="prose-mini">
                          {isCommunity ? (
                            <Content aiStructure={entry.data.aiStructure} />
                          ) : (
                            <Content />
                          )}
                        </div>
                      </div>
                      <div class="scroll-fade-overlay pointer-events-none"></div>
                    </div>

                    {/* 我能帮表单抽屉 overlay */}
                    <div class="help-form-overlay" data-help-overlay hidden>
                      <form class="help-form" data-help-form data-idea-id={entry.id}>
                        <div class="help-form-header">
                          <span class="text-xs font-bold text-brand">🤝 提报合作意向</span>
                          <button type="button" class="close-help-btn" data-close-help>&times;</button>
                        </div>
                        <div class="space-y-2 mt-2">
                          <input type="text" placeholder="你的名字" required name="name" class="help-input" />
                          <input type="email" placeholder="电子邮箱" required name="email" class="help-input" />
                          <select name="helpType" required class="help-input select-input">
                            <option value="" disabled selected>选择你的擅长领域...</option>
                            <option value="tech">💻 编程/技术</option>
                            <option value="design">🎨 设计/视觉</option>
                            <option value="operation">📢 运营/增长</option>
                            <option value="content">✍️ 内容/文案</option>
                            <option value="other">💡 其它支持</option>
                          </select>
                          <textarea placeholder="你想怎么帮？(简短描述)" required name="note" class="help-textarea" rows="2"></textarea>
                          <button type="submit" class="help-submit-btn">
                            确认提交
                          </button>
                        </div>
                      </form>
                    </div>

                    {/* 互动反应按钮栏 */}
                    <div class="reaction-buttons-bar" data-idea-id={entry.id}>
                      <button type="button" class="reaction-btn" data-reaction-type="need" title="我需要这个点子变成现实">
                        <span>💡 我需要</span>
                        <span class="reaction-count" data-count="need">{reactions?.need || 0}</span>
                      </button>
                      <button type="button" class="reaction-btn" data-reaction-type="thought_before" title="我也曾想过这个方案">
                        <span>👍 我也想过</span>
                        <span class="reaction-count" data-count="thought_before">{reactions?.thought_before || 0}</span>
                      </button>
                      <button type="button" class="reaction-btn help-btn-trigger" data-reaction-type="can_help" title="我愿意提供能力支持共创">
                        <span>🤝 我能帮</span>
                        <span class="reaction-count" data-count="can_help">{reactions?.can_help || 0}</span>
                      </button>
                    </div>

                    <!-- 底部返回与连结 -->
                    <div class="card-back-footer">
                      {isCommunity ? (
                        <div class="canvas-direct-link opacity-50 cursor-not-allowed">社区提报点子</div>
                      ) : (
                        <a href={`/posts/${entry.id}/canvas`} class="canvas-direct-link">
                          进入共创画布
                        </a>
                      )}
                      <div class="card-back-footer-row">
                        <button type="button" class="flip-back-btn">
                          返回
                        </button>
                        {isCommunity ? (
                          <div class="read-full-link opacity-50">无全文</div>
                        ) : (
                          <a href={buildPostPath(entry.id)} class="read-full-link">
                            阅读全文 →
                          </a>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <!-- 空状态 -->
      <div class="empty-state text-center py-20 text-parchment-dim" id="ideas-empty" hidden>
        <Icon name="lucide:lightbulb-off" width={42} height={42} class="mx-auto mb-4 opacity-30 animate-pulse text-brand" />
        <p class="text-sm font-bold">该状态下暂无点子牌</p>
        <p class="text-xs mt-1 opacity-60">灵感火花正在孕育中，稍后再来瞧瞧吧。</p>
      </div>
    </div>

    <!-- 底部高价值组队 CTA -->
    <div class="cta-section panel-glass p-6 sm:p-8 rounded-[2rem] border border-border">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="space-y-2 text-center md:text-left">
          <div class="cta-kicker">TEAM UP / 共促社区</div>
          <h3 class="text-lg sm:text-xl font-bold text-parchment">🃏 看中了哪张牌？来组队。</h3>
          <p class="text-xs sm:text-sm text-parchment-dim leading-relaxed max-w-2xl">
            此处的每个点子都开放共享，期待同行者一起加入，不管是提出交互反馈、技术建议还是共同编码，都随时欢迎。
          </p>
          <a href={`mailto:${SITE_EMAIL}`} class="cta-mail-link">
            <Icon name="lucide:mail" width={11} height={11} />
            {SITE_EMAIL}
          </a>
        </div>
        <div class="flex flex-col items-center gap-2 shrink-0">
          <a href="/tools#info-source" class="cta-join-link">
            <Icon name="lucide:users" width={14} height={14} />
            加入点子共促
          </a>
          <span class="text-[10px] font-mono text-parchment-dim tracking-wide">二维码在工具页</span>
        </div>
      </div>
    </div>
  </div>
</SidebarLayout>

<style>
  /* ------------------- Tabletop 桌面风格 ------------------- */
  .ideas-tabletop {
    border-radius: 1.75rem;
    padding: clamp(1rem, 3.5vw, 2.5rem);
    min-height: 520px;
    background-color: var(--color-inner-bg);
    background-image:
      radial-gradient(circle at 50% 50%, var(--color-brand-glow) 0%, transparent 100%),
      linear-gradient(color-mix(in srgb, var(--color-brand) 6%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--color-brand) 6%, transparent) 1px, transparent 1px);
    background-size: 100% 100%, 30px 30px, 30px 30px;
    border: 1px solid var(--color-border);
    box-shadow: 
      inset 0 24px 48px rgba(0, 0, 0, 0.03),
      0 12px 36px var(--color-inner-shadow);
    transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }

  body.theme-aurora .ideas-tabletop,
  body.theme-sunset .ideas-tabletop,
  body.theme-mint .ideas-tabletop {
    box-shadow: 
      inset 0 24px 48px rgba(0, 0, 0, 0.55),
      0 12px 40px rgba(0, 0, 0, 0.45);
  }

  .tabletop-ambient-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 80%;
    background: radial-gradient(circle, var(--color-brand-glow) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ------------------- Grid 与卡牌卡槽 ------------------- */
  .card-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 2rem;
  }

  .card-container {
    perspective: 1200px;
    height: 380px;
    width: 100%;
    position: relative;
  }

  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    /* transition: transform 0.65s cubic-bezier(0.4, 0, 0.2, 1); */ /* GSAP 接管 */
  }

  /* 3D 翻转动作 */
  .card-container.is-flipped .card-inner {
    /* transform: rotateY(180deg); */ /* GSAP 接管 */
  }

  /* 当翻开牌面阅读时，强力清除所有外部投影、发光、脉冲与动画，安安静静看书 */
  .card-container.is-flipped .card-inner {
    box-shadow: none !important;
    animation: none !important;
  }
  .card-container.is-flipped .card-front,
  .card-container.is-flipped .card-back {
    animation: none !important;
    box-shadow: inset 0 0 20px var(--color-inner-shadow) !important; /* 仅保留极弱内凹陷，彻底移除外部发光 */
  }

  /* 卡牌面基础面貌 */
  .card-face {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 1.25rem;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ------------------- Card Front 正面 (全息毛玻璃) ------------------- */
  .card-front {
    background: #FFFFFF;
    border: 1px solid rgba(0, 0, 0, 0.06);
    cursor: pointer;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .card-container:hover .card-front {
    /* transform: translateY(-12px) rotate(0.8deg); */ /* GSAP 接管 */
    border-color: var(--color-brand);
    box-shadow: 
      0 6px 20px rgba(110, 91, 255, 0.08),
      0 1px 3px rgba(0, 0, 0, 0.02);
  }

  body.theme-aurora .card-front,
  body.theme-sunset .card-front,
  body.theme-mint .card-front {
    background: var(--color-card);
    backdrop-filter: blur(40px) saturate(200%);
    border: 1px solid var(--color-border);
    box-shadow: none;
  }

  body.theme-aurora .card-container:hover .card-front,
  body.theme-sunset .card-container:hover .card-front,
  body.theme-mint .card-container:hover .card-front {
    box-shadow: 
      inset 0 1.5px 3.5px rgba(255, 255, 255, 0.12),
      0 24px 48px -8px rgba(0, 0, 0, 0.6),
      0 0 20px var(--color-brand-glow);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.35rem;
  }

  .card-header-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }

  .card-header-badges {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .card-date {
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    color: var(--color-brand);
    font-weight: 700;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.68rem;
    font-weight: 800;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .status-indicator {
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }

  /* 状态特异性配色 */
  .badge-thinking {
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.08);
    color: var(--color-brand);
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.18);
  }
  .badge-thinking .status-indicator { background: var(--color-brand); }

  .badge-validating {
    background: color-mix(in srgb, var(--color-brand-secondary) 12%, transparent);
    color: var(--color-brand-secondary);
    border-color: color-mix(in srgb, var(--color-brand-secondary) 25%, transparent);
  }
  .badge-validating .status-indicator { background: var(--color-brand-secondary); }

  .badge-building {
    background: var(--color-brand-glow);
    color: var(--color-brand);
    border-color: color-mix(in srgb, var(--color-brand) 30%, transparent);
  }
  .badge-building .status-indicator { background: var(--color-brand); }

  .badge-verified {
    background: color-mix(in srgb, var(--color-brand-secondary) 12%, transparent);
    color: var(--color-brand-secondary);
    border-color: color-mix(in srgb, var(--color-brand-secondary) 25%, transparent);
  }
  .badge-verified .status-indicator { background: var(--color-brand-secondary); }

  .badge-archived {
    background: color-mix(in srgb, var(--color-parchment-dim) 10%, transparent);
    color: var(--color-parchment-dim);
    border-color: color-mix(in srgb, var(--color-parchment-dim) 20%, transparent);
  }
  .badge-archived .status-indicator { background: var(--color-parchment-dim); opacity: 0.5; }

  .demand-signal-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.62rem;
    font-weight: 750;
    padding: 0.2rem 0.45rem;
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.1);
    color: rgb(56, 189, 248);
    border: 1px solid rgba(56, 189, 248, 0.2);
  }

  .collab-count-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.62rem;
    font-weight: 750;
    padding: 0.2rem 0.45rem;
    border-radius: 999px;
    background: rgba(110, 91, 255, 0.1);
    color: var(--brand-purple, var(--color-brand, #6E5BFF));
    border: 1px solid rgba(110, 91, 255, 0.2);
  }

  .card-title {
    margin: 0 0 0.65rem;
    font-family: var(--font-heading, inherit);
    color: var(--color-parchment);
    font-size: 1.15rem;
    font-weight: 850;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-summary {
    font-size: 0.82rem;
    color: var(--color-parchment-dim);
    line-height: 1.7;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1rem;
    padding-top: 0.65rem;
    border-top: 1px dashed var(--color-border);
  }

  .card-tag {
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    color: var(--color-parchment-dim);
    opacity: 0.8;
  }

  .card-footer {
    margin-top: auto;
  }

  .flip-btn-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    width: 100%;
    padding: 0.55rem 0.8rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-inner-bg);
    color: var(--color-parchment);
    font-size: 0.75rem;
    font-weight: 750;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .flip-btn-action:hover {
    background: var(--color-brand);
    color: #ffffff;
    border-color: var(--color-brand);
    box-shadow: 0 4px 12px var(--color-brand-glow);
  }

  .flip-icon {
    transition: transform 0.4s ease;
  }

  .flip-btn-action:hover .flip-icon {
    transform: rotate(180deg);
  }

  /* ------------------- Card Back 背面 ------------------- */
  .card-back {
    transform: rotateY(180deg);
    background: var(--color-card);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border: 1px solid var(--color-border);
    box-shadow: inset 0 0 20px var(--color-inner-shadow);
  }

  .card-back-container {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.15rem;
  }

  .card-back-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.85rem;
  }

  .card-back-title {
    margin: 0.15rem 0 0;
    font-family: var(--font-heading, inherit);
    color: var(--color-parchment);
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

