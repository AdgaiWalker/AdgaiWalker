---
import BaseLayout from '../../layouts/Base.astro';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import { Icon } from 'astro-icon/components';

export const prerender = false;
---

<SidebarLayout title="你有新点子吗？ · DIANZI">
  <div class="max-w-4xl mx-auto space-y-8 py-6 px-4" data-new-idea-page>
    <!-- Header -->
    <div class="space-y-2">
      <div class="flex items-center gap-2 text-xs font-mono text-brand uppercase tracking-wider">
        <a href="/ideas" class="hover:text-brand-glow transition-colors">点子卡牌桌</a>
        <span>/</span>
        <span class="text-parchment-dim">捕捉灵感</span>
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-parchment">💡 捕捉你的点子</h1>
      <p class="text-xs sm:text-sm text-parchment-dim leading-relaxed">
        在这里写下你模糊的闪光想法。AI 将协助你进行结构化梳理，帮助它在卡牌桌上遇见能一起完善它的人。
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Left Column: Input Form -->
      <div class="panel-glass p-6 rounded-2xl border border-border flex flex-col space-y-4">
        <h2 class="text-sm font-bold text-parchment flex items-center gap-1.5 border-b border-border pb-3">
          <Icon name="lucide:pen-line" width={16} height={16} class="text-brand" />
          1. 灵感原始输入
        </h2>

        <div class="space-y-4">
          <div class="space-y-1">
            <label class="text-xs text-parchment-dim font-bold">点子描述</label>
            <textarea
              id="raw-input"
              class="new-idea-input"
              placeholder="我想做一个能够自动根据天气改变背景色彩的个人网站..."
              rows="6"
              required
            ></textarea>
          </div>

          <div class="space-y-1">
            <label class="text-xs text-parchment-dim font-bold">灵感类别</label>
            <select
              id="source-type"
              class="new-idea-input select-input"
            >
              <option value="life_observation">🌱 生活微小观察 (Life Observation)</option>
              <option value="work_efficiency">🛠️ 工作效率痛点 (Work Efficiency)</option>
              <option value="random_spark">⚡ 偶发闪光灵感 (Random Spark)</option>
              <option value="future_draft">🔮 未来雏形方案 (Future Draft)</option>
            </select>
          </div>

          <button id="refine-btn" class="w-full py-3 rounded-xl bg-brand text-white text-xs font-bold transition-all hover:bg-brand-glow flex items-center justify-center gap-2">
            <Icon name="lucide:wand" width={14} height={14} />
            让 AI 整理结构化
          </button>
        </div>
      </div>

      <!-- Right Column: AI Preview & Final Publish -->
      <div class="panel-glass p-6 rounded-2xl border border-border flex flex-col space-y-4 relative overflow-hidden">
        <h2 class="text-sm font-bold text-parchment flex items-center gap-1.5 border-b border-border pb-3">
          <Icon name="lucide:sparkles" width={16} height={16} class="text-brand" />
          2. AI 整理预览
        </h2>

        <!-- Empty State / Loading State -->
        <div id="preview-empty" class="flex-grow flex flex-col items-center justify-center py-12 text-center text-parchment-dim space-y-3">
          <Icon name="lucide:box" width={40} height={40} class="opacity-20 animate-pulse text-brand" />
          <p class="text-xs">在左侧写完并点击 AI 整理后，卡牌预览会在这里生成</p>
        </div>

        <div id="preview-loading" class="flex-grow flex flex-col items-center justify-center py-12 text-center text-parchment-dim space-y-3 hidden">
          <Icon name="lucide:loader-2" width={40} height={40} class="animate-spin text-brand" />
          <p class="text-xs">AI 正在理解你的点子，请稍候...</p>
        </div>

        <!-- Real preview layout -->
        <div id="preview-content" class="flex-grow flex flex-col space-y-4 hidden">
          <!-- Editable Fields -->
          <div class="space-y-3">
            <div class="space-y-1">
              <label class="text-[10px] text-brand font-bold uppercase tracking-wider">标题 (可修改)</label>
              <input type="text" id="preview-title" class="new-idea-input new-idea-input-sm font-bold" />
            </div>
            <div class="space-y-1">
              <label class="text-[10px] text-brand font-bold uppercase tracking-wider">一句话简介 (可修改)</label>
              <input type="text" id="preview-summary" class="new-idea-input new-idea-input-sm" />
            </div>
          </div>

          <!-- Structured details readout -->
          <div class="flex-grow scrollable-y max-h-[220px] pr-1 space-y-3 text-xs leading-relaxed text-parchment-dim">
            <div>
              <span class="font-bold text-parchment block">🎯 想解决的问题：</span>
              <p id="preview-problem" class="mt-1"></p>
            </div>
            <div>
              <span class="font-bold text-parchment block">👥 目标群体：</span>
              <p id="preview-target-users" class="mt-1"></p>
            </div>
            <div>
              <span class="font-bold text-parchment block">🚀 建议实现方向：</span>
              <ul id="preview-solutions" class="list-disc pl-4 mt-1 space-y-0.5"></ul>
            </div>
            <div>
              <span class="font-bold text-parchment block">🧪 验证步骤建议：</span>
              <ul id="preview-validation" class="list-disc pl-4 mt-1 space-y-0.5"></ul>
            </div>
            <div>
              <span class="font-bold text-parchment block">⚠️ 潜在风险：</span>
              <ul id="preview-risks" class="list-disc pl-4 mt-1 space-y-0.5"></ul>
            </div>
            <div class="pt-2">
              <span class="font-bold text-parchment block mb-1.5">🏷️ 标签：</span>
              <div id="preview-tags" class="flex flex-wrap gap-1"></div>
            </div>
          </div>

          <!-- Action Button -->
          <button id="submit-btn" class="w-full py-3 rounded-xl bg-brand text-white text-xs font-bold transition-all hover:bg-brand-glow flex items-center justify-center gap-2 mt-auto">
            <Icon name="lucide:check" width={14} height={14} />
            确认并发布到点子广场
          </button>
        </div>
      </div>
    </div>
  </div>
</SidebarLayout>

<style>
  .new-idea-input {
    width: 100%;
    box-sizing: border-box;
    padding: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-parchment-dim) 6%, transparent);
    color: var(--color-parchment);
    font-size: 0.75rem;
    transition: all 0.2s ease;
  }
  .new-idea-input:focus {
    outline: none;
    border-color: var(--color-brand);
    background: var(--color-card);
  }
  .new-idea-input::placeholder {
    opacity: 0.5;
  }
  .new-idea-input-sm {
    padding: 0.5rem;
  }
  .select-input {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='gray' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 0.75rem center;
    background-size: 1.2em;
  }
</style>

<script>
  let structuredData: any = null;

  document.addEventListener('DOMContentLoaded', () => {
    const rawInputEl = document.getElementById('raw-input') as HTMLTextAreaElement;
    const sourceTypeEl = document.getElementById('source-type') as HTMLSelectElement;
    const refineBtn = document.getElementById('refine-btn') as HTMLButtonElement;
    
    const previewEmpty = document.getElementById('preview-empty') as HTMLElement;
    const previewLoading = document.getElementById('preview-loading') as HTMLElement;
    const previewContent = document.getElementById('preview-content') as HTMLElement;

    const previewTitle = document.getElementById('preview-title') as HTMLInputElement;
    const previewSummary = document.getElementById('preview-summary') as HTMLInputElement;
    const previewProblem = document.getElementById('preview-problem') as HTMLElement;
    const previewTargetUsers = document.getElementById('preview-target-users') as HTMLElement;
    const previewSolutions = document.getElementById('preview-solutions') as HTMLElement;
    const previewValidation = document.getElementById('preview-validation') as HTMLElement;
    const previewRisks = document.getElementById('preview-risks') as HTMLElement;
    const previewTags = document.getElementById('preview-tags') as HTMLElement;
    
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    // 1. AI 整理灵感
    refineBtn.addEventListener('click', async () => {
      const text = rawInputEl.value.trim();
      if (text.length < 5) {
        alert('灵感太短啦，多输入几个字吧！(最少5字)');
        return;
      }

      // 切换视图
      previewEmpty.classList.add('hidden');
      previewLoading.classList.remove('hidden');
      previewContent.classList.add('hidden');
      refineBtn.disabled = true;
      refineBtn.textContent = 'AI 整理中...';

      try {
        const res = await fetch('/api/ideas/ai-refine', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            rawInput: text,
            sourceType: sourceTypeEl.value,
          }),
        });

        if (res.ok) {
          const data = await res.json();
          structuredData = data;

          // 填充表单与预览
          previewTitle.value = data.title || '';
          previewSummary.value = data.summary || '';
          previewProblem.textContent = data.problem || '暂无说明';
          previewTargetUsers.textContent = data.targetUsers || '暂无说明';

          previewSolutions.innerHTML = (data.solutions || []).map((s: string) => `<li>${s}</li>`).join('');
          previewValidation.innerHTML = (data.validationSteps || []).map((s: string) => `<li>${s}</li>`).join('');
          previewRisks.innerHTML = (data.risks || []).map((r: string) => `<li>${r}</li>`).join('');

          previewTags.innerHTML = (data.tags || []).map((t: string) => 
            `<span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-[#1a1a1a] text-brand border border-brand/20">${t}</span>`
          ).join('');

          previewLoading.classList.add('hidden');
          previewContent.classList.remove('hidden');
        } else {
          const err = await res.json();
          alert(err.error || '整理失败，请稍后重试。');
          previewLoading.classList.add('hidden');
          previewEmpty.classList.remove('hidden');
        }
      } catch (err) {
        console.error(err);
        alert('服务器通信错误。');
        previewLoading.classList.add('hidden');
        previewEmpty.classList.remove('hidden');
      } finally {
        refineBtn.disabled = false;
        refineBtn.innerHTML = `✨ 让 AI 整理结构化`;
      }
    });

    // 2. 发布卡牌到点子广场
    submitBtn.addEventListener('click', async () => {
      if (!structuredData) return;

      submitBtn.disabled = true;
      submitBtn.textContent = '正在发布...';

      const payload = {
        title: previewTitle.value.trim(),
        summary: previewSummary.value.trim(),
        rawInput: rawInputEl.value.trim(),
        sourceType: sourceTypeEl.value,
        tags: structuredData.tags,
        aiStructure: {
          problem: previewProblem.textContent,
          targetUsers: previewTargetUsers.textContent,
          possibleSolutions: structuredData.solutions,
          validationSteps: structuredData.validationSteps,
          risks: structuredData.risks,
        }
      };

      try {
        const res = await fetch('/api/ideas/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          const data = await res.json();
          // 重定向回广场，并用 hash 锚定刚提交的卡片 ID，自动翻牌
          window.location.href = `/ideas#${data.id}`;
        } else {
          alert('发布失败，请稍后重试。');
          submitBtn.disabled = false;
          submitBtn.innerHTML = `🚀 确认并发布到点子广场`;
        }
      } catch (err) {
        console.error(err);
        alert('发布异常。');
        submitBtn.disabled = false;
        submitBtn.innerHTML = `🚀 确认并发布到点子广场`;
      }
    });
  });
</script>
