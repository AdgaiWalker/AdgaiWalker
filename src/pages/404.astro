---
import Base from '../layouts/Base.astro';
import { ArrowLeft } from 'lucide-astro';
---

<Base title="404 — Walker">
  <div class="max-w-3xl mx-auto px-6 pt-32 pb-20 text-center">
    <div class="w-16 h-16 mx-auto mb-8 rounded-full border border-border flex items-center justify-center">
      <span class="text-text-muted text-2xl font-heading">⊘</span>
    </div>

    <h1 class="font-heading text-3xl text-text mb-3">这里空空如也</h1>

    <p class="text-text-muted text-base leading-relaxed mb-8">
      你到达了从未被记录的坐标。
    </p>

    <a
      href="/"
      class="inline-flex items-center gap-2 px-5 py-2 rounded-lg bg-gold/10 border border-gold/25 text-gold text-sm font-heading hover:bg-gold/20 hover:border-gold/40 transition-all no-underline"
    >
      <ArrowLeft class="w-4 h-4" strokeWidth={1.8} />
      回到首页
    </a>
  </div>
</Base>
