---
import Base from '../layouts/Base.astro';
---

<Base title="迷失方向 — Walker">
  <div class="relative">
    <div class="fixed inset-0 pointer-events-none z-0"
      style="background: linear-gradient(180deg, #132040 0%, #0a1628 30%, #060e1a 100%);">
    </div>

    <div class="relative z-10 max-w-2xl mx-auto px-6 pt-32 pb-20 text-center">
      <div class="w-20 h-20 mx-auto mb-8 rounded-full border border-mist/20 flex items-center justify-center">
        <span class="text-mist/40 text-3xl font-heading">⊘</span>
      </div>

      <h1 class="font-heading text-4xl text-parchment tracking-wide mb-4">这片海域没有标记</h1>

      <p class="text-parchment/50 text-base font-body leading-relaxed mb-10">
        你到达了一个从未被记录的坐标。<br />
        也许风把它吹走了，也许它从未存在过。
      </p>

      <a
        href="/"
        class="inline-block px-6 py-2.5 rounded-lg bg-gold/10 border border-gold/25 text-gold/80 font-heading text-sm tracking-wider hover:bg-gold/20 hover:border-gold/40 transition-all no-underline"
      >
        回到港口
      </a>
    </div>
  </div>
</Base>
