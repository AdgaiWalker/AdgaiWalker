---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';

export const prerender = true;
---

<Base
  title="页面不存在 — Walker"
  description="这片海域暂时没有对应的航线。"
  ogTitle="页面不存在 — Walker"
  ogDescription="这片海域暂时没有对应的航线。"
>
  <section class="min-h-[72vh] px-6 pt-28 pb-20 flex items-center justify-center">
    <div class="panel-glass max-w-xl w-full p-8 md:p-10 text-center">
      <div class="mx-auto mb-6 w-14 h-14 rounded-2xl bg-coral/10 border border-coral/20 flex items-center justify-center text-coral">
        <Icon name="lucide:map" width={28} height={28} />
      </div>
      <p class="text-xs font-mono uppercase tracking-[0.28em] text-coral/70 mb-3">404 Not Found</p>
      <h1 class="font-heading text-3xl md:text-4xl text-parchment mb-4">页面不存在</h1>
      <p class="text-parchment-dim leading-relaxed mb-8">
        这条航线暂时没有记录。可能是链接已经移动，也可能是你发现了一片还没命名的水域。
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center gap-2 rounded-xl bg-bio-cyan/12 border border-bio-cyan/20 px-5 py-3 text-sm font-heading text-bio-cyan no-underline hover:bg-bio-cyan/18 hover:border-bio-cyan/35 transition-colors"
      >
        <Icon name="lucide:house" width={16} height={16} />
        返回首页
      </a>

      {/* 搜索入口 */}
      <div class="mt-6 pt-5 border-t border-coral/15">
        <p class="text-xs text-parchment-dim mb-3">试试搜索你想找的内容：</p>
        <button
          id="notfound-search-btn"
          class="inline-flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm bg-[var(--color-card)] border border-[var(--color-border)] text-parchment-dim hover:text-parchment hover:border-brand/30 transition-colors cursor-pointer w-full"
        >
          <Icon name="lucide:search" width={16} height={16} />
          <span>在这片海域中搜索...</span>
          <kbd class="ml-auto text-[10px] font-mono px-1.5 py-0.5 rounded bg-black/5 border border-[var(--color-nav-border)] text-parchment-dim">⌘K</kbd>
        </button>
      </div>

      {/* 推荐航线 */}
      <div class="mt-5">
        <p class="text-[10px] font-mono uppercase tracking-widest text-parchment-dim/60 mb-3">推荐航线</p>
        <div class="grid grid-cols-2 gap-2 text-left">
          <a href="/learn?tab=thoughts" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[var(--color-card)] border border-[var(--color-border)] text-parchment-dim text-xs no-underline hover:border-brand/30 hover:text-brand transition-colors">
            <Icon name="lucide:pen-line" width={14} height={14} />
            文章
          </a>
          <a href="/ideas" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[var(--color-card)] border border-[var(--color-border)] text-parchment-dim text-xs no-underline hover:border-brand/30 hover:text-brand transition-colors">
            <Icon name="lucide:lightbulb" width={14} height={14} />
            点子
          </a>
          <a href="/tools" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[var(--color-card)] border border-[var(--color-border)] text-parchment-dim text-xs no-underline hover:border-brand/30 hover:text-brand transition-colors">
            <Icon name="lucide:wrench" width={14} height={14} />
            工具
          </a>
          <a href="/about" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[var(--color-card)] border border-[var(--color-border)] text-parchment-dim text-xs no-underline hover:border-brand/30 hover:text-brand transition-colors">
            <Icon name="lucide:user" width={14} height={14} />
            关于
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  document.getElementById('notfound-search-btn')?.addEventListener('click', () => {
    document.dispatchEvent(new KeyboardEvent('keydown', { metaKey: true, key: 'k' }));
  });
</script>
