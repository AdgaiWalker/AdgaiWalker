---
interface Props {
  pagePath: string;
}

const { pagePath } = Astro.props;
---

<button
  class="panel-glass self-start px-5 py-2.5 items-center gap-2 reveal reveal-delay-4 shadow-md bg-abyss/40 border-coral/20 hidden md:flex text-coral/90 hover:text-coral transition-colors disabled:opacity-60"
  type="button"
  data-like-counter
  data-page-path={pagePath}
  aria-label="喜欢这个页面"
>
  <span class="relative flex h-2 w-2">
    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-coral opacity-75"></span>
    <span class="relative inline-flex rounded-full h-2 w-2 bg-coral"></span>
  </span>
  <iconify-icon icon="lucide:heart" width="14" height="14"></iconify-icon>
  <span class="text-[13px] font-mono tracking-widest pl-0.5" data-like-count>0</span>
</button>

<script>
  const SUPABASE_URL = 'https://ttjfsnhmhsuohugrexwq.supabase.co';
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR0amZzbmhtaHN1b2h1Z3JleHdxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgyODAwNTUsImV4cCI6MjA5Mzg1NjA1NX0.tgfvETm3ldMR4yvV7V2K8Ax00-FnY1yV1mK-4UtJpCg';

  const setupLikes = async () => {
    const { createClient } = await import('@supabase/supabase-js');
    const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
      auth: { persistSession: false, autoRefreshToken: false },
    });

    document.querySelectorAll<HTMLButtonElement>('[data-like-counter]').forEach((button) => {
      if (button.dataset.ready === 'true') return;
      button.dataset.ready = 'true';

      const pagePath = button.dataset.pagePath ?? '/';
      const countEl = button.querySelector<HTMLElement>('[data-like-count]');
      const storageKey = `walker-liked:${pagePath}`;

      const setCount = (count: number) => {
        if (countEl) countEl.textContent = String(count);
      };

      const markLiked = () => {
        button.disabled = true;
        button.setAttribute('aria-label', '已经喜欢过这个页面');
        button.classList.add('bg-coral/10');
      };

      if (localStorage.getItem(storageKey) === 'true') {
        markLiked();
      }

      supabase
        .from('likes')
        .select('count')
        .eq('page_path', pagePath)
        .maybeSingle<{ count: number }>()
        .then(({ data }) => setCount(data?.count ?? 0))
        .catch(() => setCount(0));

      button.addEventListener('click', async () => {
        if (localStorage.getItem(storageKey) === 'true') {
          markLiked();
          return;
        }

        button.disabled = true;
        try {
          const { data: current } = await supabase
            .from('likes')
            .select('count')
            .eq('page_path', pagePath)
            .maybeSingle<{ count: number }>();

          const nextCount = (current?.count ?? 0) + 1;

          const { data } = await supabase
            .from('likes')
            .upsert({ page_path: pagePath, count: nextCount }, { onConflict: 'page_path' })
            .select('count')
            .single<{ count: number }>();

          setCount(data?.count ?? nextCount);
          localStorage.setItem(storageKey, 'true');
          markLiked();
          button.animate(
            [
              { transform: 'scale(1)' },
              { transform: 'scale(1.08)' },
              { transform: 'scale(1)' },
            ],
            { duration: 260, easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)' }
          );
        } catch {
          button.disabled = false;
        }
      });
    });
  };

  setupLikes();
  document.addEventListener('astro:after-swap', setupLikes);
</script>
