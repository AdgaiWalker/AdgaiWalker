---
/**
 * LikeCounter — 点赞组件
 * 视觉优化：未点击(描边心形 + 中性色) → 已点击(实心心形 + 粉色 + 弹跳动画)
 */
interface Props {
  pagePath: string;
}

const { pagePath } = Astro.props;
---

<div class="like-wrapper">
  <button
    class="like-btn"
    type="button"
    data-like-counter
    data-page-path={pagePath}
    aria-label="喜欢这个页面"
  >
    {/* 未点击状态 — 描边心形 */}
    <span class="like-icon like-icon-outline">
      <iconify-icon icon="lucide:heart" width="26" height="26"></iconify-icon>
    </span>
    {/* 已点击状态 — 实心心形 */}
    <span class="like-icon like-icon-filled">
      <iconify-icon icon="mingcute:heart-fill" width="26" height="26"></iconify-icon>
    </span>

    {/* 计数气泡 */}
    <div class="like-count-badge">
      <span class="like-count-num" data-like-count>0</span>
    </div>
  </button>
</div>

<script>
  const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const headers = {
    apikey: SB_KEY,
    Authorization: `Bearer ${SB_KEY}`,
    'Content-Type': 'application/json',
    Prefer: 'resolution=merge-duplicates',
  };

  async function fetchCount(pagePath: string): Promise<number> {
    const res = await fetch(
      `${SB_URL}/rest/v1/likes?select=count&page_path=eq.${encodeURIComponent(pagePath)}`,
      { headers }
    );
    if (!res.ok) return 0;
    const rows: { count: number }[] = await res.json();
    return rows[0]?.count ?? 0;
  }

  async function upsertCount(pagePath: string, nextCount: number): Promise<number> {
    const res = await fetch(`${SB_URL}/rest/v1/likes`, {
      method: 'POST',
      headers,
      body: JSON.stringify({ page_path: pagePath, count: nextCount }),
    });
    if (!res.ok) throw new Error(`upsert failed: ${res.status}`);
    const rows: { count: number }[] = await res.json();
    return rows[0]?.count ?? nextCount;
  }

  const setupLikes = async () => {
    if (!SB_URL || !SB_KEY) return;

    // One-time migration: remap old /ai/ and /life/ like keys to /posts/
    const keysToMigrate: string[] = [];
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i);
      if (key?.startsWith('walker-liked:/ai/') || key?.startsWith('walker-liked:/life/')) {
        keysToMigrate.push(key);
      }
    }
    for (const oldKey of keysToMigrate) {
      const newKey = oldKey.replace(/\/(ai|life)\//, '/posts/');
      if (!localStorage.getItem(newKey)) {
        localStorage.setItem(newKey, localStorage.getItem(oldKey)!);
      }
      localStorage.removeItem(oldKey);
    }

    document.querySelectorAll<HTMLButtonElement>('[data-like-counter]').forEach((button) => {
      if (button.dataset.ready === 'true') return;
      button.dataset.ready = 'true';

      const pagePath = button.dataset.pagePath ?? '/';
      const countEl = button.querySelector<HTMLElement>('[data-like-count]');
      const storageKey = `walker-liked:${pagePath}`;

      const setCount = (count: number) => {
        if (countEl) countEl.textContent = String(count);
      };

      const markLiked = () => {
        button.disabled = true;
        button.classList.add('liked');
        button.setAttribute('aria-label', '已经喜欢过这个页面');
      };

      if (localStorage.getItem(storageKey) === 'true') {
        markLiked();
      }

      fetchCount(pagePath).then(setCount).catch(() => setCount(0));

      button.addEventListener('click', async () => {
        if (localStorage.getItem(storageKey) === 'true') {
          markLiked();
          return;
        }

        button.disabled = true;
        try {
          const current = await fetchCount(pagePath);
          const nextCount = current + 1;
          const finalCount = await upsertCount(pagePath, nextCount);

          setCount(finalCount);
          localStorage.setItem(storageKey, 'true');
          markLiked();

          button.classList.add('like-bounce');
          button.addEventListener('animationend', () => {
            button.classList.remove('like-bounce');
          }, { once: true });
        } catch {
          button.disabled = false;
        }
      });
    });
  };

  document.addEventListener('astro:page-load', setupLikes);
</script>

<style>
  .like-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .like-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1.5px solid rgba(42, 59, 62, 0.1);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    outline: none;
  }

  .like-btn:hover:not(.liked) {
    border-color: rgba(255, 107, 138, 0.3);
    background: rgba(255, 107, 138, 0.05);
    transform: scale(1.05);
  }

  .like-btn:active:not(.liked) {
    transform: scale(0.95);
  }

  /* 未点击 — 描边心形 */
  .like-icon-outline {
    color: rgba(42, 59, 62, 0.35);
    transition: all 0.3s ease;
  }

  .like-btn:hover:not(.liked) .like-icon-outline {
    color: rgba(255, 107, 138, 0.6);
  }

  /* 已点击 — 实心心形 */
  .like-icon-filled {
    position: absolute;
    color: #ff6b8a;
    opacity: 0;
    transform: scale(0);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* 已点击状态 */
  .like-btn.liked {
    border-color: rgba(255, 107, 138, 0.25);
    background: rgba(255, 107, 138, 0.06);
    cursor: default;
  }

  .like-btn.liked .like-icon-outline {
    opacity: 0;
    transform: scale(0);
  }

  .like-btn.liked .like-icon-filled {
    opacity: 1;
    transform: scale(1);
  }

  /* 弹跳动画 */
  .like-bounce {
    animation: like-pop 0.45s cubic-bezier(0.17, 0.89, 0.32, 1.49);
  }

  @keyframes like-pop {
    0% { transform: scale(1); }
    30% { transform: scale(1.2); }
    50% { transform: scale(0.9); }
    70% { transform: scale(1.08); }
    100% { transform: scale(1); }
  }

  /* 计数气泡 */
  .like-count-badge {
    position: absolute;
    top: -6px;
    right: -10px;
    min-width: 24px;
    height: 22px;
    padding: 0 6px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(42, 59, 62, 0.08);
    transition: all 0.3s ease;
  }

  .like-btn.liked .like-count-badge {
    background: rgba(255, 107, 138, 0.12);
  }

  .like-count-num {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    color: rgba(42, 59, 62, 0.4);
    line-height: 1;
    transition: color 0.3s ease;
  }

  .like-btn.liked .like-count-num {
    color: #ff6b8a;
  }

  /* disabled 样式 */
  .like-btn:disabled {
    opacity: 1;
  }
</style>
