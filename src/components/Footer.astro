---
/**
 * Footer — 导航 + 版权
 */
import { HOME, POSTS, TOOLS, IDEAS, ABOUT } from '@/shared/routes';
import { getSolarTerm } from '@/lib/solar-terms';

const term = getSolarTerm();
const termHighlight = `${term.name} · ${term.poetic.split(/[，,]/)[0]}`;
---
<footer class="py-10 flex flex-col items-center justify-center gap-3 opacity-30 hover:opacity-60 transition-opacity duration-500">
  <nav class="flex items-center gap-4 text-[11px] font-body tracking-wide text-parchment">
    <a href={HOME}>首页</a>
    <span class="opacity-30">·</span>
    <a href={POSTS}>思考</a>
    <span class="opacity-30">·</span>
    <a href={TOOLS}>资源</a>
    <span class="opacity-30">·</span>
    <a href={IDEAS}>点子</a>
    <span class="opacity-30">·</span>
    <a href={ABOUT}>关于</a>
    <span class="opacity-30">·</span>
    <a href="/support">支持</a>
    <span class="opacity-30">·</span>
    <a href="/rss.xml">RSS</a>
  </nav>
  <div class="flex flex-col items-center gap-1 text-[11px] font-body tracking-widest text-parchment uppercase">
    <div>&copy; {new Date().getFullYear()} Walker · 行过万里水路</div>
    <div class="text-[9px] font-mono opacity-50 tracking-wider normal-case">{termHighlight}</div>
  </div>
</footer>
