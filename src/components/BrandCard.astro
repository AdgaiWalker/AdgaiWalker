---
/**
 * BrandCard.astro — 首页品牌卡片 (Walker 专属灵感版)
 * 升级：植入打字机品牌文案金句，追加“碰碰运气 (Spark!)”创意脑洞盲盒按钮，触发流星与极酷弹窗
 */
import { Icon } from 'astro-icon/components';

const quotes = [
  "最好的生活状态是，带着自己的目标，准备出发、正在出发、歇会再出发。",
  "别人教你概念，我教你动手。",
  "点子 × AI = ？答案在文章里。",
  "不会写代码，但会想点子。",
  "你有一个点子？好，我们把它做出来。",
  "工具不重要，做出来才重要。",
  "从零开始，用 AI 把想法变成现实。",
  "不讲道理，只讲做法。",
];

const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];
---

<div
  class="brand-card panel-glass p-5 py-6 flex flex-col group/brand h-full rounded-[32px] pointer-events-auto"
  id="brand-card"
>
  {/* Header: icon + tagline */}
  <div class="flex items-center gap-2.5 mb-4 px-1">
    <div class="w-8 h-8 rounded-xl flex items-center justify-center transition-colors duration-300" style="background: var(--color-player-icon-bg, rgba(53, 191, 171, 0.15)); border: 1px solid var(--color-inner-border, rgba(53, 191, 171, 0.15));">
      <Icon name="lucide:sparkles" width={16} height={16} style="color: var(--color-brand, #35bfab);" />
    </div>
    <div class="text-parchment text-[14px] font-body font-bold tracking-tight">
      有点子，就试试
    </div>
  </div>

  {/* Typing area */}
  <div class="flex-1 mb-4 px-1">
    <div class="font-mono text-[13px] text-parchment/65 leading-relaxed min-h-[22px]">
      <span class="font-bold select-none" style="color: var(--color-brand, #35bfab);">❯ </span>
      <span id="typing-text" class="typing-cursor"></span>
    </div>

    {/* Random quote */}
    <p
      id="brand-quote"
      class="text-parchment/40 text-[11px] font-body mt-2 leading-relaxed opacity-0 transition-opacity duration-700"
    >
      {randomQuote}
    </p>
  </div>

  {/* 下方控制栏 (包含 CTA 链接 与 Spark 趣味抽盲盒) */}
  <div class="flex items-center gap-2 w-full mt-2">
    <!-- CTA 文章 -->
    <a
      href="/posts"
      class="flex-1 flex items-center justify-between px-4 py-2.5 rounded-2xl border transition-all no-underline shadow-sm hover:opacity-95"
      style="background: var(--color-inner-bg, rgba(255, 255, 255, 0.7)); border-color: var(--color-inner-border, rgba(255, 255, 255, 0.8));"
    >
      <span class="text-parchment-dim/80 text-[11.5px] font-body">
        看看能用 AI 做些什么
      </span>
      <Icon
        name="lucide:arrow-right"
        width={13}
        height={13}
        class="text-parchment-dim/40"
      />
    </a>

    <!-- 碰碰运气 Spark! 抽盲盒按钮 (自适应变色与果冻弹性) -->
    <button
      id="spark-trigger-btn"
      class="px-4 py-2.5 rounded-2xl flex items-center gap-1.5 cursor-pointer shadow-sm relative overflow-hidden group/spark hover:scale-103 active:scale-97 transition-all font-body font-black text-[12px]"
      title="碰碰运气抽个点子盲盒"
      style="background: var(--color-player-icon-bg, #e6fcf9); color: var(--color-brand, #35bfab); border: 1px solid var(--color-inner-border, rgba(53,191,171,0.2));"
    >
      <Icon name="lucide:wand-sparkles" width={13} height={13} class="animate-bounce" />
      <span>Spark!</span>
    </button>
  </div>
</div>

<style>
  .typing-cursor::after {
    content: '▊';
    animation: blink 1s step-end infinite;
    color: var(--color-brand, #35bfab);
    opacity: 0.6;
    font-size: 13px;
  }

  @keyframes blink {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 0; }
  }
</style>

<script>
  // 准备丰富的搞怪 AI 创意脑洞库
  const BRAIN_SPARKS = [
    "🐾 开发一个可以将猫咪喵喵声自动翻译成拍立得卡通日记的 APP！",
    "🎷 做一款 VSCode 插件：当你的代码写出 Bug 时，自动播放悲伤的萨克斯风！",
    "💆‍♂️ 构建一个 AI 虚拟老板：每天早晨用极其温柔的声线催你写代码，并提供心理按摩！",
    "☕ 设计一款智能水杯：AI 会根据你今天敲键盘的次数和写 Bug 的频率，强行提醒你喝咖啡！",
    "🌙 打造一款 AI 梦境发生器：晚上输入你想梦到的场景，AI 自动为你脑补一段催眠故事！",
    "🍳 做个 AI 厨艺拯救者：拍一下冰箱里剩下的烂西红柿和半盒豆腐，AI 自动生成一道米其林级别的黑暗料理菜谱！",
    "🐾 开发一款 AI 宠物社交机器人：让你的猫在网上和隔壁的狗通过 GPT 聊天，甚至能网恋！",
    "🌸 做一款‘键盘侠净化器’：用 AI 自动把你写在终端里的脏话脏代码注释重写成高雅的古典诗词！",
    "🛹 开发一款‘滑板AI跟拍仪’：用 AI 动作捕捉算法，自动在滑板腾空那一瞬间抓拍出最帅的侧脸！",
    "💤 做一款‘睡眠AI监控器’：通过 AI 分析你晚上的呼噜声，自动编排出一首舒缓的白噪音钢琴曲！"
  ];

  function initBrandCard() {
    const el = document.getElementById('typing-text');
    const quoteEl = document.getElementById('brand-quote');
    if (!el || el.dataset.typed === 'true') return;
    el.dataset.typed = 'true';

    const phrases = [
      "你有一个点子？",
      "好，我们把它做出来。",
    ];

    let phraseIdx = 0;
    let charIdx = 0;
    let currentText = '';
    let deleting = false;
    let pauseCounter = 0;

    function tick() {
      if (phraseIdx >= phrases.length) {
        el.classList.remove('typing-cursor');
        if (quoteEl) quoteEl.style.opacity = '1';
        return;
      }

      const phrase = phrases[phraseIdx];

      if (!deleting) {
        if (charIdx <= phrase.length) {
          currentText = phrase.slice(0, charIdx);
          el.textContent = currentText;
          charIdx++;
          setTimeout(tick, 50 + Math.random() * 40);
        } else {
          if (phraseIdx < phrases.length - 1) {
            pauseCounter++;
            if (pauseCounter < 15) {
              setTimeout(tick, 60);
            } else {
              pauseCounter = 0;
              deleting = true;
              setTimeout(tick, 30);
            }
          } else {
            phraseIdx++;
            setTimeout(tick, 100);
          }
        }
      } else {
        if (charIdx > 0) {
          charIdx--;
          currentText = phrase.slice(0, charIdx);
          el.textContent = currentText;
          setTimeout(tick, 25);
        } else {
          deleting = false;
          phraseIdx++;
          setTimeout(tick, 300);
        }
      }
    }

    setTimeout(tick, 800);
  }

  // 绑定“碰碰运气抽盲盒”按钮点击响应
  function bindSparkBox() {
    const btn = document.getElementById('spark-trigger-btn');
    
    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      
      // 1. 触发流星特效 (在父页面容器中追加 div)
      const container = document.getElementById('spark-meteor-container');
      if (container) {
        const meteor = document.createElement('div');
        meteor.className = 'spark-meteor';
        
        // 随机在顶部稍微不同的偏置位置生成流星，增加拟真感
        meteor.style.top = `-100px`;
        meteor.style.right = `${10 + Math.random() * 30}%`;
        
        container.appendChild(meteor);
        
        // 1s 动画结束后自动清理 DOM
        setTimeout(() => meteor.remove(), 1000);
      }

      // 2. 0.4s 后 (当流星划过中屏) 弹出盲盒 Modal，并抽取随机脑洞
      setTimeout(() => {
        const modal = document.getElementById('spark-box-modal');
        const card = document.getElementById('spark-box-card');
        const contentEl = document.getElementById('spark-box-content');

        if (modal && card && contentEl) {
          // 抽取随机点子
          const randSparks = BRAIN_SPARKS[Math.floor(Math.random() * BRAIN_SPARKS.length)];
          contentEl.textContent = randSparks;

          // 展示动画
          modal.classList.remove('hidden');
          setTimeout(() => {
            card.classList.remove('scale-95', 'opacity-0');
            card.classList.add('scale-100', 'opacity-100');
          }, 50);
        }
      }, 400);
    });
  }

  initBrandCard();
  bindSparkBox();
  document.addEventListener('astro:page-load', () => {
    initBrandCard();
    bindSparkBox();
  });
</script>
