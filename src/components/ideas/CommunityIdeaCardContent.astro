---
const { aiStructure } = Astro.props;
---
<div class="space-y-4">
  {aiStructure.problem && (
    <div>
      <h5 class="text-[10px] font-bold text-brand uppercase tracking-wider">🎯 想解决的问题</h5>
      <p class="text-xs mt-1 text-parchment-dim leading-relaxed">{aiStructure.problem}</p>
    </div>
  )}
  
  {aiStructure.targetUsers && (
    <div>
      <h5 class="text-[10px] font-bold text-brand uppercase tracking-wider">👥 目标群体</h5>
      <p class="text-xs mt-1 text-parchment-dim leading-relaxed">{aiStructure.targetUsers}</p>
    </div>
  )}
  
  {aiStructure.possibleSolutions && aiStructure.possibleSolutions.length > 0 && (
    <div>
      <h5 class="text-[10px] font-bold text-brand uppercase tracking-wider">🚀 实现方向</h5>
      <ul class="list-disc pl-4 text-xs mt-1 text-parchment-dim space-y-1">
        {aiStructure.possibleSolutions.map((s: string) => <li>{s}</li>)}
      </ul>
    </div>
  )}
  
  {aiStructure.validationSteps && aiStructure.validationSteps.length > 0 && (
    <div>
      <h5 class="text-[10px] font-bold text-brand uppercase tracking-wider">🧪 下一步验证</h5>
      <ul class="list-disc pl-4 text-xs mt-1 text-parchment-dim space-y-1">
        {aiStructure.validationSteps.map((s: string) => <li>{s}</li>)}
      </ul>
    </div>
  )}
  
  {aiStructure.risks && aiStructure.risks.length > 0 && (
    <div>
      <h5 class="text-[10px] font-bold text-brand uppercase tracking-wider">⚠️ 潜在风险</h5>
      <ul class="list-disc pl-4 text-xs mt-1 text-parchment-dim space-y-1">
        {aiStructure.risks.map((s: string) => <li>{s}</li>)}
      </ul>
    </div>
  )}
</div>
