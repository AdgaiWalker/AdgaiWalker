---
import { getCollection } from 'astro:content';

const allConcepts = await getCollection('concepts', ({ data }) => data.status === 'active');
const allLogs = await getCollection('log', ({ data }) => data.published);

const conceptCounts = new Map<string, number>();
allLogs.forEach(entry => {
  entry.data.concepts?.forEach(id => {
    conceptCounts.set(id, (conceptCounts.get(id) ?? 0) + 1);
  });
});

const nodes = allConcepts.map(c => ({
  id: c.id,
  title: c.data.title,
  symbol: c.data.symbol || '',
  domain: c.data.domain.join(', '),
  layer: c.data.layer ?? null,
  contentCount: conceptCounts.get(c.id) ?? 0,
}));

const links: Array<{ source: string; target: string }> = [];
allConcepts.forEach(c => {
  c.data.related.forEach(r => {
    if (allConcepts.some(ac => ac.id === r)) {
      links.push({ source: c.id, target: r });
    }
  });
});
---

<section class="max-w-5xl mx-auto px-6 py-16">
  <div class="flex items-center gap-4 mb-8">
    <h2 class="font-heading text-2xl text-parchment tracking-wide">概念图谱</h2>
    <div class="flex-1 h-px bg-gradient-to-r from-gold/20 to-transparent"></div>
  </div>
  <div
    id="knowledge-graph"
    class="w-full aspect-[16/9] md:aspect-[2/1] rounded-2xl bg-sea-mid/20 border border-mist/10 overflow-hidden relative"
    data-nodes={JSON.stringify(nodes)}
    data-links={JSON.stringify(links)}
  >
    <div class="absolute inset-0 flex items-center justify-center text-mist/30 text-sm font-body">
      交互式概念图谱（加载中...）
    </div>
  </div>
</section>

<script>
  import * as d3 from 'd3';

  const container = document.getElementById('knowledge-graph');
  if (!container) throw new Error('No graph container');

  const nodesData = JSON.parse(container.dataset.nodes || '[]');
  const linksData = JSON.parse(container.dataset.links || '[]');

  // Clear placeholder
  container.innerHTML = '';

  const width = container.clientWidth;
  const height = container.clientHeight;

  const svg = d3.select(container)
    .append('svg')
    .attr('width', '100%')
    .attr('height', '100%')
    .attr('viewBox', `0 0 ${width} ${height}`);

  const maxCount = Math.max(...nodesData.map((n: any) => n.contentCount), 1);

  const simulation = d3.forceSimulation(nodesData)
    .force('link', d3.forceLink(linksData).id((d: any) => d.id).distance(120))
    .force('charge', d3.forceManyBody().strength(-300))
    .force('center', d3.forceCenter(width / 2, height / 2))
    .force('collision', d3.forceCollide().radius(40));

  // Links
  const link = svg.append('g')
    .selectAll('line')
    .data(linksData)
    .join('line')
    .attr('stroke', 'rgba(212, 175, 55, 0.15)')
    .attr('stroke-width', 1.5);

  // Node groups
  const node = svg.append('g')
    .selectAll('g')
    .data(nodesData)
    .join('g')
    .attr('cursor', 'pointer')
    .on('click', (event: any, d: any) => {
      window.location.href = `/concept/${d.id}`;
    });

  // Glow for layer concepts
  const defs = svg.append('defs');
  const filter = defs.append('filter').attr('id', 'glow');
  filter.append('feGaussianBlur').attr('stdDeviation', '4').attr('result', 'coloredBlur');
  const feMerge = filter.append('feMerge');
  feMerge.append('feMergeNode').attr('in', 'coloredBlur');
  feMerge.append('feMergeNode').attr('in', 'SourceGraphic');

  // Circles
  node.append('circle')
    .attr('r', (d: any) => 8 + (d.contentCount / maxCount) * 16)
    .attr('fill', (d: any) => d.layer ? 'rgba(212, 175, 55, 0.6)' : 'rgba(240, 234, 214, 0.3)')
    .attr('stroke', (d: any) => d.layer ? 'rgba(212, 175, 55, 0.8)' : 'rgba(240, 234, 214, 0.2)')
    .attr('stroke-width', (d: any) => d.layer ? 2 : 1)
    .attr('filter', (d: any) => d.layer ? 'url(#glow)' : 'none');

  // Labels
  node.append('text')
    .text((d: any) => d.title)
    .attr('text-anchor', 'middle')
    .attr('dy', (d: any) => -(8 + (d.contentCount / maxCount) * 16) - 8)
    .attr('fill', 'rgba(240, 234, 214, 0.7)')
    .attr('font-size', '12px')
    .attr('font-family', 'Sora, system-ui, sans-serif');

  // Symbol inside circle
  node.append('text')
    .text((d: any) => d.symbol || '')
    .attr('text-anchor', 'middle')
    .attr('dy', '0.35em')
    .attr('fill', 'rgba(240, 234, 214, 0.8)')
    .attr('font-size', '11px')
    .attr('font-family', 'Sora, system-ui, sans-serif');

  // Tooltip
  const tooltip = d3.select(container)
    .append('div')
    .style('position', 'absolute')
    .style('padding', '6px 12px')
    .style('background', 'rgba(19, 32, 64, 0.95)')
    .style('border', '1px solid rgba(212, 175, 55, 0.3)')
    .style('border-radius', '8px')
    .style('color', 'rgba(240, 234, 214, 0.9)')
    .style('font-size', '13px')
    .style('font-family', 'Sora, system-ui, sans-serif')
    .style('pointer-events', 'none')
    .style('opacity', 0)
    .style('transition', 'opacity 0.2s');

  node.on('mouseenter', (event: any, d: any) => {
    tooltip
      .html(`${d.title}${d.contentCount > 0 ? ` — ${d.contentCount} 篇` : ''}`)
      .style('left', `${event.offsetX + 16}px`)
      .style('top', `${event.offsetY - 8}px`)
      .style('opacity', 1);
  }).on('mouseleave', () => {
    tooltip.style('opacity', 0);
  });

  // Drag
  node.call(d3.drag()
    .on('start', (event: any, d: any) => {
      if (!event.active) simulation.alphaTarget(0.3).restart();
      d.fx = d.x;
      d.fy = d.y;
    })
    .on('drag', (event: any, d: any) => {
      d.fx = event.x;
      d.fy = event.y;
    })
    .on('end', (event: any, d: any) => {
      if (!event.active) simulation.alphaTarget(0);
      d.fx = null;
      d.fy = null;
    })
  );

  simulation.on('tick', () => {
    link
      .attr('x1', (d: any) => d.source.x)
      .attr('y1', (d: any) => d.source.y)
      .attr('x2', (d: any) => d.target.x)
      .attr('y2', (d: any) => d.target.y);

    node.attr('transform', (d: any) => `translate(${d.x},${d.y})`);
  });

  // Responsive resize
  const resizeObserver = new ResizeObserver(() => {
    const w = container.clientWidth;
    const h = container.clientHeight;
    svg.attr('viewBox', `0 0 ${w} ${h}`);
    simulation.force('center', d3.forceCenter(w / 2, h / 2));
    simulation.alpha(0.3).restart();
  });
  resizeObserver.observe(container);
</script>
