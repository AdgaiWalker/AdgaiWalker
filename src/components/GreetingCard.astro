---
// GreetingCard.astro — lvyovo 风格问候卡
---
<div class="panel-glass p-8 flex flex-col items-center justify-center text-center reveal h-full" id="greeting-card" style="background: rgba(255,255,240,0.5);">
  <!-- 头像圆形区 (暖黄光晕) -->
  <div class="w-[120px] h-[120px] rounded-full flex items-center justify-center mb-6 relative bg-gradient-to-br from-[#fef3c7] to-[#fef9c3] shadow-sm overflow-hidden">
    <img src="/images/avatar.jpg" alt="秋知" class="w-full h-full object-cover relative z-10" />
  </div>
  <div class="font-heading text-parchment text-[24px] font-medium tracking-wide mb-3" id="greeting-text">
    Good Afternoon
  </div>
  <h2 class="font-heading text-parchment text-[22px] font-medium tracking-wide leading-snug">
    I'm <span class="text-brand font-semibold text-[26px]">秋知</span> , Nice to<br/>meet you!
  </h2>
</div>

<script>
  function updateGreeting() {
    const hour = new Date().getHours();
    const textEl = document.getElementById('greeting-text');

    if (!textEl) return;

    const greetings: { text: string; range: [number, number] }[] = [
      { text: 'Good Morning', range: [5, 12] },
      { text: 'Good Afternoon', range: [12, 18] },
      { text: 'Good Evening', range: [18, 22] },
      { text: 'Good Night', range: [22, 24] },
      { text: 'Good Night', range: [0, 5] },
    ];

    const g = greetings.find(g => hour >= g.range[0] && hour < g.range[1]) ?? greetings[0];
    textEl.textContent = g.text;
  }

  updateGreeting();
  setInterval(updateGreeting, 60000);
</script>
