---
/**
 * GreetingCard — 首页中栏拟真看板萌猫交互问候卡 (秋知专属版)
 * 升级：植入纯手绘眨眼、抖耳、摆尾 SVG 看板萌猫，开发鼠标悬停弹出趣味气泡猫咪语录
 */
---

<div class="panel-glass p-6 py-7 flex flex-col items-center justify-center text-center h-full rounded-[40px] pointer-events-auto relative group/greeting cursor-help" id="greeting-card">
  
  <!-- ========================================= -->
  <!-- 🐱 悬浮晶莹毛玻璃猫咪趣味语录气泡 (自适应变色) -->
  <!-- ========================================= -->
  <div class="absolute top-[-36px] scale-90 opacity-0 pointer-events-none group-hover/greeting:scale-100 group-hover/greeting:opacity-100 transition-all duration-300 z-30 px-3.5 py-1.5 rounded-full backdrop-blur-md shadow-md flex items-center justify-center min-w-[160px] max-w-[240px]" id="cat-bubble" style="background: var(--color-inner-bg, rgba(255, 255, 255, 0.9)); border: 1.5px solid var(--color-brand, #35bfab);">
    <span class="text-[11px] font-body font-bold tracking-wide" id="cat-quote" style="color: var(--color-brand, #35bfab);">
      喵呜~ 今天有什么好点子喵？
    </span>
    <!-- 气泡尖角 -->
    <div class="absolute bottom-[-5px] left-1/2 -translate-x-1/2 w-2.5 h-2.5 rotate-45 border-r border-b" style="background: var(--color-inner-bg, rgba(255, 255, 255, 0.9)); border-color: var(--color-brand, #35bfab);"></div>
  </div>

  <!-- 看板小猫卡通盒子 (背景与边框自适应) -->
  <div class="w-[84px] h-[84px] rounded-full flex items-center justify-center mb-4 relative overflow-hidden border-2 shadow-[0_4px_16px_rgba(53,191,171,0.06)] shrink-0 transition-all duration-300" style="background: var(--color-player-icon-bg, #e6fcf9); border-color: var(--color-border, #ffffff);">
    <svg viewBox="0 0 100 100" class="w-16 h-16 overflow-visible">
      <!-- 猫尾巴 (摆尾动画) -->
      <path class="cat-tail" d="M 68 62 Q 78 52 82 40" fill="none" stroke="#ed8936" stroke-width="6" stroke-linecap="round" />
      
      <!-- 猫耳朵 (抖耳动画) -->
      <polygon class="cat-ear-l" points="20,40 32,15 42,35" fill="#ed8936" />
      <polygon class="cat-ear-r" points="80,40 68,15 58,35" fill="#ed8936" />
      <polygon class="cat-ear-l" points="23,37 32,20 39,34" fill="#fed7d7" />
      <polygon class="cat-ear-r" points="77,37 68,20 61,34" fill="#fed7d7" />
      
      <!-- 猫脸 -->
      <circle cx="50" cy="55" r="32" fill="#fff" />
      <circle cx="50" cy="55" r="32" fill="#f7fafc" opacity="0.9" />
      <ellipse cx="50" cy="30" rx="6" ry="3" fill="#ed8936" />
      <ellipse cx="32" cy="40" rx="5" ry="3" fill="#ed8936" />
      <ellipse cx="68" cy="40" rx="5" ry="3" fill="#ed8936" />
      
      <!-- 眼睛 (眨眼动画) -->
      <g class="cat-eyes">
        <path class="cat-eye-l" d="M 36 52 Q 40 48 44 52" stroke="#2d3748" stroke-width="2.5" stroke-linecap="round" fill="none" />
        <path class="cat-eye-r" d="M 56 52 Q 60 48 64 52" stroke="#2d3748" stroke-width="2.5" stroke-linecap="round" fill="none" />
      </g>
      
      <!-- 腮红 -->
      <ellipse cx="32" cy="59" rx="5" ry="2.5" fill="#feb2b2" />
      <ellipse cx="68" cy="59" rx="5" ry="2.5" fill="#feb2b2" />
      
      <!-- 可爱嘴巴与小红鼻 -->
      <polygon points="50,56 48,54 52,54" fill="#f56565" />
      <path d="M 46 60 Q 50 63 50 60 Q 50 63 54 60" stroke="#2d3748" stroke-width="2" fill="none" />
      
      <!-- 猫胡须 -->
      <line x1="22" y1="58" x2="10" y2="56" stroke="#cbd5e0" stroke-width="1.2" />
      <line x1="22" y1="62" x2="8" y2="63" stroke="#cbd5e0" stroke-width="1.2" />
      <line x1="78" y1="58" x2="90" y2="56" stroke="#cbd5e0" stroke-width="1.2" />
      <line x1="78" y1="62" x2="92" y2="63" stroke="#cbd5e0" stroke-width="1.2" />
    </svg>
  </div>

  <!-- 动态问候语 (早上好/中午好/下午好) -->
  <div class="text-[10px] font-mono font-bold tracking-[0.2em] uppercase mb-1.5" id="greeting-time-tag" style="color: var(--color-brand, #35bfab);">
    GOOD MORNING
  </div>

  <!-- 问候语内容 -->
  <h2 class="font-heading text-parchment text-[17px] font-medium leading-relaxed tracking-wide">
    我是<span class="font-bold text-[20px] mx-1" style="color: var(--color-brand, #35bfab);">秋知</span>，很高兴认识你！
  </h2>
  
  <p class="text-parchment-dim/50 text-[11px] font-body mt-2 leading-relaxed max-w-[200px]">
    探索 AI · 独立开发 · 记录生活
  </p>
</div>

<style>
  /* ========================================= */
  /* 猫咪交互动效定义 */
  /* ========================================= */
  
  /* 1. 摆尾巴 */
  .cat-tail {
    transform-origin: 68px 62px;
    animation: tail-wag 2.8s ease-in-out infinite alternate;
  }
  @keyframes tail-wag {
    0% { transform: rotate(-5deg); }
    100% { transform: rotate(15deg); }
  }

  /* 2. 眨眼睛 (每 4.5s 柔和眨一下) */
  .cat-eyes {
    animation: eye-blink 4.5s infinite;
  }
  @keyframes eye-blink {
    0%, 95%, 100% { transform: scaleY(1); }
    97.5% { transform: scaleY(0.1); }
  }

  /* 3. 抖耳朵 */
  .group\/greeting:hover .cat-ear-l {
    animation: ear-shake-l 0.4s ease-in-out;
  }
  .group\/greeting:hover .cat-ear-r {
    animation: ear-shake-r 0.4s ease-in-out;
  }
  @keyframes ear-shake-l {
    0%, 100% { transform: rotate(0deg); }
    33% { transform: rotate(-8deg); }
    66% { transform: rotate(4deg); }
  }
  @keyframes ear-shake-r {
    0%, 100% { transform: rotate(0deg); }
    33% { transform: rotate(8deg); }
    66% { transform: rotate(-4deg); }
  }
</style>

<script>
  let greetingTimer: ReturnType<typeof setInterval> | null = null;

  // 傲娇幽默的猫语录气泡池
  const CAT_QUOTES = [
    "铲屎的，你今天又在写 Bug 吗？喵呜~",
    "碰碰运气点一下中栏的 Spark! 有惊喜喵~",
    "喵呜~ 秋知今天也在努力写代码喵！",
    "本喵掐指一算，你今天敲的代码毫无报错！",
    "铲屎的，划过卡片的时候，能顺便点个赞吗？",
    "AI 真的好神奇喵，我也想用 AI 写个捉老鼠插件！",
    "点子都在文章里，快进去看看喵呜~"
  ];

  function updateGreeting() {
    const hour = new Date().getHours();
    const tagEl = document.getElementById('greeting-time-tag');

    if (!tagEl) return;

    const greetings = [
      { text: 'GOOD MORNING', range: [5, 12] },
      { text: 'GOOD AFTERNOON', range: [12, 18] },
      { text: 'GOOD EVENING', range: [18, 22] },
      { text: 'GOOD NIGHT', range: [22, 24] },
      { text: 'GOOD NIGHT', range: [0, 5] },
    ];

    const g = greetings.find(g => hour >= g.range[0] && hour < g.range[1]) ?? greetings[0];
    tagEl.textContent = g.text;
  }

  // 绑定鼠标划过，随机调配傲娇猫语录
  function bindCatBubble() {
    const card = document.getElementById('greeting-card');
    const quoteEl = document.getElementById('cat-quote');
    
    card?.addEventListener('mouseenter', () => {
      if (quoteEl) {
        const rand = CAT_QUOTES[Math.floor(Math.random() * CAT_QUOTES.length)];
        quoteEl.textContent = rand;
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    updateGreeting();
    bindCatBubble();
    if (!greetingTimer) greetingTimer = setInterval(updateGreeting, 60000);
  });

  document.addEventListener('astro:before-swap', () => {
    if (greetingTimer) { clearInterval(greetingTimer); greetingTimer = null; }
  });
</script>
