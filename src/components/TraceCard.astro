---
import { CATEGORY_LABELS } from '../utils/domains';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  type: 'article' | 'photo' | 'thought' | 'project';
  category?: string;
  slug: string;
  cover?: string;
  excerpt?: string;
}

const { title, date, tags, type, category, slug, cover, excerpt } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });

const categoryLabel = category ? CATEGORY_LABELS[category] : null;
const categoryIcon = category === 'ai' ? 'lucide:cpu' : 'lucide:leaf';
---

<!-- 随想 (thought) -->
{type === 'thought' && (
  <a
    href={`/${category || 'log'}/${slug}`}
    class="block reveal group mb-6 break-inside-avoid no-underline"
  >
    <div class="rounded-xl bg-gold/[0.03] p-5 transition-all duration-300 hover:bg-gold/[0.06]">
      <div class="flex items-start gap-3">
        <div class="mt-1.5 w-2 h-2 rounded-full bg-gold/60 shrink-0" style={`animation: bio-pulse 3s ease-in-out infinite`}></div>
        <div class="min-w-0">
          {categoryLabel && (
            <span class="text-gold/40 text-xs font-mono uppercase tracking-wider flex items-center gap-1.5 mb-2">
              <iconify-icon icon={categoryIcon} width="10" height="10"></iconify-icon>
              {categoryLabel}
            </span>
          )}
          <p class="text-parchment/70 text-base italic leading-relaxed group-hover:text-parchment transition-colors">
            {excerpt || title}
          </p>
          <div class="mt-3 flex items-center gap-3">
            <time class="text-parchment/25 text-xs font-mono">{formatDate(date)}</time>
            {tags.filter(t => t !== '随想').map(tag => (
              <span class="text-xs text-parchment/30">#{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </a>
)}

<!-- 文章 (article) -->
{type === 'article' && (
  <a
    href={`/${category || 'log'}/${slug}`}
    class="block reveal group mb-6 break-inside-avoid no-underline"
  >
    <div class="panel-glass card-accent-left accent-article">
      <div class="p-5 pl-6">
        <div class="flex items-center gap-2 mb-2">
          {categoryLabel && (
            <span class="flex items-center gap-1 text-bio-cyan/60 text-xs font-mono tracking-wider">
              <iconify-icon icon={categoryIcon} width="10" height="10"></iconify-icon>
              {categoryLabel}
            </span>
          )}
          <span class="text-white/[0.06] text-xs">|</span>
          <time class="text-parchment/30 text-xs font-mono">{formatDate(date)}</time>
        </div>
        <h3 class="text-parchment font-heading text-base leading-snug group-hover:text-bio-cyan transition-colors mb-2">
          {title}
        </h3>
        {excerpt && (
          <p class="text-parchment/40 text-sm leading-relaxed line-clamp-2">
            {excerpt}
          </p>
        )}
        <div class="flex flex-wrap gap-1.5 mt-3">
          {tags.slice(0, 3).map(tag => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
        <div class="mt-4 flex items-center gap-1 text-xs text-bio-cyan/50 group-hover:text-bio-cyan transition-colors">
          <iconify-icon icon="lucide:arrow-right" width="12" height="12"></iconify-icon>
          阅读
        </div>
      </div>
    </div>
  </a>
)}

<!-- 摄影 (photo) -->
{type === 'photo' && (
  <a
    href={`/${category || 'log'}/${slug}`}
    class="block reveal group mb-6 break-inside-avoid no-underline"
  >
    <div class="panel-glass overflow-hidden transition-all duration-300 hover:border-bio-cyan/30 hover:shadow-[inset_0_0_20px_rgba(0,229,255,0.05)]">
      {cover ? (
        <div class="relative overflow-hidden aspect-[4/3]">
          <img src={cover} alt={title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-abyss/80 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4">
            {categoryLabel && (
              <span class="flex items-center gap-1 text-bio-cyan/50 text-xs font-mono mb-1">
                <iconify-icon icon={categoryIcon} width="10" height="10"></iconify-icon>
                {categoryLabel}
              </span>
            )}
            <h3 class="text-parchment font-heading text-base group-hover:text-bio-cyan transition-colors">
              {title}
            </h3>
            <time class="text-parchment/40 text-xs font-mono">{formatDate(date)}</time>
          </div>
        </div>
      ) : (
        <div class="p-8 aspect-[4/3] flex items-center justify-center">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-3 rounded-full bg-white/[0.04] border border-white/[0.08] flex items-center justify-center">
              <iconify-icon icon="lucide:image" width="24" height="24" class="text-parchment/30"></iconify-icon>
            </div>
            <h3 class="text-parchment font-heading text-base group-hover:text-bio-cyan transition-colors">
              {title}
            </h3>
            <time class="text-parchment/25 text-xs font-mono">{formatDate(date)}</time>
          </div>
        </div>
      )}
    </div>
  </a>
)}

<!-- 项目 (project) -->
{type === 'project' && (
  <a
    href={`/${category || 'log'}/${slug}`}
    class="block reveal group mb-6 break-inside-avoid no-underline"
  >
    <div class="panel-glass border-gold/20 bg-gold/[0.03] glow-gold transition-all duration-300 hover:border-gold/30 hover:bg-gold/[0.06]">
      <div class="p-5">
        <div class="flex items-center gap-2 mb-3">
          <iconify-icon icon="lucide:anchor" width="14" height="14" class="text-gold/60"></iconify-icon>
          <span class="text-gold/40 text-xs font-mono uppercase tracking-wider">Shipyard</span>
          {categoryLabel && (
            <>
              <span class="text-white/[0.06] text-xs">|</span>
              <span class="flex items-center gap-1 text-parchment/30 text-xs">
                <iconify-icon icon={categoryIcon} width="10" height="10"></iconify-icon>
                {categoryLabel}
              </span>
            </>
          )}
        </div>
        <h3 class="text-parchment font-heading text-base group-hover:text-gold-glow transition-colors">
          {title}
        </h3>
        {excerpt && (
          <p class="mt-2 text-parchment/40 text-sm line-clamp-2">{excerpt}</p>
        )}
        <div class="flex flex-wrap gap-1.5 mt-3">
          {tags.slice(0, 3).map(tag => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
        <time class="mt-3 block text-parchment/20 text-xs font-mono">{formatDate(date)}</time>
      </div>
    </div>
  </a>
)}
