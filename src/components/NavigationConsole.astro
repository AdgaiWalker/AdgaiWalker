---
/**
 * NavigationConsole — lvyovo 风格数字时钟小组件
 */
---

<div class="panel-glass p-6 flex items-center justify-center group relative overflow-hidden h-[130px] rounded-[40px] shadow-inner" style="background: rgba(220, 226, 226, 0.5); border: none; box-shadow: inset 0 4px 10px rgba(0,0,0,0.05);">
  <!-- 背景模拟 LCD 网格感 -->
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 4px 4px;"></div>
  
  <!-- 数字时钟显示 -->
  <div class="digital-clock text-[5rem] text-[#4a5f61] font-normal tracking-wider leading-none relative z-10" id="nav-clock" style="font-family: 'Share Tech Mono', monospace; font-variant-numeric: tabular-nums; opacity: 0.9;">
    00:00
  </div>
</div>

<script>
  function updateNav() {
    const now = new Date();
    const clockEl = document.getElementById('nav-clock');
    
    if (clockEl) {
      const h = String(now.getHours()).padStart(2, '0');
      const m = String(now.getMinutes()).padStart(2, '0');
      clockEl.textContent = `${h}:${m}`;
    }
  }

  updateNav();
  setInterval(updateNav, 1000);
</script>
