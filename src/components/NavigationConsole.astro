---
/**
 * NavigationConsole — 首页右栏拟真双框液晶数字时钟 (极具现代设计感)
 * 像素级复现截图时钟样式：双层圆角边框 + 内嵌晶莹时钟显示框 + 极细质感 LCD 数字
 */
---

<div class="panel-glass p-3.5 flex flex-col items-center justify-center group relative overflow-hidden h-[120px] rounded-[36px] pointer-events-auto">
  <!-- 内嵌水晶边框展示盒 (双框自适应变色设计) -->
  <div class="w-full h-full rounded-[24px] border flex items-center justify-center backdrop-blur-sm transition-all duration-300" style="background: var(--color-inner-bg, rgba(255, 255, 255, 0.3)); border-color: var(--color-inner-border, rgba(0, 0, 0, 0.04)); box-shadow: inset 0 2px 8px var(--color-inner-shadow, rgba(255, 255, 255, 0.4));">
    <!-- 极细高雅的数字时钟显示 -->
    <div class="digital-clock text-[3.2rem] text-parchment font-light tracking-widest leading-none" id="nav-clock" style="font-family: 'Outfit', sans-serif; font-weight: 200; font-variant-numeric: tabular-nums; opacity: 0.85;">
      08:56
    </div>
  </div>
</div>

<script>
  let clockTimer: ReturnType<typeof setInterval> | null = null;

  function updateNav() {
    const now = new Date();
    const clockEl = document.getElementById('nav-clock');

    if (clockEl) {
      const h = String(now.getHours()).padStart(2, '0');
      const m = String(now.getMinutes()).padStart(2, '0');
      clockEl.textContent = `${h}:${m}`;
    }
  }

  function startClock() {
    updateNav();
    if (!clockTimer) clockTimer = setInterval(updateNav, 1000);
  }

  document.addEventListener('astro:page-load', startClock);

  document.addEventListener('astro:before-swap', () => {
    if (clockTimer) { clearInterval(clockTimer); clockTimer = null; }
  });
</script>
