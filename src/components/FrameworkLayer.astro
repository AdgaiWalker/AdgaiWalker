---
interface Props {
  id: string;
  symbol?: string;
  layer?: number;
  title: string;
  body: string;
  contentCount: number;
  isFirst: boolean;
  isLast: boolean;
}

const { id, symbol, layer, title, body, contentCount, isFirst, isLast } = Astro.props;

const summary = body
  .replace(/^---[\s\S]*?---/, '')
  .replace(/[#*_`\[\]()>|]/g, '')
  .trim()
  .split('\n')
  .find(l => l.trim().length > 10) || '';
---

<div class="relative">
  <a href={`/concept/${id}`} class="block group no-underline">
    <div class:list={[
      'flex items-start gap-6 py-8 px-6 rounded-xl transition-all duration-300 hover:bg-sea-mid/30',
      isFirst ? '' : 'border-t border-mist/10',
    ]}>
      <div class="flex flex-col items-center shrink-0 pt-1">
        <div class="w-14 h-14 rounded-full border-2 border-gold/40 flex items-center justify-center text-gold/80 text-2xl font-heading group-hover:border-gold/70 group-hover:shadow-lg group-hover:shadow-gold/10 transition-all duration-300">
          {symbol}
        </div>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-gold/40 text-xs font-mono">0{layer}</span>
          <h2 class="font-heading text-xl text-parchment group-hover:text-gold transition-colors">
            {title}
          </h2>
        </div>
        <p class="text-parchment/50 text-base leading-relaxed">{summary}</p>
        {isLast && (
          <div class="mt-4 px-4 py-2 rounded-lg bg-gold/10 border border-gold/20">
            <p class="text-gold/70 text-sm font-heading">验证：你的工作更少了吗？</p>
          </div>
        )}
        {contentCount > 0 && (
          <span class="mt-2 inline-block text-mist/40 text-xs">{contentCount} 篇关联内容</span>
        )}
      </div>
    </div>
  </a>
  {isLast ? null : (
    <div class="flex justify-center -mt-2 mb-0">
      <svg class="w-4 h-8 text-gold/20" viewBox="0 0 16 32" fill="none">
        <path d="M8 0 L8 24 L3 19 M8 24 L13 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  )}
</div>
