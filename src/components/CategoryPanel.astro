---
import { Icon } from 'astro-icon/components';
/**
 * CategoryPanel — 分类导航面板
 * 按分类分组显示项目列表，支持高亮当前选中项。
 * 可用于 DockLayout、资源页等需要二级分类的场景。
 */
interface CategoryGroup {
  key: string;
  label: string;
  icon: string;
}

interface PanelItem {
  id: string;
  name: string;
  description: string;
  category: string;
  href: string;
  isActive?: boolean;
}

interface Props {
  title: string;
  count: number;
  items: PanelItem[];
  categoryGroups: CategoryGroup[];
  activeId?: string;
}

const { title, count, items, categoryGroups, activeId } = Astro.props;
---

<aside class="category-panel">
  <div class="panel-header">
    <h2>{title}</h2>
    <span>{count} 个项目</span>
  </div>

  <div class="panel-content custom-scrollbar">
    {categoryGroups.map(group => {
      const groupItems = items.filter(item => item.category === group.key);
      if (groupItems.length === 0) return null;
      return (
        <div class="category-group">
          <h3 class="category-title">{group.label}</h3>
          <nav class="category-item-list">
            {groupItems.map(item => (
              <a
                href={item.href}
                class:list={['category-item-link', activeId === item.id ? 'active' : '']}
              >
                <span class="category-item-icon">
                  <Icon name={`lucide:${group.icon}`} width={16} height={16} />
                </span>
                <span class="category-item-info">
                  <span class="category-item-name">{item.name}</span>
                  <span class="category-item-desc">{item.description}</span>
                </span>
              </a>
            ))}
          </nav>
        </div>
      );
    })}
  </div>
</aside>

<style>
  .category-panel {
    position: sticky;
    top: 0;
    align-self: start;
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-nav-bg);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border-right: 1px solid var(--color-nav-border);
    transition: background 0.4s ease, border-color 0.4s ease;
  }

  .panel-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 1.6rem 1.35rem 1rem;
    border-bottom: 1px solid var(--color-nav-border);
  }

  .panel-header h2 {
    margin: 0;
    color: var(--color-parchment);
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    transition: color 0.4s ease;
  }

  .panel-header span {
    color: var(--color-parchment-dim);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    opacity: 0.6;
    transition: color 0.4s ease;
  }

  .panel-content {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 0.75rem 2rem;
  }

  .category-group {
    margin-bottom: 1.5rem;
  }

  .category-title {
    padding: 0 0.6rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-parchment-dim);
    opacity: 0.5;
    text-transform: uppercase;
    margin: 0;
    transition: color 0.4s ease;
  }

  .category-item-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .category-item-link {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.65rem;
    border-radius: 10px;
    color: var(--color-parchment-dim);
    opacity: 0.85;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    border: 1px solid transparent;
  }

  .category-item-link:hover {
    background: var(--color-brand-glow);
    color: var(--color-brand);
    opacity: 1;
    transform: translateX(2px);
  }

  .category-item-link.active {
    background: var(--color-inner-bg);
    border-color: var(--color-nav-border);
    box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.04), 0 4px 12px rgba(0, 0, 0, 0.05);
    color: var(--color-brand);
    font-weight: 600;
    opacity: 1;
  }

  body.theme-nature .category-item-link.active {
    background: #ffffff;
    box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.8), 0 4px 12px rgba(26, 35, 37, 0.03);
  }

  .category-item-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: inherit;
    opacity: 0.6;
    transition: opacity 0.25s ease, color 0.25s ease;
  }

  .category-item-link.active .category-item-icon {
    opacity: 1;
    color: var(--color-brand);
  }

  .category-item-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .category-item-name {
    font-size: 0.85rem;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .category-item-desc {
    font-size: 0.68rem;
    color: var(--color-parchment-dim);
    opacity: 0.6;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 0.15rem;
    transition: color 0.4s ease;
  }

  .category-item-link:hover .category-item-desc {
    color: var(--color-brand);
    opacity: 0.75;
  }

  .category-item-link.active .category-item-desc {
    color: var(--color-parchment-dim);
    opacity: 0.8;
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }

  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: var(--color-nav-border);
    border-radius: 4px;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: var(--color-brand);
  }

  @media (max-width: 1023px) {
    .category-panel {
      position: relative;
      height: auto;
      max-height: 40vh;
      border-right: none;
      border-bottom: 1px solid var(--color-nav-border);
      backdrop-filter: blur(20px);
    }
  }
</style>
