---
import { Icon } from 'astro-icon/components';
import type { NavGroup } from '@/types/nav';
import { getWorkspaceForPath } from '@/shared/workspaces';
import AuthChip from '../auth/AuthChip.astro';

interface Props {
  navGroups: NavGroup[];
  normalizedPath: string;
}

const { navGroups, normalizedPath } = Astro.props;

const workspace = getWorkspaceForPath(normalizedPath);

const isActiveHref = (href: string) => {
  if (href === '/') return normalizedPath === '/';
  return normalizedPath === href || normalizedPath.startsWith(`${href}/`);
};
---

<div
  class="hidden lg:flex flex-col flex-1 w-full overflow-y-auto custom-scrollbar app-sidebar"
  id="mobile-menu"
  data-workspace={workspace.id}
  aria-label={`${workspace.label}侧边栏`}
>
  <div class="hidden lg:flex flex-col app-shell-head">
    <div class="app-shell-toolbar">
      <button
        class="app-shell-icon-button"
        id="sidebar-collapse-btn"
        aria-label="折叠侧边栏"
        title="折叠侧边栏 ( [ )"
      >
        <Icon name="lucide:menu" width={18} height={18} class="sidebar-icon-close" />
        <Icon name="lucide:panel-left-open" width={18} height={18} class="sidebar-icon-open" />
      </button>
      <a href="/" class="app-shell-home" aria-label="返回首页" title="返回首页">
        <Icon name="lucide:home" width={18} height={18} />
      </a>
      <a href="/content" class="app-shell-title no-underline" title="Walker">
        Walker
      </a>
    </div>
  </div>

  <div class="hidden lg:block app-search-wrap">
    <button id="desktop-search-btn" class="app-search group">
      <Icon name="lucide:search" width={20} height={20} class="app-search-icon" />
      <span>搜索</span>
    </button>
  </div>

  <div class="flex-1 px-3 pb-4">
    <div class="flex flex-col gap-5">
      {navGroups.map((group) => (
        <div class="flex flex-col">
          {group.title && (
            <div class="nav-section-title">{group.title}</div>
          )}
          <div class="flex flex-col gap-0.5 relative nav-links-container">
            <div class="nav-indicator nav-active-indicator opacity-0"></div>
            {group.items.map((item) => {
              const isActive = isActiveHref(item.href);
              return (
                <a
                  href={item.href}
                  title={item.label}
                  class:list={[
                    'nav-link group relative z-10',
                    isActive ? 'nav-link-active' : 'nav-link-idle',
                  ]}
                >
                  <Icon name={item.icon} width={18} height={18} class="nav-link-icon" />
                  <span class="nav-link-main">{item.label}</span>
                  {item.hint && <span class="nav-link-hint">{item.hint}</span>}
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <div class="nav-extension mt-4">
      <slot />
    </div>
  </div>

  <div class="hidden lg:flex items-center justify-between px-5 py-5 mt-auto border-t border-[var(--color-nav-border)] text-gray-400 z-20 app-footer-tools">
    <div class="flex items-center gap-3.5">
      <a href="https://github.com/AdgaiWalker" target="_blank" rel="noopener noreferrer" class="hover:text-brand transition-colors" aria-label="Github"><Icon name="lucide:github" width={18} height={18} /></a>
      <a href="mailto:praxiswalker@gmail.com" class="hover:text-brand transition-colors" aria-label="Email"><Icon name="lucide:mail" width={18} height={18} /></a>
      <a href="/rss.xml" class="hover:text-brand transition-colors" aria-label="RSS"><Icon name="lucide:rss" width={16} height={16} /></a>
      <AuthChip variant="icon" />
    </div>
    <button class="hover:text-brand transition-colors bg-transparent border-none cursor-pointer flex items-center justify-center p-1" id="nav-theme-toggle" aria-label="切换主题">
      <Icon name="lucide:sun" width={18} height={18} />
    </button>
  </div>
</div>

<style>
  .app-sidebar {
    background: #f7f7f7;
    color: #1f2329;
    backdrop-filter: blur(18px);
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }

  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(31, 35, 41, 0.08);
    border-radius: 4px;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(31, 35, 41, 0.16);
  }

  .app-shell-head {
    padding: 1.8rem 1.25rem 1.45rem;
  }

  .app-shell-toolbar {
    display: grid;
    grid-template-columns: 28px 28px minmax(0, 1fr);
    align-items: center;
    column-gap: 0.6rem;
  }

  .app-shell-icon-button,
  .app-shell-home {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: #646a73;
    transition: background 0.16s ease, color 0.16s ease;
  }

  .app-shell-icon-button:hover,
  .app-shell-home:hover {
    background: rgba(31, 35, 41, 0.06);
    color: #1f2329;
  }

  .app-shell-title {
    min-width: 0;
    color: #1f2329;
    font-family: 'Inter', 'PingFang SC', system-ui, sans-serif;
    font-size: 1.02rem;
    font-weight: 500;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .app-search-wrap {
    padding: 0 1.25rem;
    margin-bottom: 1.05rem;
  }

  .app-search {
    display: flex;
    width: 100%;
    min-height: 48px;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
    padding: 0 1rem;
    border: 0;
    border-radius: 8px;
    background: #fff;
    color: #4e5969;
    font-family: 'Inter', 'PingFang SC', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 400;
    box-shadow: none;
    transition: box-shadow 0.16s ease, color 0.16s ease;
    cursor: pointer;
  }

  .app-search:hover {
    background: #fff;
    box-shadow: 0 2px 8px rgba(31, 35, 41, 0.05);
  }

  .app-search-icon {
    flex-shrink: 0;
    color: #4e5969;
  }

  .nav-section-title {
    padding: 0 0.7rem 0.35rem;
    color: rgba(31, 35, 41, 0.36);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .nav-link {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.7rem;
    min-height: 38px;
    padding: 0.5rem 0.75rem;
    border: 1px solid transparent;
    border-radius: 8px;
    color: #646a73;
    font-size: 0.86rem;
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  .nav-link-idle:hover {
    background: rgba(31, 35, 41, 0.05);
    color: #1f2329;
  }

  .nav-link-active {
    background: color-mix(in srgb, var(--color-brand) 14%, transparent);
    border-color: color-mix(in srgb, var(--color-brand) 22%, transparent);
    color: var(--color-brand);
    font-weight: 700;
  }

  .nav-link-icon {
    color: #646a73;
    transition: color 0.18s ease;
  }

  .nav-link-active .nav-link-icon,
  .nav-link:hover .nav-link-icon {
    color: var(--color-brand);
  }

  .nav-link-main {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .nav-link-hint {
    color: rgba(31, 35, 41, 0.32);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
  }

  @media (min-width: 1024px) {
    :global(#main-nav) {
      width: var(--walker-nav-width, 260px) !important;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) {
      width: 68px !important;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .app-shell-toolbar {
      display: flex;
      justify-content: center;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .app-shell-home,
    :global(html[data-sidebar-collapsed]) :global(#main-nav) .app-shell-title,
    :global(html[data-sidebar-collapsed]) :global(#main-nav) .nav-section-title,
    :global(html[data-sidebar-collapsed]) :global(#main-nav) .nav-link-main,
    :global(html[data-sidebar-collapsed]) :global(#main-nav) .nav-link-hint,
    :global(html[data-sidebar-collapsed]) :global(#main-nav) .nav-extension {
      display: none !important;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .app-shell-head {
      padding: 1.25rem 0.55rem 1rem;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .app-search-wrap {
      padding: 0 0.55rem;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .app-search {
      justify-content: center;
      padding: 0.6rem !important;
      background: transparent !important;
      box-shadow: none !important;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .app-search:hover {
      background: rgba(31, 35, 41, 0.05) !important;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .app-search span {
      display: none;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .nav-link {
      grid-template-columns: 1fr;
      justify-content: center;
      justify-items: center;
      padding-left: 0.55rem !important;
      padding-right: 0.55rem !important;
    }

    .sidebar-icon-open {
      display: none;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .sidebar-icon-close {
      display: none;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .sidebar-icon-open {
      display: block;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) .app-footer-tools {
      display: none !important;
    }

    :global(html[data-sidebar-collapsed]) :global(#main-nav) [id="sidebar-collapse-btn"] {
      opacity: 1 !important;
    }
  }

  @media (max-width: 1023px) {
    #mobile-menu.flex {
      position: fixed;
      top: 52px;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 49;
      padding-bottom: 2rem;
      animation: slideDown 0.2s ease-out;
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>
