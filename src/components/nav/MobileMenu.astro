---
import { Icon } from 'astro-icon/components';
---

{/* 移动端顶部栏 */}
<div class="flex lg:hidden items-center justify-between px-3 py-3 w-full bg-[var(--color-nav-bg)] backdrop-blur-md border-b border-[var(--color-nav-border)]">
  <a href="/" class="flex items-center font-heading text-lg font-bold text-parchment hover:text-brand transition-colors no-underline">
    Walker
  </a>
  <div class="flex items-center gap-2">
    {/* 搜索条 — 图标 + 文字 + 快捷键 */}
    <button
      class="mobile-search-bar flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-[rgba(255,255,255,0.06)] border border-[var(--color-nav-border)] text-[13px] text-parchment-dim hover:border-brand/30 transition-colors cursor-pointer"
      id="mobile-search-btn"
      aria-label="搜索"
    >
      <Icon name="lucide:search" width={15} height={15} class="shrink-0" />
      <span class="mobile-search-label font-body text-xs">搜索</span>
      <kbd class="mobile-search-kbd text-[10px] font-mono px-1 py-0.5 rounded bg-black/5 border border-[var(--color-nav-border)] font-medium ml-0.5">⌘K</kbd>
    </button>
    {/* 主题切换 */}
    <button
      class="text-parchment-dim hover:text-parchment p-1.5 transition-colors bg-transparent border-none cursor-pointer"
      id="mobile-theme-toggle"
      aria-label="切换主题"
    >
      <Icon name="lucide:sun" width={20} height={20} />
    </button>
    {/* 汉堡菜单 */}
    <button
      class="text-parchment-dim hover:text-parchment p-1.5 transition-colors bg-transparent border-none cursor-pointer"
      id="menu-toggle"
      aria-label="打开菜单"
    >
      <Icon name="lucide:menu" width={22} height={22} />
    </button>
  </div>
</div>

<style>
  /* 极窄屏幕退回纯图标模式 */
  @media (max-width: 380px) {
    .mobile-search-label,
    .mobile-search-kbd {
      display: none;
    }
  }
</style>
