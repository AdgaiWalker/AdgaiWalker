---
import { getActiveConcepts } from '../utils/knowledge';

interface Props {
  concepts: string[];
}

const { concepts } = Astro.props;

if (!concepts || concepts.length === 0) return;

const allConcepts = await getActiveConcepts();
const matched = allConcepts.filter(c => concepts.includes(c.id));
---

{matched.length > 0 && (
  <div class="mt-12 pt-8 border-t border-border">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-text-muted text-xs font-heading tracking-wider uppercase">关联概念</span>
      <div class="flex-1 h-px bg-border"></div>
    </div>
    <div class="flex flex-wrap gap-2">
      {matched.map(c => (
        <span
          class:list={[
            'text-sm px-3 py-1.5 rounded-lg border',
            c.data.layer
              ? 'bg-gold/10 text-gold/70 border-gold/20'
              : 'bg-bg-subtle text-text-muted border-border',
          ]}
        >
          {c.data.symbol && <span class="mr-1">{c.data.symbol}</span>}
          {c.data.title}
        </span>
      ))}
    </div>
  </div>
)}
