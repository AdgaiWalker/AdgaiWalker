---
interface Props {
  iconOnly?: boolean;
}
const { iconOnly = false } = Astro.props;
---
<!-- 搜索按钮 -->
{iconOnly ? (
  <button
    id="search-open"
    class="w-[50px] h-[50px] bg-white flex items-center justify-center text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-colors border border-gray-200 cursor-pointer shadow-sm rounded-xl"
    aria-label="搜索"
  >
    <iconify-icon icon="lucide:search" width="20" height="20"></iconify-icon>
  </button>
) : (
  <button
    id="search-open"
    class="flex items-center gap-2 text-gray-400 hover:text-brand transition-colors text-xs font-heading tracking-wider cursor-pointer bg-transparent border-none"
    aria-label="搜索"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <span class="hidden md:inline">搜索</span>
    <kbd class="hidden md:inline text-[10px] px-1.5 py-0.5 rounded border border-gray-200 text-gray-400 bg-gray-50 ml-1 font-mono">⌘K</kbd>
  </button>
)}

<!-- 搜索浮层 -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden" style="animation: modal-enter 0.2s ease-out;">
  <!-- 遮罩 -->
  <div id="search-backdrop" class="absolute inset-0 bg-gray-900/20 backdrop-blur-sm"></div>

  <!-- 搜索面板 -->
  <div class="relative z-10 max-w-2xl mx-auto mt-[15vh] px-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-gray-100 overflow-hidden" id="search-panel">
      <!-- 输入框 -->
      <div class="flex items-center gap-3 px-5 py-4 border-b border-gray-100 transition-all bg-white" id="search-input-wrap">
        <svg class="w-5 h-5 text-brand/70 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="在这片海域中搜索..."
          class="flex-1 bg-transparent border-none outline-none text-gray-900 text-base font-body placeholder:text-gray-400"
          autocomplete="off"
        />
        <button
          id="search-close"
          class="text-gray-400 hover:text-gray-700 text-xs px-2 py-1 rounded border border-gray-200 hover:border-gray-300 hover:bg-gray-50 cursor-pointer bg-transparent font-sans font-medium transition-all"
        >
          ESC
        </button>
      </div>

      <!-- 结果区域 -->
      <div id="search-results" class="max-h-[50vh] overflow-y-auto px-2 py-2 bg-gray-50/50">
        <div id="search-empty" class="py-12 text-center text-gray-400 text-sm">
          输入关键词，探索这片海域
        </div>
        <div id="search-list"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .pagefind-ui { display: none !important; }
  #search-input-wrap:focus-within {
    border-color: rgba(53, 191, 171, 0.4);
    box-shadow: 0 4px 12px rgba(53, 191, 171, 0.05);
  }
  
  @keyframes modal-enter {
    from { opacity: 0; transform: scale(0.98) translateY(-10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>

<script>
  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const openBtn = document.getElementById('search-open');
  const closeBtn = document.getElementById('search-close');
  const backdrop = document.getElementById('search-backdrop');
  const resultsList = document.getElementById('search-list');
  const emptyState = document.getElementById('search-empty');

  function openSearch() {
    modal?.classList.remove('hidden');
    input?.focus();
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    modal?.classList.add('hidden');
    input.value = '';
    if (resultsList) resultsList.innerHTML = '';
    if (emptyState) emptyState.classList.remove('hidden');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openSearch);
  closeBtn?.addEventListener('click', closeSearch);
  backdrop?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') closeSearch();
  });

  let pagefindSearch: any = null;
  let pagefindLoaded = false;
  let pagefindReady: (() => void) | null = null;
  const pagefindReadyPromise = new Promise<void>((resolve) => { pagefindReady = resolve; });

  async function loadPagefind() {
    if (pagefindLoaded) return;
    pagefindLoaded = true;
    const script = document.createElement('script');
    script.src = '/pagefind/pagefind.js';
    script.onload = async () => {
      // @ts-ignore
      pagefindSearch = window.pagefind;
      if (pagefindSearch) {
        await pagefindSearch.init();
        pagefindReady?.();
      }
    };
    script.onerror = () => {
      console.log('Pagefind 未就绪，请先构建');
    };
    document.head.appendChild(script);
  }

  const openSearchWithIndex = () => {
    openSearch();
    loadPagefind();
  };
  openBtn?.removeEventListener('click', openSearch);
  openBtn?.addEventListener('click', openSearchWithIndex);

  let debounceTimer: ReturnType<typeof setTimeout>;
  input?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(async () => {
      await pagefindReadyPromise;
      const query = input.value.trim();
      if (!query || !pagefindSearch) {
        if (resultsList) resultsList.innerHTML = '';
        if (emptyState) {
          emptyState.classList.remove('hidden');
          emptyState.textContent = !pagefindSearch
            ? '搜索索引加载中...'
            : '输入关键词，探索这片海域';
        }
        return;
      }

      const results = await pagefindSearch.search(query);
      if (results.results.length === 0) {
        if (resultsList) resultsList.innerHTML = '';
        if (emptyState) {
          emptyState.classList.remove('hidden');
          emptyState.textContent = `没有找到「${query}」相关的记录`;
        }
        return;
      }

      if (emptyState) emptyState.classList.add('hidden');

      const computedStyle = getComputedStyle(document.body);
      const fontBody = computedStyle.getPropertyValue('--font-body') || 'Inter, sans-serif';
      
      const html = await Promise.all(
        results.results.slice(0, 8).map(async (r: any) => {
          const data = await r.data();
          let excerpt = data.excerpt || '';
          
          try {
            // Import dynamically to ensure it's available client-side
            const { prepareWithSegments, layoutWithLines } = await import('@chenglou/pretext');
            // Assuming the text container max width is ~500px in the modal
            const prepared = prepareWithSegments(excerpt.replace(/<[^>]+>/g, ''), `12px ${fontBody}`);
            const layout = layoutWithLines(prepared, 500, 16);
            if (layout.lines.length > 2) {
               excerpt = layout.lines[0].text + layout.lines[1].text + '...';
            } else {
               excerpt = layout.lines.map((l: any) => l.text).join('');
            }
          } catch (e) {
            // Fallback if pretext fails
            console.error('Pretext measurement failed', e);
          }

          return `
            <a href="${data.url}" class="block px-4 py-3 mb-1 rounded-xl hover:bg-white border border-transparent hover:border-gray-200 hover:shadow-sm transition-all no-underline group bg-transparent">
              <div class="text-gray-900 text-sm font-medium group-hover:text-brand transition-colors mb-1.5 flex items-center justify-between">
                <span>${data.meta?.title || data.url}</span>
                <span class="text-gray-300 group-hover:text-brand/40 opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </span>
              </div>
              <p class="text-gray-500 text-xs leading-relaxed">${excerpt}</p>
            </a>
          `;
        })
      );

      if (resultsList) resultsList.innerHTML = html.join('');
    }, 200);
  });
</script>
