---
/**
 * CalendarWidget — 首页右栏拟真艾薇暖黄日历小组件
 * 像素级复现截图日历样式：2026/5/24 星期日 头部 + 浅黄暖色底座 + 圆润青色高亮圆圈
 */
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth();
const today = now.getDate();
const dayOfWeek = now.getDay();
const firstDay = new Date(year, month, 1).getDay();
// 调整为周一开始：0=周一, ..., 6=周日
const firstDayMon = firstDay === 0 ? 6 : firstDay - 1;
const daysInMonth = new Date(year, month + 1, 0).getDate();
const weekdays = ['一', '二', '三', '四', '五', '六', '日'];
const dayNames = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
---

<div class="panel-glass p-5 rounded-[36px] pointer-events-auto">
  <!-- 精致顶部日期头 -->
  <div class="flex items-center justify-between mb-4 px-1">
    <span class="text-[12px] font-body font-bold text-parchment/65 tracking-wide">
      {year}/{month + 1}/{today} {dayNames[dayOfWeek]}
    </span>
  </div>

  <div class="grid grid-cols-7 gap-y-1.5 gap-x-1 text-center">
    <!-- 星期头 -->
    {weekdays.map((d) => (
      <div class="text-[10px] font-body text-parchment-dim/40 py-0.5">{d}</div>
    ))}

    <!-- 空白填充 -->
    {Array.from({ length: firstDayMon }, (_, i) => (
      <div key={`empty-${i}`} />
    ))}

    <!-- 日期数字 -->
    {Array.from({ length: daysInMonth }, (_, i) => {
      const day = i + 1;
      const isToday = day === today;
      
      return (
        <div
          key={`day-${day}`}
          class="text-[11.5px] font-body py-0.5 transition-colors leading-none flex items-center justify-center min-h-[22px]"
        >
          {isToday ? (
            <span class="w-6 h-6 rounded-full text-white flex items-center justify-center font-bold text-[10px] transition-all duration-300" style="background: var(--color-brand, #35bfab); box-shadow: 0 2px 8px var(--color-brand-glow, rgba(53, 191, 171, 0.4));">{day}</span>
          ) : (
            <span class="text-parchment-dim/75">{day}</span>
          )}
        </div>
      );
    })}
  </div>
</div>
