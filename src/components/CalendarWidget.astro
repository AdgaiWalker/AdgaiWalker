---
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth();
const today = now.getDate();
const dayOfWeek = now.getDay();
const firstDay = new Date(year, month, 1).getDay();
// 调整为周一开始：0=周一, ..., 6=周日
const firstDayMon = firstDay === 0 ? 6 : firstDay - 1;
const daysInMonth = new Date(year, month + 1, 0).getDate();
const weekdays = ['一', '二', '三', '四', '五', '六', '日'];
const dayNames = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
---

<div class="panel-glass p-5" style="background: rgba(255,255,255,0.55);">
  <!-- 日期标题 (更精致的排版) -->
  <div class="flex items-baseline justify-between mb-4 px-0.5">
    <div class="flex items-baseline gap-2">
      <span class="text-[18px] font-heading font-semibold text-parchment tracking-tight">{monthNames[month]}</span>
      <span class="text-[13px] font-mono text-parchment/35">{year}</span>
    </div>
    <span class="text-[11px] font-mono text-parchment/30 tracking-wider">{dayNames[dayOfWeek]}</span>
  </div>

  <div class="grid grid-cols-7 gap-0.5 text-center">
    <!-- 星期头 -->
    {weekdays.map((d, i) => (
      <div class:list={[
        "text-[11px] font-body py-1",
        (i === 5 || i === 6) ? "text-brand/60 font-medium" : "text-parchment/30"
      ]}>{d}</div>
    ))}

    <!-- 空白填充 -->
    {Array.from({ length: firstDayMon }, () => (
      <div />
    ))}

    <!-- 日期数字 -->
    {Array.from({ length: daysInMonth }, (_, i) => {
      const day = i + 1;
      const isToday = day === today;
      const dayPos = (firstDayMon + i) % 7;
      const isWeekend = dayPos === 5 || dayPos === 6;
      return (
        <div
          class:list={[
            'text-[12px] font-body py-1 transition-colors leading-none',
            isToday
              ? 'flex items-center justify-center'
              : isWeekend
                ? 'text-parchment/30'
                : 'text-parchment/55 hover:text-parchment',
          ]}
        >
          {isToday ? (
            <span class="w-6 h-6 rounded-full bg-brand text-white flex items-center justify-center font-bold text-[11px] shadow-[0_2px_8px_rgba(53,191,171,0.3)]">{day}</span>
          ) : (
            day
          )}
        </div>
      );
    })}
  </div>
</div>
