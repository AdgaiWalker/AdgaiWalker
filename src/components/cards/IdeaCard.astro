---
/**
 * IdeaCard — Idea 卡片组件
 * 支持两种状态：开放认领 / 已完成
 */
import { postSlug } from '@/lib/routes';

interface Props {
  title: string;
  summary?: string;
  tags?: string[];
  status?: 'open' | 'completed';
  slug: string;
  date: Date;
  claimInfo?: string;
}

const { title, summary, tags = [], status = 'open', slug, date, claimInfo } = Astro.props;

const isOpen = status === 'open';
const statusLabel = isOpen ? '开放认领' : '已完成';
const statusIcon = isOpen ? 'lucide:sparkles' : 'lucide:check-circle-2';

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={postSlug(slug)} class:list={['idea-card', isOpen ? 'idea-card-open' : 'idea-card-done']}>
  {/* 状态标签 */}
  <div class="idea-card-status">
    <iconify-icon icon={statusIcon} width="12" height="12"></iconify-icon>
    <span>{statusLabel}</span>
  </div>

  {/* 标题 */}
  <h3 class="idea-card-title">{title}</h3>

  {/* 简介 */}
  {summary && (
    <p class="idea-card-summary">{summary}</p>
  )}

  {/* 底部元信息 */}
  <div class="idea-card-footer">
    <span class="idea-card-date">{formatDate(date)}</span>
    <div class="idea-card-tags">
      {tags.slice(0, 3).map(tag => (
        <span class="idea-card-tag">{tag}</span>
      ))}
    </div>
  </div>

  {/* 认领提示 */}
  {isOpen && (
    <div class="idea-card-cta">
      <iconify-icon icon="lucide:arrow-right" width="14" height="14"></iconify-icon>
      <span>查看详情</span>
    </div>
  )}
</a>

<style>
  .idea-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border-radius: 16px;
    border: 1px solid rgba(42, 59, 62, 0.06);
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(20px);
    text-decoration: none;
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
  }

  .idea-card:hover {
    background: rgba(255, 255, 255, 0.75);
    border-color: rgba(53, 191, 171, 0.2);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    transform: translateY(-2px);
  }

  /* 开放认领 — 品牌色强调 */
  .idea-card-open .idea-card-status {
    background: rgba(53, 191, 171, 0.1);
    color: #35bfab;
  }

  /* 已完成 — 柔和灰绿 */
  .idea-card-done .idea-card-status {
    background: rgba(42, 59, 62, 0.05);
    color: rgba(42, 59, 62, 0.45);
  }

  .idea-card-status {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    width: fit-content;
    margin-bottom: 0.75rem;
  }

  .idea-card-title {
    font-family: 'Sora', 'PingFang SC', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #2a3b3e;
    line-height: 1.4;
    margin: 0 0 0.375rem;
  }

  .idea-card-summary {
    font-size: 0.825rem;
    color: rgba(42, 59, 62, 0.55);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0 0 0.75rem;
  }

  .idea-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
  }

  .idea-card-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: rgba(42, 59, 62, 0.3);
  }

  .idea-card-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .idea-card-tag {
    font-size: 0.625rem;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(42, 59, 62, 0.04);
    color: rgba(42, 59, 62, 0.45);
  }

  .idea-card-cta {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(42, 59, 62, 0.05);
    font-size: 0.75rem;
    color: #35bfab;
    font-weight: 500;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .idea-card:hover .idea-card-cta {
    opacity: 1;
  }
</style>
