---
/**
 * ArticleCard — 文章卡片（列表视图）
 * 用于 /ai/learn 学习页的文章列表
 */

interface Props {
  title: string;
  summary?: string;
  date: Date;
  tags?: string[];
  cover?: string;
  slug: string;
  basePath: string;
  /** 是否有飞书文档关联 */
  hasFeishuLink?: boolean;
}

const { title, summary, date, tags = [], cover, slug, basePath, hasFeishuLink = false } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={`${basePath}/${slug}`} class="article-card">
  {/* 封面图 */}
  {cover && (
    <div class="article-card-cover">
      <img src={cover} alt={title} loading="lazy" />
    </div>
  )}

  <div class="article-card-body">
    {/* 标题行 */}
    <div class="article-card-header">
      <h3 class="article-card-title">{title}</h3>
      {hasFeishuLink && (
        <span class="article-card-feishu" title="关联飞书文档">
          <iconify-icon icon="lucide:file-text" width="12" height="12"></iconify-icon>
        </span>
      )}
    </div>

    {/* 摘要 */}
    {summary && (
      <p class="article-card-summary">{summary}</p>
    )}

    {/* 底部元信息 */}
    <div class="article-card-meta">
      <span class="article-card-date">{formatDate(date)}</span>
      <div class="article-card-tags">
        {tags.slice(0, 3).map(tag => (
          <span class="article-card-tag">{tag}</span>
        ))}
      </div>
    </div>
  </div>
</a>

<style>
  .article-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 16px;
    border: 1px solid rgba(42, 59, 62, 0.06);
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(20px);
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .article-card:hover {
    background: rgba(255, 255, 255, 0.75);
    border-color: rgba(53, 191, 171, 0.15);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    transform: translateY(-2px);
  }

  .article-card-cover {
    flex-shrink: 0;
    width: 120px;
    height: 80px;
    border-radius: 10px;
    overflow: hidden;
  }

  .article-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .article-card-header {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .article-card-title {
    font-family: 'Sora', 'PingFang SC', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: #2a3b3e;
    line-height: 1.4;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  .article-card-feishu {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: rgba(53, 191, 171, 0.08);
    color: #35bfab;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .article-card-summary {
    font-size: 0.8rem;
    color: rgba(42, 59, 62, 0.5);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0.375rem 0 0;
  }

  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .article-card-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: rgba(42, 59, 62, 0.3);
  }

  .article-card-tags {
    display: flex;
    gap: 4px;
  }

  .article-card-tag {
    font-size: 0.625rem;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(42, 59, 62, 0.04);
    color: rgba(42, 59, 62, 0.45);
  }

  @media (max-width: 640px) {
    .article-card {
      flex-direction: column;
    }
    .article-card-cover {
      width: 100%;
      height: 140px;
    }
  }
</style>
