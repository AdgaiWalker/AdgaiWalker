---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
/**
 * ArticleCard — 文章卡片（列表视图）
 * 用于 /ai/learn 学习页的文章列表
 */

interface Props {
  title: string;
  summary?: string;
  date: Date;
  tags?: string[];
  cover?: string | ImageMetadata;
  slug: string;
  basePath: string;
  /** 是否有飞书文档关联 */
  hasFeishuLink?: boolean;
}

const { title, summary, date, tags = [], cover, slug, basePath, hasFeishuLink = false } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={`${basePath}/${slug}`} class="article-card" data-astro-prefetch="viewport">
  {/* 封面图 */}
  {cover && (
    <div class="article-card-cover">
      {typeof cover === 'string' ? (
        <Image src={cover} alt={title} width={240} height={160} loading="lazy" />
      ) : (
        <Image src={cover} alt={title} loading="lazy" />
      )}
    </div>
  )}

  <div class="article-card-body">
    {/* 标题行 */}
    <div class="article-card-header">
      <h3 class="article-card-title">{title}</h3>
      {hasFeishuLink && (
        <span class="article-card-feishu" title="关联飞书文档">
          <Icon name="lucide:file-text" width={12} height={12} />
        </span>
      )}
    </div>

    {/* 摘要 */}
    {summary && (
      <p class="article-card-summary">{summary}</p>
    )}

    {/* 底部元信息 */}
    <div class="article-card-meta">
      <span class="article-card-date">{formatDate(date)}</span>
      <div class="article-card-tags">
        {tags.slice(0, 3).map(tag => (
          <span class="article-card-tag">{tag}</span>
        ))}
      </div>
    </div>
  </div>
</a>

<style>
  .article-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 16px;
    border: 1px solid var(--color-nav-border);
    background: var(--color-card);
    backdrop-filter: blur(30px) saturate(120%);
    -webkit-backdrop-filter: blur(30px) saturate(120%);
    text-decoration: none;
    transition: all 0.38s cubic-bezier(0.25, 1, 0.5, 1.2);
    box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.05), 0 4px 12px rgba(0, 0, 0, 0.02);
  }

  body.theme-nature .article-card {
    box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.6), 0 4px 12px rgba(26, 35, 37, 0.02);
  }

  .article-card:hover {
    background: var(--color-inner-bg);
    border-color: var(--color-brand);
    box-shadow: 
      inset 0 1px 3px rgba(255, 255, 255, 0.1),
      0 12px 28px rgba(0, 0, 0, 0.15),
      0 0 16px var(--color-brand-glow);
    transform: translateY(-3px);
  }

  body.theme-nature .article-card:hover {
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 
      inset 0 1px 3px rgba(255, 255, 255, 0.8),
      0 12px 28px rgba(26, 35, 37, 0.06),
      0 0 16px var(--color-brand-glow);
  }

  .article-card-cover {
    flex-shrink: 0;
    width: 120px;
    height: 80px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-nav-border);
  }

  .article-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .article-card:hover .article-card-cover img {
    transform: scale(1.06);
  }

  .article-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .article-card-header {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .article-card-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-parchment);
    line-height: 1.4;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    transition: color 0.25s ease;
  }

  .article-card:hover .article-card-title {
    color: var(--color-brand);
  }

  .article-card-feishu {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: var(--color-brand-glow);
    color: var(--color-brand);
    flex-shrink: 0;
    margin-top: 1px;
    border: 1px solid rgba(53, 191, 171, 0.15);
  }

  .article-card-summary {
    font-size: 0.8rem;
    color: var(--color-parchment-dim);
    opacity: 0.85;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0.375rem 0 0;
  }

  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .article-card-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--color-parchment-dim);
    opacity: 0.6;
  }

  .article-card-tags {
    display: flex;
    gap: 6px;
  }

  .article-card-tag {
    font-size: 0.625rem;
    padding: 2px 8px;
    border-radius: 6px;
    background: var(--color-brand-glow);
    color: var(--color-brand);
    border: 1px solid rgba(53, 191, 171, 0.1);
    transition: all 0.2s ease;
  }

  .article-card:hover .article-card-tag {
    border-color: var(--color-brand);
  }

  @media (max-width: 640px) {
    .article-card {
      flex-direction: column;
      gap: 0.75rem;
    }
    .article-card-cover {
      width: 100%;
      height: 140px;
    }
  }
</style>
