---
import { LogFilterIsland } from './react/LogFilterIsland';

interface Props {
  tags: string[];
  concepts?: {
    id: string;
    title: string;
    symbol?: string;
    contentCount: number;
  }[];
  total: number;
}

const { tags, concepts = [], total } = Astro.props;
---

<LogFilterIsland tags={tags} concepts={concepts} total={total} client:load />
