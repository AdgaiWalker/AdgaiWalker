---
/**
 * ArticleRow · 文章热度行（spec §3, §4.3 Tab2）
 * 排名 / 标题 / 看·问·停留+环比 / 动作
 */
import { Icon } from 'astro-icon/components';

interface Props {
  rank: number | string;
  title: string;
  views: number | string;
  asks?: number | string;
  stay?: string;           // "2.4m"
  delta?: string;          // "↑22%" / "↓8%"
  deltaKind?: 'good' | 'warn' | 'bad' | 'neutral';
  action: string;
  actionHref?: string;
  actionKind?: 'good' | 'warn' | 'bad' | 'default';
}
const {
  rank, title, views, asks, stay = '',
  delta = '', deltaKind = 'neutral',
  action, actionHref = '#', actionKind = 'default',
} = Astro.props;

const deltaColor = {
  good: 'var(--adm-good)',
  warn: 'var(--adm-warn)',
  bad: 'var(--adm-bad)',
  neutral: 'var(--adm-text-dim)',
}[deltaKind];

const actionClass = {
  good: 'adm-btn-primary',
  warn: '',
  bad: 'adm-btn-ghost-bad',
  default: '',
}[actionKind];
---
<div class="adm-article adm-card">
  <span class="adm-article-rank">{rank}</span>
  <div class="adm-article-body">
    <div class="adm-article-title">{title}</div>
    <div class="adm-article-meta">
      <span>看 {views}</span>
      {asks !== undefined && <span>问 {asks}</span>}
      {stay && <span>停留 {stay}</span>}
      {delta && <span style={`color:${deltaColor}`}>{delta}</span>}
    </div>
  </div>
  <a href={actionHref} class:list={["adm-btn", "adm-btn-sm", actionClass]}>
    {action} <Icon name="lucide:chevron-right" width={13} height={13} />
  </a>
</div>

<style>
  .adm-article {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
  }
  .adm-article-rank {
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    color: var(--adm-text-faint);
    flex-shrink: 0;
  }
  .adm-article-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .adm-article-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--adm-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .adm-article-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    color: var(--adm-text-dim);
  }
</style>
