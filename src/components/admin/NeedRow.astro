---
/**
 * NeedRow · 待处理需求行（spec §3, §4.1）
 * 阶段标签（带色）/ 需求标题 / meta / 动作按钮
 */
import { Icon } from 'astro-icon/components';

type StageKind = 'todo' | 'writing' | 'verify' | 'drop';

interface Props {
  stage: string;          // 阶段标签文字
  stageKind: StageKind;   // 阶段颜色
  title: string;          // 需求标题
  meta: string;           // 「N 人问 · 卡点 · N 天前」等
  action: string;         // 动作按钮文字
  actionHref?: string;    // 跳转
}
const { stage, stageKind, title, meta, action, actionHref = '#' } = Astro.props;

const stageClass = {
  todo: 'adm-tag-good',       // 待立项 · brand soft
  writing: 'adm-tag-warn',    // 写作中 · amber soft
  verify: 'adm-tag-verify',   // 待验证 · 蓝
  drop: 'adm-tag-bad',        // 命中降 · rose soft
}[stageKind];
---
<div class="adm-need-row adm-card">
  <span class:list={["adm-tag", stageClass]}>{stage}</span>
  <div class="adm-need-body">
    <div class="adm-need-title">{title}</div>
    <div class="adm-need-meta">{meta}</div>
  </div>
  <a href={actionHref} class="adm-btn adm-btn-sm">
    {action} <Icon name="lucide:chevron-right" width={13} height={13} />
  </a>
</div>

<style>
  .adm-need-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
  }
  .adm-need-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .adm-need-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--adm-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .adm-need-meta {
    font-size: 11px;
    color: var(--adm-text-dim);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
