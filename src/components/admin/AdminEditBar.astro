---
// AdminEditBar — 管理员顶部工具栏（自检测模式）
// 适用于预渲染页面：渲染但隐藏，客户端检测 admin 状态后显示
// Props: slug（当前页面内容 slug）, visibility（当前可见性，下拉默认值）
interface Props {
  slug?: string;
  visibility?: string;
}

const { slug = '', visibility = '' } = Astro.props;
---

{slug && (
  <div class="admin-topbar" id="admin-edit-bar" data-slug={slug} data-visibility={visibility} hidden>
    <div class="atb-brand">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
      <span>管理</span>
    </div>
    <div class="atb-actions">
      <button class="atb-btn" id="admin-edit-btn" type="button">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
        编辑
      </button>
      <button class="atb-btn" id="admin-history-btn" type="button">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
        历史
      </button>
      <span class="atb-sep"></span>
      <label class="atb-visibility">
        <span class="atb-vis-label">可见性</span>
        <select id="admin-visibility-select">
          <option value="public">public · 公开</option>
          <option value="draft">draft · 草稿</option>
          <option value="private">private · 私密</option>
        </select>
      </label>
      <span class="atb-sep"></span>
      <button class="atb-btn atb-btn-danger" id="admin-delete-btn" type="button">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
        删除
      </button>
    </div>
    <div class="atb-status" id="admin-status"></div>
  </div>
)}

<style>
  .admin-topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 900;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0.9rem;
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 1px 10px rgba(0,0,0,0.05);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    color: #1c1917;
  }
  .atb-brand {
    display: flex; align-items: center; gap: 0.3rem;
    font-size: 0.72rem; font-weight: 800; color: #c4704a;
    letter-spacing: 0.03em;
    padding-right: 0.4rem;
    border-right: 1px solid rgba(0,0,0,0.08);
  }
  .atb-actions { display: flex; align-items: center; gap: 0.25rem; }
  .atb-btn {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.32rem 0.7rem;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 7px;
    background: #fff;
    color: #44403c;
    font-size: 0.76rem; font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .atb-btn:hover { background: #f5f5f4; border-color: rgba(0,0,0,0.14); }
  .atb-btn-danger { color: #dc2626; }
  .atb-btn-danger:hover { background: #fef2f2; border-color: rgba(220,38,38,0.25); }
  .atb-sep { width: 1px; height: 18px; background: rgba(0,0,0,0.08); margin: 0 0.1rem; }
  .atb-visibility { display: inline-flex; align-items: center; gap: 0.35rem; }
  .atb-vis-label { font-size: 0.7rem; color: #78716c; font-weight: 600; }
  #admin-visibility-select {
    padding: 0.28rem 0.5rem;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 6px;
    background: #fff;
    color: #1c1917;
    font-size: 0.74rem; font-weight: 600;
    cursor: pointer;
  }
  .atb-status {
    margin-left: auto;
    font-size: 0.72rem; font-weight: 600;
    color: #78716c;
    display: none;
  }
  .atb-status.visible { display: block; }
  .atb-status.error { color: #dc2626; }
  .atb-status.success { color: #16a34a; }

  @media (max-width: 640px) {
    .admin-topbar { padding: 0.35rem 0.55rem; gap: 0.35rem; flex-wrap: wrap; }
    .atb-vis-label { display: none; }
  }
</style>

<script>
  import { enterInlineEditor } from '@/scripts/inline-editor';
  import { initVersionHistory } from '@/scripts/version-history';

  let adminAbort: AbortController | null = null;
  let redirectTimer: ReturnType<typeof setTimeout> | null = null;

  function cleanupAdminEditBar() {
    adminAbort?.abort();
    adminAbort = null;
    if (redirectTimer) { clearTimeout(redirectTimer); redirectTimer = null; }
  }

  async function showBarIfAdmin(bar: HTMLElement, signal: AbortSignal) {
    try {
      const res = await fetch('/api/admin/auth', { signal });
      const data = await res.json();
      if (!signal.aborted && data.admin) {
        bar.hidden = false;
        document.body.style.paddingTop = '46px';
      }
    } catch { /* ignore */ }
  }

  function initAdminEditBar() {
    cleanupAdminEditBar();
    const bar = document.getElementById('admin-edit-bar');
    if (!bar) return;

    adminAbort = new AbortController();
    const { signal } = adminAbort;
    showBarIfAdmin(bar, signal);

    const slug = bar.dataset.slug;
    const visibility = bar.dataset.visibility || 'public';
    const editBtn = document.getElementById('admin-edit-btn');
    const historyBtn = document.getElementById('admin-history-btn');
    const deleteBtn = document.getElementById('admin-delete-btn') as HTMLButtonElement | null;
    const visSelect = document.getElementById('admin-visibility-select') as HTMLSelectElement | null;
    const status = document.getElementById('admin-status');
    if (!slug) return;

    if (visSelect) visSelect.value = visibility;

    editBtn?.addEventListener('click', () => enterInlineEditor(slug), { signal });
    historyBtn?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('version-history:open', { detail: { slug } }));
    }, { signal });

    if (visSelect) {
      visSelect.addEventListener('change', async () => {
        const next = visSelect.value;
        if (!status) return;
        status.textContent = '切换中...';
        status.className = 'atb-status visible';
        try {
          const res = await fetch(`/api/admin/content/${encodeURIComponent(slug)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ visibility: next }),
            signal,
          });
          if (res.status === 401) { window.location.href = '/admin/login'; return; }
          const data = await res.json();
          if (signal.aborted) return;
          if (res.ok && data.ok) {
            status.textContent = `已切换为 ${next}，约 60s 后生效`;
            status.className = 'atb-status visible success';
          } else {
            status.textContent = data.error || '切换失败';
            status.className = 'atb-status visible error';
          }
        } catch {
          if (signal.aborted) return;
          status.textContent = '网络错误';
          status.className = 'atb-status visible error';
        }
      }, { signal });
    }

    if (!deleteBtn || !status) return;
    deleteBtn.addEventListener('click', async () => {
      const confirmed = await window.WalkerAdminUI?.confirm({
        title: '删除文章',
        message: '确定要删除这篇文章吗？此操作不可撤销。',
        confirmText: '确认删除',
        tone: 'danger',
      });
      if (!confirmed) return;
      deleteBtn.disabled = true;
      try {
        const res = await fetch(`/api/admin/content/${encodeURIComponent(slug)}`, { method: 'DELETE', signal });
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const data = await res.json();
        if (signal.aborted) return;
        if (res.ok && data.ok) {
          status.textContent = '已删除，正在跳转...';
          status.className = 'atb-status visible success';
          redirectTimer = setTimeout(() => { window.location.href = '/posts'; }, 1000);
        } else {
          status.textContent = data.error || '删除失败';
          status.className = 'atb-status visible error';
        }
      } catch {
        if (signal.aborted) return;
        status.textContent = '网络错误';
        status.className = 'atb-status visible error';
      } finally {
        if (!signal.aborted) deleteBtn.disabled = false;
      }
    }, { signal });
  }

  initVersionHistory();
  document.addEventListener('astro:page-load', initAdminEditBar);
  document.addEventListener('astro:before-swap', cleanupAdminEditBar);
</script>
