---
/**
 * ContentRow · 内容管理表格行（spec §3, §4.4）
 * 复选框 / 标题+slug / 类型标签 / 状态标签 / 访问 / 日期 / 编辑
 */
import { Icon } from 'astro-icon/components';

type TypeKind = 'method' | 'tool' | 'essay' | 'life' | 'exp';
type StatusKind = 'public' | 'draft' | 'private';

interface Props {
  title: string;
  slug: string;
  typeLabel: string;
  typeKind: TypeKind;
  statusLabel: string;
  statusKind: StatusKind;
  views: number | string;
  dateLabel: string;       // "6月17日"
  dateRel: string;         // "昨天" / "4天前"
  editHref?: string;
}
const {
  title, slug, typeLabel, typeKind, statusLabel, statusKind,
  views, dateLabel, dateRel, editHref = '#',
} = Astro.props;

const typeClass = {
  method: 'adm-tag-method',
  tool: 'adm-tag-tool',
  essay: 'adm-tag-essay',
  life: 'adm-tag-life',
  exp: 'adm-tag-exp',
}[typeKind];
const statusClass = {
  public: 'adm-tag-good',
  draft: 'adm-tag-warn',
  private: 'adm-tag-neutral',
}[statusKind];
---
<div class="adm-crow">
  <div class="adm-crow-cell adm-crow-check">
    <Icon name="lucide:square" width={16} height={16} class="adm-crow-checkbox" />
  </div>
  <div class="adm-crow-cell adm-crow-title">
    <div class="adm-crow-t">{title}</div>
    <div class="adm-crow-slug">{slug}</div>
  </div>
  <div class="adm-crow-cell adm-crow-type">
    <span class:list={["adm-tag", typeClass]}>{typeLabel}</span>
  </div>
  <div class="adm-crow-cell adm-crow-status">
    <span class:list={["adm-tag", "adm-tag-pill", statusClass]}>
      <span class="adm-tag-dot"></span>{statusLabel}
    </span>
  </div>
  <div class="adm-crow-cell adm-crow-views">{views}</div>
  <div class="adm-crow-cell adm-crow-date">
    <div class="adm-crow-date-main">{dateLabel}</div>
    <div class="adm-crow-date-rel">{dateRel}</div>
  </div>
  <div class="adm-crow-cell adm-crow-act">
    <a href={editHref} class="adm-btn adm-btn-sm">
      <Icon name="lucide:pencil" width={12} height={12} /> 编辑
    </a>
    <button class="adm-crow-more" type="button" aria-label="更多操作">
      <Icon name="lucide:ellipsis" width={16} height={16} />
    </button>
  </div>
</div>

<style>
  .adm-crow {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    background: var(--adm-surface);
    border: 1px solid var(--adm-border-soft);
    border-radius: 8px;
  }
  .adm-crow-cell { flex-shrink: 0; }
  .adm-crow-check { width: 28px; display: flex; align-items: center; color: #c8d4d6; cursor: pointer; }
  .adm-crow-title { width: 460px; max-width: 460px; display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .adm-crow-t {
    font-size: 13px;
    font-weight: 600;
    color: var(--adm-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .adm-crow-slug { font-size: 11px; color: var(--adm-text-faint); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .adm-crow-type { width: 90px; }
  .adm-crow-status { width: 110px; }
  .adm-crow-views {
    width: 80px;
    text-align: right;
    font-size: 12px;
    font-weight: 600;
    color: var(--adm-text);
    font-variant-numeric: tabular-nums;
  }
  .adm-crow-date { width: 120px; display: flex; flex-direction: column; gap: 1px; }
  .adm-crow-date-main { font-size: 12px; color: var(--adm-text); }
  .adm-crow-date-rel { font-size: 10px; color: var(--adm-text-faint); }
  .adm-crow-act {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
  }
  .adm-crow-more {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--adm-text-faint);
    padding: 4px;
    display: inline-flex;
  }
  .adm-crow-more:hover { color: var(--adm-text-dim); }

  /* 表头行 */
  :global(.adm-crow-head) {
    background: var(--adm-bg) !important;
    border: none !important;
    border-radius: 0 !important;
  }
  :global(.adm-crow-head .adm-crow-t),
  :global(.adm-crow-head .adm-crow-cell) {
    font-size: 11px;
    font-weight: 700;
    color: var(--adm-text-faint);
    letter-spacing: 0.5px;
  }

  @media (max-width: 1100px) {
    .adm-crow-title { width: 280px; max-width: 280px; }
  }
</style>
