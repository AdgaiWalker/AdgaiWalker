---
/**
 * FeatureRow · 功能使用行（spec §3, §4.3 Tab1）
 * 名称 / 状态标签 / 使用条 / 次数+环比 / 动作
 */
interface Props {
  name: string;
  count: number;
  max: number;             // 用于条宽归一化
  statusKind: 'good' | 'warn' | 'bad';   // 活跃/观察/冷门
  statusLabel: string;     // 活跃/观察/偏低/冷门
  delta?: string;          // 环比 "↑18%" / "↓41%"
  deltaKind?: 'good' | 'warn' | 'bad' | 'neutral';
  action: string;
  actionKind?: 'default' | 'bad';
}
const {
  name, count, max, statusKind, statusLabel,
  delta = '', deltaKind = 'neutral',
  action, actionKind = 'default',
} = Astro.props;

const statusClass = {
  good: 'adm-tag-good',
  warn: 'adm-tag-warn',
  bad: 'adm-tag-bad',
}[statusKind];
const barColor = {
  good: 'var(--adm-good)',
  warn: 'var(--adm-warn)',
  bad: 'var(--adm-bad)',
}[statusKind];
const deltaColor = {
  good: 'var(--adm-good)',
  warn: 'var(--adm-warn)',
  bad: 'var(--adm-bad)',
  neutral: 'var(--adm-text-dim)',
}[deltaKind];
const barWidth = Math.max(4, Math.round((count / Math.max(1, max)) * 100));
---
<div class="adm-feature adm-card">
  <div class="adm-feature-meta">
    <div class="adm-feature-namerow">
      <span class="adm-feature-name">{name}</span>
      <span class:list={["adm-tag", statusClass]}>{statusLabel}</span>
    </div>
    <div class="adm-feature-bartrack">
      <div class="adm-feature-barfill" style={`width:${barWidth}%;background:${barColor}`}></div>
    </div>
  </div>
  <div class="adm-feature-numwrap">
    <span class="adm-feature-count">{count}</span>
    <span class="adm-feature-unit">次</span>
    {delta && <span class="adm-feature-delta" style={`color:${deltaColor}`}>{delta}</span>}
  </div>
  <div class="adm-feature-actwrap">
    <button class:list={["adm-btn", "adm-btn-sm", { 'adm-btn-ghost-bad': actionKind === 'bad' }]} type="button">{action}</button>
  </div>
</div>

<style>
  .adm-feature {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
  }
  .adm-feature-meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .adm-feature-namerow {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .adm-feature-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--adm-text);
  }
  .adm-feature-bartrack {
    height: 6px;
    background: var(--adm-border-soft);
    border-radius: 3px;
    overflow: hidden;
  }
  .adm-feature-barfill { height: 100%; border-radius: 3px; }
  .adm-feature-numwrap {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
  }
  .adm-feature-count {
    font-size: 14px;
    font-weight: 700;
    color: var(--adm-text);
    font-variant-numeric: tabular-nums;
  }
  .adm-feature-unit { font-size: 10px; color: var(--adm-text-faint); padding-bottom: 1px; }
  .adm-feature-delta {
    font-size: 10px;
    margin-left: 6px;
    padding-bottom: 1px;
    white-space: nowrap;
  }
  .adm-feature-actwrap { flex-shrink: 0; }
</style>
