---
/**
 * Metric · 小指标卡（spec §3）
 * 92px 高 · 标签 / 数值 / 副信息（带趋势/基准）
 * 数据都要带趋势/基准（§1.5 铁律）
 */
interface Props {
  label: string;
  value: string | number;
  /** 副信息：环比/基准/说明 */
  sub?: string;
  /** 副信息染色（与状态语义对应） */
  subKind?: 'good' | 'warn' | 'bad' | 'neutral';
}
const { label, value, sub = '', subKind = 'neutral' } = Astro.props;
const subColor = {
  good: 'var(--adm-good)',
  warn: 'var(--adm-warn)',
  bad: 'var(--adm-bad)',
  neutral: 'var(--adm-text-dim)',
}[subKind];
---
<div class="adm-metric adm-card">
  <div class="adm-metric-label">{label}</div>
  <div class="adm-metric-value">{value}</div>
  {sub && <div class="adm-metric-sub" style={`color:${subColor}`}>{sub}</div>}
</div>

<style>
  .adm-metric {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px;
    min-height: 92px;
  }
  .adm-metric-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--adm-text-faint);
    letter-spacing: 0.4px;
  }
  .adm-metric-value {
    font-size: 26px;
    font-weight: 700;
    color: var(--adm-text);
    line-height: 1.1;
    font-variant-numeric: tabular-nums;
  }
  .adm-metric-sub {
    font-size: 11px;
    color: var(--adm-text-dim);
    margin-top: auto;
  }
</style>
