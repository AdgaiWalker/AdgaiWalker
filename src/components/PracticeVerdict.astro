---
import { BadgeCheck, Gauge, Heart, ShieldCheck } from 'lucide-astro';

interface Score {
  safety?: string;
  quality?: string;
  efficiency?: string;
  lifeReturn?: string;
}

interface Props {
  score?: Score;
  verdict?: string;
}

const { score, verdict } = Astro.props;
const hasScore = Boolean(score && Object.values(score).some(Boolean));

if (!hasScore && !verdict) return;

function valueClass(value?: string) {
  if (!value) return 'text-text-muted border-border bg-bg-subtle';
  if (value === '高' || value === '明显') return 'text-gold border-gold/25 bg-gold/10';
  if (value === '中' || value === '一般') return 'text-text border-border bg-bg-subtle';
  return 'text-text-muted border-border bg-bg-subtle';
}
---

<aside class="mb-10 rounded-2xl border border-border bg-bg-subtle p-5">
  <div class="mb-4 flex items-center justify-between gap-4">
    <div>
      <h2 class="font-heading text-base text-text">实践判断</h2>
      <p class="mt-1 text-sm text-text-muted">以安全、质量、效率和生活回流检查这次实践。</p>
    </div>
  </div>

  {hasScore && (
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-border bg-bg p-3">
        <div class="mb-2 flex items-center gap-2 text-xs text-text-muted">
          <ShieldCheck class="h-4 w-4 text-gold" strokeWidth={1.8} aria-hidden="true" />
          安全
        </div>
        <div class:list={['inline-flex rounded-full border px-2.5 py-1 text-xs font-heading', valueClass(score?.safety)]}>
          {score?.safety ?? '未评估'}
        </div>
      </div>

      <div class="rounded-xl border border-border bg-bg p-3">
        <div class="mb-2 flex items-center gap-2 text-xs text-text-muted">
          <BadgeCheck class="h-4 w-4 text-gold" strokeWidth={1.8} aria-hidden="true" />
          质量
        </div>
        <div class:list={['inline-flex rounded-full border px-2.5 py-1 text-xs font-heading', valueClass(score?.quality)]}>
          {score?.quality ?? '未评估'}
        </div>
      </div>

      <div class="rounded-xl border border-border bg-bg p-3">
        <div class="mb-2 flex items-center gap-2 text-xs text-text-muted">
          <Gauge class="h-4 w-4 text-gold" strokeWidth={1.8} aria-hidden="true" />
          效率
        </div>
        <div class:list={['inline-flex rounded-full border px-2.5 py-1 text-xs font-heading', valueClass(score?.efficiency)]}>
          {score?.efficiency ?? '未评估'}
        </div>
      </div>

      <div class="rounded-xl border border-border bg-bg p-3">
        <div class="mb-2 flex items-center gap-2 text-xs text-text-muted">
          <Heart class="h-4 w-4 text-gold" strokeWidth={1.8} aria-hidden="true" />
          生活回流
        </div>
        <div class:list={['inline-flex rounded-full border px-2.5 py-1 text-xs font-heading', valueClass(score?.lifeReturn)]}>
          {score?.lifeReturn ?? '未评估'}
        </div>
      </div>
    </div>
  )}

  {verdict && (
    <p class="mt-4 border-t border-border pt-4 text-sm leading-relaxed text-text">
      {verdict}
    </p>
  )}
</aside>
