---
import type { PromptItem } from '../utils/prompts';

interface ConceptLink {
  id: string;
  title: string;
  symbol?: string;
}

interface Props {
  prompt: PromptItem;
  concepts: ConceptLink[];
}

const { prompt, concepts } = Astro.props;
---

<article class="prompt-card group relative overflow-hidden rounded-2xl border border-gold/15 bg-[linear-gradient(135deg,rgba(212,175,55,0.08),rgba(19,32,64,0.35)_42%,rgba(10,22,40,0.75))] p-5 shadow-xl shadow-sea-deep/20">
  <div class="absolute -right-10 -top-10 h-28 w-28 rounded-full bg-gold/10 blur-2xl transition-opacity duration-300 group-hover:opacity-80"></div>

  <header class="relative mb-4">
    <div class="mb-2 flex items-center justify-between gap-3">
      <span class="text-[10px] font-heading uppercase tracking-[0.24em] text-gold/55">Prompt</span>
      <button
        class="prompt-copy rounded-full border border-gold/20 bg-sea-deep/40 px-3 py-1 text-xs font-mono text-gold/55 transition-colors hover:border-gold/40 hover:text-gold"
        data-prompt-copy
      >
        复制
      </button>
    </div>

    <h3 class="font-heading text-lg leading-snug text-parchment group-hover:text-gold transition-colors">
      {prompt.title}
    </h3>

    <a href={prompt.sourceUrl} class="mt-2 inline-block text-xs text-parchment/35 no-underline transition-colors hover:text-gold/70">
      来源：{prompt.sourceTitle}
    </a>
  </header>

  <pre class="prompt-card-content relative max-h-72 overflow-auto whitespace-pre-wrap rounded-xl border border-mist/10 bg-sea-deep/55 p-4 font-mono text-sm leading-relaxed text-parchment/78"><code>{prompt.content}</code></pre>

  <footer class="relative mt-4 flex flex-col gap-3">
    {prompt.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {prompt.tags.map(tag => (
          <span class="rounded-full bg-sea-light/30 px-2 py-0.5 text-xs text-mist-light/65">
            {tag}
          </span>
        ))}
      </div>
    )}

    {concepts.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {concepts.map(concept => (
          <a
            href={`/concept/${concept.id}`}
            class="rounded-full border border-gold/15 bg-gold/5 px-2 py-0.5 text-xs text-gold/65 no-underline transition-colors hover:border-gold/35 hover:text-gold"
          >
            {concept.symbol && <span class="mr-1">{concept.symbol}</span>}
            {concept.title}
          </a>
        ))}
      </div>
    )}
  </footer>
</article>

