---
import { PromptCardIsland } from './react/PromptCardIsland';
import type { PromptItem } from '../utils/prompts';

interface ConceptLink {
  id: string;
  title: string;
  symbol?: string;
}

interface Props {
  prompt: PromptItem;
  concepts: ConceptLink[];
}

const { prompt, concepts } = Astro.props;
---

<PromptCardIsland prompt={prompt} concepts={concepts} client:visible />
