<section class="tool-match-shell" id="tool-match" aria-labelledby="tool-match-signal-title">
  <button class="match-signal" id="match-open" type="button" aria-haspopup="dialog" aria-controls="match-dialog">
    <span class="signal-light" aria-hidden="true"></span>
    <span class="signal-copy">
      <span class="signal-kicker">AI 帮你选</span>
      <strong id="tool-match-signal-title">不确定用什么？</strong>
      <span>带着多个问题也可以。</span>
      <span>我按角色和短期记忆帮你收窄下一步。</span>
    </span>
    <span class="signal-note">受邀可解锁</span>
    <span class="signal-stat" id="match-stat"></span>
  </button>

  <dialog class="match-dialog" id="match-dialog" aria-labelledby="tool-match-title">
    <div class="match-dialog-panel">
      <!-- Header -->
      <div class="chat-header">
        <div class="chat-header-info">
          <div class="chat-header-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
          </div>
          <div>
            <h2 id="tool-match-title" class="chat-title">AI 帮你选</h2>
            <p class="chat-subtitle">先诊断目的，再给最小行动</p>
          </div>
        </div>
        <button class="chat-history-btn" id="match-history-toggle" type="button" title="对话历史">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
        </button>
        <button class="chat-close" id="match-close" type="button" aria-label="关闭">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>

      <div class="memory-strip" aria-label="当前 Agent 记忆状态">
        <div class="memory-item">
          <span class="memory-label">问题槽</span>
          <strong id="memory-turn-count">0 / 8</strong>
        </div>
        <div class="memory-item">
          <span class="memory-label">当前角色</span>
          <strong id="memory-role-label">未指定</strong>
        </div>
        <div class="memory-item">
          <span class="memory-label">当前卡点</span>
          <strong id="memory-friction-label">待诊断</strong>
        </div>
      </div>

      <!-- Chat Messages -->
      <div class="chat-messages" id="chat-messages" style="display:flex">
        <!-- Agent greeting -->
        <div class="chat-msg chat-msg-agent">
          <div class="chat-bubble chat-bubble-agent">
            <p>你可以连续问 7-8 个具体问题，也可以切换身份来试答案。</p>
            <p class="chat-hint">我保留最近 8 轮问答。每次尽量把问题收窄成一个可执行动作。</p>
          </div>
        </div>

        <!-- Quick Suggestions -->
        <div class="chat-suggestions" id="chat-suggestions" style="display:flex">
          <button type="button" data-text="我想改已有项目代码，有几个页面和接口需要调整">改已有项目</button>
          <button type="button" data-text="我想写一篇公众号，但不知道该用聊天 AI 还是别的工具">写公众号</button>
          <button type="button" data-text="我想做一个网站，但还没有现成代码">做网站</button>
          <button type="button" data-text="我想做一个报名表，能收集信息并自动整理">做报名表</button>
          <button type="button" data-text="我想学 AI，但不知道第一步做什么">学 AI</button>
          <button type="button" data-text="我想用 AI 提高工作效率，但不知道从哪开始">提效</button>
          <button type="button" data-text="我想做数据分析，但不会编程">数据分析</button>
        </div>
      </div>

      <div class="chat-history-panel" id="chat-history-panel">
        <div class="history-header">
          <span>对话历史</span>
          <button class="history-close" id="history-close" type="button">返回</button>
        </div>
        <div class="history-list" id="history-list"></div>
      </div>

      <!-- Status -->
      <div class="chat-status" id="chat-status" aria-live="polite"></div>

      <!-- Input Bar -->
      <div class="chat-input-bar">
        <div class="chat-input-wrap">
          <textarea
            id="chat-input"
            class="chat-input"
            rows="1"
            maxlength="500"
            placeholder="描述你的需求..."
          ></textarea>
          <button class="chat-send" id="chat-send" type="button" aria-label="发送">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
          </button>
        </div>
        <div class="chat-meta-bar">
          <label class="chat-consent">
            <input id="chat-consent" type="checkbox" checked />
            <span>匿名加入选题库</span>
          </label>
          <span class="chat-anon">不收集个人信息</span>
        </div>
      </div>

      <!-- Side panel toggle (audience/stage) -->
      <div class="chat-context-bar" id="chat-context-bar">
        <button class="context-toggle" id="context-toggle" type="button">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          补充背景（可选）
        </button>
        <div class="context-panel" id="context-panel">
          <label>
            <span>使用场景</span>
            <select id="match-audience">
              <option value="prefer-not-say">不想说</option>
              <option value="student">学生</option>
              <option value="office-worker">职场办公</option>
              <option value="creator">内容创作者</option>
              <option value="developer">开发者 / 技术从业者</option>
              <option value="freelancer-founder">自由职业 / 创业者</option>
              <option value="teacher">老师 / 培训者</option>
              <option value="parent">家长</option>
              <option value="minor">青少年 / 未成年</option>
              <option value="other">其他</option>
            </select>
          </label>
          <label>
            <span>AI 阶段</span>
            <select id="match-stage">
              <option value="prefer-not-say">不想说</option>
              <option value="beginner">刚开始</option>
              <option value="chat-user">会用聊天 AI</option>
              <option value="ide-user">会用 IDE</option>
              <option value="cli-user">会用命令行</option>
              <option value="builder">能做完整项目</option>
            </select>
          </label>
        </div>
      </div>
    </div>
  </dialog>
</section>

<style>
  /* ── Signal Button ── */
  .tool-match-shell { display: block; }

  .match-signal {
    position: relative;
    display: grid;
    grid-template-columns: 0.72rem minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.85rem;
    width: min(100%, 30rem);
    min-height: 4.1rem;
    padding: 0.7rem 0.85rem;
    overflow: hidden;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.13);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-surface, #fff) 76%, transparent);
    color: inherit;
    cursor: pointer;
    text-align: left;
    box-shadow: 0 0 0 0 rgba(var(--color-brand-rgb, 196, 112, 74), 0.13);
    animation: matchBreath 5.6s ease-in-out infinite;
  }

  .match-signal::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 0%, transparent 36%, rgba(255, 255, 255, 0.62) 48%, transparent 62%, transparent 100%);
    opacity: 0;
    transform: translateX(-100%);
    animation: matchScan 7.2s ease-in-out infinite;
    pointer-events: none;
  }

  .match-signal:hover {
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.28);
    background: color-mix(in srgb, var(--color-surface, #fff) 86%, transparent);
  }

  .signal-light {
    position: relative; z-index: 1;
    width: 0.64rem; height: 0.64rem;
    border-radius: 999px;
    background: var(--color-brand, #c4704a);
    box-shadow: 0 0 0 0 rgba(var(--color-brand-rgb, 196, 112, 74), 0.22);
    animation: matchLight 3.8s ease-in-out infinite;
  }

  .signal-copy, .signal-note { position: relative; z-index: 1; }
  .signal-copy { display: grid; gap: 0.15rem; min-width: 0; }
  .signal-kicker {
    color: var(--color-brand, #c4704a);
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem; font-weight: 850;
  }
  .signal-copy strong {
    color: var(--color-heading, var(--color-text, #3f3027));
    font-size: 0.9rem; font-weight: 850; line-height: 1.25;
  }
  .signal-copy span:not(.signal-kicker) {
    color: var(--color-text-muted, rgba(63, 48, 39, 0.62));
    font-size: 0.76rem; line-height: 1.45;
  }
  .signal-note {
    padding: 0.2rem 0.45rem; border-radius: 999px;
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.08);
    color: var(--color-brand, #c4704a);
    font-size: 0.68rem; font-weight: 800; white-space: nowrap;
  }

  /* ── Dialog ── */
  .match-dialog {
    width: min(42rem, calc(100vw - 2rem));
    max-height: min(44rem, calc(100vh - 2rem));
    padding: 0; border: 0; border-radius: 16px;
    background: transparent; color: inherit;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
  }
  .match-dialog::backdrop {
    background: rgba(34, 28, 24, 0.36);
    backdrop-filter: blur(12px);
  }

  .match-dialog-panel {
    display: flex;
    flex-direction: column;
    height: min(44rem, calc(100vh - 2rem));
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.12);
    border-radius: 16px;
    background: color-mix(in srgb, var(--color-surface, #fff) 96%, transparent);
    overflow: hidden;
  }


  /* ── History Panel ── */
  .chat-history-btn {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px;
    border: 0; border-radius: 8px;
    background: rgba(var(--color-muted-rgb, 63, 48, 39), 0.06);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.55));
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .chat-history-btn:hover {
    background: rgba(var(--color-muted-rgb, 63, 48, 39), 0.12);
  }

  .chat-history-panel {
    display: none;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
  }
  .chat-history-panel.visible {
    display: flex;
  }

  .history-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
    font-size: 0.88rem; font-weight: 700;
    color: var(--color-heading, var(--color-text, #3f3027));
  }
  .history-close {
    padding: 0.2rem 0.55rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
    border-radius: 6px;
    background: transparent;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.55));
    font-size: 0.75rem; font-weight: 600;
    cursor: pointer;
  }
  .history-close:hover { background: rgba(var(--color-muted-rgb, 63, 48, 39), 0.06); }

  .history-list {
    flex: 1; overflow-y: auto; padding: 0.75rem;
    display: flex; flex-direction: column; gap: 0.5rem;
  }

  .history-item {
    padding: 0.65rem 0.75rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .history-item:hover { background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.04); }
  .history-item-date {
    font-size: 0.7rem; color: var(--color-text-muted, rgba(63, 48, 39, 0.45));
    margin-bottom: 0.25rem;
  }
  .history-item-text {
    font-size: 0.82rem; color: var(--color-text, #3f3027);
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .history-empty {
    text-align: center; padding: 2rem 1rem;
    font-size: 0.85rem; color: var(--color-text-muted, rgba(63, 48, 39, 0.45));
  }

  /* ── Chat Header ── */
  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
    flex-shrink: 0;
  }
  .chat-header-info {
    display: flex; align-items: center; gap: 0.65rem;
  }
  .chat-header-icon {
    width: 32px; height: 32px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
    color: var(--color-brand, #c4704a);
  }
  .chat-title {
    margin: 0;
    font-size: 0.95rem; font-weight: 800;
    color: var(--color-heading, var(--color-text, #3f3027));
  }
  .chat-subtitle {
    margin: 0;
    font-size: 0.72rem;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.55));
  }
  .chat-close {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px;
    border: 0; border-radius: 8px;
    background: rgba(var(--color-muted-rgb, 63, 48, 39), 0.06);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.55));
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .chat-close:hover {
    background: rgba(var(--color-muted-rgb, 63, 48, 39), 0.12);
  }

  .memory-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    background: rgba(var(--color-bg-rgb, 255, 255, 255), 0.56);
  }
  .memory-item {
    min-width: 0;
    padding: 0.45rem 0.55rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    border-radius: 8px;
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.62);
  }
  .memory-label {
    display: block;
    margin-bottom: 0.18rem;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.5));
    font-size: 0.64rem;
    font-weight: 800;
  }
  .memory-item strong {
    display: block;
    overflow: hidden;
    color: var(--color-heading, var(--color-text, #3f3027));
    font-size: 0.78rem;
    font-weight: 850;
    line-height: 1.2;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── Chat Messages Area ── */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .chat-messages.hidden { display: none !important; }

  .chat-msg {
    display: flex;
    max-width: 88%;
  }
  .chat-msg-user {
    align-self: flex-end;
  }
  .chat-msg-agent {
    align-self: flex-start;
  }

  .chat-bubble {
    padding: 0.65rem 0.85rem;
    border-radius: 14px;
    font-size: 0.88rem;
    line-height: 1.6;
    word-break: break-word;
  }
  .chat-bubble p { margin: 0; }
  .chat-bubble p + p { margin-top: 0.35rem; }

  .chat-bubble-agent {
    background: rgba(var(--color-muted-rgb, 63, 48, 39), 0.06);
    color: var(--color-text, #3f3027);
    border-bottom-left-radius: 4px;
  }
  .chat-bubble-user {
    background: var(--color-brand, #c4704a);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  :global(.chat-msg) {
    display: flex;
    max-width: 88%;
  }
  :global(.chat-msg-user) {
    align-self: flex-end;
    justify-content: flex-end;
  }
  :global(.chat-msg-agent) {
    align-self: flex-start;
    justify-content: flex-start;
  }
  :global(.chat-bubble) {
    max-width: 100%;
    padding: 0.7rem 0.9rem;
    border-radius: 14px;
    font-size: 0.88rem;
    line-height: 1.65;
    word-break: break-word;
  }
  :global(.chat-bubble p) { margin: 0; }
  :global(.chat-bubble p + p) { margin-top: 0.4rem; }
  :global(.chat-bubble-agent) {
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.12);
    border-bottom-left-radius: 4px;
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.82);
    color: var(--color-text, #3f3027);
    box-shadow: 0 8px 24px rgba(var(--color-shadow-rgb, 75, 54, 42), 0.06);
  }
  :global(.chat-bubble-user) {
    border: 1px solid rgba(var(--color-brand-rgb, 196, 112, 74), 0.16);
    border-bottom-right-radius: 4px;
    background: var(--color-brand, #c4704a);
    color: #fff;
    box-shadow: 0 10px 24px rgba(var(--color-brand-rgb, 196, 112, 74), 0.18);
  }
  :global(.chat-bubble-user p) {
    color: #fff;
  }
  :global(.chat-hint) {
    font-size: 0.78rem;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.58));
  }

  .chat-hint {
    font-size: 0.78rem !important;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.5)) !important;
  }

  /* Agent typing indicator */
  .chat-typing {
    display: flex; gap: 4px; padding: 0.65rem 0.85rem;
    background: rgba(var(--color-muted-rgb, 63, 48, 39), 0.06);
    border-radius: 14px; border-bottom-left-radius: 4px;
    align-self: flex-start;
  }
  .chat-typing span {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-text-muted, rgba(63, 48, 39, 0.35));
    animation: typingBounce 1.4s ease-in-out infinite;
  }
  .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  /* ── Quick Suggestions ── */
  .chat-suggestions {
    display: flex; flex-wrap: wrap; gap: 0.4rem;
    max-width: 88%;
  }
  .chat-suggestions button {
    padding: 0.3rem 0.65rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.12);
    border-radius: 999px;
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.55);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.66));
    font-size: 0.78rem; font-weight: 600;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .chat-suggestions button:hover {
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.3);
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.08);
    color: var(--color-brand, #c4704a);
  }

  /* ── Match Result Card (inline in chat) ── */
  .chat-result-card {
    padding: 0.85rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
    border-radius: 12px;
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.5);
    display: flex; flex-direction: column; gap: 0.6rem;
  }
  .result-verdict {
    font-size: 0.9rem; font-weight: 700;
    color: var(--color-heading, var(--color-text, #3f3027));
  }
  .result-bridge {
    font-size: 0.86rem; line-height: 1.65;
    color: var(--color-text, #3f3027);
  }
  .result-reason {
    font-size: 0.82rem; line-height: 1.6;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.65));
  }
  .result-direction {
    font-size: 0.82rem; font-weight: 600;
    color: var(--color-brand, #c4704a);
  }
  .result-section-title {
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.55));
  }
  .result-tools {
    display: flex; flex-direction: column; gap: 0;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.08);
    border-radius: 8px; overflow: hidden;
  }
  .result-tool-row {
    display: flex; gap: 0.6rem;
    padding: 0.62rem 0.7rem;
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.5);
  }
  .result-tool-row + .result-tool-row {
    border-top: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.06);
  }
  .result-tool-badge {
    min-width: 2.4rem;
    height: 1.35rem;
    padding: 0 0.38rem;
    border-radius: 999px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.1);
    color: var(--color-brand, #c4704a);
    font-size: 0.66rem; font-weight: 850; flex-shrink: 0;
  }
  .result-tool-info { flex: 1; min-width: 0; }
  .result-tool-title {
    font-size: 0.84rem; font-weight: 800;
