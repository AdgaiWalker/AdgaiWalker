<section class="tool-match-shell" id="tool-match" aria-labelledby="tool-match-signal-title">
  <button class="match-signal" id="match-open" type="button" aria-haspopup="dialog" aria-controls="match-dialog">
    <span class="signal-light" aria-hidden="true"></span>
    <span class="signal-copy">
      <span class="signal-kicker">需求判断</span>
      <strong id="tool-match-signal-title">别急着用 Codex</strong>
      <span>先说你要做什么。</span>
      <span>我帮你判断该用 Codex、聊天 AI，还是别的工具。</span>
    </span>
    <span class="signal-note">匿名</span>
  </button>

  <dialog class="match-dialog" id="match-dialog" aria-labelledby="tool-match-title">
    <div class="match-dialog-panel">
      <div class="match-head">
        <div class="match-title-block">
          <p class="match-kicker">需求判断</p>
          <h2 id="tool-match-title">先判断这件事该不该用 Codex。</h2>
          <p class="match-intro">说清楚你要完成的事，我先判断工具方向，再给站内资料路径。</p>
        </div>
        <div class="match-head-actions">
          <button class="match-clear" id="match-clear" type="button">清空</button>
          <button class="match-close" id="match-close" type="button">关闭</button>
        </div>
      </div>

      <div class="match-privacy">
        <span>只收集匿名需求。不要输入姓名、联系方式、API Key、公司机密。</span>
      </div>

      <div class="match-workbench">
        <div class="match-panel match-panel-primary">
          <div class="panel-label">
            <span>需求判断</span>
          </div>
          <div class="match-suggestions" aria-label="常见需求">
            <button type="button" data-text="我想改已有项目代码，有几个页面和接口需要调整">改已有项目</button>
            <button type="button" data-text="我想写一篇公众号，但不知道该用聊天 AI 还是 Codex">写公众号</button>
            <button type="button" data-text="我想做一个网站，但还没有现成代码">做网站</button>
            <button type="button" data-text="我想做一个报名表，能收集信息并自动整理">做报名表</button>
            <button type="button" data-text="我想学 AI，但不知道第一步做什么">AI 入门</button>
            <button type="button" data-text="我想省钱用 AI，token 和中转该怎么看">省钱用 AI</button>
          </div>

          <form class="match-form" id="match-form">
            <label class="match-input-wrap" for="match-input">
              <span>你现在想完成哪件事？</span>
              <textarea
                id="match-input"
                class="match-input"
                rows="4"
                maxlength="500"
                placeholder="例如：我想改项目 / 写文章 / 做网站 / 做表格 / 学 AI / 省钱用 AI。补一句你在哪里、要交付什么、卡在哪一步。"
                required
              ></textarea>
            </label>
            <div class="match-actions">
              <label class="match-consent">
                <input id="match-consent" type="checkbox" checked />
                <span>匿名加入选题库</span>
              </label>
              <button class="match-submit" id="match-submit" type="submit">判断工具方向</button>
            </div>
          </form>
        </div>

        <aside class="match-panel match-panel-side" aria-label="需求背景">
          <label>
            <span>使用场景</span>
            <select id="match-audience">
              <option value="prefer-not-say">不想说</option>
              <option value="student">学生</option>
              <option value="office-worker">职场办公</option>
              <option value="creator">内容创作者</option>
              <option value="developer">开发者 / 技术从业者</option>
              <option value="freelancer-founder">自由职业 / 创业者</option>
              <option value="teacher">老师 / 培训者</option>
              <option value="parent">家长</option>
              <option value="minor">青少年 / 未成年</option>
              <option value="other">其他</option>
            </select>
          </label>
          <label>
            <span>AI 阶段</span>
            <select id="match-stage">
              <option value="prefer-not-say">不想说</option>
              <option value="beginner">刚开始</option>
              <option value="chat-user">会用聊天 AI</option>
              <option value="ide-user">会用 IDE</option>
              <option value="cli-user">会用命令行</option>
              <option value="builder">能做完整项目</option>
            </select>
          </label>
          <div class="match-microcopy">
            <span>选不准就留空，真实问题比标签更重要。</span>
          </div>
        </aside>
      </div>

      <div class="match-status" id="match-status" aria-live="polite"></div>

      <div class="match-result" id="match-result" hidden>
        <div class="result-head">
          <div>
            <p class="result-label">先判断</p>
            <p class="result-verdict" id="match-verdict"></p>
            <p class="result-bridge" id="match-reason"></p>
          </div>
          <div class="result-meta" id="match-meta"></div>
        </div>
        <div class="result-section">
          <p class="result-label">该用什么</p>
          <p class="result-bridge" id="match-tool-direction"></p>
        </div>
        <div class="result-section">
          <p class="result-label">看这些资料</p>
          <p class="result-bridge" id="match-bridge"></p>
        </div>
        <div class="resource-pack" id="match-resources"></div>
        <p class="understand-note" id="match-understand"></p>
      </div>
    </div>
  </dialog>
</section>

