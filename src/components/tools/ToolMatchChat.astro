<script>
  interface MatchResourceResult {
    id: string;
    title: string;
    href: string;
    kind: string;
    useFor: string;
    summary: string;
  }

  interface MatchResponse {
    sessionId?: string;
    fitVerdict?: 'codex-fit' | 'codex-not-needed' | 'codex-maybe' | 'not-enough-info';
    toolDirection?: string;
    reason?: string;
    bridge?: string;
    needSummary?: string;
    categories?: Array<{ id: string; label: string }>;
    resources?: MatchResourceResult[];
    remaining?: number;
    error?: string;
    understandNote?: string;
    safety?: {
      piiDetected?: boolean;
      consentForTopic?: boolean;
      isMinorContext?: boolean;
      note?: string;
    };
  }

  let matchAbort: AbortController | null = null;
  let matchSessionId: string | null = null;
  let inactivityTimer: ReturnType<typeof setTimeout> | null = null;

  function initToolMatch() {
    matchAbort?.abort();
    matchAbort = new AbortController();
    const { signal } = matchAbort;

    const open = document.getElementById('match-open') as HTMLButtonElement | null;
    const dialog = document.getElementById('match-dialog') as HTMLDialogElement | null;
    const close = document.getElementById('match-close') as HTMLButtonElement | null;
    const form = document.getElementById('match-form') as HTMLFormElement | null;
    const input = document.getElementById('match-input') as HTMLTextAreaElement | null;
    const submit = document.getElementById('match-submit') as HTMLButtonElement | null;
    const clear = document.getElementById('match-clear') as HTMLButtonElement | null;
    const audience = document.getElementById('match-audience') as HTMLSelectElement | null;
    const stage = document.getElementById('match-stage') as HTMLSelectElement | null;
    const consent = document.getElementById('match-consent') as HTMLInputElement | null;
    const status = document.getElementById('match-status');
    const result = document.getElementById('match-result');
    const verdict = document.getElementById('match-verdict');
    const reason = document.getElementById('match-reason');
    const toolDirection = document.getElementById('match-tool-direction');
    const bridge = document.getElementById('match-bridge');
    const meta = document.getElementById('match-meta');
    const resources = document.getElementById('match-resources');
    const understand = document.getElementById('match-understand');

    if (!open || !dialog || !close || !form || !input || !submit || !clear || !audience || !stage || !consent || !status || !result || !verdict || !reason || !toolDirection || !bridge || !meta || !resources || !understand) return;

    const openEl = open;
    const dialogEl = dialog;
    const closeEl = close;
    const formEl = form;
    const inputEl = input;
    const submitEl = submit;
    const clearEl = clear;
    const audienceEl = audience;
    const stageEl = stage;
    const consentEl = consent;
    const statusEl = status;
    const resultEl = result;
    const verdictEl = verdict;
    const reasonEl = reason;
    const toolDirectionEl = toolDirection;
    const bridgeEl = bridge;
    const metaEl = meta;
    const resourcesEl = resources;
    const understandEl = understand;
    const suggestionButtons = document.querySelectorAll<HTMLButtonElement>('.match-suggestions button');

    function setStatus(text: string) {
      statusEl.textContent = text;
    }

    function openDialog() {
      if (!dialogEl.open) dialogEl.showModal();
      window.setTimeout(() => inputEl.focus(), 60);
    }

    function closeDialog() {
      dialogEl.close();
    }

    function resetInactivityTimer() {
      if (inactivityTimer) clearTimeout(inactivityTimer);
      inactivityTimer = setTimeout(() => {
        void endSession();
      }, 10 * 60 * 1000);
    }

    async function endSession() {
      if (!matchSessionId) return;
      const sessionId = matchSessionId;
      matchSessionId = null;
      try {
        await fetch('/api/match-end', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionId }),
          keepalive: true,
        });
      } catch {
        // 会话结束记录失败不影响用户使用。
      }
    }

    function clearResult() {
      resultEl.hidden = true;
      verdictEl.textContent = '';
      reasonEl.textContent = '';
      toolDirectionEl.textContent = '';
      bridgeEl.textContent = '';
      metaEl.replaceChildren();
      resourcesEl.replaceChildren();
      understandEl.textContent = '';
      setStatus('');
      suggestionButtons.forEach(button => button.classList.remove('is-active'));
    }

    function renderChip(text: string) {
      const chip = document.createElement('span');
      chip.className = 'result-chip';
      chip.textContent = text;
      return chip;
    }

    function getVerdictText(verdictValue?: MatchResponse['fitVerdict']) {
      if (verdictValue === 'codex-fit') return '这个需求适合 Codex。';
      if (verdictValue === 'codex-not-needed') return '这个需求不一定要用 Codex。';
      if (verdictValue === 'codex-maybe') return '这个需求可能适合 Codex，但要先看有没有现成代码。';
      if (verdictValue === 'not-enough-info') return '信息还不够。';
      return '先判断需求，再决定工具。';
    }

    function renderResourceRow(resource: MatchResourceResult, index: number) {
      const link = document.createElement('a');
      link.className = 'resource-row';
      link.href = resource.href;

      const order = document.createElement('span');
      order.className = 'resource-index';
      order.textContent = String(index + 1);

      const main = document.createElement('span');
      const title = document.createElement('span');
      title.className = 'resource-title';
      title.textContent = resource.title;

      const useFor = document.createElement('span');
      useFor.className = 'resource-use';
      useFor.textContent = resource.useFor;

      const kind = document.createElement('span');
      kind.className = 'resource-kind';
      kind.textContent = resource.kind;

      main.append(title, useFor);
      link.append(order, main, kind);
      return link;
    }

    function renderResult(data: MatchResponse) {
      resultEl.hidden = false;
      verdictEl.textContent = getVerdictText(data.fitVerdict);
      reasonEl.textContent = data.reason || data.bridge || '补一句：你现在在哪里、要交付什么、卡在哪一步。';
      toolDirectionEl.textContent = data.toolDirection || '先把目标和卡点说清楚，再判断该用代码 Agent、聊天 AI、办公工具还是资料路线。';
      bridgeEl.textContent = data.bridge || '按下面资料顺序看，先判断需求，再选择对应资料和工具。';
      metaEl.replaceChildren();
      resourcesEl.replaceChildren();

      for (const category of data.categories ?? []) {
        metaEl.appendChild(renderChip(category.label));
      }
      if (typeof data.remaining === 'number') {
        metaEl.appendChild(renderChip(`今日剩余 ${data.remaining} 次`));
      }
      if (data.safety?.piiDetected) {
        metaEl.appendChild(renderChip('已隐藏敏感信息'));
      }
      if (data.safety?.isMinorContext) {
        metaEl.appendChild(renderChip('青少年保护模式'));
      }

      (data.resources ?? []).forEach((resource, index) => {
        resourcesEl.appendChild(renderResourceRow(resource, index));
      });

      understandEl.textContent = data.understandNote || '如果看不懂，把推荐资料原文丢给 AI，让它用生活里的例子讲一遍。';
    }

    async function submitNeed(text: string) {
      const need = text.trim();
      if (!need) return;

      submitEl.disabled = true;
      setStatus('正在判断需求和工具方向...');
      resetInactivityTimer();

      try {
        const payload = {
          ...(matchSessionId ? { sessionId: matchSessionId } : {}),
          sourcePage: '/tools',
          audienceGroup: audienceEl.value,
          aiStage: stageEl.value,
          consentForTopic: consentEl.checked,
          messages: [{ role: 'user', content: need }],
        };

        const response = await fetch('/api/match', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json() as MatchResponse;

        if (!response.ok || data.error) {
          setStatus(data.error || '匹配失败，请稍后再试。');
          return;
        }

        matchSessionId = data.sessionId ?? matchSessionId;
        inputEl.value = '';
        renderResult(data);
        setStatus(data.safety?.consentForTopic === false ? '本次问题不会进入选题库。' : '判断完成，匿名需求会进入选题分析。');
      } catch {
        setStatus('网络异常，请稍后再试。');
      } finally {
        submitEl.disabled = false;
        inputEl.focus();
      }
    }

    openEl.addEventListener('click', openDialog, { signal });
    closeEl.addEventListener('click', closeDialog, { signal });
    dialogEl.addEventListener('click', (event) => {
      if (event.target === dialogEl) closeDialog();
    }, { signal });

    formEl.addEventListener('submit', (event) => {
      event.preventDefault();
      void submitNeed(inputEl.value);
    }, { signal });

    clearEl.addEventListener('click', () => {
      void endSession();
      inputEl.value = '';
      clearResult();
      setStatus('已清空本次需求。');
    }, { signal });

    suggestionButtons.forEach((button) => {
      button.addEventListener('click', () => {
        suggestionButtons.forEach(item => item.classList.remove('is-active'));
        button.classList.add('is-active');
        inputEl.value = button.dataset.text ?? '';
        inputEl.focus();
      }, { signal });
    });

    window.addEventListener('beforeunload', () => {
      void endSession();
    }, { signal });
  }

  initToolMatch();
  document.addEventListener('astro:page-load', initToolMatch);
  document.addEventListener('astro:before-swap', () => {
    matchAbort?.abort();
    matchAbort = null;
  });
</script>
