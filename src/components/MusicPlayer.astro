<!-- MusicPlayer — lvyovo 风格音乐播放器 -->
<div class="panel-glass px-5 py-4 flex flex-row items-center justify-between gap-4 group cursor-pointer rounded-[40px]" id="music-player" style="background: rgba(255,255,255,0.6);">
  <div class="flex items-center gap-3 w-full">
    <iconify-icon icon="lucide:music" width="22" height="22" class="text-[#2dd4bf] shrink-0"></iconify-icon>
    <div class="flex-1">
      <div class="text-[#4a5f61] text-[15px] font-body font-medium tracking-wide group-hover:text-brand transition-colors" id="music-title">
        Close To You
      </div>
      <div class="w-[85%] h-[6px] bg-white/40 rounded-full mt-1.5 overflow-hidden relative">
        <div class="h-full bg-white w-2/3 rounded-full relative z-10" id="music-progress"></div>
      </div>
    </div>
  </div>
  <button class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-[#2dd4bf] hover:scale-105 transition-transform shrink-0 shadow-sm border-none cursor-pointer" aria-label="Play" id="music-toggle">
    <iconify-icon icon="lucide:play" width="16" height="16" class="ml-0.5" id="music-icon"></iconify-icon>
  </button>
  
  <!-- 真实的 HTML5 音频元素 -->
  <audio id="ambient-audio" loop src="https://cdn.freesound.org/previews/387/387435_3612089-lq.mp3"></audio>
</div>

<script>
  const toggle = document.getElementById('music-toggle');
  const icon = document.getElementById('music-icon');
  const audio = document.getElementById('ambient-audio') as HTMLAudioElement;
  let playing = false;

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (!icon || !audio) return;
    
    if (playing) {
      audio.pause();
      icon.setAttribute('icon', 'lucide:play');
    } else {
      audio.volume = 0.5;
      audio.play().catch(e => console.error("Audio play failed:", e));
      icon.setAttribute('icon', 'lucide:pause');
    }
    playing = !playing;
  });
</script>
