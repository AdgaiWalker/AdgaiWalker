---
/**
 * MusicPlayer — 首页右栏极简律动胶囊音乐播放器
 * 升级：进度条升级为 6 轨动态音波谱柱，随音乐播放动态高度起伏，极其有趣解压
 */
import { Icon } from 'astro-icon/components';
---

<div class="panel-glass px-4 py-2 flex flex-row items-center justify-between gap-3 group cursor-pointer rounded-full pointer-events-auto shadow-sm" id="music-player" style="max-width: 250px;">
  <!-- 左侧音乐图标和动态波形 -->
  <div class="flex items-center gap-2.5 flex-1 min-w-0">
    <div class="w-7.5 h-7.5 rounded-full flex items-center justify-center shrink-0 border transition-all duration-300" style="background: var(--color-player-icon-bg, #e6fcf9); border-color: var(--color-player-btn-border, rgba(0,0,0,0.04));">
      <Icon name="lucide:music" width={13} height={13} style="color: var(--color-player-icon-text, #35bfab);" />
    </div>
    
    <!-- 歌名与跳舞小波谱 -->
    <div class="flex flex-col min-w-0 flex-1">
      <div class="text-parchment text-[12.5px] font-body font-bold transition-colors truncate leading-none mb-1.5" id="music-title" style="color: var(--color-parchment, #1a2325);">
        最近你
      </div>
      <!-- 动态拟真音波谱 (音频播放时跳跃律动) -->
      <div class="flex items-end gap-[2px] h-3.5 pointer-events-none" id="music-spectrum">
        <span class="w-[2px] rounded-full bar" style="height: 3px; background: var(--color-brand, #35bfab); opacity: 0.6;"></span>
        <span class="w-[2px] rounded-full bar" style="height: 4px; background: var(--color-brand, #35bfab); opacity: 0.6;"></span>
        <span class="w-[2px] rounded-full bar" style="height: 3px; background: var(--color-brand, #35bfab); opacity: 0.6;"></span>
        <span class="w-[2px] rounded-full bar" style="height: 5px; background: var(--color-brand, #35bfab); opacity: 0.6;"></span>
        <span class="w-[2px] rounded-full bar" style="height: 3px; background: var(--color-brand, #35bfab); opacity: 0.6;"></span>
        <span class="w-[2px] rounded-full bar" style="height: 4px; background: var(--color-brand, #35bfab); opacity: 0.6;"></span>
      </div>
    </div>
  </div>

  <!-- 右侧圆形自适应播放按钮 -->
  <button class="w-7.5 h-7.5 rounded-full flex items-center justify-center hover:scale-108 active:scale-95 transition-all shrink-0 shadow-[0_2px_8px_rgba(0,0,0,0.06)] cursor-pointer" aria-label="Play" id="music-toggle" style="background: var(--color-player-btn-bg, #ffffff); color: var(--color-player-btn-text, #35bfab); border: 1px solid var(--color-player-btn-border, rgba(0, 0, 0, 0.04));">
    <Icon name="lucide:play" width={11} height={11} class="ml-0.5" id="music-icon-play" />
    <Icon name="lucide:pause" width={11} height={11} class="hidden" id="music-icon-pause" />
  </button>
  
  <!-- 真实的 HTML5 音频元素 -->
  <audio id="ambient-audio" loop src="https://cdn.freesound.org/previews/387/387435_3612089-lq.mp3"></audio>
</div>

<style>
  /* ========================================= */
  /* 动态音谱跳跃动画定义 */
  /* ========================================= */
  #music-spectrum.playing .bar {
    animation: bounce-bar 0.75s ease-in-out infinite alternate;
  }
  #music-spectrum.playing .bar:nth-child(1) { animation-delay: 0.1s; animation-duration: 0.8s; }
  #music-spectrum.playing .bar:nth-child(2) { animation-delay: 0.25s; animation-duration: 0.6s; }
  #music-spectrum.playing .bar:nth-child(3) { animation-delay: 0.05s; animation-duration: 0.75s; }
  #music-spectrum.playing .bar:nth-child(4) { animation-delay: 0.3s; animation-duration: 0.65s; }
  #music-spectrum.playing .bar:nth-child(5) { animation-delay: 0.15s; animation-duration: 0.9s; }
  #music-spectrum.playing .bar:nth-child(6) { animation-delay: 0.2s; animation-duration: 0.7s; }

  @keyframes bounce-bar {
    0% {
      height: 3px;
      opacity: 0.5;
    }
    100% {
      height: 14px;
      opacity: 1;
    }
  }
</style>

<script>
  const toggle = document.getElementById('music-toggle');
  const playIcon = document.getElementById('music-icon-play');
  const pauseIcon = document.getElementById('music-icon-pause');
  const audio = document.getElementById('ambient-audio') as HTMLAudioElement;
  const spectrum = document.getElementById('music-spectrum');
  let playing = false;

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (!playIcon || !pauseIcon || !audio || !spectrum) return;
    
    if (playing) {
      audio.pause();
      playIcon.classList.remove('hidden');
      pauseIcon.classList.add('hidden');
      spectrum.classList.remove('playing');
    } else {
      audio.volume = 0.4;
      audio.play().catch(e => console.error("Audio play failed:", e));
      playIcon.classList.add('hidden');
      pauseIcon.classList.remove('hidden');
      spectrum.classList.add('playing');
    }
    playing = !playing;
  });
</script>
