<!-- MusicPlayer — 精致音乐播放器 -->
<div class="panel-glass px-5 py-3.5 flex flex-row items-center justify-between gap-3 group cursor-pointer rounded-[40px]" id="music-player" style="background: rgba(255,255,255,0.5);">
  <div class="flex items-center gap-3 w-full">
    <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand/15 to-brand-secondary/10 flex items-center justify-center shrink-0">
      <iconify-icon icon="lucide:music" width="18" height="18" class="text-brand"></iconify-icon>
    </div>
    <div class="flex-1 min-w-0">
      <div class="text-parchment text-[13px] font-body font-medium tracking-wide group-hover:text-brand transition-colors truncate" id="music-title">
        Close To You
      </div>
      <div class="w-full h-[4px] bg-parchment/[0.06] rounded-full mt-1.5 overflow-hidden relative">
        <div class="h-full bg-brand/30 w-2/3 rounded-full relative z-10 transition-all" id="music-progress"></div>
      </div>
    </div>
  </div>
  <button class="w-9 h-9 rounded-full bg-white/80 flex items-center justify-center text-brand hover:scale-110 transition-transform shrink-0 shadow-[0_1px_4px_rgba(0,0,0,0.04)] border border-white/60 cursor-pointer" aria-label="Play" id="music-toggle">
    <iconify-icon icon="lucide:play" width="14" height="14" class="ml-0.5" id="music-icon"></iconify-icon>
  </button>
  
  <!-- 真实的 HTML5 音频元素 -->
  <audio id="ambient-audio" loop src="https://cdn.freesound.org/previews/387/387435_3612089-lq.mp3"></audio>
</div>

<script>
  const toggle = document.getElementById('music-toggle');
  const icon = document.getElementById('music-icon');
  const audio = document.getElementById('ambient-audio') as HTMLAudioElement;
  let playing = false;

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (!icon || !audio) return;
    
    if (playing) {
      audio.pause();
      icon.setAttribute('icon', 'lucide:play');
    } else {
      audio.volume = 0.5;
      audio.play().catch(e => console.error("Audio play failed:", e));
      icon.setAttribute('icon', 'lucide:pause');
    }
    playing = !playing;
  });
</script>
