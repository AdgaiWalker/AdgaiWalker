---
interface Props {
  role: 'human' | 'ai';
  name: string;
}

const { role, name } = Astro.props;
---

<div class:list={[
  'my-4 p-4 rounded-xl border',
  role === 'human'
    ? 'border-gold/20 bg-gold/5'
    : 'border-border bg-bg-subtle',
]}>
  <div class="text-xs font-heading mb-2 text-text-muted">{name}</div>
  <div class="text-text text-sm leading-relaxed">
    <slot />
  </div>
</div>
