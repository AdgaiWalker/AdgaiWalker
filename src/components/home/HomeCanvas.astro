---
import GreetingCard from '../GreetingCard.astro';
import AuthChip from '../auth/AuthChip.astro';
import { Icon } from 'astro-icon/components';
import { CONTENT, ABOUT, LEARN, TOOLS, IDEAS, PROJECTS, buildPostPath } from '@/shared/routes';
import type { CollectionEntry } from 'astro:content';

interface Props {
  recentLogs: CollectionEntry<'log'>[];
  featuredLog?: CollectionEntry<'log'>;
  recentPosts: CollectionEntry<'log'>[];
  recentIdeas: { title: string; slug: string | null; isReal: boolean }[];
}

const { recentLogs, featuredLog, recentPosts, recentIdeas } = Astro.props;
const traceLog = featuredLog || recentLogs[0];
---

<div id="canvas-container" class="fixed inset-0 overflow-hidden select-none pointer-events-auto z-0 flex items-center justify-center">

  {/* 右上角常驻身份胶囊（登录 / 账号 · 登出） */}
  <AuthChip variant="pill" />


  <div id="desktop-canvas" class="absolute w-[820px] pointer-events-none transition-transform duration-300 origin-center flex justify-center items-center">
    <div class="grid grid-cols-[280px_400px] justify-center gap-6 items-start w-full relative pb-4 pointer-events-auto px-4">

      <!-- 左栏：身份条 + 快速入口 + 最近文章 -->
      <div class="flex flex-col gap-4 mt-6">
        <!-- 身份条 — 品牌缩影 + 最近一条内容 -->
        <div class="directory-card panel-glass p-4 pop-in draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[24px]" style="animation-delay: 0.04s;">
          <div class="directory-brand">
            <span class="directory-mark">
              <span class="text-brand text-[12px] font-heading font-bold leading-none">W</span>
            </span>
            <div class="directory-copy">
              <span class="directory-name">Walker</span>
              <span class="directory-tagline" id="status-text">用 AI 走自己的路</span>
            </div>
          </div>
          {traceLog && (
            <a href={buildPostPath(traceLog.id)} class:list={["directory-trace group/trace", { "is-featured": traceLog.data.featured }]}>
              <span class="directory-trace-label">{traceLog.data.featured ? '推荐' : '最近'}</span>
              <span class="directory-trace-title group-hover/trace:text-brand transition-colors">{traceLog.data.title}</span>
              <Icon name="lucide:arrow-right" width={12} height={12} class="directory-trace-arrow" />
            </a>
          )}
          <!-- 隐形导航：hover 身份条时显示 -->
          <div class="directory-ghost-nav">
            <a href={CONTENT}>内容</a>
            <a href={ABOUT}>关于</a>
            <button id="canvas-theme-toggle" aria-label="切换主题" title="切换主题">主题</button>
          </div>
        </div>

        <!-- 快速入口 — 四大板块 -->
        <div class="panel-glass p-3 pop-in draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[20px] delay-1" style="animation-delay: 0.12s;">
          <div class="quick-grid">
            <a href={`${LEARN}?tab=thoughts`} class="quick-link group/q">
              <Icon name="lucide:pen-line" width={15} height={15} />
              <span>文章</span>
            </a>
            <a href={TOOLS} class="quick-link group/q">
              <Icon name="lucide:bookmark" width={15} height={15} />
              <span>资源</span>
            </a>
            <a href={IDEAS} class="quick-link group/q">
              <Icon name="lucide:lightbulb" width={15} height={15} />
              <span>点子</span>
            </a>
            <a href={PROJECTS} class="quick-link group/q">
              <Icon name="lucide:folder-kanban" width={15} height={15} />
              <span>项目</span>
            </a>
          </div>
        </div>

        <!-- 最近文章 — 让用户一眼看到内容 -->
        <div class="panel-glass p-4 pop-in draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[24px] delay-2" style="animation-delay: 0.20s;">
          <div class="recent-header">
            <Icon name="lucide:pen-line" width={13} height={13} class="text-brand" />
            <span class="recent-label">最近文章</span>
            <a href={`${LEARN}?tab=thoughts`} class="recent-more">全部 →</a>
          </div>
          <div class="recent-list">
            {recentPosts.map(post => (
              <a href={buildPostPath(post.id)} class="recent-item group/item">
                <span class="recent-item-title group-hover/item:text-brand transition-colors">{post.data.title}</span>
                <span class="recent-item-date">{(post.data.date.getMonth() + 1).toString().padStart(2, '0')}/{post.data.date.getDate().toString().padStart(2, '0')}</span>
              </a>
            ))}
          </div>
        </div>

      </div>

      <!-- 右栏：头像卡 -->
      <div class="flex flex-col items-center gap-5 -mt-3">
        <div class="pop-in delay-1 w-full draggable-card cursor-grab rounded-[40px] relative">
          <GreetingCard sparks={recentIdeas} />
        </div>
      </div>
    </div>
  </div>

</div>

<style>
  /* 画布内 panel-glass 亮色主题 */
  :global(body:not(.theme-aurora):not(.theme-sunset):not(.theme-mint)) #canvas-container :global(.panel-glass) {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(32px);
    border: 1.5px solid rgba(255, 255, 255, 0.9);
    transition: all 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }


  .pop-in {
    will-change: transform, opacity;
  }
  .cursor-grab {
    cursor: grab !important;
  }

  /* ===== 身份条 ===== */
  .directory-card {
    border-radius: 24px;
  }

  .directory-brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .directory-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 9px;
    background: color-mix(in srgb, var(--color-brand) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand) 12%, transparent);
    flex-shrink: 0;
  }

  .directory-copy {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .directory-name {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-parchment);
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .directory-tagline {
    margin-top: 2px;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    letter-spacing: 0.06em;
    opacity: 0.5;
  }

  /* 内容钩子 — 最近一条线索 */
  .directory-trace {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
    padding: 8px 10px;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .directory-trace:hover {
    background: color-mix(in srgb, var(--color-brand) 10%, transparent);
  }

  .directory-trace-label {
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--color-brand);
    font-weight: 600;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  /* 推荐文章特殊样式 */
  .directory-trace.is-featured {
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-brand) 5%, transparent), color-mix(in srgb, var(--color-brand) 2%, transparent));
    border-left: 2px solid color-mix(in srgb, var(--color-brand) 30%, transparent);
    padding-left: 10px;
  }

  .directory-trace-title {
    font-size: 0.78rem;
    color: var(--color-parchment-dim);
    font-weight: 500;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }

  .directory-trace-arrow {
    color: var(--color-parchment-dim);
    opacity: 0.3;
    flex-shrink: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .directory-trace:hover .directory-trace-arrow {
    opacity: 0.6;
    transform: translateX(2px);
  }

  /* 隐形导航 — 音符跳动：平时隐形，轮流蹦出亮起再落回隐形 */
  .directory-ghost-nav {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid color-mix(in srgb, var(--color-parchment-dim) 6%, transparent);
    position: relative;
  }

  .directory-ghost-nav a,
  .directory-ghost-nav button {
    font-size: 0.68rem;
    font-family: var(--font-mono);
    font-weight: 700;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--color-brand);
    opacity: 0;
    transform: translateY(6px);
    animation: note-bounce 4.5s ease-in-out infinite;
  }

  .directory-ghost-nav a:nth-child(1) { animation-delay: 0s; }
  .directory-ghost-nav a:nth-child(2) { animation-delay: 1.5s; }
  .directory-ghost-nav button:nth-child(3) { animation-delay: 3s; }

  .directory-ghost-nav a:hover,
  .directory-ghost-nav button:hover {
    opacity: 1;
    transform: translateY(0);
    color: var(--color-brand);
    animation-play-state: paused;
  }

  @keyframes note-bounce {
    0% {
      opacity: 0;
      transform: translateY(6px);
    }
    8% {
      opacity: 1;
      transform: translateY(-4px);
    }
    16% {
      transform: translateY(1px);
    }
    22% {
      opacity: 1;
      transform: translateY(-1px);
    }
    28% {
      opacity: 1;
      transform: translateY(0);
    }
    38% {
      opacity: 0.6;
      transform: translateY(2px);
    }
    45%, 100% {
      opacity: 0;
      transform: translateY(6px);
    }
  }

  .cursor-grabbing {
    cursor: grabbing !important;
  }

  .draggable-card {
    transition: box-shadow 0.35s ease, transform 0.35s ease;
  }
  .draggable-card:hover {
    box-shadow: 0 8px 32px rgba(53, 191, 171, 0.08), 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  @keyframes ripple-out {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 0.35; }
    100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
  }
  .click-ripple {
    position: absolute;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(53, 191, 171, 0.18) 0%, transparent 70%);
    pointer-events: none;
    z-index: 50;
    animation: ripple-out 0.55s ease-out forwards;
  }

  #status-text {
    transition: opacity 0.25s ease;
  }

  /* ===== 最近文章卡 ===== */
  .recent-header {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }
  .recent-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-parchment);
    letter-spacing: 0.02em;
  }
  .recent-more {
    margin-left: auto;
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .recent-more:hover {
    opacity: 1;
    color: var(--color-brand);
  }
  .recent-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .recent-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .recent-item:hover {
    background: color-mix(in srgb, var(--color-brand) 5%, transparent);
  }
  .recent-item-title {
    font-size: 0.76rem;
    color: var(--color-parchment-dim);
    font-weight: 500;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }
  .recent-item-date {
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    opacity: 0.4;
    flex-shrink: 0;
  }

  /* ===== 快速入口 ===== */
  .quick-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }
  .quick-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 8px 4px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-parchment-dim);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .quick-link:hover {
    background: color-mix(in srgb, var(--color-brand) 6%, transparent);
    color: var(--color-brand);
  }
  .quick-link span {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

</style>
