---
import GreetingCard from '../GreetingCard.astro';
import { Icon } from 'astro-icon/components';
import { CONTENT, ABOUT, POSTS, TOOLS, IDEAS, PROJECTS, buildPostPath } from '@/lib/routes';
import type { CollectionEntry } from 'astro:content';

interface Props {
  recentLogs: CollectionEntry<'log'>[];
  featuredLog?: CollectionEntry<'log'>;
  recentPosts: CollectionEntry<'log'>[];
  ideasCount: number;
}

const { recentLogs, featuredLog, recentPosts } = Astro.props;
const traceLog = featuredLog || recentLogs[0];
---

<div id="canvas-container" class="fixed inset-0 overflow-hidden select-none pointer-events-auto z-0 flex items-center justify-center">
  <div id="dynamic-bg-glows" class="absolute inset-0 -z-30 overflow-hidden pointer-events-none transition-all duration-1000">
    <div class="glow-orb absolute w-[80vw] h-[80vw] rounded-full blur-[160px] opacity-[0.10] transition-all duration-1000" id="orb-1"></div>
    <div class="glow-orb absolute w-[70vw] h-[70vw] rounded-full blur-[160px] opacity-[0.08] transition-all duration-1000" id="orb-2"></div>
    <div class="glow-orb absolute w-[60vw] h-[60vw] rounded-full blur-[140px] opacity-[0.08] transition-all duration-1000" id="orb-3"></div>
    <div class="glow-orb absolute w-[55vw] h-[55vw] rounded-full blur-[140px] opacity-[0.08] transition-all duration-1000" id="orb-4"></div>
  </div>

  <div id="mist-overlay" class="absolute inset-0 -z-10 pointer-events-none backdrop-blur-[120px] saturate-[140%] transition-all duration-1000"></div>

  <div class="absolute inset-0 -z-5 opacity-[0.02] pointer-events-none" style="background-image: radial-gradient(#000 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>

  <div id="desktop-canvas" class="absolute w-[820px] pointer-events-none transition-transform duration-300 origin-center flex justify-center items-center">
    <div class="grid grid-cols-[280px_400px] justify-center gap-6 items-start w-full relative pb-4 pointer-events-auto px-4">

      <!-- 左栏：身份条 + 最近文章 -->
      <div class="flex flex-col gap-4 mt-6">
        <!-- 身份条 — 品牌缩影 + 最近一条内容 -->
        <div class="directory-card panel-glass p-4 pop-in draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[24px]" style="animation-delay: 0.04s;">
          <div class="directory-brand">
            <span class="directory-mark">
              <span class="text-brand text-[12px] font-heading font-bold leading-none">W</span>
            </span>
            <div class="directory-copy">
              <span class="directory-name">Walker</span>
              <span class="directory-tagline" id="status-text">用 AI 走自己的路</span>
            </div>
          </div>
          {traceLog && (
            <a href={buildPostPath(traceLog.id)} class="directory-trace group/trace">
              <span class="directory-trace-label">{traceLog.data.featured ? '推荐' : '最近'}</span>
              <span class="directory-trace-title group-hover/trace:text-brand transition-colors">{traceLog.data.title}</span>
              <Icon name="lucide:arrow-right" width={12} height={12} class="directory-trace-arrow" />
            </a>
          )}
          <!-- 隐形导航：hover 身份条时显示 -->
          <div class="directory-ghost-nav">
            <a href={CONTENT}>内容</a>
            <a href={ABOUT}>关于</a>
            <button id="canvas-theme-toggle" aria-label="切换主题" title="切换主题">主题</button>
          </div>
        </div>

        <!-- 最近文章 — 让用户一眼看到内容 -->
        <div class="panel-glass p-4 pop-in draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[24px] delay-1" style="animation-delay: 0.12s;">
          <div class="recent-header">
            <Icon name="lucide:pen-line" width={13} height={13} class="text-brand" />
            <span class="recent-label">最近文章</span>
            <a href={POSTS} class="recent-more">全部 →</a>
          </div>
          <div class="recent-list">
            {recentPosts.map(post => (
              <a href={buildPostPath(post.id)} class="recent-item group/item">
                <span class="recent-item-title group-hover/item:text-brand transition-colors">{post.data.title}</span>
                <span class="recent-item-date">{(post.data.date.getMonth() + 1).toString().padStart(2, '0')}/{post.data.date.getDate().toString().padStart(2, '0')}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- 快速入口 — 四大板块 -->
        <div class="panel-glass p-3 pop-in draggable-card cursor-grab transition-shadow hover:shadow-xl rounded-[20px] delay-2" style="animation-delay: 0.20s;">
          <div class="quick-grid">
            <a href={POSTS} class="quick-link group/q">
              <Icon name="lucide:pen-line" width={15} height={15} />
              <span>文章</span>
            </a>
            <a href={TOOLS} class="quick-link group/q">
              <Icon name="lucide:wrench" width={15} height={15} />
              <span>工具</span>
            </a>
            <a href={IDEAS} class="quick-link group/q">
              <Icon name="lucide:lightbulb" width={15} height={15} />
              <span>点子</span>
            </a>
            <a href={PROJECTS} class="quick-link group/q">
              <Icon name="lucide:folder-kanban" width={15} height={15} />
              <span>项目</span>
            </a>
          </div>
        </div>
      </div>

      <!-- 右栏：头像卡 -->
      <div class="flex flex-col items-center gap-5 -mt-3">
        <div class="pop-in delay-1 w-full draggable-card cursor-grab rounded-[40px]">
          <GreetingCard />
        </div>
      </div>
    </div>
  </div>

</div>

<style>
  .glow-orb#orb-1 { background: var(--orb-color-1); top: -10%; left: -10%; }
  .glow-orb#orb-2 { background: var(--orb-color-2); bottom: -15%; right: -10%; }
  .glow-orb#orb-3 { background: var(--orb-color-3); top: 20%; right: 15%; }
  .glow-orb#orb-4 { background: var(--orb-color-4); bottom: 10%; left: 20%; }

  #mist-overlay {
    background: rgba(251, 251, 248, 0.45);
  }
  :global(body.theme-aurora) #mist-overlay {
    background: rgba(7, 6, 20, 0.5) !important;
  }
  :global(body.theme-sunset) #mist-overlay {
    background: rgba(18, 9, 6, 0.5) !important;
  }
  :global(body.theme-mint) #mist-overlay {
    background: rgba(4, 15, 12, 0.5) !important;
  }
  :global(body.theme-custom) #mist-overlay {
    background: rgba(251, 251, 248, 0.45) !important;
  }

  :global(body:not(.theme-aurora):not(.theme-sunset):not(.theme-mint) .panel-glass) {
    background: rgba(255, 255, 255, 0.65) !important;
    backdrop-filter: blur(32px) !important;
    border: 1.5px solid rgba(255, 255, 255, 0.9) !important;
    transition: all 0.45s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  .glow-orb {
    animation: subtle-drift-1 25s ease-in-out infinite;
  }
  .glow-orb:nth-child(2) {
    animation: subtle-drift-2 30s ease-in-out infinite reverse;
  }
  .glow-orb:nth-child(3) {
    animation: subtle-drift-3 28s ease-in-out infinite 2s;
  }
  .glow-orb:nth-child(4) {
    animation: subtle-drift-4 32s ease-in-out infinite 4s;
  }

  @keyframes subtle-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
    33% { transform: translate(12%, 8%) scale(1.08) rotate(120deg); }
    66% { transform: translate(-8%, 12%) scale(0.92) rotate(240deg); }
  }
  @keyframes subtle-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
    40% { transform: translate(-12%, -8%) scale(1.05) rotate(-120deg); }
    70% { transform: translate(8%, -12%) scale(0.95) rotate(-240deg); }
  }
  @keyframes subtle-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(10%, -6%) scale(1.1); }
  }
  @keyframes subtle-drift-4 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-10%, 10%) scale(1.08); }
  }

  .pop-in {
    will-change: transform, opacity;
  }
  .delay-1 { }
  .delay-2 { }
  .delay-3 { }

  .cursor-grab {
    cursor: grab !important;
  }

  /* ===== 身份条 ===== */
  .directory-card {
    border-radius: 24px;
  }

  .directory-brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .directory-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 9px;
    background: color-mix(in srgb, var(--color-brand) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand) 12%, transparent);
    flex-shrink: 0;
  }

  .directory-copy {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .directory-name {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-parchment);
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .directory-tagline {
    margin-top: 2px;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    letter-spacing: 0.06em;
    opacity: 0.5;
  }

  /* 内容钩子 — 最近一条线索 */
  .directory-trace {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
    padding: 8px 10px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--color-brand) 5%, transparent);
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .directory-trace:hover {
    background: color-mix(in srgb, var(--color-brand) 10%, transparent);
  }

  .directory-trace-label {
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--color-brand);
    font-weight: 600;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .directory-trace-title {
    font-size: 0.78rem;
    color: var(--color-parchment-dim);
    font-weight: 500;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }

  .directory-trace-arrow {
    color: var(--color-parchment-dim);
    opacity: 0.3;
    flex-shrink: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .directory-trace:hover .directory-trace-arrow {
    opacity: 0.6;
    transform: translateX(2px);
  }

  /* 隐形导航 — hover 身份条时淡入 */
  .directory-ghost-nav {
    display: flex;
    gap: 16px;
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid color-mix(in srgb, var(--color-parchment-dim) 6%, transparent);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
  }

  .directory-card:hover .directory-ghost-nav {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .directory-ghost-nav a,
  .directory-ghost-nav button {
    font-size: 0.68rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    opacity: 0.5;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .directory-ghost-nav a:hover,
  .directory-ghost-nav button:hover {
    opacity: 1;
    color: var(--color-brand);
  }

  .cursor-grabbing {
    cursor: grabbing !important;
  }

  .draggable-card {
    transition: box-shadow 0.35s ease, transform 0.35s ease;
  }
  .draggable-card:hover {
    box-shadow: 0 8px 32px rgba(53, 191, 171, 0.08), 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  @keyframes ripple-out {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 0.35; }
    100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
  }
  .click-ripple {
    position: absolute;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(53, 191, 171, 0.18) 0%, transparent 70%);
    pointer-events: none;
    z-index: 50;
    animation: ripple-out 0.55s ease-out forwards;
  }

  #status-text {
    transition: opacity 0.25s ease;
  }

  /* ===== 最近文章卡 ===== */
  .recent-header {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }
  .recent-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-parchment);
    letter-spacing: 0.02em;
  }
  .recent-more {
    margin-left: auto;
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .recent-more:hover {
    opacity: 1;
    color: var(--color-brand);
  }
  .recent-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .recent-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .recent-item:hover {
    background: color-mix(in srgb, var(--color-brand) 5%, transparent);
  }
  .recent-item-title {
    font-size: 0.76rem;
    color: var(--color-parchment-dim);
    font-weight: 500;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }
  .recent-item-date {
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--color-parchment-dim);
    opacity: 0.4;
    flex-shrink: 0;
  }

  /* ===== 快速入口 ===== */
  .quick-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }
  .quick-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 8px 4px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-parchment-dim);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .quick-link:hover {
    background: color-mix(in srgb, var(--color-brand) 6%, transparent);
    color: var(--color-brand);
  }
  .quick-link span {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
</style>
