---
import { Icon } from 'astro-icon/components';

import {
  domainLabels,
  formLabels,
  intentLabels,
  type ContentItem,
  type ContentSpace,
  valueModeLabels,
} from '@/knowledge/content-model';
import { STATUS_LABELS } from '@/shared/constants';
import { formatDateCompact } from '@/shared/format';

interface Props {
  item: ContentItem;
  spaces?: ContentSpace[];
}

const { item, spaces = ['all'] } = Astro.props;
const cardSpaces = spaces.join(' ');

const statusLabel = item.status ? STATUS_LABELS[item.status] : '未标记';
const summary = item.summary ?? '这条内容还没有摘要，先从标题进入阅读。';
const cardFormClass = `form-${item.form}`;
---

<article class:list={["content-card panel-glass", cardFormClass]} data-spaces={cardSpaces}>
  <a
    class="card-link"
    href={item.href}
    target={item.isExternal ? '_blank' : undefined}
    rel={item.isExternal ? 'noopener noreferrer' : undefined}
  >
    <div class="card-topline">
      {item.form === 'idea' && (
        <span class="idea-sparkle-dot" aria-hidden="true" title="创意火花"></span>
      )}
      <span class="date">{formatDateCompact(item.date)}</span>
      <span class="meta-pill">{formLabels[item.form]}</span>
      {item.form === 'idea' && item.status && (
        <span class="idea-status-badge" data-status={item.status}>{statusLabel}</span>
      )}
      {item.isExternal && (
        <span class="external-indicator" aria-label="外部链接">
          <Icon name="lucide:external-link" width={15} height={15} />
        </span>
      )}
    </div>

    <h2 class="card-title">{item.title}</h2>
    <p class="card-summary">{summary}</p>

    <div class="card-details" aria-label="内容属性">
      <span class="detail-chip domain-chip" data-domain={item.domain}>{domainLabels[item.domain]}</span>
      <span class="detail-chip">{intentLabels[item.intent]}</span>
      <span class="detail-chip value-mode">{valueModeLabels[item.valueMode]}</span>
      <span class="detail-chip">{statusLabel}</span>
      <span class="detail-chip ai-level">{item.aiUseLevel}</span>
    </div>

    {item.tags.length > 0 && (
      <div class="tag-list" aria-label="标签">
        {item.tags.slice(0, 3).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .content-card {
    height: 100%;
    overflow: hidden;
    position: relative;
    border: 1px solid var(--color-border) !important;
    background: var(--color-card) !important;
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.4s ease;
  }

  .content-card:hover,
  .content-card:focus-within {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.8) !important;
    border-color: var(--color-brand) !important;
  }

  body.theme-aurora .content-card:hover,
  body.theme-sunset .content-card:hover,
  body.theme-mint .content-card:hover {
    background: rgba(255, 255, 255, 0.05) !important;
    border-color: rgba(255, 255, 255, 0.18) !important;
  }

  /* --- 差异化语义卡片外观 (Card Semantic Styles) --- */

  /* 1. 点子 (Idea) */
  .form-idea:hover {
    box-shadow: 0 16px 40px -10px rgba(245, 158, 11, 0.15) !important;
    border-color: rgba(245, 158, 11, 0.4) !important;
  }
  body.theme-aurora .form-idea:hover,
  body.theme-sunset .form-idea:hover,
  body.theme-mint .form-idea:hover {
    box-shadow: 0 16px 40px -10px rgba(245, 158, 11, 0.3) !important;
    border-color: rgba(245, 158, 11, 0.5) !important;
  }

  .idea-sparkle-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #f59e0b;
    box-shadow: 0 0 8px #f59e0b;
    animation: idea-pulse 2s ease-in-out infinite;
    display: inline-block;
    flex-shrink: 0;
  }

  @keyframes idea-pulse {
    0%, 100% { opacity: 0.5; transform: scale(0.9); }
    50% { opacity: 1; transform: scale(1.15); box-shadow: 0 0 12px #f59e0b; }
  }

  /* 2. 工具/项目 (Resource/Project) */
  .form-resource,
  .form-project {
    padding-left: 3px;
  }
  .form-resource::before,
  .form-project::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20px;
    bottom: 20px;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background: var(--color-brand);
    opacity: 0.4;
    transition: opacity 0.3s ease, height 0.3s ease;
  }
  .form-resource:hover::before,
  .form-project:hover::before {
    opacity: 1;
  }

  /* 3. 吐槽/日记 (Rant/Diary) */
  .form-rant,
  .form-diary {
    opacity: 0.88;
  }
  .form-rant:hover,
  .form-diary:hover {
    opacity: 1;
    border-color: var(--color-border) !important;
    box-shadow: 0 10px 25px -8px rgba(0, 0, 0, 0.05) !important;
  }

  /* 4. 领域配色 (Domain Colors) —— 不同领域用专属色相，一眼分区 */
  .domain-chip[data-domain="ai"] { background: rgba(124,58,237,0.1) !important; color:#7c3aed !important; border-color: rgba(124,58,237,0.22) !important; }
  .domain-chip[data-domain="coding"] { background: rgba(37,99,235,0.1) !important; color:#2563eb !important; border-color: rgba(37,99,235,0.22) !important; }
  .domain-chip[data-domain="product"] { background: rgba(8,145,178,0.1) !important; color:#0891b2 !important; border-color: rgba(8,145,178,0.22) !important; }
  .domain-chip[data-domain="philosophy"] { background: rgba(76,81,191,0.1) !important; color:#4c51bf !important; border-color: rgba(76,81,191,0.22) !important; }
  .domain-chip[data-domain="life"] { background: rgba(22,163,74,0.1) !important; color:#16a34a !important; border-color: rgba(22,163,74,0.22) !important; }
  .domain-chip[data-domain="cooking"] { background: rgba(234,88,12,0.1) !important; color:#ea580c !important; border-color: rgba(234,88,12,0.22) !important; }
  .domain-chip[data-domain="calligraphy"] { background: rgba(120,53,15,0.12) !important; color:#92400e !important; border-color: rgba(120,53,15,0.22) !important; }
  .domain-chip[data-domain="reading"] { background: rgba(217,119,6,0.1) !important; color:#d97706 !important; border-color: rgba(217,119,6,0.22) !important; }
  .domain-chip[data-domain="travel"] { background: rgba(14,165,233,0.1) !important; color:#0ea5e9 !important; border-color: rgba(14,165,233,0.22) !important; }
  .domain-chip[data-domain="emotion"] { background: rgba(219,39,119,0.1) !important; color:#db2777 !important; border-color: rgba(219,39,119,0.22) !important; }
  .domain-chip[data-domain="community"] { background: rgba(5,150,105,0.1) !important; color:#059669 !important; border-color: rgba(5,150,105,0.22) !important; }
  body.theme-aurora .domain-chip,
  body.theme-sunset .domain-chip,
  body.theme-mint .domain-chip { opacity: 0.9; }

  /* 5. 点子状态徽章 (Idea Status) —— 点子卡片常驻显示成熟阶段 */
  .idea-status-badge {
    padding: 0.22rem 0.5rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 750;
    line-height: 1;
    white-space: nowrap;
  }
  .idea-status-badge[data-status="thinking"] { background: rgba(245,158,11,0.14); color:#b45309; }
  .idea-status-badge[data-status="validating"] { background: rgba(59,130,246,0.14); color:#2563eb; }
  .idea-status-badge[data-status="building"] { background: rgba(124,58,237,0.14); color:#7c3aed; }
  .idea-status-badge[data-status="verified"] { background: rgba(16,185,129,0.14); color:#059669; }
  .idea-status-badge[data-status="archived"] { background: rgba(120,113,108,0.16); color:#57534e; }
  body.theme-aurora .idea-status-badge,
  body.theme-sunset .idea-status-badge,
  body.theme-mint .idea-status-badge { opacity: 0.92; }

  .card-link {
    display: flex;
    min-height: 16.25rem;
    height: 100%;
    flex-direction: column;
    padding: 1.15rem;
    color: var(--color-text, #3f3027);
    text-decoration: none;
  }

  .card-link:focus-visible {
    outline: 2px solid rgba(var(--color-brand-rgb, 196, 112, 74), 0.44);
    outline-offset: -4px;
  }

  .card-topline {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
    flex-wrap: wrap;
  }

  .date {
    color: var(--color-brand, #c4704a);
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .meta-pill,
  .detail-chip,
  .tag {
    display: inline-flex;
    align-items: center;
    max-width: 100%;
    border-radius: 999px;
    line-height: 1;
    white-space: nowrap;
  }

  .meta-pill {
    padding: 0.28rem 0.5rem;
    background: rgba(var(--color-muted-rgb, 63, 48, 39), 0.06);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.58));
    font-size: 0.72rem;
    font-weight: 650;
  }

  .external-indicator {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    color: var(--color-brand, #c4704a);
    opacity: 0.78;
  }

  .card-title {
    margin: 1rem 0 0;
    color: var(--color-heading, var(--color-text, #3f3027));
    font-family: var(--font-heading, inherit);
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    font-weight: 800;
    line-height: 1.22;
  }

  .card-summary {
    display: -webkit-box;
    margin: 0.65rem 0 0;
    overflow: hidden;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.64));
    font-size: 0.9rem;
    line-height: 1.75;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  .card-details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
    padding-top: 1.05rem;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 0.25s ease, max-height 0.25s ease, padding-top 0.25s ease;
    padding-top: 0;
  }

  .content-card:hover .card-details {
    opacity: 1;
    max-height: 60px;
    padding-top: 1.05rem;
  }

  .detail-chip {
    padding: 0.34rem 0.58rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.5);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.6));
    font-size: 0.74rem;
    font-weight: 700;
  }

  .value-mode {
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.18);
    color: var(--color-brand, #c4704a);
  }

  .ai-level {
    font-family: var(--font-mono, monospace);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
  }

  .tag {
    padding: 0.3rem 0.52rem;
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.08);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.62));
    font-size: 0.72rem;
    font-weight: 650;
  }

  @media (max-width: 640px) {
    .card-link {
      min-height: 0;
      padding: 1rem;
    }

    .external-indicator {
      margin-left: 0;
    }
  }
</style>
