---
import { Icon } from 'astro-icon/components';

import {
  domainLabels,
  formLabels,
  intentLabels,
  type ContentItem,
  type ContentSpace,
  valueModeLabels,
} from '@/lib/content-model';
import { formatDateCompact } from '@/lib/format';

interface Props {
  item: ContentItem;
  spaces?: ContentSpace[];
}

const { item, spaces = ['all'] } = Astro.props;
const cardSpaces = spaces.join(' ');

const statusLabels: Record<NonNullable<ContentItem['status']>, string> = {
  thinking: '构思中',
  validating: '验证中',
  building: '实现中',
  verified: '已完成',
  archived: '已归档',
};

const statusLabel = item.status ? statusLabels[item.status] : '未标记';
const summary = item.summary ?? '这条内容还没有摘要，先从标题进入阅读。';
---

<article class="content-card panel-glass" data-spaces={cardSpaces}>
  <a
    class="card-link"
    href={item.href}
    target={item.isExternal ? '_blank' : undefined}
    rel={item.isExternal ? 'noopener noreferrer' : undefined}
  >
    <div class="card-topline">
      <span class="date">{formatDateCompact(item.date)}</span>
      <span class="meta-pill">{formLabels[item.form]}</span>
      <span class="meta-pill">{domainLabels[item.domain]}</span>
      <span class="meta-pill">{intentLabels[item.intent]}</span>
      {item.isExternal && (
        <span class="external-indicator" aria-label="外部链接">
          <Icon name="lucide:external-link" width={15} height={15} />
        </span>
      )}
    </div>

    <h2 class="card-title">{item.title}</h2>
    <p class="card-summary">{summary}</p>

    <div class="card-details" aria-label="内容属性">
      <span class="detail-chip value-mode">{valueModeLabels[item.valueMode]}</span>
      <span class="detail-chip">{statusLabel}</span>
      <span class="detail-chip ai-level">{item.aiUseLevel}</span>
    </div>

    {item.tags.length > 0 && (
      <div class="tag-list" aria-label="标签">
        {item.tags.slice(0, 5).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .content-card {
    height: 100%;
    overflow: hidden;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.12);
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.58);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .content-card:hover,
  .content-card:focus-within {
    transform: translateY(-3px);
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.3);
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.72);
    box-shadow: 0 20px 46px rgba(var(--color-shadow-rgb, 75, 54, 42), 0.1);
  }

  .card-link {
    display: flex;
    min-height: 16.25rem;
    height: 100%;
    flex-direction: column;
    padding: 1.15rem;
    color: var(--color-text, #3f3027);
    text-decoration: none;
  }

  .card-link:focus-visible {
    outline: 2px solid rgba(var(--color-brand-rgb, 196, 112, 74), 0.44);
    outline-offset: -4px;
  }

  .card-topline {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
    flex-wrap: wrap;
  }

  .date {
    color: var(--color-brand, #c4704a);
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .meta-pill,
  .detail-chip,
  .tag {
    display: inline-flex;
    align-items: center;
    max-width: 100%;
    border-radius: 999px;
    line-height: 1;
    white-space: nowrap;
  }

  .meta-pill {
    padding: 0.28rem 0.5rem;
    background: rgba(var(--color-muted-rgb, 63, 48, 39), 0.06);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.58));
    font-size: 0.72rem;
    font-weight: 650;
  }

  .external-indicator {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    color: var(--color-brand, #c4704a);
    opacity: 0.78;
  }

  .card-title {
    margin: 1rem 0 0;
    color: var(--color-heading, var(--color-text, #3f3027));
    font-family: var(--font-heading, inherit);
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    font-weight: 800;
    line-height: 1.22;
  }

  .card-summary {
    display: -webkit-box;
    margin: 0.65rem 0 0;
    overflow: hidden;
    color: var(--color-text-muted, rgba(63, 48, 39, 0.64));
    font-size: 0.9rem;
    line-height: 1.75;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  .card-details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
    padding-top: 1.05rem;
  }

  .detail-chip {
    padding: 0.34rem 0.58rem;
    border: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
    background: rgba(var(--color-surface-rgb, 255, 255, 255), 0.5);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.6));
    font-size: 0.74rem;
    font-weight: 700;
  }

  .value-mode {
    border-color: rgba(var(--color-brand-rgb, 196, 112, 74), 0.18);
    color: var(--color-brand, #c4704a);
  }

  .ai-level {
    font-family: var(--font-mono, monospace);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(var(--color-border-rgb, 121, 85, 72), 0.1);
  }

  .tag {
    padding: 0.3rem 0.52rem;
    background: rgba(var(--color-brand-rgb, 196, 112, 74), 0.08);
    color: var(--color-text-muted, rgba(63, 48, 39, 0.62));
    font-size: 0.72rem;
    font-weight: 650;
  }

  @media (max-width: 640px) {
    .card-link {
      min-height: 0;
      padding: 1rem;
    }

    .external-indicator {
      margin-left: 0;
    }
  }
</style>
