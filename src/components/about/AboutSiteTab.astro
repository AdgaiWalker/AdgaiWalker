---
/**
 * AboutSiteTab — "关于站" Tab 的完整内容
 * 数据来自 src/data/site-stats.json
 */
import { Icon } from 'astro-icon/components';
import stats from '@/data/site-stats.json';
import { getPublishedContentItems } from '@/lib/content';
import { contentSpaces, itemBelongsToSpace, domainLabels, type ContentDomain } from '@/lib/content-model';
import { articles, pillars, aiTools, totalCost, costByCategory } from '@/data/site-data';
import SectionHeader from '@/components/about/SectionHeader.astro';

const { siteTimeline, roadmap } = stats;

const contentItems = await getPublishedContentItems();

// 按 domain 统计分布
const domainCounts = new Map<ContentDomain, number>();
for (const item of contentItems) {
  domainCounts.set(item.domain, (domainCounts.get(item.domain) || 0) + 1);
}
const maxDomainCount = Math.max(...domainCounts.values(), 1);

function domainToSpace(d: ContentDomain): string {
  if (['ai', 'coding', 'product', 'community'].includes(d)) return 'progress';
  if (['life', 'cooking', 'calligraphy', 'reading', 'travel', 'emotion'].includes(d)) return 'life';
  return 'learning';
}

const domainEntries = [...domainCounts.entries()]
  .map(([id, count]) => ({
    id,
    label: domainLabels[id],
    count,
    pct: Math.round((count / maxDomainCount) * 100),
    space: domainToSpace(id),
  }))
  .sort((a, b) => b.count - a.count);

// 成本分类颜色
const costColors = ['#35bfab', '#f59e0b', '#fb7299', '#a78bfa', '#34d399'];
---

<div class="site-tab-content" id="about-site-content" hidden>
  {/* 1. 为什么建 */}
  <section class="site-section py-16 px-4 sm:px-6 flex justify-center">
    <div class="max-w-[620px] w-full">
      <SectionHeader title="为什么建" />

      <div class="panel-glass p-6 sm:p-8 space-y-5 mb-8">
        <p class="text-sm leading-[1.9] text-parchment/80">
          从去年（25年）九月开始，我一直在飞书写学习记录，建了好几个知识库。飞书很好用，但 15G 不够用，而且它没法按我的想法长成我想要的样子。
        </p>
        <p class="text-sm leading-[1.9] text-parchment/80">
          后来看到 lvy01 的博客，他的内容就是他的自我介绍，既是知识库又是名片。还有海哥的博客，像一个小型飞书，但比飞书灵活，足够承载他的内容。
        </p>
        <p class="text-sm leading-[1.9] text-parchment/80">
          我想，我已经会用 AI 编程了，为什么不自己搭一个？
        </p>
        <p class="text-sm leading-[1.9] text-parchment/80">
          对内，沉淀之后能反哺自己——省时间、提效率、保证做事的质量。对外，就是我的个人介绍。也满足我的好奇心：用好奇心去创造，创造出新的东西让自己继续好奇。
        </p>
      </div>

      <p class="text-xs text-parchment-dim/40 mb-4 text-center">这三篇文章说了完整的来龙去脉</p>
      <div class="grid gap-4">
        {articles.map((a) => (
          <a href={a.href} class="panel-glass p-5 rounded-2xl hover:border-brand/30 transition-all duration-300 block group">
            <h3 class="text-sm font-bold mb-1.5 flex items-center gap-1.5 group-hover:text-brand transition-colors">
              <Icon name="lucide:file-text" width={14} height={14} class="text-brand" />
              {a.title}
            </h3>
            <p class="text-xs text-parchment/60 leading-relaxed">{a.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* 2. 是什么 */}
  <section class="site-section py-16 px-4 sm:px-6 flex justify-center">
    <div class="max-w-[700px] w-full">
      <SectionHeader title="是什么" />

      <div class="panel-glass p-6 sm:p-8 mb-8">
        <p class="text-sm text-parchment/70 leading-relaxed text-center">
          对内是整理思考、沉淀资源、酝酿点子的前进系统。
        </p>
        <p class="text-sm text-parchment/70 leading-relaxed text-center mt-2">
          对外是给想用 AI 解决真实问题的人的参考。
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-10">
        {pillars.map((p) => (
          <a href={p.route} class="pillar-card panel-glass p-5 rounded-2xl hover:border-brand/30 transition-all duration-300 block group">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-brand/10 border border-brand/20 flex items-center justify-center">
                <Icon name={p.icon} width={16} height={16} class="text-brand" />
              </div>
              <span class="text-sm font-bold">{p.label}</span>
              <span class="text-[9px] font-mono text-parchment-dim/40 uppercase">{p.hint}</span>
            </div>
            <p class="text-xs text-parchment/60 leading-relaxed">{p.desc}</p>
          </a>
        ))}
      </div>

      <div class="panel-glass p-6 sm:p-8 text-center">
        <p class="font-heading text-[15px] text-parchment leading-relaxed font-medium italic">
          这个站永久免费开源，同更多人同行。
        </p>
        <a href="https://github.com/AdgaiWalker/AdgaiWalker" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-3 text-sm text-brand hover:underline">
          <Icon name="lucide:github" width={14} height={14} />
          GitHub 仓库
        </a>
      </div>
    </div>
  </section>

  {/* 3. 怎么做的 */}
  <section class="site-section py-16 px-4 sm:px-6 flex justify-center">
    <div class="max-w-[620px] w-full">
      <SectionHeader title="怎么做的" />

      <div class="panel-glass p-6 sm:p-8 mb-8 border-l-3 border-brand">
        <p class="font-heading text-[15px] text-parchment leading-relaxed font-medium italic">
          因为需要，所以存在。
        </p>
        <p class="text-sm text-parchment/60 leading-relaxed mt-4">
          我不是先选了一个框架，然后看它能做什么。是我先想清楚这个产品要填补我什么需求，然后 AI 根据我的需求推荐框架。
        </p>
      </div>

      <div class="panel-glass p-6 sm:p-8 mb-8">
        <p class="text-[10px] font-mono text-brand uppercase tracking-widest mb-4">开发时间线</p>
        <div class="space-y-4">
          {siteTimeline.map((t) => (
            <div class="flex items-start gap-4">
              <span class="font-mono text-xs text-brand font-bold bg-brand/10 px-2 py-0.5 rounded-full shrink-0 mt-0.5">{t.date}</span>
              <span class="text-sm text-parchment/70">{t.text}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="panel-glass p-5 rounded-2xl mb-6">
        <p class="text-[10px] font-mono text-brand uppercase tracking-widest mb-3">发布流程</p>
        <div class="flex items-center justify-center gap-2 flex-wrap text-xs text-parchment/60">
          <span class="px-2.5 py-1 rounded-lg bg-brand/10 border border-brand/15 font-bold">Obsidian</span>
          <Icon name="lucide:arrow-right" width={12} height={12} class="text-parchment-dim/30" />
          <span class="px-2.5 py-1 rounded-lg bg-brand/10 border border-brand/15 font-bold">GitHub</span>
          <Icon name="lucide:arrow-right" width={12} height={12} class="text-parchment-dim/30" />
          <span class="px-2.5 py-1 rounded-lg bg-brand/10 border border-brand/15 font-bold">Vercel + Upstash</span>
        </div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
        {aiTools.map((t) => (
          <div class="panel-glass p-4 rounded-xl text-center">
            <p class="text-sm font-bold text-parchment">{t.name}</p>
            <p class="text-[10px] text-parchment-dim/50 mt-1">{t.role}</p>
            <p class="text-[9px] text-parchment-dim/30 mt-0.5 font-mono">{t.model}</p>
          </div>
        ))}
      </div>

      <div class="panel-glass p-5 rounded-2xl mb-4">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-bold text-parchment">总成本</span>
          <span class="text-lg font-bold text-brand">{totalCost} 元</span>
        </div>
        <div class="grid grid-cols-3 gap-3">
          {costByCategory.map(([cat, amount]) => (
            <div class="text-center">
              <p class="text-[10px] text-parchment-dim/50">{cat}</p>
              <p class="text-sm font-bold text-parchment">{amount} 元</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* 4. 数据台 — 航海仪表盘 */}
  <section class="site-section py-16 px-4 sm:px-6 flex justify-center" id="data-dock-section">
    <div class="max-w-[620px] w-full">
      <SectionHeader title="数据台" />

      <div class="about-data-panel panel-glass">

        {/* 英雄数字 */}
        <div class="data-hero" data-animate="hero">
          <span class="data-hero-label">航行至今，留下</span>
          <div class="data-hero-number">
            <strong class="data-hero-num" data-target={contentItems.length}>0</strong>
            <span class="data-hero-unit">条记录</span>
          </div>
          <p class="data-hero-footnote">数据提供现象，不提供目的。</p>
        </div>

        {/* 海域图 — 按 domain 分布的气泡 */}
        <div class="data-archipelago" data-animate="archipelago">
          <p class="data-sub-label">内容海域</p>
          <div class="archipelago-map">
            {domainEntries.map((d, i) => {
              const size = Math.max(32, 24 + d.pct * 0.4);
              return (
              <a
                href={`/content?space=${d.space}`}
                class="island"
                style={`--size: ${size}px; --delay: ${i * 0.06}s;`}
                title={`${d.label}：${d.count} 条`}
              >
                <span class="island-core"></span>
                <span class="island-label">{d.label}</span>
                <span class="island-count">{d.count}</span>
              </a>
              );
            })}
          </div>
        </div>

        {/* 成本透明条 */}
        <div class="data-cost-bar" data-animate="cost">
          <div class="cost-header">
            <span class="cost-label">建设成本</span>
            <span class="cost-total" data-target={totalCost} data-suffix=" 元">0 元</span>
          </div>
          <div class="cost-track">
            {costByCategory.map(([cat, amount], i) => {
              const pct = totalCost > 0 ? (amount / totalCost * 100) : 0;
              return (
                <div
                  class="cost-segment"
                  style={`--color: ${costColors[i % costColors.length]}; --pct: ${pct}%; --delay: ${0.8 + i * 0.1}s;`}
                  title={`${cat}：${amount} 元`}
                >
                </div>
              );
            })}
          </div>
          <div class="cost-legend">
            {costByCategory.map(([cat, amount], i) => (
              <span class="cost-legend-item">
                <span class="cost-dot" style={`background: ${costColors[i % costColors.length]}`}></span>
                {cat} {amount}
              </span>
            ))}
          </div>
        </div>

        {/* 航线状态 — 合并原 roadmap */}
        <div class="data-roadmap" data-animate="roadmap">
          <div class="roadmap-col">
            <p class="data-sub-label">已上线</p>
            <div class="roadmap-list">
              {roadmap.done.map((item) => (
                <div class="roadmap-item roadmap-done">
                  <Icon name="lucide:check" width={12} height={12} />
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="roadmap-col roadmap-col-planned">
            <p class="data-sub-label">计划中</p>
            <div class="roadmap-list">
              {roadmap.planned.map((item) => (
                <div class="roadmap-item roadmap-planned">
                  <Icon name="lucide:circle-dashed" width={10} height={10} />
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</div>
