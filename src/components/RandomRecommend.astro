---
/**
 * RandomRecommend — 首页中栏随机推荐卡片组件 (Walker 专属动态版)
 * 完美恢复动态随机读取真实博客的逻辑，同时视觉参考拟真黄色图书封面设计
 */
import { getCollection } from 'astro:content';
import { postSlug } from '@/lib/routes';

const allLogs = await getCollection('log', ({ data }) =>
  data.published && data.type === 'knowledge'
);
const allContent = allLogs.map(l => {
  const rawText = l.body ? l.body.replace(/<[^>]+>/g, '').replace(/[#*_\\`\\[\\]()>|]/g, '').trim() : '';
  const wordCount = rawText.length;
  return {
    title: l.data.title,
    type: l.data.type,
    slug: postSlug(l.id),
    tags: l.data.tags || [],
    wordCount,
  };
});

const random = allContent[Math.floor(Math.random() * allContent.length)];

// 根据类型映射精美的小配色和代号
const typeLabels: Record<string, { label: string; bg: string; text: string }> = {
  knowledge: { label: 'DOC', bg: '#e0f2f1', text: '#00796b' },
  project: { label: 'DEV', bg: '#e8eaf6', text: '#3f51b5' },
};
const currentType = random ? typeLabels[random.type] || { label: 'BOOK', bg: '#fffdeb', text: '#ed8936' } : { label: 'BOOK', bg: '#fffdeb', text: '#ed8936' };
---

<div class="panel-glass p-4 py-4.5 flex flex-col h-full rounded-[32px] pointer-events-auto" style="background: rgba(255, 255, 255, 0.45); border: 1.5px solid rgba(255, 255, 255, 0.85);">
  <!-- 卡片头部小标题 -->
  <div class="text-[11px] font-body text-parchment-dim/40 mb-3 px-1 font-bold">
    随机推荐
  </div>

  {random ? (
    <a href={random.slug} class="flex items-center gap-3.5 no-underline group/book cursor-pointer px-1">
      
      <!-- 左侧拟真黄色图书封面 (带有拟真书脊阴影与分类标识) -->
      <div class="w-[42px] h-[56px] rounded-md shrink-0 overflow-hidden bg-gradient-to-b from-[#fffdeb] to-[#fbd38d] border-[1.5px] border-white flex flex-col items-center justify-between p-1 shadow-[0_4px_12px_rgba(0,0,0,0.06)] relative group-hover/book:scale-105 transition-transform duration-300">
        <!-- 书脊拟真阴影 -->
        <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-black/10"></div>
        
        <!-- 卡通书籍主饰 (小灯泡/小齿轮) -->
        <div class="flex-1 flex items-center justify-center mt-1">
          <svg viewBox="0 0 100 100" class="w-7 h-7 text-orange-800/40">
            <circle cx="50" cy="50" r="30" fill="none" stroke="currentColor" stroke-width="6" />
            <path d="M 50 20 L 50 80 M 20 50 L 80 50" stroke="currentColor" stroke-width="6" />
          </svg>
        </div>
        <!-- 图书封面文字 (随文章分类动态呈现) -->
        <div class="w-full text-center text-[6px] font-bold text-orange-950/50 font-mono tracking-wider leading-none mb-0.5 shrink-0">
          {currentType.label}
        </div>
      </div>

      <!-- 右侧动态文本区 -->
      <div class="flex flex-col flex-1 min-w-0">
        <h3 class="text-parchment text-[13px] font-body font-bold tracking-wide leading-snug group-hover/book:text-[#35bfab] transition-colors truncate">
          {random.title}
        </h3>
        <p class="text-parchment-dim/50 text-[10.5px] font-body mt-1.5 flex items-center gap-2">
          <span class="px-2 py-0.5 rounded bg-black/[0.03]">{random.type.toUpperCase()}</span>
          <span class="text-parchment-dim/20">|</span>
          <span>约 {random.wordCount} 字</span>
        </p>
      </div>

    </a>
  ) : (
    <div class="text-parchment-dim text-xs py-4 text-center">暂无推荐内容</div>
  )}
</div>
