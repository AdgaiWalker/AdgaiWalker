---
import { getCollection } from 'astro:content';

const allLogs = await getCollection('log', ({ data }) => data.published);
const allIdeas = await getCollection('idea', ({ data }) => data.published);

const allContent = [
  ...allLogs.map(l => {
    const rawText = l.body ? l.body.replace(/<[^>]+>/g, '').replace(/[#*_\`\[\]()>|]/g, '').trim() : '';
    const wordCount = rawText.length;
    return {
      title: l.data.title,
      type: l.data.type,
      slug: `/log/${l.id}`,
      tags: l.data.tags,
      excerpt: rawText.slice(0, 80),
      wordCount,
    };
  }),
  ...allIdeas.map(i => {
    const rawText = i.data.scenario || '';
    const wordCount = rawText.length;
    return {
      title: i.data.title,
      type: 'idea' as const,
      slug: `/ideas`,
      tags: i.data.tags,
      excerpt: rawText.slice(0, 80),
      wordCount,
    };
  }),
];

const random = allContent[Math.floor(Math.random() * allContent.length)];
---

<div class="panel-glass p-6 flex flex-col h-full group rounded-[40px]" style="background: rgba(255,255,255,0.6);">
  <div class="text-[13px] font-body text-parchment/60 mb-4 px-1">
    随机推荐
  </div>

  {random ? (
    <a href={random.slug} class="flex items-center gap-4 no-underline px-1">
      <!-- 左侧图标框 -->
      <div class="w-14 h-14 rounded-2xl shrink-0 overflow-hidden bg-white/70 border border-white flex flex-col items-center justify-center relative shadow-sm">
        <iconify-icon icon="lucide:linux" width="22" height="22" class="text-brand"></iconify-icon>
      </div>
      
      <!-- 右侧信息 -->
      <div class="flex flex-col flex-1 min-w-0">
        <div class="text-parchment text-[14px] font-body font-medium leading-snug truncate group-hover:text-brand transition-colors">
          {random.title}
        </div>
        <div class="text-parchment-dim/60 text-[11px] font-body mt-2 flex items-center gap-2">
          <span>Views: {Math.floor(Math.random() * 200000).toLocaleString()}</span>
          <span>Marks: {Math.floor(Math.random() * 5000).toLocaleString()}</span>
        </div>
      </div>
    </a>
  ) : (
    <div class="text-parchment-dim text-xs">暂无推荐内容</div>
  )}
</div>
