---
import { getCollection } from 'astro:content';

const allConcepts = await getCollection('concepts', ({ data }) => data.status === 'active');
const allLogs = await getCollection('log', ({ data }) => data.published);

const layerConcepts = allConcepts
  .filter(c => c.data.layer !== undefined)
  .sort((a, b) => (a.data.layer ?? 0) - (b.data.layer ?? 0));

// Count related content for each concept
const contentCounts = new Map<string, number>();
for (const concept of layerConcepts) {
  const count = allLogs.filter(log =>
    log.data.concepts?.includes(concept.id)
  ).length;
  contentCounts.set(concept.id, count);
}

// Extract a one-line summary from body
function getSummary(body: string | undefined): string {
  if (!body) return '';
  return body
    .replace(/^---[\s\S]*?---/, '')
    .replace(/[#*_`\[\]()>|]/g, '')
    .trim()
    .split('\n')
    .find(l => l.trim().length > 10) || '';
}
---

<section class="max-w-5xl mx-auto px-6 py-20">
  <div class="flex items-center gap-4 mb-10">
    <h2 class="font-heading text-2xl text-parchment tracking-wide">五层逻辑</h2>
    <div class="flex-1 h-px bg-gradient-to-r from-gold/20 to-transparent"></div>
  </div>

  <!-- Horizontal flow (desktop) -->
  <div class="hidden md:flex items-stretch gap-0">
    {layerConcepts.map((concept, i) => {
      const isFirst = i === 0;
      const isLast = i === layerConcepts.length - 1;
      const summary = getSummary(concept.body);
      return (
        <div class="flex items-center flex-1">
          <a
            href={`/concept/${concept.id}`}
            class="block group no-underline flex-1"
          >
            <div class="flex flex-col items-center text-center px-4 py-6 rounded-xl transition-all duration-300 hover:bg-sea-mid/30">
              <div class="w-14 h-14 rounded-full border-2 border-gold/40 flex items-center justify-center text-gold/80 text-2xl font-heading group-hover:border-gold/70 group-hover:shadow-lg group-hover:shadow-gold/10 transition-all duration-300 mb-3">
                {concept.data.symbol}
              </div>
              <span class="text-gold/40 text-xs font-mono mb-1">0{concept.data.layer}</span>
              <h3 class="font-heading text-base text-parchment group-hover:text-gold transition-colors mb-2">
                {concept.data.title}
              </h3>
              <p class="text-parchment/40 text-sm leading-relaxed line-clamp-2">
                {summary}
              </p>
              {isLast && (
                <div class="mt-3 px-3 py-1.5 rounded-lg bg-gold/10 border border-gold/20">
                  <p class="text-gold/70 text-xs font-heading">验证：你的工作更少了吗？</p>
                </div>
              )}
            </div>
          </a>
          {!isLast && (
            <div class="flex items-center justify-center px-1 shrink-0">
              <svg class="w-8 h-4" viewBox="0 0 32 16" fill="none">
                <defs>
                  <linearGradient id={`arrow-grad-${i}`} x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="var(--color-gold-dim)" stop-opacity="0.4" />
                    <stop offset="100%" stop-color="var(--color-gold)" stop-opacity="0.8" />
                  </linearGradient>
                </defs>
                <line x1="0" y1="8" x2="24" y2="8" stroke={`url(#arrow-grad-${i})`} stroke-width="1.5" />
                <polyline points="22,4 28,8 22,12" fill="none" stroke="var(--color-gold)" stroke-opacity="0.7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          )}
        </div>
      );
    })}
  </div>

  <!-- Vertical flow (mobile) -->
  <div class="md:hidden">
    {layerConcepts.map((concept, i) => {
      const isFirst = i === 0;
      const isLast = i === layerConcepts.length - 1;
      const summary = getSummary(concept.body);
      return (
        <div>
          {!isFirst && (
            <div class="flex justify-center py-1">
              <svg class="w-4 h-8" viewBox="0 0 16 32" fill="none">
                <defs>
                  <linearGradient id={`arrow-grad-v-${i}`} x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="var(--color-gold-dim)" stop-opacity="0.4" />
                    <stop offset="100%" stop-color="var(--color-gold)" stop-opacity="0.8" />
                  </linearGradient>
                </defs>
                <line x1="8" y1="0" x2="8" y2="24" stroke={`url(#arrow-grad-v-${i})`} stroke-width="1.5" />
                <polyline points="4,22 8,28 12,22" fill="none" stroke="var(--color-gold)" stroke-opacity="0.7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          )}
          <a
            href={`/concept/${concept.id}`}
            class="block group no-underline"
          >
            <div class="flex items-start gap-4 py-5 px-4 rounded-xl transition-all duration-300 hover:bg-sea-mid/30">
              <div class="flex flex-col items-center shrink-0 pt-1">
                <div class="w-12 h-12 rounded-full border-2 border-gold/40 flex items-center justify-center text-gold/80 text-xl font-heading group-hover:border-gold/70 transition-all duration-300">
                  {concept.data.symbol}
                </div>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-gold/40 text-xs font-mono">0{concept.data.layer}</span>
                  <h3 class="font-heading text-base text-parchment group-hover:text-gold transition-colors">
                    {concept.data.title}
                  </h3>
                </div>
                <p class="text-parchment/40 text-sm leading-relaxed">{summary}</p>
                {isLast && (
                  <div class="mt-3 px-3 py-1.5 rounded-lg bg-gold/10 border border-gold/20 inline-block">
                    <p class="text-gold/70 text-xs font-heading">验证：你的工作更少了吗？</p>
                  </div>
                )}
              </div>
            </div>
          </a>
        </div>
      );
    })}
  </div>
</section>
