---
/**
 * WalkerProfile — 首页左栏个人资料卡 (精致风格)
 * 名字+在线状态+纯文字导航链接
 */
import { POSTS, DOCK } from '@/lib/routes';
---

<div class="panel-glass p-5 pt-7 flex flex-col h-full group">
  <!-- 名字与状态 -->
  <div class="flex items-center gap-3 mb-8 px-1">
    <h2 class="font-heading text-parchment text-[22px] font-semibold tracking-tight">Walker</h2>
    <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-brand/8 border border-brand/15">
      <span class="status-dot" style="width: 6px; height: 6px;"></span>
      <span class="text-[11px] text-brand font-body font-medium">开发中</span>
    </div>
  </div>

  <!-- 导航标题 -->
  <div class="text-[10px] font-mono text-parchment-dim/35 uppercase tracking-[0.2em] mb-3 px-1">
    NAVIGATION
  </div>

  <!-- 频道导航 -->
  <nav class="flex flex-col gap-0.5" aria-label="频道导航">
    <a href={POSTS} class="flex items-center gap-3 px-4 py-2.5 rounded-2xl bg-white/80 shadow-[0_1px_4px_rgba(0,0,0,0.03)] text-parchment transition-all text-[14px] font-body tracking-wide no-underline font-medium">
      <iconify-icon icon="lucide:pen-line" width="16" height="16" class="text-parchment/50"></iconify-icon>
      文章
    </a>
    <a href={DOCK} class="flex items-center gap-3 px-4 py-2.5 rounded-2xl text-parchment/55 hover:bg-white/50 hover:text-parchment transition-all text-[14px] font-body tracking-wide no-underline">
      <iconify-icon icon="lucide:package" width="16" height="16" class="text-parchment/35"></iconify-icon>
      装备库
    </a>
    <a href="/about-me" class="flex items-center gap-3 px-4 py-2.5 rounded-2xl text-parchment/55 hover:bg-white/50 hover:text-parchment transition-all text-[14px] font-body tracking-wide no-underline">
      <iconify-icon icon="lucide:user" width="16" height="16" class="text-parchment/35"></iconify-icon>
      关于
    </a>
  </nav>
</div>
