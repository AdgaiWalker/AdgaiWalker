---
/**
 * WalkerProfile — 首页个人身份卡
 * 只展示身份，不做导航。导航由 Bento 卡片承担。
 */
---

<div class="panel-glass p-5 pt-6 flex flex-col h-full group">
  <div class="flex items-center gap-3 mb-4 px-1">
    <h2 class="font-heading text-parchment text-[22px] font-semibold tracking-tight">Walker</h2>
    <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-brand/8 border border-brand/15">
      <span class="status-dot" style="width: 6px; height: 6px;"></span>
      <span class="text-[11px] text-brand font-body font-medium">探索中</span>
    </div>
  </div>

  <p class="text-parchment/45 text-[13px] font-body leading-relaxed px-1 mb-5">
    行过万里水路，记录每一次停靠。
  </p>

  <div class="mt-auto flex items-center gap-3 px-1">
    <a href="https://github.com/AdgaiWalker" target="_blank" class="text-parchment/30 hover:text-parchment transition-colors no-underline" aria-label="Github">
      <iconify-icon icon="mdi:github" width="16" height="16"></iconify-icon>
    </a>
    <a href="mailto:praxiswalker@gmail.com" class="text-parchment/30 hover:text-parchment transition-colors no-underline" aria-label="Email">
      <iconify-icon icon="lucide:mail" width="16" height="16"></iconify-icon>
    </a>
    <a href="/rss.xml" class="text-parchment/30 hover:text-parchment transition-colors no-underline" aria-label="RSS">
      <iconify-icon icon="lucide:rss" width="14" height="14"></iconify-icon>
    </a>
  </div>
</div>
