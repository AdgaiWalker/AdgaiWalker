---
/**
 * WalkerProfile — 首页左栏个人资料卡 (lvyovo 风格)
 * 只有名字+状态标签+纯文字导航链接
 */
---

<div class="panel-glass p-5 pt-7 flex flex-col h-full group">
  <!-- 名字与状态 -->
  <div class="flex items-baseline gap-2 mb-8 px-1">
    <h2 class="font-heading text-parchment text-[24px] font-semibold tracking-wide">秋知</h2>
    <span class="text-[12px] text-brand font-body font-medium">(开发中)</span>
  </div>

  <!-- 导航标题 -->
  <div class="text-[10px] font-mono text-parchment-dim/40 uppercase tracking-widest mb-4 px-1">
    NAL
  </div>

  <!-- 频道导航（纯文字，无图标） -->
  <nav class="flex flex-col gap-1" aria-label="频道导航">
    <a href="/log" class="block px-4 py-2.5 rounded-2xl text-parchment/60 hover:bg-white/40 hover:text-parchment transition-all text-[15px] font-body tracking-wider no-underline">
      近期文章
    </a>
    <a href="/works" class="block px-4 py-2.5 rounded-2xl text-parchment/60 hover:bg-white/40 hover:text-parchment transition-all text-[15px] font-body tracking-wider no-underline">
      我的项目
    </a>
    <a href="/about" class="block px-4 py-2.5 rounded-2xl text-parchment/60 hover:bg-white/40 hover:text-parchment transition-all text-[15px] font-body tracking-wider no-underline">
      关于网站
    </a>
    <a href="/dock" class="block px-4 py-2.5 rounded-2xl bg-white/90 shadow-sm text-parchment transition-all text-[15px] font-body tracking-wider no-underline font-medium">
      推荐分享
    </a>
    <a href="/compass" class="block px-4 py-2.5 rounded-2xl text-parchment/60 hover:bg-white/40 hover:text-parchment transition-all text-[15px] font-body tracking-wider no-underline">
      优秀博客
    </a>
  </nav>
</div>
