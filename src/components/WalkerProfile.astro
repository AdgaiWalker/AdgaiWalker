---
/**
 * WalkerProfile — 首页左栏个人资料卡 (Walker 专属精致高奢版)
 * 完美恢复 Walker 名字、真实菜单路由，并以高奢白底高亮视觉进行重塑
 */
import { Image } from 'astro:assets';
import avatar from '/public/images/秋知（我的头像）.jpg';
import { Icon } from 'astro-icon/components';
import { POSTS, TOOLS } from '@/lib/routes';
---

<div class="panel-glass p-5 py-6 flex flex-col h-full group rounded-[40px] pointer-events-auto" style="background: rgba(255, 255, 255, 0.48); border: 1.5px solid rgba(255, 255, 255, 0.85);">
  
  <!-- 用户头部信息：头像 + 名字 + 状态标签 -->
  <div class="flex items-center gap-3 mb-6 px-1">
    <!-- 圆形头像 -->
    <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-white/90 shadow-sm relative shrink-0">
      <Image src={avatar} alt="Walker" width={40} height={40} class="w-full h-full object-cover" />
    </div>
    <!-- 名字与开发中胶囊 -->
    <div class="flex flex-col">
      <div class="flex items-center gap-1.5">
        <span class="font-heading text-parchment text-[18px] font-semibold tracking-tight">Walker</span>
        <span class="text-[9px] text-[#35bfab] bg-[#e6fcf9] px-2 py-0.5 rounded-full font-body font-medium border border-[#35bfab]/20 shrink-0">开发中</span>
      </div>
    </div>
  </div>

  <!-- 分组小标题 -->
  <div class="text-[11px] font-body text-parchment-dim/40 mb-3 px-2">
    导航菜单
  </div>

  <!-- 频道导航 (融合极具现代美感的高亮状态，恢复 Walker 路由) -->
  <nav class="flex flex-col gap-1.5" aria-label="核心导航">
    
    <!-- 文章 (高亮状态：白底圆润背景 + 品牌高亮点) -->
    <a href={POSTS} class="flex items-center gap-3.5 px-4.5 py-2.5 rounded-full bg-white text-parchment shadow-[0_4px_16px_rgba(0,0,0,0.02)] border border-white/80 transition-all text-[13.5px] font-body no-underline font-semibold relative group/item">
      <span class="w-3.5 h-3.5 rounded-full bg-[#35bfab] flex items-center justify-center relative shrink-0">
        <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
      </span>
      <span>近期文章</span>
    </a>

    <!-- 工具 -->
    <a href={TOOLS} class="flex items-center gap-3.5 px-4.5 py-2.5 rounded-2xl text-parchment-dim/75 hover:bg-white/40 hover:text-parchment transition-all text-[13.5px] font-body no-underline">
      <Icon name="lucide:wrench" width={15} height={15} class="text-parchment-dim/40" />
      <span>工具</span>
    </a>

    <!-- 关于 -->
    <a href="/about" class="flex items-center gap-3.5 px-4.5 py-2.5 rounded-2xl text-parchment-dim/75 hover:bg-white/40 hover:text-parchment transition-all text-[13.5px] font-body no-underline">
      <Icon name="lucide:user" width={15} height={15} class="text-parchment-dim/40" />
      <span>关于我</span>
    </a>

  </nav>
</div>
