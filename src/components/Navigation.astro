---
import SearchModal from './SearchModal.astro';
import SidebarNav from './nav/SidebarNav.astro';
import MobileMenu from './nav/MobileMenu.astro';
import { ABOUT, CONTENT, TOOLS, IDEAS, PROJECTS, LEARN } from '@/shared/routes';
import type { NavGroup } from '@/types/nav';

const navGroups: NavGroup[] = [
  {
    items: [
      { label: '内容', href: CONTENT, icon: 'lucide:layout-grid', hint: 'Content' },
      { label: '关于', href: ABOUT, icon: 'lucide:user', hint: 'About' },
      { label: '支持', href: '/support', icon: 'lucide:heart', hint: 'Support' },
    ]
  },
  {
    title: '空间',
    items: [
      { label: '项目', href: PROJECTS, icon: 'lucide:folder-kanban', hint: 'Projects' },
      { label: '学习', href: LEARN, icon: 'lucide:rocket', hint: 'Learn' },
      { label: '资源', href: TOOLS, icon: 'lucide:bookmark', hint: 'Tools' },
      { label: '点子', href: IDEAS, icon: 'lucide:lightbulb', hint: 'Ideas' },
    ]
  },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const normalizedPath = currentPath.replace(/\/$/, '') || '/';
---

<SearchModal />

{isHome ? null : (
  <nav class="fixed top-0 left-0 z-50 transition-all duration-300 w-full lg:w-[260px] lg:bottom-0 lg:border-r lg:border-b-0 border-b border-[var(--color-nav-border)] bg-[var(--color-nav-bg)] backdrop-blur-md flex flex-col" id="main-nav">
    <MobileMenu />
    <SidebarNav navGroups={navGroups} normalizedPath={normalizedPath}>
      <slot />
    </SidebarNav>
  </nav>
)}

<script>
  import '../scripts/sidebar-state';

  let navAbort: AbortController | null = null;

  document.addEventListener('astro:page-load', () => {
    if (navAbort) navAbort.abort();
    navAbort = new AbortController();
    const { signal } = navAbort;

    // --- (a) 移动端菜单开关 ---
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');

    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
      menu?.classList.toggle('flex');
      menu?.classList.toggle('absolute');
      menu?.classList.toggle('top-full');
      menu?.classList.toggle('left-0');
      menu?.classList.toggle('right-0');
      menu?.classList.toggle('border-b');
      menu?.classList.toggle('border-gray-200');
      menu?.classList.toggle('shadow-lg');
      menu?.classList.toggle('max-h-[80vh]');
    }, { signal });

    // --- (b) 搜索框唤起 ---
    const desktopSearchBtn = document.getElementById('desktop-search-btn');
    const mobileSearchBtn = document.getElementById('mobile-search-btn');

    const triggerSearch = () => {
      document.dispatchEvent(new CustomEvent("walker:open-search"));
    };

    desktopSearchBtn?.addEventListener('click', triggerSearch, { signal });
    mobileSearchBtn?.addEventListener('click', triggerSearch, { signal });



    // --- (d) Liquid Sliding Indicator 液态滑动高亮指示器 ---
    const containers = document.querySelectorAll('.nav-links-container');
    const navTimers: ReturnType<typeof setTimeout>[] = [];
    signal.addEventListener('abort', () => {
      navTimers.forEach((timer) => clearTimeout(timer));
    }, { once: true });

    containers.forEach(container => {
      const indicator = container.querySelector('.nav-indicator') as HTMLElement | null;
      if (!indicator) return;

      const updateIndicator = (target: HTMLElement, animate = true) => {
        if (!animate) {
          indicator.style.transition = 'none';
        } else {
          indicator.style.transition = 'top 0.38s cubic-bezier(0.25, 1, 0.5, 1.2), height 0.38s cubic-bezier(0.25, 1, 0.5, 1.2), opacity 0.25s ease';
        }
        indicator.style.top = `${target.offsetTop}px`;
        indicator.style.height = `${target.offsetHeight}px`;
        indicator.style.left = `${target.offsetLeft}px`;
        indicator.style.width = `${target.offsetWidth}px`;
        indicator.style.opacity = '1';
      };

      const activeLink = container.querySelector('.nav-link-active') as HTMLElement | null;
      if (activeLink) {
        const timer = setTimeout(() => {
          if (activeLink) updateIndicator(activeLink, false);
        }, 30);
        navTimers.push(timer);
      }

      const links = container.querySelectorAll('.nav-link');
      links.forEach(link => {
        link.addEventListener('mouseenter', () => {
          updateIndicator(link as HTMLElement, true);
        }, { signal });
      });

      container.addEventListener('mouseleave', () => {
        const active = container.querySelector('.nav-link-active') as HTMLElement | null;
        if (active) {
          updateIndicator(active, true);
        } else {
          indicator.style.opacity = '0';
        }
      }, { signal });
    });
  });

  document.addEventListener('astro:before-swap', () => {
    if (navAbort) { navAbort.abort(); navAbort = null; }
  });
</script>

<style>
  .home-nav-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 32px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    color: rgba(42, 59, 62, 0.7);
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--font-body, system-ui);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.04);
  }

  .home-nav-pill:hover {
    background: rgba(255, 255, 255, 0.85);
    color: rgba(42, 59, 62, 0.95);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .home-nav-icon-only {
    padding: 0;
    width: 32px;
    justify-content: center;
  }

  :global(body.theme-aurora) .home-nav-pill,
  :global(body.theme-sunset) .home-nav-pill,
  :global(body.theme-mint) .home-nav-pill {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.75);
  }

  :global(body.theme-aurora) .home-nav-pill:hover,
  :global(body.theme-sunset) .home-nav-pill:hover,
  :global(body.theme-mint) .home-nav-pill:hover {
    background: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.95);
  }

  @media (max-width: 480px) {
    .home-nav-pill span { display: none; }
    .home-nav-pill { padding: 0; width: 32px; justify-content: center; }
  }
</style>
