---
import SearchModal from './SearchModal.astro';

interface NavItem {
  label: string;
  href: string;
  icon: string;
  hint?: string;
}

interface NavGroup {
  title?: string;
  items: NavItem[];
}

const navGroups: NavGroup[] = [
  {
    title: '写作',
    items: [
      { label: 'AI 探索', href: '/ai', icon: 'lucide:brain', hint: 'Posts' },
      { label: '生活日志', href: '/life', icon: 'lucide:leaf', hint: 'Life' },
    ]
  },
  {
    title: 'AI 探索',
    items: [
      { label: '学习笔记', href: '/ai/learn', icon: 'lucide:book-open', hint: 'Learn' },
      { label: '工具箱', href: '/ai/toolkit', icon: 'lucide:wrench', hint: 'Tools' },
      { label: '信息源', href: '/ai/sources', icon: 'lucide:radio', hint: 'Sources' },
      { label: '想法', href: '/ai/ideas', icon: 'lucide:lightbulb', hint: 'Ideas' },
    ]
  },
  {
    title: '收藏',
    items: [
      { label: '装备库', href: '/dock', icon: 'lucide:package', hint: 'Resources' },
    ]
  },
  {
    items: [
      { label: '关于', href: '/about-me', icon: 'lucide:user', hint: 'About' },
    ]
  },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const normalizedPath = currentPath.replace(/\/$/, '') || '/';
const aiSubPaths = ['/ai/learn', '/ai/toolkit', '/ai/sources', '/ai/ideas'];

const isActiveHref = (href: string) => {
  if (href === '/ai') {
    return normalizedPath === '/ai' || (
      normalizedPath.startsWith('/ai/') &&
      !aiSubPaths.some(p => normalizedPath === p || normalizedPath.startsWith(`${p}/`))
    );
  }
  if (href === '/life') {
    return normalizedPath === '/life' || normalizedPath.startsWith('/life/');
  }
  return normalizedPath === href || normalizedPath.startsWith(`${href}/`);
};
---

<div class="hidden">
  <SearchModal />
</div>

{isHome ? (
  <nav class="fixed top-0 left-0 right-0 z-50 bg-transparent transition-all duration-300" id="main-nav">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-3.5 flex items-center justify-between">
      <a href="/" class="flex items-center font-heading text-xl text-parchment hover:text-brand transition-colors no-underline font-bold">
        Walker
      </a>
      <div class="flex items-center">
      </div>
    </div>
  </nav>
) : (
  <nav class="fixed top-0 left-0 z-50 transition-all duration-300 w-full lg:w-[260px] lg:bottom-0 lg:border-r lg:border-b-0 border-b border-[rgba(42,59,62,0.08)] bg-[#fbfbfa] flex flex-col" id="main-nav">
    {/* 移动端顶部栏 */}
    <div class="flex lg:hidden items-center justify-between px-4 py-3 w-full bg-[#fbfbfa]/95 backdrop-blur-md">
      <a href="/" class="flex items-center font-heading text-lg font-bold text-parchment hover:text-brand transition-colors no-underline">
        Walker
      </a>
      <div class="flex items-center gap-3">
        <button
          class="text-parchment-dim hover:text-parchment p-1.5 transition-colors bg-transparent border-none cursor-pointer"
          id="mobile-search-btn"
          aria-label="搜索"
        >
          <iconify-icon icon="lucide:search" width="20" height="20"></iconify-icon>
        </button>
        <button
          class="text-parchment-dim hover:text-parchment p-1.5 transition-colors bg-transparent border-none cursor-pointer"
          id="menu-toggle"
          aria-label="打开菜单"
        >
          <iconify-icon icon="lucide:menu" width="22" height="22"></iconify-icon>
        </button>
      </div>
    </div>

    {/* 侧边栏/移动端菜单内容 */}
    <div class="hidden lg:flex flex-col flex-1 w-full overflow-y-auto custom-scrollbar bg-[#fbfbfa]" id="mobile-menu">

      {/* 桌面端头部 */}
      <div class="hidden lg:flex flex-col px-5 pt-7 pb-5">
        <a href="/" class="nav-brand no-underline" title="返回首页">
          <span class="nav-brand-mark">W</span>
          <span class="nav-brand-copy">
            <span class="nav-brand-name">Walker</span>
            <span class="nav-brand-tagline">行过万里水路</span>
          </span>
        </a>
      </div>

      {/* 分割线 */}
      <div class="hidden lg:block mx-5 border-b border-[rgba(42,59,62,0.06)] mb-5"></div>

      {/* 搜索框 */}
      <div class="hidden lg:block px-4 mb-1">
        <button id="desktop-search-btn" class="nav-search group">
          <div class="flex items-center gap-2.5 text-[13px]">
            <iconify-icon icon="lucide:search" width="16" height="16" class="text-gray-400 group-hover:text-gray-500 transition-colors"></iconify-icon>
            <span class="font-body text-gray-500">搜索</span>
          </div>
          <kbd class="text-[10px] font-sans px-1.5 py-0.5 rounded bg-gray-50 border border-gray-100 text-gray-400 font-medium">⌘K</kbd>
        </button>
      </div>

      {/* 导航列表 */}
      <div class="flex-1 px-3 pb-4">
        <div class="flex flex-col gap-5">
          {navGroups.map((group) => (
            <div class="flex flex-col">
              {group.title && (
                <div class="nav-section-title">{group.title}</div>
              )}
              <div class="flex flex-col gap-0.5">
                {group.items.map(item => {
                  const isActive = isActiveHref(item.href);
                  return (
                    <a
                      href={item.href}
                      title={item.label}
                      class:list={[
                        'nav-link group',
                        isActive
                          ? 'nav-link-active'
                          : 'nav-link-idle',
                      ]}
                    >
                      <iconify-icon icon={item.icon} width="18" height="18" class="nav-link-icon"></iconify-icon>
                      <span class="nav-link-main">{item.label}</span>
                      {item.hint && <span class="nav-link-hint">{item.hint}</span>}
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </div>

        {/* 文章列表扩展插槽 */}
        <div class="nav-extension mt-4">
          <slot />
        </div>
      </div>

      {/* 侧边栏折叠按钮 */}
      <div class="hidden lg:flex items-center justify-end px-4 py-3 opacity-0 hover:opacity-100 transition-opacity absolute bottom-[72px] right-0">
        <button
          class="flex items-center justify-center w-8 h-8 rounded-lg text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition-all bg-transparent border-none cursor-pointer"
          id="sidebar-collapse-btn"
          aria-label="折叠侧边栏"
          title="折叠侧边栏 ( [ )"
        >
          <iconify-icon icon="lucide:panel-left-close" width="16" height="16"></iconify-icon>
        </button>
      </div>

      {/* 底部社交栏 */}
      <div class="hidden lg:flex items-center justify-between px-5 py-5 mt-auto border-t border-[rgba(42,59,62,0.08)] text-gray-400">
        <div class="flex items-center gap-3.5">
          <a href="https://github.com/AdgaiWalker" target="_blank" class="hover:text-gray-700 transition-colors" aria-label="Github"><iconify-icon icon="mdi:github" width="18" height="18"></iconify-icon></a>
          <a href="mailto:praxiswalker@gmail.com" class="hover:text-gray-700 transition-colors" aria-label="Email"><iconify-icon icon="lucide:mail" width="18" height="18"></iconify-icon></a>
          <a href="/rss.xml" class="hover:text-gray-700 transition-colors" aria-label="RSS"><iconify-icon icon="lucide:rss" width="16" height="16"></iconify-icon></a>
        </div>
        <button class="hover:text-gray-700 transition-colors bg-transparent border-none cursor-pointer flex items-center justify-center" aria-label="Theme toggle">
          <iconify-icon icon="lucide:sun" width="18" height="18"></iconify-icon>
        </button>
      </div>
    </div>
  </nav>
)}

<script>
  import '../scripts/sidebar-state';

  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');

    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
      menu?.classList.toggle('flex');
      menu?.classList.toggle('absolute');
      menu?.classList.toggle('top-full');
      menu?.classList.toggle('left-0');
      menu?.classList.toggle('right-0');
      menu?.classList.toggle('border-b');
      menu?.classList.toggle('border-gray-200');
      menu?.classList.toggle('shadow-lg');
      menu?.classList.toggle('max-h-[80vh]');
    });

    const desktopSearchBtn = document.getElementById('desktop-search-btn');
    const mobileSearchBtn = document.getElementById('mobile-search-btn');

    const triggerSearch = () => {
      document.dispatchEvent(new KeyboardEvent('keydown', { metaKey: true, key: 'k' }));
    };

    desktopSearchBtn?.addEventListener('click', triggerSearch);
    mobileSearchBtn?.addEventListener('click', triggerSearch);
  });
</script>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.05);
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 0, 0, 0.1);
  }

  /* ===== Brand ===== */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #1a2325;
  }

  .nav-brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: 1px solid rgba(42, 59, 62, 0.08);
    background: #fff;
    color: #35bfab;
    font-family: 'Sora', 'PingFang SC', system-ui, sans-serif;
    font-weight: 700;
    box-shadow: 0 10px 26px rgba(25, 38, 40, 0.05);
  }

  .nav-brand-copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .nav-brand-name {
    font-family: 'Sora', 'PingFang SC', system-ui, sans-serif;
    font-size: 0.98rem;
    font-weight: 600;
    color: #1a2325;
    line-height: 1.1;
  }

  .nav-brand-tagline {
    margin-top: 0.18rem;
    font-size: 0.68rem;
    color: rgba(42, 59, 62, 0.38);
    letter-spacing: 0.04em;
  }

  /* ===== Search ===== */
  .nav-search {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 0.8rem;
    border-radius: 10px;
    border: 1px solid rgba(42, 59, 62, 0.08);
    background: rgba(255, 255, 255, 0.82);
    color: rgba(42, 59, 62, 0.52);
    transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    cursor: pointer;
  }

  .nav-search:hover {
    border-color: rgba(53, 191, 171, 0.24);
    background: #fff;
    box-shadow: 0 10px 28px rgba(25, 38, 40, 0.05);
  }

  /* ===== Section Titles ===== */
  .nav-section-title {
    padding: 0 0.7rem 0.35rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(42, 59, 62, 0.32);
  }

  /* ===== Nav Links ===== */
  .nav-link {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.7rem;
    min-height: 42px;
    padding: 0.5rem 0.75rem;
    border-radius: 10px;
    border: 1px solid transparent;
    font-size: 0.86rem;
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  .nav-link-idle {
    color: rgba(42, 59, 62, 0.6);
  }

  .nav-link-idle:hover {
    color: #1a2325;
    background: rgba(42, 59, 62, 0.04);
  }

  .nav-link-active {
    color: #218f80;
    background: rgba(53, 191, 171, 0.08);
    border-color: rgba(53, 191, 171, 0.12);
    font-weight: 600;
  }

  .nav-link-icon {
    color: rgba(42, 59, 62, 0.34);
    transition: color 0.18s ease;
  }

  .nav-link-active .nav-link-icon,
  .nav-link:hover .nav-link-icon {
    color: #35bfab;
  }

  .nav-link-main {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .nav-link-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: rgba(42, 59, 62, 0.26);
  }

  /* ===== 侧边栏折叠样式适配 ===== */
  @media (min-width: 1024px) {
    #main-nav {
      width: var(--walker-nav-width, 260px) !important;
    }

    .sidebar-collapsed-nav {
      width: 68px !important;
    }

    .sidebar-collapsed-nav .nav-brand {
      justify-content: center;
    }

    .sidebar-collapsed-nav .nav-brand-copy,
    .sidebar-collapsed-nav .nav-section-title,
    .sidebar-collapsed-nav .nav-link-main,
    .sidebar-collapsed-nav .nav-link-hint,
    .sidebar-collapsed-nav .nav-extension {
      display: none !important;
    }

    .sidebar-collapsed-nav [id="desktop-search-btn"] {
      padding: 0.6rem !important;
      justify-content: center;
      border-color: transparent !important;
      background: transparent !important;
      box-shadow: none !important;
    }

    .sidebar-collapsed-nav [id="desktop-search-btn"]:hover {
      background: rgba(0,0,0,0.05) !important;
    }

    .sidebar-collapsed-nav [id="desktop-search-btn"] span,
    .sidebar-collapsed-nav [id="desktop-search-btn"] kbd {
      display: none;
    }

    .sidebar-collapsed-nav .nav-link {
      grid-template-columns: 1fr;
      justify-content: center;
      justify-items: center;
      padding-left: 0.55rem !important;
      padding-right: 0.55rem !important;
    }

    .sidebar-collapsed-nav .nav-link iconify-icon {
      margin: 0;
    }

    .sidebar-collapsed-nav .mt-auto {
      display: none !important;
    }

    .sidebar-collapsed-nav [id="sidebar-collapse-btn"] {
      opacity: 1 !important;
    }
  }

  /* ===== 移动端 ===== */
  @media (max-width: 1023px) {
    #mobile-menu.flex {
      position: fixed;
      top: 52px;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 49;
      padding-bottom: 2rem;
      animation: slideDown 0.2s ease-out;
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>
