---
/**
 * RecentTraces — 精致最新文章卡片 (支持多篇)
 */
import { POSTS, postSlug } from '@/lib/routes';

interface LogEntry {
  id: string;
  data: {
    title: string;
    date: Date;
    tags: string[];
    type: 'article' | 'photo' | 'thought' | 'project' | 'dialogue' | 'idea';
    category: 'ai' | 'life';
    cover?: string;
  };
  body?: string;
}

interface Props {
  logs: LogEntry[];
}

const { logs } = Astro.props;

const formatDate = (d: Date) => {
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${month}/${day}`;
};
---

<div class="panel-glass p-5 flex flex-col h-full group" style="background: rgba(255,255,255,0.35);">
  <!-- 标题行 -->
  <div class="flex items-center justify-between mb-3 px-0.5">
    <div class="flex items-center gap-2">
      <iconify-icon icon="lucide:file-text" width="13" height="13" class="text-parchment/30"></iconify-icon>
      <span class="text-[11px] font-mono text-parchment/30 uppercase tracking-[0.15em]">Recent</span>
    </div>
    <a href={POSTS} class="text-[11px] font-mono text-brand/40 hover:text-brand no-underline tracking-wider transition-colors">All →</a>
  </div>

  <!-- 文章列表 -->
  <div class="flex flex-col gap-1">
    {logs.slice(0, 3).map((log) => (
      <a href={postSlug(log.id)} class="flex items-center gap-3 no-underline py-2 px-1 rounded-xl hover:bg-white/30 transition-all group/item">
        <span class="text-[11px] font-mono text-parchment/25 w-10 shrink-0">{formatDate(log.data.date)}</span>
        <span class="text-parchment/65 text-[13px] font-body leading-snug truncate flex-1 group-hover/item:text-parchment transition-colors">
          {log.data.title}
        </span>
      </a>
    ))}
  </div>
</div>
