---
/**
 * RecentTraces — lvyovo 风格最新文章卡片
 */
import { FORMAT_LABELS } from '../utils/formats';

interface LogEntry {
  id: string;
  data: {
    title: string;
    date: Date;
    tags: string[];
    type: 'article' | 'photo' | 'thought' | 'project' | 'dialogue';
    domain: string;
    cover?: string;
  };
  body?: string;
}

interface Props {
  logs: LogEntry[];
}

const { logs } = Astro.props;
const latest = logs[0];

const formatDate = (d: Date) =>
  `${d.getFullYear()}/${d.getMonth() + 1}/${d.getDate()}`;

let excerpt = '';
if (latest && latest.body) {
  excerpt = latest.body
    .replace(/<[^>]+>/g, '')
    .replace(/[#*_\`\[\]()>|]/g, '')
    .trim()
    .slice(0, 60);
}
---

<div class="panel-glass p-5 flex flex-col h-full group" style="background: rgba(255,255,255,0.35);">
  {latest ? (
    <a href={`/log/${latest.id}`} class="flex flex-col gap-2 no-underline">
      <!-- 标题 -->
      <div class="text-parchment text-[14px] font-body font-medium leading-snug line-clamp-2 group-hover:text-brand transition-colors">
        {latest.data.title}
      </div>
      <!-- 摘要 -->
      <div class="text-parchment-dim text-[12px] font-body line-clamp-2 leading-relaxed">
        {excerpt || "暂无描述"}
      </div>
      <!-- 日期 -->
      <div class="text-parchment-dim/60 text-[11px] font-body mt-1">
        {formatDate(latest.data.date)}
      </div>
    </a>
  ) : (
    <div class="text-parchment-dim text-xs">暂无文章</div>
  )}
</div>
