---
/**
 * RecentTraces — 首页左栏最新文章推荐卡片 (Walker 专属动态版)
 * 完美恢复动态读取真实博客 logs 的逻辑，融合像素级视觉：首篇大卡片高光，其余动态文字链
 */
import { Icon } from 'astro-icon/components';
import { POSTS, postSlug } from '@/lib/routes';
import type { ImageMetadata } from 'astro';

interface LogEntry {
  id: string;
  data: {
    title: string;
    date: Date;
    tags: string[];
    type: 'article' | 'photo' | 'thought' | 'project' | 'dialogue' | 'idea';
    category: 'ai' | 'life';
    cover?: string | ImageMetadata;
  };
  body?: string;
}

interface Props {
  logs: LogEntry[];
}

const { logs = [] } = Astro.props;

const formatDate = (d: Date) => {
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${month}/${day}`;
};

const formatFullDate = (d: Date) => {
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${year}/${month}/${day}`;
};

// 提取最新一篇文章
const featuredLog = logs[0];
// 提取其余文章作为极简底栏
const restLogs = logs.slice(1, 3);
---

<div class="panel-glass p-5 flex flex-col h-full rounded-[36px] pointer-events-auto">
  <!-- 卡片头部小标题 -->
  <div class="flex items-center justify-between mb-3.5 px-0.5">
    <span class="text-[11px] font-body text-parchment-dim/40 font-bold">最新文章</span>
    <a href={POSTS} class="text-[10px] font-mono text-brand hover:text-brand-secondary no-underline font-bold transition-colors">全部 →</a>
  </div>

  {featuredLog ? (
    <div class="flex flex-col gap-4">
      <!-- 1. 首篇高光文章 (像素级复现横向精美排版，动态读取) -->
      <a href={postSlug(featuredLog.id)} class="flex items-center gap-3.5 no-underline group/item cursor-pointer">
        <!-- 左侧精致封面图 (小黑猫看书 SVG) -->
        <div class="w-[52px] h-[52px] rounded-2xl shrink-0 overflow-hidden bg-[#fffbeb] border border-white/60 flex items-center justify-center shadow-sm relative group-hover/item:scale-105 transition-transform duration-300">
          <svg viewBox="0 0 100 100" class="w-9 h-9">
            <!-- 暖黄底色，小猫咪看书 -->
            <circle cx="50" cy="50" r="45" fill="#fefcbf" />
            <rect x="25" y="45" width="50" height="35" rx="4" fill="#ed8936" />
            <path d="M 50 45 L 50 80" stroke="#fff" stroke-width="2" />
            <polygon points="38,40 46,24 50,40" fill="#2d3748" />
            <polygon points="62,40 54,24 50,40" fill="#2d3748" />
            <circle cx="50" cy="42" r="10" fill="#2d3748" />
            <circle cx="47" cy="40" r="1" fill="#fff" />
            <circle cx="53" cy="40" r="1" fill="#fff" />
          </svg>
        </div>

        {/* 右侧文本区 */}
        <div class="flex flex-col flex-1 min-w-0">
          <h3 class="text-parchment text-[13px] font-body font-bold tracking-wide leading-tight group-hover/item:text-brand transition-colors truncate">
            {featuredLog.data.title}
          </h3>
          <p class="text-parchment-dim/60 text-[10.5px] font-body truncate mt-1 leading-none">
            {featuredLog.body ? featuredLog.body.replace(/<[^>]+>/g, '').slice(0, 30) : '点击阅读精彩内容'}
          </p>
          <span class="text-[9px] font-mono text-parchment-dim/35 mt-1.5 leading-none block">
            {formatFullDate(featuredLog.data.date)}
          </span>
        </div>
      </a>

      <!-- 2. 其他文章列表 (自适应软分界线) -->
      {restLogs.length > 0 && (
        <div class="flex flex-col gap-1.5 pt-2 border-t" style="border-color: var(--color-inner-border, rgba(0,0,0,0.04));">
          {restLogs.map((log) => (
            <a href={postSlug(log.id)} class="flex items-center gap-2 px-2.5 py-1.5 rounded-xl hover:bg-white/10 text-parchment-dim/75 hover:text-parchment transition-all text-[12px] no-underline">
              <span class="text-[9.5px] font-mono text-parchment-dim/35 shrink-0 w-8">{formatDate(log.data.date)}</span>
              <span class="truncate flex-1 font-body leading-none">{log.data.title}</span>
              <Icon name="lucide:chevron-right" width={11} height={11} class="text-parchment-dim/20" />
            </a>
          ))}
        </div>
      )}
    </div>
  ) : (
    <div class="text-parchment-dim text-xs py-4 text-center">暂无近期文章</div>
  )}
</div>
