---
/**
 * DockShowcase — homepage tools showcase.
 */
import type { CollectionEntry } from 'astro:content';
import { TOOLS } from '@/lib/routes';
import { Icon } from 'astro-icon/components';

interface Props {
  entries: CollectionEntry<'log'>[];
}

const { entries } = Astro.props;

const featured = entries
  .filter(entry => entry.data.type === 'tool' && entry.data.rating)
  .sort((a, b) => (b.data.rating ?? 0) - (a.data.rating ?? 0))
  .slice(0, 3);
---

<a href={TOOLS} class="block panel-glass p-6 group h-full no-underline transition-all hover:shadow-xl hover:-translate-y-1" style="background: rgba(255, 255, 255, 0.55);">
  <div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-2.5">
      <div class="w-9 h-9 rounded-xl bg-brand/10 border border-brand/15 flex items-center justify-center">
        <Icon name="lucide:wrench" width={18} height={18} class="text-brand" />
      </div>
      <div>
        <div class="text-parchment text-[15px] font-heading font-semibold">资源</div>
        <div class="text-parchment/35 text-[11px] font-mono tracking-wider">RESOURCES</div>
      </div>
    </div>
    <span class="text-parchment/25 text-[12px] font-mono">{entries.length} 件</span>
  </div>

  <div class="flex flex-col gap-2.5">
    {featured.map(entry => (
      <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-white/50 group-hover:bg-white/70 transition-all">
        <Icon name={entry.data.type === 'idea' ? 'lucide:lightbulb' : 'lucide:wrench'} width={16} height={16} class="text-brand/60 shrink-0" />
        <div class="flex-1 min-w-0">
          <div class="text-parchment/75 text-[13px] font-body truncate">{entry.data.title}</div>
          {entry.data.summary && (
            <div class="text-parchment/35 text-[11px] font-body truncate mt-0.5">{entry.data.summary}</div>
          )}
        </div>
        {entry.data.rating && (
          <div class="flex gap-0.5 shrink-0">
            {Array.from({ length: 5 }).map((_, i) => (
              <Icon name="lucide:star" width={10} height={10} class={i < entry.data.rating! ? 'text-amber-400/60' : 'text-parchment/[0.06]'} />
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  <div class="flex items-center justify-between mt-5 pt-4 border-t border-parchment/[0.06]">
    <span class="text-parchment/40 text-[12px] font-body">我日常使用的资源、点子和社群</span>
    <span class="text-brand/50 group-hover:text-brand transition-colors flex items-center gap-1 text-[12px] font-body font-medium">
      浏览全部
      <Icon name="lucide:arrow-right" width={14} height={14} />
    </span>
  </div>
</a>
