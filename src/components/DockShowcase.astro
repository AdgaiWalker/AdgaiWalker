---
/**
 * DockShowcase — 首页装备库展示卡
 * 作为首页的核心钩子，展示精选工具，引导读者进入装备库。
 */
import { getCollection } from 'astro:content';
import { DOCK } from '@/lib/routes';

const items = (await getCollection('dockItem', ({ data }) => data.published))
  .sort((a, b) => (b.data.rating ?? 0) - (a.data.rating ?? 0));

const featured = items.slice(0, 3);

const categoryIcons: Record<string, string> = {
  tool: 'lucide:wrench',
  skill: 'lucide:wand-2',
  'info-source': 'lucide:radio',
  community: 'lucide:users',
};
---

<a href={DOCK} class="block panel-glass p-6 group h-full no-underline transition-all hover:shadow-xl hover:-translate-y-1" style="background: rgba(255, 255, 255, 0.55);">
  {/* 头部 */}
  <div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-2.5">
      <div class="w-9 h-9 rounded-xl bg-brand/10 border border-brand/15 flex items-center justify-center">
        <iconify-icon icon="lucide:package" width="18" height="18" class="text-brand"></iconify-icon>
      </div>
      <div>
        <div class="text-parchment text-[15px] font-heading font-semibold">AI探索</div>
        <div class="text-parchment/35 text-[11px] font-mono tracking-wider">RESOURCES</div>
      </div>
    </div>
    <span class="text-parchment/25 text-[12px] font-mono">{items.length} 件</span>
  </div>

  {/* 精选条目 */}
  <div class="flex flex-col gap-2.5">
    {featured.map(item => (
      <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-white/50 group-hover:bg-white/70 transition-all">
        <iconify-icon icon={categoryIcons[item.data.category] || 'lucide:box'} width="16" height="16" class="text-brand/60 shrink-0"></iconify-icon>
        <div class="flex-1 min-w-0">
          <div class="text-parchment/75 text-[13px] font-body truncate">{item.data.name}</div>
        </div>
        {item.data.rating && (
          <div class="flex gap-0.5 shrink-0">
            {Array.from({ length: 5 }).map((_, i) => (
              <iconify-icon icon="lucide:star" width="10" height="10" class={i < item.data.rating! ? 'text-amber-400/60' : 'text-parchment/[0.06]'} />
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  {/* 底部引导 */}
  <div class="flex items-center justify-between mt-5 pt-4 border-t border-parchment/[0.06]">
    <span class="text-parchment/40 text-[12px] font-body">我日常使用的工具、信息源和社群</span>
    <span class="text-brand/50 group-hover:text-brand transition-colors flex items-center gap-1 text-[12px] font-body font-medium">
      浏览全部
      <iconify-icon icon="lucide:arrow-right" width="14" height="14"></iconify-icon>
    </span>
  </div>
</a>
