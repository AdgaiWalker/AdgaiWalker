---
import type { BlockWidth } from '@/knowledge/block-types';

interface Props {
  role: 'human' | 'ai';
  name?: string;
  width?: BlockWidth;
}

const { role, name, width = 'narrow' } = Astro.props;
const isHuman = role === 'human';
const displayName = name || (isHuman ? '你' : 'AI');
---
<div class:list={['cs-block', `cs-block--${width}`, 'not-prose']}>
  <div class:list={['cs-dialogue flex gap-3 my-3', isHuman ? 'flex-row' : 'flex-row-reverse']}>
    <div class:list={['cs-avatar shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold', isHuman ? 'bg-brand/10 text-brand' : 'bg-purple-500/10 text-purple-400']}>
      {isHuman ? 'H' : 'A'}
    </div>
    <div class:list={['cs-bubble rounded-2xl px-4 py-3 max-w-[85%]', isHuman ? 'bg-white/[0.06]' : 'bg-purple-500/8']}>
      <div class:list={['cs-name text-xs font-bold mb-1', isHuman ? 'text-parchment/50' : 'text-purple-400/70']}>
        {displayName}
      </div>
      <div class="cs-dialogue-body text-sm text-parchment/80 leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>
