---
import type { BlockWidth } from '@/knowledge/block-types';

/**
 * BlockStep —— 编号步骤块（P3-B）。
 *
 * 把教程/流程中的一个步骤渲染为带序号标记的结构化块，序号由内容显式给定
 * （"1"、"一"、"Step 1" 均可），避免自动计数与多实例/SSR 顺序耦合。
 *
 * 遵守宽度契约：cs-block--full | normal | narrow。
 */
interface Props {
  /** 步骤序号/标签，由内容显式提供 */
  n: string;
  title?: string;
  width?: BlockWidth;
}

const { n, title, width = 'normal' } = Astro.props;
---

<div class:list={['cs-block', `cs-block--${width}`, 'not-prose']}>
  <div class="cs-step panel-glass">
    <div class="cs-step-marker" aria-hidden="true">{n}</div>
    <div class="cs-step-body">
      {title && <div class="cs-step-title">{title}</div>}
      <div class="cs-step-content text-parchment/80 text-sm leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>

<style>
  .cs-step {
    position: relative;
    display: flex;
    gap: 1rem;
    padding: 1rem 1.1rem;
    margin: 1.25rem 0;
    border-radius: 0.5rem;
    overflow: hidden;
    break-inside: avoid;
  }
  /* 强调彩条用 ::before，绕开 .panel-glass 的 border !important（站级债） */
  .cs-step::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: rgb(161 98 7 / 55%);
  }
  .cs-step-marker {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgb(161 98 7 / 18%);
    color: rgb(161 98 7);
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1;
  }
  .cs-step-body {
    min-width: 0;
    flex: 1;
    padding-top: 0.05rem;
  }
  .cs-step-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-parchment);
    margin-bottom: 0.25rem;
  }
  .cs-step-content :global(p:last-child) { margin-bottom: 0; }
  .cs-step-content :global(p:first-child) { margin-top: 0; }
</style>
