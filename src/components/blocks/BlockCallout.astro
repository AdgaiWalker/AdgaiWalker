---
import { Icon } from 'astro-icon/components';
import type { BlockWidth } from '@/knowledge/block-types';

/**
 * BlockCallout —— 强调/提示/警告/重要 标注块（P3-B）。
 *
 * 用于在正文中突出一条读者必须注意的信息：note（补充说明）、tip（建议）、
 * warning（注意/坑）、important（关键）。变体只改变图标与强调色，文本仍走
 * 主题 parchment，保证跨主题可读。
 *
 * 变体色用 <style> 里的 .cs-callout--${accent} 后代选择器显式定义
 * （不动态拼接 tailwind 类名，避免 JIT 扫描漏掉）。
 *
 * 遵守宽度契约：cs-block--full | normal | narrow。
 */
type CalloutVariant = 'note' | 'tip' | 'warning' | 'important';

interface VariantStyle {
  icon: string;
  accent: 'sky' | 'emerald' | 'amber' | 'rose';
  label: string;
}

const VARIANT_STYLES: Record<CalloutVariant, VariantStyle> = {
  note: { icon: 'lucide:info', accent: 'sky', label: '说明' },
  tip: { icon: 'lucide:lightbulb', accent: 'emerald', label: '建议' },
  warning: { icon: 'lucide:triangle-alert', accent: 'amber', label: '注意' },
  important: { icon: 'lucide:octagon-alert', accent: 'rose', label: '关键' },
};

interface Props {
  variant?: CalloutVariant;
  title?: string;
  width?: BlockWidth;
}

const { variant = 'note', title, width = 'normal' } = Astro.props;
const style = VARIANT_STYLES[variant] ?? VARIANT_STYLES.note;
---

<div class:list={['cs-block', `cs-block--${width}`, 'not-prose']}>
  <aside
    class:list={['cs-callout', 'panel-glass', `cs-callout--${style.accent}`]}
    aria-label={title ?? style.label}
    role="note"
  >
    <div class="cs-callout-icon">
      <Icon name={style.icon} width={18} height={18} />
    </div>
    <div class="cs-callout-body">
      <div class="cs-callout-head">
        <span class="cs-callout-label">{style.label}</span>
        {title && <span class="cs-callout-title">{title}</span>}
      </div>
      <div class="cs-callout-content text-parchment/80 text-sm leading-relaxed">
        <slot />
      </div>
    </div>
  </aside>
</div>

<style>
  .cs-callout {
    position: relative;
    display: flex;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    margin: 1.25rem 0;
    border-radius: 0.5rem;
    overflow: hidden;
    break-inside: avoid;
  }
  /* 强调彩条用 ::before，绕开 .panel-glass 的 border !important（站级债） */
  .cs-callout::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
  }
  .cs-callout-icon { flex-shrink: 0; margin-top: 0.1rem; }
  .cs-callout-body { min-width: 0; flex: 1; }
  .cs-callout-head {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }
  .cs-callout-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .cs-callout-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-parchment);
  }
  .cs-callout-content :global(p:last-child) { margin-bottom: 0; }
  .cs-callout-content :global(p:first-child) { margin-top: 0; }

  /* 变体色：彩条 + 图标 + 标签同色（固定色板，玻璃面板上跨主题可读） */
  .cs-callout--sky::before { background: rgb(56 189 248); }
  .cs-callout--sky .cs-callout-icon, .cs-callout--sky .cs-callout-label { color: rgb(56 189 248); }
  .cs-callout--emerald::before { background: rgb(52 211 153); }
  .cs-callout--emerald .cs-callout-icon, .cs-callout--emerald .cs-callout-label { color: rgb(52 211 153); }
  .cs-callout--amber::before { background: rgb(251 191 36); }
  .cs-callout--amber .cs-callout-icon, .cs-callout--amber .cs-callout-label { color: rgb(251 191 36); }
  .cs-callout--rose::before { background: rgb(251 113 133); }
  .cs-callout--rose .cs-callout-icon, .cs-callout--rose .cs-callout-label { color: rgb(251 113 133); }
</style>
