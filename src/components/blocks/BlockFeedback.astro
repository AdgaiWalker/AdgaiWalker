---
/**
 * BlockFeedback — 内容阅读结果反馈（P1-B01）
 *
 * 极简即时反馈系统：
 * - 移除大面积边框背景与繁琐的“提交”按钮及复选框，界面单行对齐、留白通透。
 * - 选项按钮点击即瞬间静默提交（Instant submit）。
 * - 仅当选择“需补充”/“已过时”时，才在下方就地展开轻量补充文本框。
 */
import { Icon } from 'astro-icon/components';

interface Props {
  contentId: string;
}

const { contentId } = Astro.props;
---

<section class="block-feedback" data-block-feedback data-content-id={contentId} aria-labelledby="bf-title">
  <div class="bf-main-row">
    <span id="bf-title" class="bf-title">这篇内容对你有帮助吗？</span>
    <div class="bf-options">
      <button type="button" class="bf-option-btn" data-signal="useful" aria-label="有用">
        <Icon name="lucide:thumbs-up" width={14} height={14} />
        <span>有用</span>
      </button>
      <button type="button" class="bf-option-btn" data-signal="needs-more" aria-label="需补充">
        <Icon name="lucide:message-circle-plus" width={14} height={14} />
        <span>需补充</span>
      </button>
      <button type="button" class="bf-option-btn" data-signal="outdated" aria-label="已过时">
        <Icon name="lucide:clock-alert" width={14} height={14} />
        <span>已过时</span>
      </button>
    </div>
    <span class="bf-status" data-bf-status role="status" aria-live="polite"></span>
  </div>

  <!-- Collapsible feedback note drawer -->
  <div class="bf-note-drawer" data-bf-note-drawer hidden>
    <div class="bf-note-input-wrapper">
      <input type="text" class="bf-note-input" data-bf-note placeholder="告诉我们可以改进什么（回车发送，可选）..." maxlength="240" />
      <button type="button" class="bf-note-send-btn" data-bf-note-submit>发送</button>
      <button type="button" class="bf-note-cancel-btn" data-bf-note-cancel>不用了</button>
    </div>
  </div>

  <!-- Success message -->
  <div class="bf-success-msg" data-bf-success hidden>
    <Icon name="lucide:check-circle-2" width={14} height={14} class="bf-success-icon" />
    <span>已收到反馈，感谢协助改进内容。</span>
    <button type="button" class="bf-redo-btn" data-bf-redo>重新反馈</button>
  </div>
</section>

<style>
  .block-feedback {
    margin: 2.5rem 0 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px dashed color-mix(in srgb, var(--color-border) 40%, transparent);
    font-family: var(--font-cjk);
  }

  .bf-main-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .bf-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-parchment-dim);
    margin: 0;
  }

  .bf-options {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .bf-option-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 15%, transparent);
    background: transparent;
    color: var(--color-parchment-dim);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .bf-option-btn:hover {
    border-color: var(--color-brand);
    color: var(--color-brand);
    background: color-mix(in srgb, var(--color-brand) 5%, transparent);
  }

  .bf-option-btn.active {
    border-color: var(--color-brand);
    background: color-mix(in srgb, var(--color-brand) 8%, transparent);
    color: var(--color-brand);
  }

  /* Note Drawer */
  .bf-note-drawer {
    margin-top: 0.75rem;
    padding: 0.5rem 0;
    animation: slideDown 0.25s ease-out;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .bf-note-input-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    max-width: 600px;
  }

  .bf-note-input {
    flex: 1;
    min-height: 36px;
    padding: 0.4rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-parchment-dim) 20%, transparent);
    background: var(--color-inner-bg, rgba(255, 255, 255, 0.1));
    color: var(--color-parchment);
    font-size: 0.8rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .bf-note-input:focus {
    border-color: var(--color-brand);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-brand) 15%, transparent);
  }

  .bf-note-send-btn {
    padding: 0.4rem 0.9rem;
    border-radius: 0.5rem;
    border: none;
    background: var(--color-brand);
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .bf-note-send-btn:hover {
    opacity: 0.9;
  }

  .bf-note-cancel-btn {
    padding: 0.4rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid transparent;
    background: transparent;
    color: var(--color-parchment-dim);
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .bf-note-cancel-btn:hover {
    background: rgba(0, 0, 0, 0.03);
    color: var(--color-parchment);
  }

  /* Success Msg */
  .bf-success-msg {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.9rem;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--color-brand) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand) 15%, transparent);
    color: var(--color-brand);
    font-size: 0.78rem;
    animation: fadeIn 0.3s;
  }

  .bf-success-icon {
    flex-shrink: 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .bf-redo-btn {
    margin-left: auto;
    background: transparent;
    border: none;
    color: var(--color-parchment-dim);
    font-size: 0.75rem;
    cursor: pointer;
    text-decoration: underline;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .bf-redo-btn:hover {
    opacity: 1;
    color: var(--color-brand);
  }

  .bf-status {
    font-size: 0.75rem;
    color: #ef4444;
  }

  @media (max-width: 600px) {
    .bf-main-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .bf-options {
      width: 100%;
      justify-content: space-between;
    }
    .bf-option-btn {
      flex: 1;
      justify-content: center;
    }
  }
</style>

<script>
  import { registerLifecycle } from '@/scripts/with-lifecycle';

  const DONE_KEY_PREFIX = 'walker-feedback-done:';

  function setupBlockFeedback(root: HTMLElement, abortSignal: AbortSignal) {
    const contentId = root.dataset.contentId;
    if (!contentId) return;

    const mainRow = root.querySelector<HTMLElement>('.bf-main-row');
    const optionBtns = root.querySelectorAll<HTMLButtonElement>('.bf-option-btn');
    const noteDrawer = root.querySelector<HTMLElement>('[data-bf-note-drawer]');
    const noteInput = root.querySelector<HTMLInputElement>('[data-bf-note]');
    const noteSubmit = root.querySelector<HTMLButtonElement>('[data-bf-note-submit]');
    const noteCancel = root.querySelector<HTMLButtonElement>('[data-bf-note-cancel]');
    const successMsg = root.querySelector<HTMLElement>('[data-bf-success]');
    const redoBtn = root.querySelector<HTMLButtonElement>('[data-bf-redo]');
    const status = root.querySelector<HTMLElement>('[data-bf-status]');

    if (!mainRow || !successMsg) return;

    let selectedSignal: 'useful' | 'needs-more' | 'outdated' | null = null;

    // Check localStorage
    if (localStorage.getItem(DONE_KEY_PREFIX + contentId) === 'true') {
      mainRow.style.display = 'none';
      successMsg.hidden = false;
      if (redoBtn) redoBtn.style.display = 'none';
    }

    async function submitFeedback(signal: string, noteText?: string) {
      if (status) status.textContent = '';
      
      try {
        const res = await fetch('/api/content-feedback', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            contentId,
            signal,
            note: noteText,
            consentForAnalysis: true
          })
        });

        if (res.ok) {
          localStorage.setItem(DONE_KEY_PREFIX + contentId, 'true');
          mainRow.style.display = 'none';
          if (noteDrawer) noteDrawer.hidden = true;
          successMsg.hidden = false;
        } else {
          const data = await res.json().catch(() => ({}));
          if (status) status.textContent = data.error ? `提交失败：${data.error}` : '提交失败，请重试';
        }
      } catch (err) {
        if (status) status.textContent = '网络错误，请稍后再试';
      }
    }

    optionBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const signal = btn.dataset.signal as 'useful' | 'needs-more' | 'outdated';
        selectedSignal = signal;

        optionBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        if (signal === 'useful') {
          submitFeedback(signal);
        } else {
          if (noteDrawer) {
            noteDrawer.hidden = false;
            if (noteInput) {
              noteInput.focus();
              noteInput.value = '';
            }
          }
        }
      }, { signal: abortSignal });
    });

    noteSubmit?.addEventListener('click', () => {
      if (selectedSignal) {
        const text = noteInput?.value.trim();
        submitFeedback(selectedSignal, text || undefined);
      }
    }, { signal: abortSignal });

    noteInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && selectedSignal) {
        e.preventDefault();
        const text = noteInput.value.trim();
        submitFeedback(selectedSignal, text || undefined);
      }
    }, { signal: abortSignal });

    noteCancel?.addEventListener('click', () => {
      if (selectedSignal) {
        submitFeedback(selectedSignal);
      }
    }, { signal: abortSignal });

    redoBtn?.addEventListener('click', () => {
      localStorage.removeItem(DONE_KEY_PREFIX + contentId);
      successMsg.hidden = true;
      mainRow.style.display = '';
      if (noteDrawer) noteDrawer.hidden = true;
      optionBtns.forEach(b => b.classList.remove('active'));
      selectedSignal = null;
    }, { signal: abortSignal });
  }

  function initAll() {
    const abort = new AbortController();
    document.querySelectorAll<HTMLElement>('[data-block-feedback]').forEach(root => setupBlockFeedback(root, abort.signal));
    return () => abort.abort();
  }

  registerLifecycle(initAll);
</script>
