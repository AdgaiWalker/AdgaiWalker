---
interface Props {
  title?: string;
  tags?: string[];
}

const { title, tags } = Astro.props;
---

<div class="my-6 p-4 rounded-xl border border-gold/20 bg-gold/5">
  {title && (
    <div class="font-heading text-sm text-gold mb-2">{title}</div>
  )}
  <div class="text-text text-sm leading-relaxed">
    <slot />
  </div>
  {tags && tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {tags.map((tag: string) => (
        <span class="text-xs px-2 py-0.5 rounded-full border border-gold/15 text-gold/70">{tag}</span>
      ))}
    </div>
  )}
</div>
