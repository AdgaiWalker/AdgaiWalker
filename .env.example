# Giscus 评论系统配置
# 获取方式：https://giscus.app → 填入仓库信息 → 复制配置值
PUBLIC_GISCUS_REPO="AdgaiWalker/AdgaiWalker"
PUBLIC_GISCUS_REPO_ID=""
PUBLIC_GISCUS_CATEGORY=""
PUBLIC_GISCUS_CATEGORY_ID=""

# 管理后台（生产必填）
# 管理员登录密码，同时作为 admin cookie HMAC 签名密钥（7 天有效）。
# 未配置时 admin 登录会直接失败（signToken 抛错）。
ADMIN_PASSWORD=

# Upstash Redis 点赞系统（Vercel Marketplace）
# 自动注入：在 Vercel Dashboard → Storage → Upstash for Redis → Connect to Project
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# REDIS_URL=

# AI Gateway（匹配 Agent 的模型调用，可选）
# ANTHROPIC_API_KEY 仍作为 src/agent/gateway.ts 的运行时 fallback 被读取
# （config.apiKey || import.meta.env.ANTHROPIC_API_KEY）。服务商 API key、baseUrl、model
# 在 /admin/ai-gateway 管理页配置（运行时存 Redis hash `ai-gateway:config`），建议优先用管理页配置。
# 未配置时只用本地规则匹配，不调用模型，不产生费用。

# 可选：用于 Redis 限流键加盐。生产环境建议配置一个随机长字符串。
# MATCH_RATE_LIMIT_SALT=

# 可选：单 IP 调用上限。
# MATCH_DAILY_LIMIT=20
# MATCH_MINUTE_LIMIT=5

# 可选：全站每日模型匹配请求上限，保护 API Key 财产安全。
# MATCH_GLOBAL_DAILY_LIMIT=1000

# 生产环境必填其一：保护选题库批处理接口。
# Vercel Cron 会使用 CRON_SECRET；手动触发可使用 MATCH_PROCESS_SECRET 请求头。
# CRON_SECRET=
# MATCH_PROCESS_SECRET=

# Admin 内容编辑回写（可选）
# /admin/content/edit 通过 GitHub API 回写 src/content/log/ 下的 markdown。
# 未配置时内容编辑接口返回 503。
# GITHUB_TOKEN=

# 邀请码准入（可选）
# 格式 code:label:maxUses，逗号分隔多组，如 walker-test:测试批次:10
# 被 stores/invite-code.store.ts 读取，用于 /api/invite/verify 准入。
# INVITE_CODES=

# 需求与选题库存储：生产环境必须配置 Redis，否则只会存在于本地内存，重启后丢失。
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
