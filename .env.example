# Giscus 评论系统配置
# 获取方式：https://giscus.app → 填入仓库信息 → 复制配置值
PUBLIC_GISCUS_REPO="AdgaiWalker/AdgaiWalker"
PUBLIC_GISCUS_REPO_ID=""
PUBLIC_GISCUS_CATEGORY=""
PUBLIC_GISCUS_CATEGORY_ID=""

# Upstash Redis 点赞系统（Vercel Marketplace）
# 自动注入：在 Vercel Dashboard → Storage → Upstash for Redis → Connect to Project
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# REDIS_URL=

# 需求索引匹配 Agent
# 可选：不配置时只用本地规则匹配，不调用模型，不产生模型费用。
# ANTHROPIC_API_KEY=

# 可选：用于 Redis 限流键加盐。生产环境建议配置一个随机长字符串。
# MATCH_RATE_LIMIT_SALT=

# 可选：单 IP 调用上限。
# MATCH_DAILY_LIMIT=20
# MATCH_MINUTE_LIMIT=5

# 可选：全站每日模型匹配请求上限，保护 API Key 财产安全。
# MATCH_GLOBAL_DAILY_LIMIT=1000

# 生产环境必填其一：保护选题库批处理接口。
# Vercel Cron 会使用 CRON_SECRET；手动触发可使用 MATCH_PROCESS_SECRET 请求头。
# CRON_SECRET=
# MATCH_PROCESS_SECRET=

# 需求与选题库存储：生产环境必须配置 Redis，否则只会存在于本地内存，重启后丢失。
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
